Cell["\<\
We now apply these operators to the right-hand side. In order to speed up the \
evaluation, we consider each summand of an operator in ann separately: we \
first apply the operator monomial, cancel away the Gammas, and then multiply \
by the relatively big coefficients. Then simplification basically boils down \
to rational function arithmetic.\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"myApply", "[", 
    RowBox[{"OrePolynomial", "[", 
     RowBox[{"data_List", ",", "alg_OreAlgebraObject", ",", "mon_"}], "]"}], 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"result", "=", "0"}], ",", "expr"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"expr", "=", 
       RowBox[{"I", "*", 
        RowBox[{"Sin", "[", 
         RowBox[{"Pi", "*", 
          RowBox[{"(", 
           RowBox[{"s", "-", "t"}], ")"}]}], "]"}], "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", 
           RowBox[{"Sin", "[", 
            RowBox[{"th", "/", "2"}], "]"}]}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"a", "+", "b", "+", "c", "+", "d", "-", "4"}], ")"}]}], "*", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"I", "*", 
               RowBox[{"(", 
                RowBox[{"Pi", "-", "th"}], ")"}], "*", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"a", "-", "b", "+", "c", "-", "d", "+", 
                  RowBox[{"2", "s"}], "+", 
                  RowBox[{"2", "t"}]}], ")"}], "/", "2"}]}], "]"}], "/", 
             "Pi"}], "/", 
            RowBox[{"Gamma", "[", 
             RowBox[{"a", "+", "b", "-", "1"}], "]"}]}], "/", 
           RowBox[{"Gamma", "[", 
            RowBox[{"b", "+", "c", "-", "1"}], "]"}]}], "/", 
          RowBox[{"Gamma", "[", 
           RowBox[{"c", "+", "d", "-", "1"}], "]"}]}], "/", 
         RowBox[{"Gamma", "[", 
          RowBox[{"d", "+", "a", "-", "1"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"result", "+=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"data", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], "/.", 
            RowBox[{"z", "\[Rule]", 
             RowBox[{
              RowBox[{"Cos", "[", "th", "]"}], "+", 
              RowBox[{"I", "*", 
               RowBox[{"Sin", "[", "th", "]"}]}]}]}]}], ")"}], "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"FullSimplify", "[", 
             RowBox[{
              RowBox[{"ApplyOreOperator", "[", 
               RowBox[{
                RowBox[{"OrePolynomial", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"{", 
                    RowBox[{"1", ",", 
                    RowBox[{"data", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}], "}"}], 
                  ",", "alg", ",", "mon"}], "]"}], ",", "expr"}], "]"}], "/", 
              "expr"}], "]"}], "/.", 
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"I", "*", "x_"}], "]"}], "\[Rule]", 
             RowBox[{
              RowBox[{"Cos", "[", "x", "]"}], "+", 
              RowBox[{"I", "*", 
               RowBox[{"Sin", "[", "x", "]"}]}]}]}]}], ")"}]}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "data", "]"}]}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "result", "]"}], ";"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"Together", "[", 
   RowBox[{"myApply", "/@", "ann"}], "]"}], "]"}]], "Input"],


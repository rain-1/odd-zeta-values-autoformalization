 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"z", 
      SubsuperscriptBox["D", "z", "2"]}], "+", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"2", " ", "n"}]}], ")", 
      SubscriptBox["D", "z"]}], "+", "z"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     FractionBox[
      RowBox[{"1", "-", 
       SuperscriptBox["t", "2"]}], "t"], 
     SubscriptBox["D", "z"]}], "}"}]}], "}"}]], "Output"]
}, Open  ]],


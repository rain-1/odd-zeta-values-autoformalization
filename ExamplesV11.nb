        RowBox[{"f", "[", "n", "]"}]}], "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{"f", "[", "n", "]"}], ",", "n"}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", "1", ",", "2"}], "]"}], "]"}]}]], "Input"],


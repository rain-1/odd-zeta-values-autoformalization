Cell["Stirling summation", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Binomial", "[", 
        RowBox[{"k", ",", "m"}], "]"}], "*", 
       RowBox[{"Pochhammer", "[", 
        RowBox[{
         RowBox[{"x", "-", 
          RowBox[{"(", 
           RowBox[{"k", "-", "m"}], ")"}], "+", "1"}], ",", 
         RowBox[{"k", "-", "m"}]}], "]"}], "*", 
       RowBox[{"StirlingS2", "[", 
        RowBox[{"n", ",", "k"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Binomial", "[", 
        RowBox[{"n", ",", "k"}], "]"}], "*", 
       RowBox[{"x", "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "k"}], ")"}]}], "*", 
       RowBox[{"StirlingS2", "[", 
        RowBox[{"k", ",", "m"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}]}], "]"}], "//", 
  "TraditionalForm"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], "n"], 
     RowBox[{
      TemplateBox[{"k","m"},
       "Binomial"], " ", 
      TemplateBox[{RowBox[{"x", "-", 
          RowBox[{"(", 
            RowBox[{"k", "-", "m"}], ")"}], "+", "1"}],
        RowBox[{"k", "-", "m"}]},
       "Pochhammer"], " ", 
      TemplateBox[{"n","k"},
       "StirlingS2"]}]}], "\[LongEqual]", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], "n"], 
     RowBox[{
      TemplateBox[{"n","k"},
       "Binomial"], " ", 
      SuperscriptBox["x", 
       RowBox[{"n", "-", "k"}]], " ", 
      TemplateBox[{"k","m"},
       "StirlingS2"]}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


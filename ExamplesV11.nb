      RowBox[{"(", 
       RowBox[{
        RowBox[{"t", "^", "2"}], "-", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"n", "+", 
        RowBox[{"1", "/", "2"}]}], ")"}]}]}], ",", "z"}], "]"}], "/.", 
  RowBox[{"n", "\[Rule]", "0"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"t", " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"t", " ", "z"}], "]"}]}], 
   SqrtBox[
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     SuperscriptBox["t", "2"]}]]]}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{"%", ",", 
   RowBox[{"{", 

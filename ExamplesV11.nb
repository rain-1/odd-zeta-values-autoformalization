 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], " ", 
     FractionBox[
      RowBox[{"\[PartialD]", 
       RowBox[{
        SubsuperscriptBox["P", "a", 
         RowBox[{"(", 
          RowBox[{"b", ",", "n"}], ")"}]], "(", "x", ")"}]}], 
      RowBox[{"\[PartialD]", "x"}],
      MultilineFunction->None]}], "\[LongEqual]", 
    RowBox[{
     RowBox[{"a", " ", 
      RowBox[{
       SubsuperscriptBox["P", "n", 
        RowBox[{"(", 
         RowBox[{"a", ",", "b"}], ")"}]], "(", "x", ")"}]}], "-", 

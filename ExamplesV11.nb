      RowBox[{"8", " ", "a", " ", "n", " ", "nu", " ", "x"}], "-", 
      RowBox[{"8", " ", "a", " ", 
       SuperscriptBox["nu", "2"], " ", "x"}], "+", 
      RowBox[{"4", " ", "nu", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"4", " ", "n", " ", "nu", " ", 

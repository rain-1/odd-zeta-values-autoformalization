Cell[CellGroupData[{

Cell[TextData[{
 "Bernoulli polynomials ",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "n"], 
      RowBox[{
       TagBox[
        RowBox[{"(", GridBox[{
           {
            TagBox["n",
             Identity,
             Editable->True,
             Selectable->True]},
           {
            TagBox["k",
             Identity,
             Editable->True,
             Selectable->True]}
          }], ")"}],
        InterpretTemplate[Binomial[#, #2]& ],
        Editable->False,
        Selectable->False], " ", 
       RowBox[{
        SubscriptBox[
         TagBox["B",
          BernoulliB], 
         RowBox[{"n", "-", "k"}]], "(", "x", ")"}]}]}], "\[LongEqual]", 
     RowBox[{"n", " ", 
      SuperscriptBox["x", 
       RowBox[{"n", "-", "1"}]]}]}],
    HoldForm], TraditionalForm]], "Input",
  CellChangeTimes->{{3.465571331258073*^9, 3.465571335087404*^9}}]
}], "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Binomial", "[", 
        RowBox[{"n", ",", "k"}], "]"}], "*", 
       RowBox[{"BernoulliB", "[", 
        RowBox[{
         RowBox[{"n", "-", "k"}], ",", "x"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{"n", "*", 
     RowBox[{"x", "^", 
      RowBox[{"(", 
       RowBox[{"n", "-", "1"}], ")"}]}]}]}], "]"}], "]"}]], "Input"],


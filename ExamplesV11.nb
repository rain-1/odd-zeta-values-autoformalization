       SuperscriptBox["x", "5"]}], "-", 
      SuperscriptBox["x", "7"], "-", 
      RowBox[{"n", " ", 
       SuperscriptBox["x", "7"]}]}], ")", 
     SubsuperscriptBox["D", "x", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"3", " ", "a"}], "+", 
      RowBox[{"3", " ", 
       SuperscriptBox["a", "2"]}], "-", 
      SuperscriptBox["a", "3"], "+", 
      RowBox[{"7", " ", 
       SuperscriptBox["x", "2"]}], "-", 

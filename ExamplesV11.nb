}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
Larry Glasser: Integral representations for exceptional univariate Lommel \
functions\
\>", "Subsection"],

Cell["\<\
This problem has been sent to us by Larry Glasser (see his paper of the same \
title, submitted to J.Phys.A:Math.Gen.).\
\>", "Text"],

Cell[TextData[{
 "We are considering the Lommel function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", 
     RowBox[{"m", ",", "n"}]], "(", "z", ")"}], TraditionalForm]]],
 " which is a particular solution to the inhomogeneous Bessel equation"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"BesselEq", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"z", "^", "2"}], "*", 
     RowBox[{
      RowBox[{"w", "''"}], "[", "z", "]"}]}], "+", 
    RowBox[{"z", "*", 
     RowBox[{
      RowBox[{"w", "'"}], "[", "z", "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "-", 
       RowBox[{"n", "^", "2"}]}], ")"}], "*", 
     RowBox[{"w", "[", "z", "]"}]}]}], "==", 
   RowBox[{"z", "^", 
    RowBox[{"(", 
     RowBox[{"m", "+", "1"}], ")"}]}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["n", "2"]}], "+", 
      SuperscriptBox["z", "2"]}], ")"}], " ", 
    RowBox[{"w", "[", "z", "]"}]}], "+", 
   RowBox[{"z", " ", 
    RowBox[{
     SuperscriptBox["w", "\[Prime]",
      MultilineFunction->None], "[", "z", "]"}]}], "+", 
   RowBox[{
    SuperscriptBox["z", "2"], " ", 
    RowBox[{
     SuperscriptBox["w", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "z", "]"}]}]}], "\[Equal]", 
  SuperscriptBox["z", 
   RowBox[{"1", "+", "m"}]]}]], "Output"]
}, Open  ]],

Cell["\<\
In the following computations we do not include treatment of initial values, \
which would be necessary in order to have rigorous proofs.\
\>", "Text"],

Cell[CellGroupData[{

Cell["\<\
Formula (14) gives the following integral representation of this function:\
\>", "Subsubsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"ArcSinh", "[", "x", "]"}], "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", "1"}], "]"}]}], "*", 
       RowBox[{"E", "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "z"}], "*", "x"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"Subscript", "[", 
      RowBox[{"S", ",", "\"\<-1,0\>\""}], "]"}], "[", "z", "]"}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{
         SuperscriptBox["sinh", 
          RowBox[{"-", "1"}]], "(", "x", ")"}], " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "z"}], " ", "x"}]]}], 
       SqrtBox[
        RowBox[{
         SuperscriptBox["x", "2"], "+", "1"}]]], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     SubscriptBox["S", "\<\"-1,0\"\>"], "(", "z", ")"}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
We compute an inhomogeneous differential equation for this integral and \
compare it to the defining Bessel equation.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"ArcSinh", "[", "x", "]"}], "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", "1"}], "]"}]}], "*", 
       RowBox[{"E", "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "z"}], "*", "x"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
    RowBox[{"Der", "[", "z", "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"Re", "[", "z", "]"}], ">", "0"}]}], ",", 
    RowBox[{"Inhomogeneous", "\[Rule]", "True"}], ",", 
    RowBox[{"Head", "\[Rule]", "S"}]}], "]"}], "//", "ReleaseHold"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "z"]}], "+", 
    RowBox[{"z", " ", 
     RowBox[{"S", "[", "z", "]"}]}], "+", 
    RowBox[{
     SuperscriptBox["S", "\[Prime]",
      MultilineFunction->None], "[", "z", "]"}], "+", 
    RowBox[{"z", " ", 
     RowBox[{
      SuperscriptBox["S", "\[Prime]\[Prime]",
       MultilineFunction->None], "[", "z", "]"}]}]}], "\[Equal]", "0"}], 
  "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"First", "[", "%", "]"}], "\[Equal]", 
    RowBox[{"(", 
     RowBox[{"BesselEq", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"w", "\[Rule]", "S"}], ",", 
        RowBox[{"m", "\[Rule]", 
         RowBox[{"-", "1"}]}], ",", 
        RowBox[{"n", "\[Rule]", "0"}]}], "}"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"Re", "[", "z", "]"}], ">", "0"}]}], "]"}]], "Input"],

Cell[BoxData["True"], "Output"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Formula (15) states", "Subsubsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"ArcSinh", "[", "x", "]"}], "^", "2"}], "*", 

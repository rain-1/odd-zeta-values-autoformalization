Cell["\<\
With closure properties an annihilating ideal for the right-hand side is now \
obtained, and it turns out that the previously one computed indeed was \
correct:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GBEqual", "[", 
  RowBox[{"rhs", ",", 
   RowBox[{"DFiniteTimes", "[", 
    RowBox[{
     RowBox[{"Annihilator", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Gamma", "[", "r", "]"}], "*", 
        RowBox[{
         RowBox[{"Gamma", "[", "s", "]"}], "/", 
         RowBox[{"Gamma", "[", 
          RowBox[{"r", "+", "s"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"S", "[", "a", "]"}], ",", 
         RowBox[{"S", "[", "b", "]"}], ",", 
         RowBox[{"S", "[", "c", "]"}], ",", 
         RowBox[{"S", "[", "r", "]"}], ",", 
         RowBox[{"S", "[", "s", "]"}]}], "}"}]}], "]"}], ",", "pfq"}], 
    "]"}]}], "]"}]], "Input"],

Cell[BoxData["True"], "Output"]
}, Open  ]],


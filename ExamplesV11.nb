Cell["Exact solution using DSolve with initial values", "Subsubsection"],

Cell["\<\
Let Int[a] be the integral. We compute initial values for Int[0] and Int'[0].\
\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"i0", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "^", "4"}], "+", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"m", "+", "1"}], ")"}]}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"Re", "[", "m", "]"}], "\[GreaterEqual]", "0"}]}]}], 
   "]"}]}]], "Input"],


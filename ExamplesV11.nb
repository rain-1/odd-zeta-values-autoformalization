Cell["\<\
Now we could either compare initial values, or assume that we did not know \
the evaluation of the integral and recover it from solving the differential \
equation.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{
   RowBox[{"DSolve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ApplyOreOperator", "[", 
       RowBox[{
        RowBox[{"First", "[", "rhs", "]"}], ",", 
        RowBox[{"f", "[", "p", "]"}]}], "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{"f", "[", "p", "]"}], ",", "p"}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", "1", ",", "2"}], "]"}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"C", "[", "1", "]"}], 
   SuperscriptBox["p", "2"]], "+", 
  FractionBox[
   RowBox[{
    RowBox[{"ArcTan", "[", "p", "]"}], " ", 
    RowBox[{"C", "[", "2", "]"}]}], 
   SuperscriptBox["p", "2"]], "+", 
  FractionBox[
   RowBox[{
    RowBox[{"C", "[", "3", "]"}], " ", 
    RowBox[{"Log", "[", 
     RowBox[{"1", "+", 
      SuperscriptBox["p", "2"]}], "]"}]}], 
   RowBox[{"2", " ", 
    SuperscriptBox["p", "2"]}]], "+", 
  FractionBox[
   RowBox[{
    RowBox[{"ArcTan", "[", "p", "]"}], " ", 
    RowBox[{"C", "[", "4", "]"}], " ", 
    RowBox[{"Log", "[", 
     RowBox[{"1", "+", 
      SuperscriptBox["p", "2"]}], "]"}]}], 
   RowBox[{"2", " ", 
    SuperscriptBox["p", "2"]}]]}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"inits", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ArcTan", "[", 
             RowBox[{"p", "*", "x"}], "]"}], "/", 
            RowBox[{"(", 

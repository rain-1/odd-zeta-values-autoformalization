    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", "z"}], "]"}], "2"], ",", 
   RowBox[{
    RowBox[{"-", "2"}], " ", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", "z"}], "]"}], " ", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"1", ",", "z"}], "]"}]}], ",", 
   FractionBox[
    RowBox[{"2", " ", 
     RowBox[{"BesselJ", "[", 
      RowBox[{"0", ",", "z"}], "]"}], " ", 
     RowBox[{"BesselJ", "[", 
      RowBox[{"1", ",", "z"}], "]"}]}], "z"], ",", 
   RowBox[{
    RowBox[{"2", " ", 
     SuperscriptBox[
      RowBox[{"BesselJ", "[", 
       RowBox[{"1", ",", "z"}], "]"}], "2"]}], "+", 
    RowBox[{
     RowBox[{"BesselJ", "[", 
      RowBox[{"0", ",", "z"}], "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"BesselJ", "[", 
         RowBox[{"0", ",", "z"}], "]"}]}], "+", 
       RowBox[{"BesselJ", "[", 
        RowBox[{"2", ",", "z"}], "]"}]}], ")"}]}]}]}], "}"}]], "Output"]
}, Open  ]],


          RowBox[{"1", "/", "2"}]}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "m", "]"}], ",", 
        RowBox[{"Der", "[", "a", "]"}]}], "}"}]}], "]"}], ",", "pma"}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"4", "+", 
      RowBox[{"4", " ", "m"}]}], ")", 
     SubscriptBox["S", "m"]}], "-", 
    RowBox[{
     RowBox[{"2", " ", "a"}], 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 

Cell["\<\
But Chyzak's algorithm is preferable. The only problem is that in this \
instance the inhomogeneous part cannot be evaluated automatically. Hence we \
use the option Inhomogeneous->True and simplify it ourselves (it turns out to \
be 0 anyway).\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"lhs", ",", "inh"}], "}"}], "=", 
   RowBox[{"Annihilator", "[", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "a"}], "-", "x"}], ")"}]}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"nu", "-", 
           RowBox[{"1", "/", "2"}]}], ")"}]}], "*", 
        RowBox[{"GegenbauerC", "[", 
         RowBox[{"n", ",", "nu", ",", 
          RowBox[{
           RowBox[{"x", "/", "a"}], "-", "1"}]}], "]"}], "*", 
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "b"}], "*", "x"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", 
         RowBox[{"2", "a"}]}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Der", "[", "a", "]"}], ",", 
       RowBox[{"Der", "[", "b", "]"}], ",", 
       RowBox[{"S", "[", "n", "]"}], ",", 
       RowBox[{"S", "[", "nu", "]"}]}], "}"}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{"nu", "\[GreaterEqual]", "1"}]}], ",", 
     RowBox[{"Inhomogeneous", "\[Rule]", "True"}]}], "]"}]}], ";"}]], "Input"],


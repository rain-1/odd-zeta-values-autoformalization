            HypergeometricPFQ,
            Editable->True,
            Selectable->True]}], ")"}]}],
        InterpretTemplate[HypergeometricPFQ[#, #2, #3]& ],
        Editable->False,
        Selectable->False],
       HypergeometricPFQ]}], 
     TemplateBox[{RowBox[{"r", "+", "s"}]},
      "Gamma"]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
We prove this identity for integers a,b,c,r,s such that c + s - a - b > 0  \
and  a \[GreaterEqual] 0, b \[GreaterEqual] 0, c \[GreaterEqual] 1, r \
\[GreaterEqual] 1, s \[GreaterEqual] 2. The latter condition is because for s \
\[GreaterEqual] 1, the delta part in the following computation cannot be \
simplified. However, the special case s=1 could be treated separately in the \
very same manner. \
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", 
        RowBox[{"(", 
         RowBox[{"r", "-", "1"}], ")"}]}], "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "x"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"s", "-", "1"}], ")"}]}], "*", 
       RowBox[{"Hypergeometric2F1", "[", 
        RowBox[{"a", ",", "b", ",", "c", ",", "x"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], ",", 
      RowBox[{"S", "[", "b", "]"}], ",", 
      RowBox[{"S", "[", "c", "]"}], ",", 
      RowBox[{"S", "[", "r", "]"}], ",", 
      RowBox[{"S", "[", "s", "]"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"s", ">", "1"}]}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SubscriptBox["S", "r"], "+", 
    SubscriptBox["S", "s"], "-", "1"}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b", " ", "c"}], "-", 
      RowBox[{"a", " ", 
       SuperscriptBox["c", "2"]}], "-", 
      RowBox[{"b", " ", 
       SuperscriptBox["c", "2"]}], "+", 
      SuperscriptBox["c", "3"], "-", 
      RowBox[{"a", " ", "b", " ", "r"}], "+", 
      RowBox[{"a", " ", "c", " ", "r"}], "+", 
      RowBox[{"b", " ", "c", " ", "r"}], "-", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "r"}]}], ")", 
     SubscriptBox["S", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "a"}], " ", "b", " ", "c"}], "+", 
      RowBox[{"a", " ", "c", " ", "r"}], "+", 
      RowBox[{"b", " ", "c", " ", "r"}], "-", 
      RowBox[{"c", " ", 
       SuperscriptBox["r", "2"]}], "+", 
      RowBox[{"a", " ", "c", " ", "s"}], "+", 
      RowBox[{"b", " ", "c", " ", "s"}], "-", 
      RowBox[{"2", " ", "c", " ", "r", " ", "s"}], "-", 
      RowBox[{"c", " ", 
       SuperscriptBox["s", "2"]}]}], ")", 
     SubscriptBox["S", "s"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       SuperscriptBox["c", "2"]}], "+", 
      RowBox[{"b", " ", 
       SuperscriptBox["c", "2"]}], "-", 
      SuperscriptBox["c", "3"], "-", 
      RowBox[{"a", " ", "c", " ", "r"}], "-", 
      RowBox[{"b", " ", "c", " ", "r"}], "+", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "r"}], "-", 
      RowBox[{"a", " ", "c", " ", "s"}], "-", 
      RowBox[{"b", " ", "c", " ", "s"}], "+", 
      RowBox[{"c", " ", "r", " ", "s"}], "+", 
      RowBox[{"c", " ", 
       SuperscriptBox["s", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "b"}], "-", 
      RowBox[{"a", " ", "b"}], "-", 
      SuperscriptBox["b", "2"], "+", 
      RowBox[{"b", " ", "c"}], "+", 
      RowBox[{"b", " ", "s"}]}], ")", 
     SubscriptBox["S", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b"}], "-", 
      RowBox[{"a", " ", "r"}], "-", 
      RowBox[{"b", " ", "r"}], "+", 
      SuperscriptBox["r", "2"], "-", 
      RowBox[{"a", " ", "s"}], "-", 
      RowBox[{"b", " ", "s"}], "+", 
      RowBox[{"2", " ", "r", " ", "s"}], "+", 
      SuperscriptBox["s", "2"]}], ")", 
     SubscriptBox["S", "s"]}], "+", 
    RowBox[{"(", 
     RowBox[{"b", "+", 
      SuperscriptBox["b", "2"], "-", 
      RowBox[{"b", " ", "c"}], "+", 
      RowBox[{"a", " ", "s"}], "-", 
      RowBox[{"r", " ", "s"}], "-", 
      SuperscriptBox["s", "2"]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "a"}], "-", 
      SuperscriptBox["a", "2"], "-", 
      RowBox[{"a", " ", "b"}], "+", 
      RowBox[{"a", " ", "c"}], "+", 
      RowBox[{"a", " ", "s"}]}], ")", 
     SubscriptBox["S", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b"}], "-", 
      RowBox[{"a", " ", "r"}], "-", 
      RowBox[{"b", " ", "r"}], "+", 
      SuperscriptBox["r", "2"], "-", 
      RowBox[{"a", " ", "s"}], "-", 
      RowBox[{"b", " ", "s"}], "+", 
      RowBox[{"2", " ", "r", " ", "s"}], "+", 
      SuperscriptBox["s", "2"]}], ")", 
     SubscriptBox["S", "s"]}], "+", 
    RowBox[{"(", 
     RowBox[{"a", "+", 
      SuperscriptBox["a", "2"], "-", 
      RowBox[{"a", " ", "c"}], "+", 
      RowBox[{"b", " ", "s"}], "-", 
      RowBox[{"r", " ", "s"}], "-", 
      SuperscriptBox["s", "2"]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "a", "-", "b", "+", 
      RowBox[{"a", " ", "b"}], "+", 
      RowBox[{"2", " ", "r"}], "-", 
      RowBox[{"a", " ", "r"}], "-", 
      RowBox[{"b", " ", "r"}], "+", 
      SuperscriptBox["r", "2"], "+", 
      RowBox[{"2", " ", "s"}], "-", 
      RowBox[{"a", " ", "s"}], "-", 
      RowBox[{"b", " ", "s"}], "+", 
      RowBox[{"2", " ", "r", " ", "s"}], "+", 
      SuperscriptBox["s", "2"]}], ")", 
     SubsuperscriptBox["S", "s", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "a", "+", "b", "-", 
      RowBox[{"a", " ", "b"}], "-", "r", "+", 
      RowBox[{"a", " ", "r"}], "+", 
      RowBox[{"b", " ", "r"}], "-", 
      RowBox[{"c", " ", "r"}], "-", 
      RowBox[{"2", " ", "s"}], "+", 
      RowBox[{"2", " ", "a", " ", "s"}], "+", 
      RowBox[{"2", " ", "b", " ", "s"}], "-", 
      RowBox[{"c", " ", "s"}], "-", 
      RowBox[{"2", " ", "r", " ", "s"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["s", "2"]}]}], ")", 
     SubscriptBox["S", "s"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "a"}], " ", "s"}], "-", 
      RowBox[{"b", " ", "s"}], "+", 
      RowBox[{"c", " ", "s"}], "+", 
      SuperscriptBox["s", "2"]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Now the right-hand side. Substituting 1 into a hypergeometric PFQ often leads \
to the following problem.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Gamma", "[", "r", "]"}], "*", 
     RowBox[{
      RowBox[{"Gamma", "[", "s", "]"}], "/", 
      RowBox[{"Gamma", "[", 
       RowBox[{"r", "+", "s"}], "]"}]}], "*", 
     RowBox[{"HypergeometricPFQ", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "b", ",", "r"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", 
         RowBox[{"r", "+", "s"}]}], "}"}], ",", "1"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], ",", 
      RowBox[{"S", "[", "b", "]"}], ",", 
      RowBox[{"S", "[", "c", "]"}], ",", 
      RowBox[{"S", "[", "r", "]"}], ",", 
      RowBox[{"S", "[", "s", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SubscriptBox["S", "r"], "+", 
    SubscriptBox["S", "s"], "-", "1"}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b", " ", "c"}], "-", 
      RowBox[{"a", " ", 
       SuperscriptBox["c", "2"]}], "-", 
      RowBox[{"b", " ", 
       SuperscriptBox["c", "2"]}], "+", 
      SuperscriptBox["c", "3"], "-", 
      RowBox[{"a", " ", "b", " ", "r"}], "+", 
      RowBox[{"a", " ", "c", " ", "r"}], "+", 
      RowBox[{"b", " ", "c", " ", "r"}], "-", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "r"}]}], ")", 
     SubscriptBox["S", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "a"}], " ", "b", " ", "c"}], "+", 
      RowBox[{"a", " ", "c", " ", "r"}], "+", 
      RowBox[{"b", " ", "c", " ", "r"}], "-", 
      RowBox[{"c", " ", 
       SuperscriptBox["r", "2"]}], "+", 
      RowBox[{"a", " ", "c", " ", "s"}], "+", 
      RowBox[{"b", " ", "c", " ", "s"}], "-", 
      RowBox[{"2", " ", "c", " ", "r", " ", "s"}], "-", 
      RowBox[{"c", " ", 
       SuperscriptBox["s", "2"]}]}], ")", 
     SubscriptBox["S", "s"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       SuperscriptBox["c", "2"]}], "+", 
      RowBox[{"b", " ", 
       SuperscriptBox["c", "2"]}], "-", 
      SuperscriptBox["c", "3"], "-", 
      RowBox[{"a", " ", "c", " ", "r"}], "-", 
      RowBox[{"b", " ", "c", " ", "r"}], "+", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "r"}], "-", 
      RowBox[{"a", " ", "c", " ", "s"}], "-", 
      RowBox[{"b", " ", "c", " ", "s"}], "+", 
      RowBox[{"c", " ", "r", " ", "s"}], "+", 
      RowBox[{"c", " ", 
       SuperscriptBox["s", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"b", "+", 
      RowBox[{"a", " ", "b"}], "+", 
      SuperscriptBox["b", "2"], "-", 
      RowBox[{"b", " ", "c"}], "-", 
      RowBox[{"b", " ", "s"}]}], ")", 
     SubscriptBox["S", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "a"}], " ", "b"}], "+", 
      RowBox[{"a", " ", "r"}], "+", 
      RowBox[{"b", " ", "r"}], "-", 
      SuperscriptBox["r", "2"], "+", 
      RowBox[{"a", " ", "s"}], "+", 
      RowBox[{"b", " ", "s"}], "-", 
      RowBox[{"2", " ", "r", " ", "s"}], "-", 
      SuperscriptBox["s", "2"]}], ")", 
     SubscriptBox["S", "s"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "b"}], "-", 
      SuperscriptBox["b", "2"], "+", 
      RowBox[{"b", " ", "c"}], "-", 
      RowBox[{"a", " ", "s"}], "+", 
      RowBox[{"r", " ", "s"}], "+", 
      SuperscriptBox["s", "2"]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"a", "+", 
      SuperscriptBox["a", "2"], "+", 
      RowBox[{"a", " ", "b"}], "-", 
      RowBox[{"a", " ", "c"}], "-", 
      RowBox[{"a", " ", "s"}]}], ")", 
     SubscriptBox["S", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "a"}], " ", "b"}], "+", 
      RowBox[{"a", " ", "r"}], "+", 
      RowBox[{"b", " ", "r"}], "-", 
      SuperscriptBox["r", "2"], "+", 
      RowBox[{"a", " ", "s"}], "+", 
      RowBox[{"b", " ", "s"}], "-", 
      RowBox[{"2", " ", "r", " ", "s"}], "-", 
      SuperscriptBox["s", "2"]}], ")", 
     SubscriptBox["S", "s"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "a"}], "-", 
      SuperscriptBox["a", "2"], "+", 
      RowBox[{"a", " ", "c"}], "-", 
      RowBox[{"b", " ", "s"}], "+", 
      RowBox[{"r", " ", "s"}], "+", 
      SuperscriptBox["s", "2"]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "a", "-", "b", "+", 
      RowBox[{"a", " ", "b"}], "+", 
      RowBox[{"2", " ", "r"}], "-", 
      RowBox[{"a", " ", "r"}], "-", 
      RowBox[{"b", " ", "r"}], "+", 
      SuperscriptBox["r", "2"], "+", 
      RowBox[{"2", " ", "s"}], "-", 
      RowBox[{"a", " ", "s"}], "-", 
      RowBox[{"b", " ", "s"}], "+", 
      RowBox[{"2", " ", "r", " ", "s"}], "+", 
      SuperscriptBox["s", "2"]}], ")", 
     SubsuperscriptBox["S", "s", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "a", "+", "b", "-", 
      RowBox[{"a", " ", "b"}], "-", "r", "+", 
      RowBox[{"a", " ", "r"}], "+", 
      RowBox[{"b", " ", "r"}], "-", 
      RowBox[{"c", " ", "r"}], "-", 
      RowBox[{"2", " ", "s"}], "+", 
      RowBox[{"2", " ", "a", " ", "s"}], "+", 
      RowBox[{"2", " ", "b", " ", "s"}], "-", 
      RowBox[{"c", " ", "s"}], "-", 
      RowBox[{"2", " ", "r", " ", "s"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["s", "2"]}]}], ")", 
     SubscriptBox["S", "s"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "a"}], " ", "s"}], "-", 
      RowBox[{"b", " ", "s"}], "+", 
      RowBox[{"c", " ", "s"}], "+", 
      SuperscriptBox["s", "2"]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
We can compute an annihilating ideal for the PFQ by using its definition.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"pfq", ",", "inh"}], "}"}], "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Pochhammer", "[", 
        RowBox[{"a", ",", "k"}], "]"}], "*", 
       RowBox[{"Pochhammer", "[", 
        RowBox[{"b", ",", "k"}], "]"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Pochhammer", "[", 
           RowBox[{"r", ",", "k"}], "]"}], "/", 
          RowBox[{"Pochhammer", "[", 
           RowBox[{"c", ",", "k"}], "]"}]}], "/", 
         RowBox[{"Pochhammer", "[", 
          RowBox[{
           RowBox[{"r", "+", "s"}], ",", "k"}], "]"}]}], "/", 
        RowBox[{"k", "!"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], ",", 
      RowBox[{"S", "[", "b", "]"}], ",", 
      RowBox[{"S", "[", "c", "]"}], ",", 
      RowBox[{"S", "[", "r", "]"}], ",", 
      RowBox[{"S", "[", "s", "]"}]}], "}"}], ",", 
    RowBox[{"Inhomogeneous", "\[Rule]", "True"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"r", 
       SubscriptBox["S", "r"]}], "+", 
      RowBox[{"s", 
       SubscriptBox["S", "s"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "r"}], "-", "s"}], ")"}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"a", " ", "b", " ", "c", " ", "r"}], "-", 
        RowBox[{"a", " ", 
         SuperscriptBox["c", "2"], " ", "r"}], "-", 
        RowBox[{"b", " ", 
         SuperscriptBox["c", "2"], " ", "r"}], "+", 
        RowBox[{
         SuperscriptBox["c", "3"], " ", "r"}], "-", 
        RowBox[{"a", " ", "b", " ", 
         SuperscriptBox["r", "2"]}], "+", 
        RowBox[{"a", " ", "c", " ", 
         SuperscriptBox["r", "2"]}], "+", 
        RowBox[{"b", " ", "c", " ", 
         SuperscriptBox["r", "2"]}], "-", 
        RowBox[{
         SuperscriptBox["c", "2"], " ", 
         SuperscriptBox["r", "2"]}], "+", 
        RowBox[{"a", " ", "b", " ", "c", " ", "s"}], "-", 
        RowBox[{"a", " ", 
         SuperscriptBox["c", "2"], " ", "s"}], "-", 
        RowBox[{"b", " ", 
         SuperscriptBox["c", "2"], " ", "s"}], "+", 
        RowBox[{
         SuperscriptBox["c", "3"], " ", "s"}], "-", 
        RowBox[{"a", " ", "b", " ", "r", " ", "s"}], "+", 
        RowBox[{"a", " ", "c", " ", "r", " ", "s"}], "+", 
        RowBox[{"b", " ", "c", " ", "r", " ", "s"}], "-", 
        RowBox[{
         SuperscriptBox["c", "2"], " ", "r", " ", "s"}]}], ")", 
       SubscriptBox["S", "c"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "a"}], " ", "b", " ", "c", " ", "s"}], "+", 
        RowBox[{"a", " ", "c", " ", "r", " ", "s"}], "+", 
        RowBox[{"b", " ", "c", " ", "r", " ", "s"}], "-", 
        RowBox[{"c", " ", 
         SuperscriptBox["r", "2"], " ", "s"}], "+", 
        RowBox[{"a", " ", "c", " ", 
         SuperscriptBox["s", "2"]}], "+", 
        RowBox[{"b", " ", "c", " ", 
         SuperscriptBox["s", "2"]}], "-", 
        RowBox[{"2", " ", "c", " ", "r", " ", 
         SuperscriptBox["s", "2"]}], "-", 
        RowBox[{"c", " ", 
         SuperscriptBox["s", "3"]}]}], ")", 
       SubscriptBox["S", "s"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"a", " ", 
         SuperscriptBox["c", "2"], " ", "r"}], "+", 
        RowBox[{"b", " ", 
         SuperscriptBox["c", "2"], " ", "r"}], "-", 
        RowBox[{
         SuperscriptBox["c", "3"], " ", "r"}], "-", 
        RowBox[{"a", " ", "c", " ", 
         SuperscriptBox["r", "2"]}], "-", 
        RowBox[{"b", " ", "c", " ", 
         SuperscriptBox["r", "2"]}], "+", 
        RowBox[{
         SuperscriptBox["c", "2"], " ", 
         SuperscriptBox["r", "2"]}], "+", 
        RowBox[{"a", " ", 
         SuperscriptBox["c", "2"], " ", "s"}], "+", 
        RowBox[{"b", " ", 
         SuperscriptBox["c", "2"], " ", "s"}], "-", 
        RowBox[{
         SuperscriptBox["c", "3"], " ", "s"}], "-", 
        RowBox[{"2", " ", "a", " ", "c", " ", "r", " ", "s"}], "-", 
        RowBox[{"2", " ", "b", " ", "c", " ", "r", " ", "s"}], "+", 
        RowBox[{
         SuperscriptBox["c", "2"], " ", "r", " ", "s"}], "+", 
        RowBox[{"c", " ", 
         SuperscriptBox["r", "2"], " ", "s"}], "-", 
        RowBox[{"a", " ", "c", " ", 
         SuperscriptBox["s", "2"]}], "-", 
        RowBox[{"b", " ", "c", " ", 
         SuperscriptBox["s", "2"]}], "+", 
        RowBox[{"2", " ", "c", " ", "r", " ", 
         SuperscriptBox["s", "2"]}], "+", 
        RowBox[{"c", " ", 
         SuperscriptBox["s", "3"]}]}], ")"}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"b", " ", "r"}], "+", 
        RowBox[{"a", " ", "b", " ", "r"}], "+", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", "r"}], "-", 
        RowBox[{"b", " ", "c", " ", "r"}], "+", 
        RowBox[{"b", " ", "s"}], "+", 
        RowBox[{"a", " ", "b", " ", "s"}], "+", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", "s"}], "-", 
        RowBox[{"b", " ", "c", " ", "s"}], "-", 
        RowBox[{"b", " ", "r", " ", "s"}], "-", 
        RowBox[{"b", " ", 
         SuperscriptBox["s", "2"]}]}], ")", 
       SubscriptBox["S", "b"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "a"}], " ", "b", " ", "s"}], "+", 
        RowBox[{"a", " ", "r", " ", "s"}], "+", 
        RowBox[{"b", " ", "r", " ", "s"}], "-", 
        RowBox[{
         SuperscriptBox["r", "2"], " ", "s"}], "+", 
        RowBox[{"a", " ", 
         SuperscriptBox["s", "2"]}], "+", 
        RowBox[{"b", " ", 
         SuperscriptBox["s", "2"]}], "-", 
        RowBox[{"2", " ", "r", " ", 
         SuperscriptBox["s", "2"]}], "-", 
        SuperscriptBox["s", "3"]}], ")", 
       SubscriptBox["S", "s"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "b"}], " ", "r"}], "-", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", "r"}], "+", 
        RowBox[{"b", " ", "c", " ", "r"}], "-", 
        RowBox[{"b", " ", "s"}], "-", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", "s"}], "+", 
        RowBox[{"b", " ", "c", " ", "s"}], "-", 
        RowBox[{"a", " ", "r", " ", "s"}], "+", 

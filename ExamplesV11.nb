Cell["\<\
We have to compare two initial values. For any n, in particular for n=3 and \
n=4, we have:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Binomial", "[", 
       RowBox[{
        RowBox[{"k", "+", "n", "-", "2"}], ",", "k"}], "]"}], "/", 
      RowBox[{"Binomial", "[", 
       RowBox[{
        RowBox[{"k", "+", 
         RowBox[{"n", "/", "2"}], "-", "2"}], ",", "k"}], "]"}]}], "*", 
     RowBox[{"t", "^", "k"}], "*", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{"k", ",", 
       RowBox[{"1", "-", 
        RowBox[{"n", "/", "2"}]}], ",", 
       RowBox[{"k", "+", 
        RowBox[{"n", "/", "2"}]}], ",", 
       RowBox[{"t", "^", "2"}]}], "]"}], "*", 
     RowBox[{"GegenbauerC", "[", 
      RowBox[{"k", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "2"}], ")"}], "/", "2"}], ",", "x"}], "]"}]}], "/.", 
    RowBox[{"t", "\[Rule]", "0"}]}], "/.", 
   RowBox[{"x", "\[Rule]", "0"}]}], "//", "FullSimplify"}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["0", "k"], " ", 
   RowBox[{"Binomial", "[", 

Cell[CellGroupData[{

Cell["Symeonidis identities", "Subsection"],

Cell["\<\
We found these two identities in the paper of Flavia Stan: \
\"Computer-assisted proofs of special function identities related to Poisson \
integrals\".\
\>", "Text"],

Cell[CellGroupData[{

Cell["Theorem 1", "Subsubsection"],

Cell["\<\
For real x and t such that Abs[x]<1 and Abs[t]<1, and integer n>=3:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"k", "+", "n", "-", "2"}], ",", "k"}], "]"}], "/", 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"k", "+", 
           RowBox[{"n", "/", "2"}], "-", "2"}], ",", "k"}], "]"}]}], "*", 
       RowBox[{"t", "^", "k"}], "*", 
       RowBox[{"Hypergeometric2F1", "[", 
        RowBox[{"k", ",", 
         RowBox[{"1", "-", 
          RowBox[{"n", "/", "2"}]}], ",", 
         RowBox[{"k", "+", 
          RowBox[{"n", "/", "2"}]}], ",", 
         RowBox[{"t", "^", "2"}]}], "]"}], "*", 
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"k", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"n", "-", "2"}], ")"}], "/", "2"}], ",", "x"}], "]"}]}], 
      ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"t", "^", "2"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"2", "*", "t", "*", "x"}], "+", 
         RowBox[{"t", "^", "2"}]}], ")"}]}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"n", "-", "1"}], ")"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], "\[Infinity]"], 
     FractionBox[
      RowBox[{
       TemplateBox[{RowBox[{"k", "+", "n", "-", "2"}],"k"},
        "Binomial"], " ", 
       SuperscriptBox["t", "k"], " ", 
       TemplateBox[{"k",RowBox[{"1", "-", 
           FractionBox["n", "2"]}],RowBox[{"k", "+", 
           FractionBox["n", "2"]}],SuperscriptBox["t", "2"]},
        "Hypergeometric2F1"], " ", 
       RowBox[{
        SubsuperscriptBox["C", "k", 
         RowBox[{"(", 
          FractionBox[
           RowBox[{"n", "-", "2"}], "2"], ")"}]], "(", "x", ")"}]}], 
      TemplateBox[{RowBox[{"k", "+", 
          FractionBox["n", "2"], "-", "2"}],"k"},
       "Binomial"]]}], "\[LongEqual]", 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox[
       RowBox[{"1", "-", 
        SuperscriptBox["t", "2"]}], 
       RowBox[{"1", "-", 
        RowBox[{"2", " ", "t", " ", "x"}], "+", 
        SuperscriptBox["t", "2"]}]], ")"}], 
     RowBox[{"n", "-", "1"}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


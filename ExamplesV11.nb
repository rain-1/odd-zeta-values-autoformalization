     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], "p", "*", 
       RowBox[{"Der", "[", "p", "]"}]}], "-", "1"}], ",", 
     RowBox[{"ArcTan", "[", "p", "]"}]}], "]"}], ",", 
   RowBox[{"Der", "[", "p", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "3"}], "-", 
     RowBox[{"2", " ", 
      SuperscriptBox["p", "2"]}], "+", 
     SuperscriptBox["p", "4"]}], ")", 
    SubsuperscriptBox["D", "p", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "14"}], " ", "p"}], "+", 
     RowBox[{"2", " ", 
      SuperscriptBox["p", "3"]}]}], ")", 
    SubscriptBox["D", "p"]}]}], "}"}]], "Output"]
}, Open  ]],


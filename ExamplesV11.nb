       RowBox[{"n", "+", "2"}], ",", "m", ",", "x"}], "]"}]}], "\[Equal]", 
    RowBox[{"m", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"GegenbauerC", "[", 
        RowBox[{
         RowBox[{"n", "+", "2"}], ",", 
         RowBox[{"m", "+", "1"}], ",", "x"}], "]"}], "-", 
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"n", ",", 
         RowBox[{"m", "+", "1"}], ",", "x"}], "]"}]}], ")"}]}]}], ",", 
   RowBox[{"GegenbauerC", "[", 
    RowBox[{"n", ",", "m", ",", "x"}], "]"}]}], "]"}]], "Input"],


 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0"}], 
  "}"}]], "Output"]
}, Open  ]],

Cell["Comparing initial values is not so easy here. We omit it.", "Text"]
}, Closed]],

Cell[CellGroupData[{

Cell["Stoll/Zeng: differential equations related to ChebyshevU", "Subsection"],

Cell["\<\
The following examples can be found in:
Stoll/Zeng: \"On the total weight of weighted matchings of segment graphs\" \
(Electronic Journal of Combinatorics), 
Proposition 2.2\
\>", "Text"],

Cell["\<\
The task is to derive differential equations (in x) for U_n(x,a) where \
(according to Prop. 2.1) for n=2k+1 we have\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"U", "[", 
     RowBox[{"n", ",", "x", ",", "a"}], "]"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"Sqrt", "[", "a", "]"}], "^", "k"}], "*", "x", "*", 
     RowBox[{"ChebyshevU", "[", 
      RowBox[{"k", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "-", "a", "-", "1"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", 
          RowBox[{"Sqrt", "[", "a", "]"}]}], ")"}]}]}], "]"}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{"U", "(", 
     RowBox[{"n", ",", "x", ",", "a"}], ")"}], "=", 
    RowBox[{
     SuperscriptBox[
      SqrtBox["a"], "k"], " ", "x", " ", 
     RowBox[{
      SubscriptBox["U", "k"], "(", 
      FractionBox[
       RowBox[{
        SuperscriptBox["x", "2"], "-", "a", "-", "1"}], 
       RowBox[{"2", " ", 
        SqrtBox["a"]}]], ")"}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["and for n=2k we have", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"U", "[", 
     RowBox[{"n", ",", "x", ",", "a"}], "]"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"Sqrt", "[", "a", "]"}], "^", "k"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"ChebyshevU", "[", 
        RowBox[{"k", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "-", "a", "-", "1"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", 
            RowBox[{"Sqrt", "[", "a", "]"}]}], ")"}]}]}], "]"}], "+", 
       RowBox[{
        RowBox[{"Sqrt", "[", "a", "]"}], "*", 
        RowBox[{"ChebyshevU", "[", 
         RowBox[{
          RowBox[{"k", "-", "1"}], ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"x", "^", "2"}], "-", "a", "-", "1"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"2", 
             RowBox[{"Sqrt", "[", "a", "]"}]}], ")"}]}]}], "]"}]}]}], 
      ")"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{"U", "(", 
     RowBox[{"n", ",", "x", ",", "a"}], ")"}], "=", 
    RowBox[{
     SuperscriptBox[
      SqrtBox["a"], "k"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SubscriptBox["U", "k"], "(", 
        FractionBox[
         RowBox[{
          SuperscriptBox["x", "2"], "-", "a", "-", "1"}], 
         RowBox[{"2", " ", 
          SqrtBox["a"]}]], ")"}], "+", 
       RowBox[{
        SqrtBox["a"], " ", 
        RowBox[{
         SubscriptBox["U", 
          RowBox[{"k", "-", "1"}]], "(", 
         FractionBox[
          RowBox[{
           SuperscriptBox["x", "2"], "-", "a", "-", "1"}], 
          RowBox[{"2", " ", 
           SqrtBox["a"]}]], ")"}]}]}], ")"}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"annUodd", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Sqrt", "[", "a", "]"}], "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "/", "2"}], ")"}]}], "*", "x", "*", 
     RowBox[{"ChebyshevU", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "/", "2"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "-", "a", "-", "1"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", 
          RowBox[{"Sqrt", "[", "a", "]"}]}], ")"}]}]}], "]"}]}], ",", 
    RowBox[{"Der", "[", "x", "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["x", "2"], "-", 
     RowBox[{"2", " ", "a", " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["x", "2"]}], "-", 
     RowBox[{"2", " ", 
      SuperscriptBox["x", "4"]}], "-", 
     RowBox[{"2", " ", "a", " ", 
      SuperscriptBox["x", "4"]}], "+", 
     SuperscriptBox["x", "6"]}], ")", 
    SubsuperscriptBox["D", "x", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "3"}], " ", "x"}], "+", 
     RowBox[{"6", " ", "a", " ", "x"}], "-", 
     RowBox[{"3", " ", 
      SuperscriptBox["a", "2"], " ", "x"}], "+", 
     RowBox[{"3", " ", 
      SuperscriptBox["x", "5"]}]}], ")", 
    SubscriptBox["D", "x"]}], "+", 
   RowBox[{"(", 
    RowBox[{"3", "-", 
     RowBox[{"6", " ", "a"}], "+", 
     RowBox[{"3", " ", 
      SuperscriptBox["a", "2"]}], "-", 
     RowBox[{"2", " ", "n", " ", 
      SuperscriptBox["x", "4"]}], "-", 
     RowBox[{
      SuperscriptBox["n", "2"], " ", 
      SuperscriptBox["x", "4"]}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Collect", "[", 
     RowBox[{"#", ",", "x", ",", "Factor"}], "]"}], "&"}], "/@", 

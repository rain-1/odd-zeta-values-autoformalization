Cell[CellGroupData[{

Cell["Bilateral hypergeometric sum from Ramanujan's Lost Notebook", \
"Subsection"],

Cell["\<\
This identity appeared as Formula no. 10 in \"Andrews/Berndt: Your Hit \
Parade: The Top Ten Most Fascinating Formulas in Ramanujan's Lost Notebook\"\
\>", "Text"],

Cell["\<\
Define, for any real numbers \[Theta] and s and for any complex numbers \
a,b,c, and d, such that Re(a+b+c+d)>3,\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Subscript", "[", 
      RowBox[{"\[Phi]", ",", "s"}], "]"}], "[", "\[Theta]", "]"}], "\[Equal]", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"E", "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"n", "+", "s"}], ")"}], "*", "I", "*", "\[Theta]"}], 
         ")"}]}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{"a", "+", "s", "+", "n"}], "]"}], "*", 
         RowBox[{"Gamma", "[", 
          RowBox[{"b", "-", "s", "-", "n"}], "]"}], "*", 
         RowBox[{"Gamma", "[", 
          RowBox[{"c", "+", "s", "+", "n"}], "]"}], "*", 
         RowBox[{"Gamma", "[", 
          RowBox[{"d", "-", "s", "-", "n"}], "]"}]}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}]}], "]"}]}], "]"}],
   "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Phi]", "s"], "(", "\[Theta]", ")"}], "\[LongEqual]", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", 
       RowBox[{"-", "\[Infinity]"}]}], "\[Infinity]"], 
     FractionBox[
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "+", "s"}], ")"}], " ", "\[ImaginaryI]", " ", 
        "\[Theta]"}]], 
      RowBox[{
       TemplateBox[{RowBox[{"a", "+", "s", "+", "n"}]},
        "Gamma"], " ", 
       TemplateBox[{RowBox[{"b", "-", "s", "-", "n"}]},
        "Gamma"], " ", 
       TemplateBox[{RowBox[{"c", "+", "s", "+", "n"}]},
        "Gamma"], " ", 
       TemplateBox[{RowBox[{"d", "-", "s", "-", "n"}]},
        "Gamma"]}]]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["Theorem 1 states that", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Subscript", "[", 
         RowBox[{"\[Phi]", ",", "s"}], "]"}], "[", "\[Theta]", "]"}], "/", 
       RowBox[{
        RowBox[{"Subscript", "[", 
         RowBox[{"\[Phi]", ",", "t"}], "]"}], "[", "\[Theta]", "]"}]}], ",", 
      "\[Theta]"}], "]"}], "\[Equal]", 
    RowBox[{"I", "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"Pi", "*", 
       RowBox[{"(", 
        RowBox[{"s", "-", "t"}], ")"}]}], "]"}], "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"2", 
        RowBox[{"Sin", "[", 
         RowBox[{
          RowBox[{"1", "/", "2"}], "*", "\[Theta]"}], "]"}]}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"a", "+", "b", "+", "c", "+", "d", "-", "4"}], ")"}]}], "*", 
     RowBox[{
      RowBox[{"E", "^", 
       RowBox[{"(", 
        RowBox[{"I", "*", 
         RowBox[{"(", 
          RowBox[{"Pi", "-", "\[Theta]"}], ")"}], "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"a", "-", "b", "+", "c", "-", "d", "+", 
            RowBox[{"2", "s"}], "+", 
            RowBox[{"2", "t"}]}], ")"}], "/", "2"}]}], ")"}]}], "/", 
      RowBox[{"(", 
       RowBox[{"Pi", "*", 
        RowBox[{
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"\[Phi]", ",", "t"}], "]"}], "[", "\[Theta]", "]"}], "^", 
         "2"}], "*", 
        RowBox[{"Gamma", "[", 
         RowBox[{"a", "+", "b", "-", "1"}], "]"}], "*", 
        RowBox[{"Gamma", "[", 
         RowBox[{"b", "+", "c", "-", "1"}], "]"}], "*", 
        RowBox[{"Gamma", "[", 
         RowBox[{"c", "+", "d", "-", "1"}], "]"}], "*", 
        RowBox[{"Gamma", "[", 
         RowBox[{"d", "+", "a", "-", "1"}], "]"}]}], ")"}]}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    TagBox[
     RowBox[{
      FractionBox["\[PartialD]", 
       RowBox[{"\[PartialD]", "\[Theta]"}]], 
      FractionBox[
       RowBox[{
        SubscriptBox["\[Phi]", "s"], "(", "\[Theta]", ")"}], 
       RowBox[{
        SubscriptBox["\[Phi]", "t"], "(", "\[Theta]", ")"}]]}],
     D], "\[LongEqual]", 
    FractionBox[
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"sin", "(", 
       RowBox[{"\[Pi]", " ", 
        RowBox[{"(", 
         RowBox[{"s", "-", "t"}], ")"}]}], ")"}], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"2", " ", 
         RowBox[{"sin", "(", 
          FractionBox["\[Theta]", "2"], ")"}]}], ")"}], 
       RowBox[{"a", "+", "b", "+", "c", "+", "d", "-", "4"}]], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
        RowBox[{"(", 
         RowBox[{"\[Pi]", "-", "\[Theta]"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"a", "-", "b", "+", "c", "-", "d", "+", 
          RowBox[{"2", " ", "s"}], "+", 
          RowBox[{"2", " ", "t"}]}], ")"}]}]]}], 
     RowBox[{"\[Pi]", " ", 
      SuperscriptBox[
       RowBox[{
        SubscriptBox["\[Phi]", "t"], "(", "\[Theta]", ")"}], "2"], " ", 
      TemplateBox[{RowBox[{"a", "+", "b", "-", "1"}]},
       "Gamma"], " ", 
      TemplateBox[{RowBox[{"b", "+", "c", "-", "1"}]},
       "Gamma"], " ", 
      TemplateBox[{RowBox[{"c", "+", "d", "-", "1"}]},
       "Gamma"], " ", 
      TemplateBox[{RowBox[{"d", "+", "a", "-", "1"}]},
       "Gamma"]}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[TextData[{
 "For convenience, we replace  Exp[I*theta]  by z. Further we multiply both \
sides by ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{
     SubscriptBox["\[Phi]", "t"], "(", "\[Theta]", ")"}], "2"], 
   TraditionalForm]], "Output",
  CellChangeTimes->{3.466900729620732*^9}],
 ". Starting from the definition of \[Phi], we are now going to compute an \
annihilating ideal for ",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{"\[PartialD]", 
        RowBox[{
         SubscriptBox["\[Phi]", "s"], "(", "\[Theta]", ")"}]}], 
       RowBox[{"\[PartialD]", "\[Theta]"}],
       MultilineFunction->None], " ", 
      RowBox[{
       SubscriptBox["\[Phi]", "t"], "(", "\[Theta]", ")"}]}], "-", 
     RowBox[{
      FractionBox[
       RowBox[{"\[PartialD]", 
        RowBox[{
         SubscriptBox["\[Phi]", "t"], "(", "\[Theta]", ")"}]}], 
       RowBox[{"\[PartialD]", "\[Theta]"}],
       MultilineFunction->None], " ", 
      RowBox[{
       SubscriptBox["\[Phi]", "s"], "(", "\[Theta]", ")"}]}]}],
    HoldForm], TraditionalForm]], "Output",
  CellChangeTimes->{3.466900878428307*^9}],
 "."
}], "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"phiSmnd", "[", "s_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"z", "^", 
       RowBox[{"(", 
        RowBox[{"n", "+", "s"}], ")"}]}], "/", 

          RowBox[{"{", 
           RowBox[{"x", ",", "d"}], "}"}]}], "]"}], "/.", 
        RowBox[{"x", "\[Rule]", "xx"}]}], ")"}], "-", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", "k"}], "*", 
          RowBox[{
           RowBox[{
            RowBox[{"PolyGamma", "[", 

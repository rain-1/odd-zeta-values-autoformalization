     RowBox[{
      RowBox[{"Re", "[", "z", "]"}], ">", "0"}]}], ",", 
    RowBox[{"Inhomogeneous", "\[Rule]", "True"}], ",", 
    RowBox[{"Head", "\[Rule]", "S"}]}], "]"}], "//", "ReleaseHold"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "z"]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", 
       SuperscriptBox["z", "2"]}], ")"}], " ", 
     RowBox[{"S", "[", "z", "]"}]}], "+", 
    RowBox[{"z", " ", 
     RowBox[{
      SuperscriptBox["S", "\[Prime]",
       MultilineFunction->None], "[", "z", "]"}]}], "+", 

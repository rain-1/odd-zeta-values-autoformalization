       SuperscriptBox["m", "2"]}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "15"}], "-", 
      RowBox[{"32", " ", "m"}], "-", 
      RowBox[{"16", " ", 
       SuperscriptBox["m", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"2", " ", "a"}], 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "4"}], "-", 
      RowBox[{"4", " ", "m"}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 

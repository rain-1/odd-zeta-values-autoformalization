Cell["\<\
Hence we have this recurrence for both the even and the odd case. The same \
recurrence can be obtained by combining the two given in formula (2):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"recEven", "=", 
  RowBox[{"ToOrePolynomial", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"S", "[", "n", "]"}], "^", "2"}], "-", 
    RowBox[{"x", "*", 
     RowBox[{"S", "[", "n", "]"}]}], "+", "a"}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["S", "n", "2"], "-", 
  RowBox[{"x", 
   SubscriptBox["S", "n"]}], "+", "a"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"recOdd", "=", 
  RowBox[{"ToOrePolynomial", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"S", "[", "n", "]"}], "^", "2"}], "-", 
    RowBox[{"x", "*", 
     RowBox[{"S", "[", "n", "]"}]}], "+", "1"}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["S", "n", "2"], "-", 
  RowBox[{"x", 
   SubscriptBox["S", "n"]}], "+", "1"}]], "Output"]
}, Open  ]],


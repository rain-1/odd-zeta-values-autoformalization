      RowBox[{
       RowBox[{"(", 
        RowBox[{"3", "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"4", "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"7", "+", 
         RowBox[{"2", " ", "i"}], "+", 
         RowBox[{"2", " ", "j"}]}], ")"}]}], 
      SubsuperscriptBox["S", "j", "4"], 
      SubscriptBox["D", "y"]}], "-", 
     RowBox[{
      RowBox[{"4", " ", 
       RowBox[{"(", 
        RowBox[{"2", "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"4", "+", "i", "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"6", "+", 
         RowBox[{"2", " ", "i"}], "+", "j"}], ")"}]}], 
      SubsuperscriptBox["S", "i", "2"], 
      SubscriptBox["S", "j"], 
      SubscriptBox["D", "y"]}], "+", 
     RowBox[{
      RowBox[{"4", " ", 
       RowBox[{"(", 
        RowBox[{"3", "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"4", "+", "i", "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"5", "+", 
         RowBox[{"2", " ", "i"}], "+", "j"}], ")"}]}], 
      SubsuperscriptBox["S", "j", "3"], 
      SubscriptBox["D", "y"]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"2", "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"9", "+", 
         RowBox[{"2", " ", "i"}], "+", 
         RowBox[{"2", " ", "j"}]}], ")"}]}], 
      SubsuperscriptBox["S", "i", "2"], 
      SubscriptBox["D", "y"]}], "-", 
     RowBox[{
      RowBox[{"4", " ", 
       RowBox[{"(", 
        RowBox[{"3", "+", 
         RowBox[{"2", " ", "i"}]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"4", "+", "i", "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"7", "+", 
         RowBox[{"2", " ", "i"}], "+", 
         RowBox[{"2", " ", "j"}]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"9", "+", 
         RowBox[{"2", " ", "i"}], "+", 
         RowBox[{"2", " ", "j"}]}], ")"}]}], 
      SubscriptBox["S", "i"], 
      SubsuperscriptBox["S", "j", "2"]}], "-", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"4", "+", 
         RowBox[{"2", " ", "i"}], "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"5", "+", 
         RowBox[{"2", " ", "i"}], "+", "j"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"9", "+", 
         RowBox[{"2", " ", "i"}], "+", 
         RowBox[{"2", " ", "j"}]}], ")"}]}], 
      SubsuperscriptBox["S", "j", "2"], 
      SubscriptBox["D", "y"]}]}], "}"}]}], "}"}]], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Integral over 3 Gegenbauer polynomials", "Subsection"],

Cell["\<\
The following identity can be found as formula (6.8.10) in Adrews/Askey/Roy, \
p. 321. 
For \[Lambda]>-1/2 and \[Lambda] \[NotEqual] 0, for  l+m+n  even and the sum \
of any two of l,m,n is not less than the third. The integral is zero in all \
other cases.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"l", ",", "\[Lambda]", ",", "x"}], "]"}], "*", 
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"m", ",", "\[Lambda]", ",", "x"}], "]"}], "*", 
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"n", ",", "\[Lambda]", ",", "x"}], "]"}], "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"x", "^", "2"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"\[Lambda]", "-", 
          RowBox[{"1", "/", "2"}]}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"Pochhammer", "[", 
      RowBox[{"\[Lambda]", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"m", "+", "n", "-", "l"}], ")"}], "/", "2"}]}], "]"}], "*", 
     RowBox[{"Pochhammer", "[", 
      RowBox[{"\[Lambda]", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "+", "l", "-", "m"}], ")"}], "/", "2"}]}], "]"}], "*", 
     RowBox[{"Pochhammer", "[", 
      RowBox[{"\[Lambda]", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"l", "+", "m", "-", "n"}], ")"}], "/", "2"}]}], "]"}], "*", 
     RowBox[{"2", "^", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"2", "*", "\[Lambda]"}]}], ")"}]}], "*", "Pi", "*", 
     RowBox[{
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"l", "+", "m", "+", "n"}], ")"}], "/", "2"}], "+", 
        RowBox[{"2", "*", "\[Lambda]"}]}], "]"}], "/", "\[IndentingNewLine]", 
      
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"m", "+", "n", "-", "l"}], ")"}], "/", "2"}], ")"}], 
         "!"}], "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"l", "+", "n", "-", "m"}], ")"}], "/", "2"}], ")"}], 
         "!"}], "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"l", "+", "m", "-", "n"}], ")"}], "/", "2"}], ")"}], 
         "!"}], "*", 
        RowBox[{"Pochhammer", "[", 
         RowBox[{"\[Lambda]", ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"l", "+", "m", "+", "n"}], ")"}], "/", "2"}]}], "]"}], 
        "*", 
        RowBox[{
         RowBox[{"Gamma", "[", "\[Lambda]", "]"}], "^", "2"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"l", "+", "m", "+", "n"}], ")"}], "/", "2"}], "+", 
          "\[Lambda]"}], ")"}]}], ")"}]}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"-", "1"}], "1"], 
     RowBox[{
      RowBox[{
       RowBox[{
        SubsuperscriptBox["C", "l", 
         RowBox[{"(", "\[Lambda]", ")"}]], "(", "x", ")"}], " ", 
       RowBox[{
        SubsuperscriptBox["C", "m", 
         RowBox[{"(", "\[Lambda]", ")"}]], "(", "x", ")"}], " ", 
       RowBox[{
        SubsuperscriptBox["C", "n", 
         RowBox[{"(", "\[Lambda]", ")"}]], "(", "x", ")"}], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["x", "2"]}], ")"}], 
        RowBox[{"\[Lambda]", "-", 
         FractionBox["1", "2"]}]]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{
      TemplateBox[{"\[Lambda]",RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
            RowBox[{"m", "+", "n", "-", "l"}], ")"}]}]},
       "Pochhammer"], " ", 
      TemplateBox[{"\[Lambda]",RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
            RowBox[{"n", "+", "l", "-", "m"}], ")"}]}]},
       "Pochhammer"], " ", 
      TemplateBox[{"\[Lambda]",RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
            RowBox[{"l", "+", "m", "-", "n"}], ")"}]}]},
       "Pochhammer"], " ", 
      SuperscriptBox["2", 
       RowBox[{"1", "-", 
        RowBox[{"2", " ", "\[Lambda]"}]}]], " ", "\[Pi]", " ", 
      TemplateBox[{RowBox[{
          RowBox[{
            FractionBox["1", "2"], " ", 
            RowBox[{"(", 
              RowBox[{"l", "+", "m", "+", "n"}], ")"}]}], "+", 
          RowBox[{"2", " ", "\[Lambda]"}]}]},
       "Gamma"]}], 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         FractionBox["1", "2"], " ", 
         RowBox[{"(", 
          RowBox[{"m", "+", "n", "-", "l"}], ")"}]}], ")"}], "!"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         FractionBox["1", "2"], " ", 
         RowBox[{"(", 
          RowBox[{"l", "+", "n", "-", "m"}], ")"}]}], ")"}], "!"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         FractionBox["1", "2"], " ", 
         RowBox[{"(", 
          RowBox[{"l", "+", "m", "-", "n"}], ")"}]}], ")"}], "!"}], " ", 
      TemplateBox[{"\[Lambda]",RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
            RowBox[{"l", "+", "m", "+", "n"}], ")"}]}]},
       "Pochhammer"], " ", 
      SuperscriptBox[
       TemplateBox[{"\[Lambda]"},
        "Gamma"], "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         FractionBox["1", "2"], " ", 
         RowBox[{"(", 
          RowBox[{"l", "+", "m", "+", "n"}], ")"}]}], "+", "\[Lambda]"}], 
       ")"}]}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
This example is quite involved. First, if we try to apply Annihilator to the \
integral, some problems concerning the automatic simplification of the delta \
parts arise. In order to assist in this part by hand, we use the option \
Inhomogeneous. Still, the computation takes a while:\
\>", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"integrand", "=", 
   RowBox[{
    RowBox[{"GegenbauerC", "[", 
     RowBox[{"l", ",", "\[Lambda]", ",", "x"}], "]"}], "*", 
    RowBox[{"GegenbauerC", "[", 
     RowBox[{"m", ",", "\[Lambda]", ",", "x"}], "]"}], "*", 
    RowBox[{"GegenbauerC", "[", 
     RowBox[{"n", ",", "\[Lambda]", ",", "x"}], "]"}], "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"x", "^", "2"}]}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"\[Lambda]", "-", 
       RowBox[{"1", "/", "2"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"expr", "=", 
   RowBox[{
    RowBox[{"Pochhammer", "[", 
     RowBox[{"\[Lambda]", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"m", "+", "n", "-", "l"}], ")"}], "/", "2"}]}], "]"}], "*", 
    RowBox[{"Pochhammer", "[", 
     RowBox[{"\[Lambda]", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"n", "+", "l", "-", "m"}], ")"}], "/", "2"}]}], "]"}], "*", 
    RowBox[{"Pochhammer", "[", 
     RowBox[{"\[Lambda]", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"l", "+", "m", "-", "n"}], ")"}], "/", "2"}]}], "]"}], "*", 
    RowBox[{"2", "^", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"2", "*", "\[Lambda]"}]}], ")"}]}], "*", "Pi", "*", 
    RowBox[{
     RowBox[{"Gamma", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"l", "+", "m", "+", "n"}], ")"}], "/", "2"}], "+", 
       RowBox[{"2", "*", "\[Lambda]"}]}], "]"}], "/", "\[IndentingNewLine]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "+", "n", "-", "l"}], ")"}], "/", "2"}], ")"}], "!"}],
        "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"l", "+", "n", "-", "m"}], ")"}], "/", "2"}], ")"}], "!"}],
        "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"l", "+", "m", "-", "n"}], ")"}], "/", "2"}], ")"}], "!"}],
        "*", 
       RowBox[{"Pochhammer", "[", 
        RowBox[{"\[Lambda]", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"l", "+", "m", "+", "n"}], ")"}], "/", "2"}]}], "]"}], "*", 
       RowBox[{
        RowBox[{"Gamma", "[", "\[Lambda]", "]"}], "^", "2"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"l", "+", "m", "+", "n"}], ")"}], "/", "2"}], "+", 
         "\[Lambda]"}], ")"}]}], ")"}]}]}]}], ";"}]}], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"With", " ", "$NormalizeMethod"}], "=", "\"\<gcd\>\""}], ",", 
    RowBox[{"Mathematica", " ", "crashes"}]}], "*)"}], 
  RowBox[{
   RowBox[{"nm", "=", "$NormalizeMethod"}], ";", 
   RowBox[{"$NormalizeMethod", "=", "\"\<ftl\>\""}], ";"}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Timing", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"lhs", ",", "inh"}], "}"}], "=", 
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{"integrand", ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "l", "]"}], ",", 
        RowBox[{"S", "[", "m", "]"}], ",", 
        RowBox[{"S", "[", "n", "]"}]}], "}"}], ",", 
      RowBox[{"Assumptions", "\[Rule]", 
       RowBox[{"\[Lambda]", ">", 
        RowBox[{"1", "/", "2"}]}]}], ",", 
      RowBox[{"Inhomogeneous", "\[Rule]", "True"}]}], "]"}]}], ";"}], 
  "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"484.256`", ",", "Null"}], "}"}]], "Output"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"$NormalizeMethod", "=", "nm"}], ";"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ReleaseHold", "[", 
   RowBox[{"inh", "/.", 
    RowBox[{
     RowBox[{"HoldPattern", "[", 
      RowBox[{"Limit", "[", 
       RowBox[{"a_", ",", "b_", ",", "_"}], "]"}], "]"}], "\[RuleDelayed]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Expand", "[", "a", "]"}], "/.", "b"}], ")"}]}]}], "]"}], "/.", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"0", "^", "a_"}], ")"}], "\[RuleDelayed]", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"0", "^", "a"}], ",", 
     RowBox[{"\[Lambda]", ">", 
      RowBox[{"1", "/", "2"}]}]}], "]"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0"}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
So the delta parts vanish and lhs is an annihilating ideal for the integral. \
The right-hand side gives rise to exactly the same annihilating ideal.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Factor", "[", 
  RowBox[{"rhs", "=", 
   RowBox[{"Annihilator", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"S", "[", "l", "]"}], ",", 
       RowBox[{"S", "[", "m", "]"}], ",", 
       RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", "l", "+", "m", "-", "n"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "l", "-", "m", "+", "n", "+", 
        RowBox[{"2", " ", "\[Lambda]"}]}], ")"}]}], 
     SubscriptBox["S", "m"]}], "-", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", "l", "-", "m", "+", "n"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "l", "+", "m", "-", "n", "+", 
        RowBox[{"2", " ", "\[Lambda]"}]}], ")"}]}], 
     SubscriptBox["S", "n"]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", "l", "+", "m", "-", "n"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", "l", "-", "m", "-", "n", "-", 
        RowBox[{"2", " ", "\[Lambda]"}]}], ")"}]}], 
     SubscriptBox["S", "l"]}], "-", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "l", "-", "m", "-", "n"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "l", "+", "m", "-", "n", "+", 
        RowBox[{"2", " ", "\[Lambda]"}]}], ")"}]}], 
     SubscriptBox["S", "n"]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "2"}], "+", "l", "-", "m", "-", "n"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"2", "+", "l", "-", "m", "+", "n"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "2"}], "+", "l", "+", "m", "-", "n", "+", 
        RowBox[{"2", " ", "\[Lambda]"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"2", "+", "l", "+", "m", "+", "n", "+", 
        RowBox[{"2", " ", "\[Lambda]"}]}], ")"}]}], 
     SubsuperscriptBox["S", "n", "2"]}], "-", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"l", "+", "m", "-", "n"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"l", "-", "m", "-", "n", "-", 
       RowBox[{"2", " ", "\[Lambda]"}]}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"l", "-", "m", "+", "n", "+", 
       RowBox[{"2", " ", "\[Lambda]"}]}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"l", "+", "m", "+", "n", "+", 
       RowBox[{"4", " ", "\[Lambda]"}]}], ")"}]}]}]}], "}"}]], "Output"]
}, Open  ]],


Cell[TextData[{
 "Since we choose the parameters a,b,c,r,s in a way that everything goes \
well, we believe that the above limits go to 0, although ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " does not evaluate them (also not when giving assumptions). Alternatively, \
having ensured that the bounds of the sum are natural, we can call Takayama \
and get the same result:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tak", "=", 
  RowBox[{"Takayama", "[", 
   RowBox[{
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Pochhammer", "[", 
        RowBox[{"a", ",", "k"}], "]"}], "*", 
       RowBox[{"Pochhammer", "[", 
        RowBox[{"b", ",", "k"}], "]"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Pochhammer", "[", 
           RowBox[{"r", ",", "k"}], "]"}], "/", 
          RowBox[{"Pochhammer", "[", 
           RowBox[{"c", ",", "k"}], "]"}]}], "/", 
         RowBox[{"Pochhammer", "[", 
          RowBox[{
           RowBox[{"r", "+", "s"}], ",", "k"}], "]"}]}], "/", 
        RowBox[{"k", "!"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "k", "]"}], ",", 
        RowBox[{"S", "[", "a", "]"}], ",", 
        RowBox[{"S", "[", "b", "]"}], ",", 
        RowBox[{"S", "[", "c", "]"}], ",", 
        RowBox[{"S", "[", "r", "]"}], ",", 
        RowBox[{"S", "[", "s", "]"}]}], "}"}]}], "]"}], ",", 
    RowBox[{"{", "k", "}"}]}], "]"}]}]], "Input"],


Cell[TextData[{
 "Task: For the above function, find a representation of the derivatives \
w.r.t. x and y in terms of shifts of this function in i and j, i.e., find a \
relation of the form ",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     FractionBox[
      RowBox[{"\[PartialD]", 
       RowBox[{"phi", "(", 
        RowBox[{"i", ",", "j", ",", "x", ",", "y"}], ")"}]}], 
      RowBox[{"\[PartialD]", "x"}],
      MultilineFunction->None], "\[LongEqual]", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"m", "=", "0"}], "M"], 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"n", "=", "0"}], "N"], 
       RowBox[{
        RowBox[{"c", "(", 
         RowBox[{"m", ",", "n"}], ")"}], " ", 
        RowBox[{"phi", "(", 
         RowBox[{
          RowBox[{"i", "+", "m"}], ",", 
          RowBox[{"j", "+", "n"}], ",", "x", ",", "y"}], ")"}]}]}]}]}],
    HoldForm], TraditionalForm]], "Output",
  CellChangeTimes->{
   3.433577419085334*^9, {3.433577462133247*^9, 3.433577471386878*^9}}],
 ". The coefficients have to be free of x and y."
}], "Text"],


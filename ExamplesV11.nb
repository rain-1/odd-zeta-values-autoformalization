Cell[TextData[{
 "7.313  ",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"-", "1"}], "1"], 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["x", "2"]}], ")"}], 
        RowBox[{"nu", "-", 

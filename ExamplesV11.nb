Cell["Compute an annihilating ideal for the integrand:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"m", "*", "x"}], "]"}], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"n", "*", "x"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}], ",", 
      RowBox[{"Der", "[", "x", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","nondf",
   "\"The expression \\!\\(\\*RowBox[{\\\"\\\\\\\"Sin[m*x]w.r.t. {S[m]}\\\\\\\
\"\\\"}]\\) is not recognized to be \[PartialD]-finite. The result might not \
generate a zero-dimensional ideal.\"",2,249,6,31736665789155565964,"Local"},
  "MessageTemplate"]], "Message", "MSG"],


Cell[CellGroupData[{

Cell["with Chyzak's algorithm", "Subsubsection"],

Cell["\<\
Next, compute a creative telescoping relation with Chyzak's algorithm:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ct", "=", 
  RowBox[{"CreativeTelescoping", "[", 
   RowBox[{"ann", ",", 
    RowBox[{"Der", "[", "x", "]"}], ",", 
    RowBox[{"S", "[", "k", "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox["S", "k"]}], "+", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["x", "2"], "-", 
        SuperscriptBox["x", "4"]}], 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", "k"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"3", "+", 
          RowBox[{"2", " ", "k"}]}], ")"}]}]], 
      SubscriptBox["D", "x"]}], "+", 
     RowBox[{
      FractionBox["x", 
       RowBox[{"5", "+", 
        RowBox[{"4", " ", "k"}]}]], 
      SubscriptBox["S", "k"]}], "+", 
     FractionBox[
      RowBox[{
       RowBox[{"4", " ", "x"}], "+", 
       RowBox[{"3", " ", "k", " ", "x"}], "-", 
       RowBox[{"5", " ", 
        SuperscriptBox["x", "3"]}], "-", 
       RowBox[{"4", " ", "k", " ", 
        SuperscriptBox["x", "3"]}]}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", "k"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"5", "+", 
         RowBox[{"4", " ", "k"}]}], ")"}]}]]}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Check the delta part. It does not contribute any inhomogeneous part from \
telescoping.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"delta", "=", 
  RowBox[{
   RowBox[{"ApplyOreOperator", "[", 
    RowBox[{
     RowBox[{"ct", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"LegendreP", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"2", "k"}], "+", "1"}], ",", "x"}], "]"}], "/", "x"}], 
       ")"}], "^", "2"}]}], "]"}], "//", "Simplify"}]}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"7", "+", 
      RowBox[{"6", " ", "k"}]}], ")"}], " ", 
    SuperscriptBox[
     RowBox[{"LegendreP", "[", 
      RowBox[{
       RowBox[{"1", "+", 
        RowBox[{"2", " ", "k"}]}], ",", "x"}], "]"}], "2"]}], "-", 
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{"5", "+", 
      RowBox[{"4", " ", "k"}]}], ")"}], " ", "x", " ", 
    RowBox[{"LegendreP", "[", 
     RowBox[{
      RowBox[{"1", "+", 
       RowBox[{"2", " ", "k"}]}], ",", "x"}], "]"}], " ", 
    RowBox[{"LegendreP", "[", 
     RowBox[{
      RowBox[{"2", "+", 
       RowBox[{"2", " ", "k"}]}], ",", "x"}], "]"}]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"3", "+", 
      RowBox[{"2", " ", "k"}]}], ")"}], " ", 
    SuperscriptBox[
     RowBox[{"LegendreP", "[", 
      RowBox[{
       RowBox[{"3", "+", 
        RowBox[{"2", " ", "k"}]}], ",", "x"}], "]"}], "2"]}]}], 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"3", "+", 
     RowBox[{"2", " ", "k"}]}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"5", "+", 
     RowBox[{"4", " ", "k"}]}], ")"}], " ", "x"}]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{"delta", "/.", 
    RowBox[{"x", "\[Rule]", "1"}]}], ")"}], "-", 
  RowBox[{"(", 
   RowBox[{"delta", "/.", 
    RowBox[{"x", "\[Rule]", 
     RowBox[{"-", "1"}]}]}], ")"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"10", "+", 
    RowBox[{"8", " ", "k"}], "-", 
    RowBox[{"2", " ", 
     RowBox[{"(", 
      RowBox[{"5", "+", 
       RowBox[{"4", " ", "k"}]}], ")"}]}]}], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"3", "+", 
      RowBox[{"2", " ", "k"}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"5", "+", 
      RowBox[{"4", " ", "k"}]}], ")"}]}]], "+", 
  FractionBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"7", "+", 
       RowBox[{"6", " ", "k"}]}], ")"}], " ", 
     SuperscriptBox[
      RowBox[{"LegendreP", "[", 
       RowBox[{
        RowBox[{"1", "+", 
         RowBox[{"2", " ", "k"}]}], ",", 
        RowBox[{"-", "1"}]}], "]"}], "2"]}], "+", 
    RowBox[{"2", " ", 
     RowBox[{"(", 
      RowBox[{"5", "+", 
       RowBox[{"4", " ", "k"}]}], ")"}], " ", 
     RowBox[{"LegendreP", "[", 
      RowBox[{
       RowBox[{"1", "+", 
        RowBox[{"2", " ", "k"}]}], ",", 
       RowBox[{"-", "1"}]}], "]"}], " ", 
     RowBox[{"LegendreP", "[", 
      RowBox[{
       RowBox[{"2", "+", 
        RowBox[{"2", " ", "k"}]}], ",", 
       RowBox[{"-", "1"}]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"3", "+", 
       RowBox[{"2", " ", "k"}]}], ")"}], " ", 
     SuperscriptBox[
      RowBox[{"LegendreP", "[", 
       RowBox[{
        RowBox[{"3", "+", 
         RowBox[{"2", " ", "k"}]}], ",", 
        RowBox[{"-", "1"}]}], "]"}], "2"]}]}], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"3", "+", 
      RowBox[{"2", " ", "k"}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"5", "+", 
      RowBox[{"4", " ", "k"}]}], ")"}]}]]}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"%", ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"Element", "[", 
      RowBox[{"k", ",", "Integers"}], "]"}], "&&", 
     RowBox[{"k", ">", "0"}]}]}]}], "]"}]], "Input"],

Cell[BoxData["0"], "Output"]
}, Open  ]],

Cell["\<\
Hence, S[k]-1 is a recurrence for the integral. The same result can be more \
easily (i.e., completely automatically) obtained by\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"LegendreP", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"2", "*", "k"}], "+", "1"}], ",", "x"}], "]"}], "/", "x"}],
        ")"}], "^", "2"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
   RowBox[{"S", "[", "k", "]"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"Element", "[", 
      RowBox[{"k", ",", "Integers"}], "]"}], "&&", 
     RowBox[{"k", "\[GreaterEqual]", "0"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    SubscriptBox["S", "k"]}], "+", "1"}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
One initial value suffices to obtain the evaluation of the integral:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"LegendreP", "[", 
       RowBox[{"1", ",", "x"}], "]"}], "/", "x"}], ")"}], "^", "2"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData["2"], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["with Takayama's algorithm", "Subsubsection"],

Cell["\<\
Takayama's algorithm delivers a bigger recurrence (which is a multiple of the \
above). But one has to be careful since the integral does not have natural \
boundaries.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Takayama", "[", 
  RowBox[{"ann", ",", 
   RowBox[{"{", "x", "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "500"}], "-", 
     RowBox[{"1300", " ", "k"}], "-", 
     RowBox[{"1325", " ", 
      SuperscriptBox["k", "2"]}], "-", 
     RowBox[{"664", " ", 
      SuperscriptBox["k", "3"]}], "-", 
     RowBox[{"164", " ", 
      SuperscriptBox["k", "4"]}], "-", 
     RowBox[{"16", " ", 
      SuperscriptBox["k", "5"]}]}], ")", 
    SubsuperscriptBox["S", "k", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{"581", "+", 
     RowBox[{"1606", " ", "k"}], "+", 
     RowBox[{"1778", " ", 
      SuperscriptBox["k", "2"]}], "+", 
     RowBox[{"992", " ", 
      SuperscriptBox["k", "3"]}], "+", 
     RowBox[{"280", " ", 
      SuperscriptBox["k", "4"]}], "+", 
     RowBox[{"32", " ", 
      SuperscriptBox["k", "5"]}]}], ")", 
    SubscriptBox["S", "k"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "81"}], "-", 
     RowBox[{"306", " ", "k"}], "-", 
     RowBox[{"453", " ", 
      SuperscriptBox["k", "2"]}], "-", 
     RowBox[{"328", " ", 
      SuperscriptBox["k", "3"]}], "-", 
     RowBox[{"116", " ", 
      SuperscriptBox["k", "4"]}], "-", 
     RowBox[{"16", " ", 
      SuperscriptBox["k", "5"]}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
With the option Extended \[RightArrow] True, we can force the command  \
Takayama to carry the delta parts through the Gr\[ODoubleDot]bner basis \
computation.\
\>", "Text"],


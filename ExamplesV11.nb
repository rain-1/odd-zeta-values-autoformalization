Cell[TextData[{
 "Bernoulli polynomials ",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", "1"], 
       RowBox[{
        TemplateBox[{"m","x"},
         "BernoulliB2"], " ", 
        TemplateBox[{"n","x"},
         "BernoulliB2"], 
        RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
      FractionBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], 
         RowBox[{"n", "-", "1"}]], " ", 
        RowBox[{"m", "!"}], " ", 
        RowBox[{"n", "!"}], " ", 
        SubscriptBox[
         TagBox["B",
          BernoulliB], 
         RowBox[{"m", "+", "n"}]]}], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"m", "+", "n"}], ")"}], "!"}]]}], "=", 
     FractionBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "m"], " ", 
       RowBox[{"m", "!"}], " ", 
       RowBox[{"n", "!"}], " ", 
       RowBox[{"cos", "(", 
        RowBox[{
         FractionBox["1", "2"], " ", "\[Pi]", " ", 
         RowBox[{"(", 
          RowBox[{"m", "+", "n"}], ")"}]}], ")"}], " ", 
       TemplateBox[{RowBox[{"m", "+", "n"}]},
        "Zeta"]}], 
      RowBox[{
       SuperscriptBox["2", 
        RowBox[{"m", "+", "n", "-", "1"}]], " ", 
       SuperscriptBox["\[Pi]", 
        RowBox[{"m", "+", "n"}]]}]]}],
    HoldForm], TraditionalForm]], "Output",
  CellChangeTimes->{3.465313337404736*^9, 3.465313370311473*^9, 
   3.465320598510811*^9}]
}], "Subsection"],


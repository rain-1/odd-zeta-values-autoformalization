Cell["[98b, p.18]: Takayama f\[UDoubleDot]r q-Summation", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"q", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"i", "+", "j"}], ")"}], "^", "2"}], "+", 
           RowBox[{"j", "^", "2"}]}], ")"}]}], "/", 
        RowBox[{"QPochhammer", "[", 
         RowBox[{"q", ",", "q", ",", 
          RowBox[{"n", "-", "i", "-", "j"}]}], "]"}]}], "/", 
       RowBox[{"QPochhammer", "[", 
        RowBox[{"q", ",", "q", ",", "i"}], "]"}]}], "/", 
      RowBox[{"QPochhammer", "[", 
       RowBox[{"q", ",", "q", ",", "j"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "0", ",", "n"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "j"}], "}"}]}], "]"}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"j", "=", "0"}], "n"], 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"k", "=", "1"}], "j"], 
     FractionBox[
      SuperscriptBox["q", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"i", "+", "j"}], ")"}], "2"], "+", 
        SuperscriptBox["j", "2"]}]], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         TemplateBox[{"q","q",RowBox[{"n", "-", "i", "-", "j"}]},
          "QPochhammer"], " ", 
         TemplateBox[{"q","q","i"},
          "QPochhammer"]}], ")"}], " ", 
       TemplateBox[{"q","q","j"},
        "QPochhammer"]}]]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
In order to find a recurrence for this double sum, we first compute an \
annihilating ideal for the summand (it is q-hypergeometric).\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"q", "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"i", "+", "j"}], ")"}], "^", "2"}], "+", 
          RowBox[{"j", "^", "2"}]}], ")"}]}], "/", 
       RowBox[{"QPochhammer", "[", 
        RowBox[{"q", ",", "q", ",", 
         RowBox[{"n", "-", "i", "-", "j"}]}], "]"}]}], "/", 
      RowBox[{"QPochhammer", "[", 
       RowBox[{"q", ",", "q", ",", "i"}], "]"}]}], "/", 
     RowBox[{"QPochhammer", "[", 
      RowBox[{"q", ",", "q", ",", "j"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"QS", "[", 
       RowBox[{"qi", ",", 
        RowBox[{"q", "^", "i"}]}], "]"}], ",", 
      RowBox[{"QS", "[", 
       RowBox[{"qj", ",", 
        RowBox[{"q", "^", "j"}]}], "]"}], ",", 
      RowBox[{"QS", "[", 
       RowBox[{"qn", ",", 
        RowBox[{"q", "^", "n"}]}], "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"qi", " ", "qj"}], "-", 
      RowBox[{"q", " ", "qn"}]}], ")", 
     SubscriptBox["S", 
      RowBox[{"qn", ",", "q"}]]}], "-", 
    RowBox[{"qi", " ", "qj"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"q", " ", "qj"}]}], ")", 
     SubscriptBox["S", 
      RowBox[{"qj", ",", "q"}]]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["q", "2"], " ", 
       SuperscriptBox["qi", "2"], " ", 
       SuperscriptBox["qj", "4"]}], "-", 
      RowBox[{
       SuperscriptBox["q", "2"], " ", "qi", " ", 
       SuperscriptBox["qj", "3"], " ", "qn"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"q", " ", "qi"}]}], ")", 
     SubscriptBox["S", 
      RowBox[{"qi", ",", "q"}]]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"q", " ", 
       SuperscriptBox["qi", "2"], " ", 
       SuperscriptBox["qj", "2"]}], "-", 
      RowBox[{"q", " ", "qi", " ", "qj", " ", "qn"}]}], ")"}]}]}], 
  "}"}]], "Output"]
}, Open  ]],


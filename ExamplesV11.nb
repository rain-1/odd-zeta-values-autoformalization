Cell["\<\
Task: Find relations between \[Psi](i, j) and \[Phi](i, j)! Indeed, we need \
c=a+1.\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ann", "=", 
   RowBox[{"Annihilator", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"JacobiP", "[", 
       RowBox[{"i", ",", "a", ",", "0", ",", 
        RowBox[{"y", "/", 
         RowBox[{"(", 
          RowBox[{"1", "-", "x"}], ")"}]}]}], "]"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}], "^", "i"}], "*", 
      RowBox[{"JacobiP", "[", 
       RowBox[{"j", ",", 
        RowBox[{"c", "+", 
         RowBox[{"2", " ", "i"}]}], ",", "0", ",", "x"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"S", "[", "a", "]"}], ",", 
       RowBox[{"S", "[", "c", "]"}], ",", 
       RowBox[{"S", "[", "i", "]"}], ",", 
       RowBox[{"S", "[", "j", "]"}]}], "}"}]}], "]"}]}], ";"}]], "Input"],


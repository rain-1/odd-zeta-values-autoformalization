     RowBox[{"Log", "[", "x", "]"}]}], "+", 
    SubscriptBox["D", "a"]}], ",", 
   RowBox[{
    RowBox[{
     SubsuperscriptBox["D", "x", "2"], 
     SuperscriptBox["x", "2"], 
     RowBox[{"Log", "[", "x", "]"}]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"2", " ", "a"}]}], ")", 
     SubscriptBox["D", "x"], "x", 
     RowBox[{"Log", "[", "x", "]"}]}], "-", 
    RowBox[{
     SubscriptBox["D", "x"], "x"}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "a"}], "+", 
      SuperscriptBox["a", "2"]}], ")", 
     RowBox[{"Log", "[", "x", "]"}]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "+", "a"}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],


Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"b", "^", "n"}], "*", 
     RowBox[{"a", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "n"}], "-", "1"}], ")"}]}], "*", 
     RowBox[{
      RowBox[{
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"m", "+", "n", "+", "1"}], ")"}], "/", "2"}], "]"}], "/", 
       RowBox[{"Gamma", "[", 
        RowBox[{"n", "+", "1"}], "]"}]}], "/", 
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"m", "-", "n", "+", "1"}], ")"}], "/", "2"}], "]"}]}], "*", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"m", "+", "n", "+", "1"}], ")"}], "/", "2"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "m", "+", "1"}], ")"}], "/", "2"}], ",", 
       RowBox[{"n", "+", "1"}], ",", 
       RowBox[{
        RowBox[{"b", "^", "2"}], "/", 
        RowBox[{"a", "^", "2"}]}]}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"Der", "[", "b", "]"}], ",", 
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}]}]], "Input"],


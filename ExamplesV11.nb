     RowBox[{"1", "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["t", "2"]}]}], ")", 
     SubscriptBox["D", "x"], 
     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "t"}], "+", 
      RowBox[{"8", " ", 
       SuperscriptBox["t", "3"]}], "-", 
      RowBox[{"16", " ", 
       SuperscriptBox["t", "5"]}]}], ")", 
     SubsuperscriptBox["D", "t", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"4", " ", "t", " ", "x"}], "-", 
      RowBox[{"2", " ", "y"}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "x"}], "+", 
      RowBox[{"4", " ", "t", " ", "y"}]}], ")", 
     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"16", " ", 
       SuperscriptBox["t", "2"]}], "-", 
      RowBox[{"48", " ", 
       SuperscriptBox["t", "4"]}], "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["t", "2"], " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"4", " ", "t", " ", "x", " ", "y"}], "+", 
      RowBox[{"16", " ", 
       SuperscriptBox["t", "3"], " ", "x", " ", "y"}], "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["t", "2"], " ", 
       SuperscriptBox["y", "2"]}]}], ")", 
     SubscriptBox["D", "t"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"4", " ", "t"}], "-", 
      RowBox[{"16", " ", 
       SuperscriptBox["t", "3"]}], "-", 
      RowBox[{"8", " ", "t", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"4", " ", "x", " ", "y"}], "+", 
      RowBox[{"16", " ", 
       SuperscriptBox["t", "2"], " ", "x", " ", "y"}], "-", 
      RowBox[{"8", " ", "t", " ", 
       SuperscriptBox["y", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    SubsuperscriptBox["D", "x", "2"], "-", 
    RowBox[{
     RowBox[{"2", " ", "x"}], 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{
     RowBox[{"2", " ", "t"}], 
     SubscriptBox["D", "t"]}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "t"}], "+", 
      RowBox[{"12", " ", 
       SuperscriptBox["t", "3"]}], "-", 
      RowBox[{"48", " ", 
       SuperscriptBox["t", "5"]}], "+", 
      RowBox[{"64", " ", 
       SuperscriptBox["t", "7"]}]}], ")", 
     SubsuperscriptBox["D", "t", "3"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "+", 
      RowBox[{"44", " ", 
       SuperscriptBox["t", "2"]}], "-", 
      RowBox[{"256", " ", 
       SuperscriptBox["t", "4"]}], "+", 
      RowBox[{"448", " ", 
       SuperscriptBox["t", "6"]}], "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["t", "2"], " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"32", " ", 
       SuperscriptBox["t", "4"], " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"4", " ", "t", " ", "x", " ", "y"}], "-", 
      RowBox[{"64", " ", 
       SuperscriptBox["t", "5"], " ", "x", " ", "y"}], "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["t", "2"], " ", 
       SuperscriptBox["y", "2"]}], "+", 
      RowBox[{"32", " ", 
       SuperscriptBox["t", "4"], " ", 
       SuperscriptBox["y", "2"]}]}], ")", 
     SubsuperscriptBox["D", "t", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"8", " ", "x"}], "+", 
      RowBox[{"32", " ", 
       SuperscriptBox["t", "2"], " ", "x"}], "-", 
      RowBox[{"32", " ", "t", " ", "y"}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "32"}], " ", "t", " ", "x"}], "+", 
      RowBox[{"8", " ", "y"}], "+", 
      RowBox[{"32", " ", 
       SuperscriptBox["t", "2"], " ", "y"}]}], ")", 
     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"40", " ", "t"}], "-", 
      RowBox[{"320", " ", 
       SuperscriptBox["t", "3"]}], "+", 
      RowBox[{"640", " ", 
       SuperscriptBox["t", "5"]}], "-", 
      RowBox[{"32", " ", "t", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"8", " ", "x", " ", "y"}], "+", 
      RowBox[{"128", " ", 
       SuperscriptBox["t", "2"], " ", "x", " ", "y"}], "-", 
      RowBox[{"128", " ", 
       SuperscriptBox["t", "4"], " ", "x", " ", "y"}], "-", 
      RowBox[{"32", " ", "t", " ", 
       SuperscriptBox["y", "2"]}]}], ")", 
     SubscriptBox["D", "t"]}], "+", 
    RowBox[{"(", 
     RowBox[{"8", "-", 
      RowBox[{"64", " ", 
       SuperscriptBox["t", "2"]}], "+", 
      RowBox[{"128", " ", 
       SuperscriptBox["t", "4"]}], "-", 
      RowBox[{"16", " ", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"64", " ", 
       SuperscriptBox["t", "2"], " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"128", " ", "t", " ", "x", " ", "y"}], "-", 
      RowBox[{"16", " ", 
       SuperscriptBox["y", "2"]}], "-", 
      RowBox[{"64", " ", 
       SuperscriptBox["t", "2"], " ", 
       SuperscriptBox["y", "2"]}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OreReduce", "[", 
  RowBox[{"%", ",", "lhs1"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0"}], 
  "}"}]], "Output"]
}, Open  ]],

Cell["\<\
For finding the right-hand side, we could now take either of the three \
first-order differential equations and solve it.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"var", "=", 
       RowBox[{"First", "[", 
        RowBox[{"Normal", "[", 
         RowBox[{"LeadingPowerProduct", "[", "#", "]"}], "]"}], "]"}]}], 
      "}"}], ",", 
     RowBox[{"DSolve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ApplyOreOperator", "[", 
         RowBox[{"#", ",", 
          RowBox[{"f", "[", "var", "]"}]}], "]"}], "\[Equal]", "0"}], ",", 
       RowBox[{"f", "[", "var", "]"}], ",", "var"}], "]"}]}], "]"}], "&"}], "/@",
   "lhs1"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", "[", "y", "]"}], "\[Rule]", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        FractionBox[
         RowBox[{"4", " ", "t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "x"}], " ", "y"}], "+", 
            RowBox[{"t", " ", 
             SuperscriptBox["y", "2"]}]}], ")"}]}], 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          RowBox[{"4", " ", 
           SuperscriptBox["t", "2"]}]}]]], " ", 
       RowBox[{"C", "[", "1", "]"}]}]}], "}"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], "\[Rule]", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        FractionBox[
         RowBox[{"4", " ", "t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"t", " ", 
             SuperscriptBox["x", "2"]}], "-", 
            RowBox[{"x", " ", "y"}]}], ")"}]}], 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          RowBox[{"4", " ", 
           SuperscriptBox["t", "2"]}]}]]], " ", 
       RowBox[{"C", "[", "1", "]"}]}]}], "}"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", "[", "t", "]"}], "\[Rule]", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"4", " ", 
         RowBox[{"(", 
          RowBox[{
           FractionBox[
            RowBox[{
             SuperscriptBox["x", "2"], "-", 
             RowBox[{"4", " ", "t", " ", "x", " ", "y"}], "+", 
             SuperscriptBox["y", "2"]}], 
            RowBox[{
             RowBox[{"-", "4"}], "+", 
             RowBox[{"16", " ", 
              SuperscriptBox["t", "2"]}]}]], "-", 
           RowBox[{
            FractionBox["1", "8"], " ", 
            RowBox[{"Log", "[", 
             RowBox[{"1", "-", 
              RowBox[{"4", " ", 
               SuperscriptBox["t", "2"]}]}], "]"}]}]}], ")"}]}]], " ", 
       RowBox[{"C", "[", "1", "]"}]}]}], "}"}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
However, concerning initial values, it is the simplest to consider t=0, \
because then the sum simplifies to 1.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"solution", "=", 
  RowBox[{
   RowBox[{"f", "[", "t", "]"}], "/.", 
   RowBox[{"First", "[", 
    RowBox[{"Last", "[", "%", "]"}], "]"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"4", " ", 
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["x", "2"], "-", 
        RowBox[{"4", " ", "t", " ", "x", " ", "y"}], "+", 
        SuperscriptBox["y", "2"]}], 
       RowBox[{
        RowBox[{"-", "4"}], "+", 
        RowBox[{"16", " ", 
         SuperscriptBox["t", "2"]}]}]], "-", 
      RowBox[{
       FractionBox["1", "8"], " ", 
       RowBox[{"Log", "[", 
        RowBox[{"1", "-", 
         RowBox[{"4", " ", 
          SuperscriptBox["t", "2"]}]}], "]"}]}]}], ")"}]}]], " ", 
  RowBox[{"C", "[", "1", "]"}]}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"%", "/.", 
      RowBox[{"t", "\[Rule]", "0"}]}], ")"}], "\[Equal]", "1"}], ",", 
   RowBox[{"C", "[", "1", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"C", "[", "1", "]"}], "\[Rule]", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["y", "2"]}]]}], "}"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"solution", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"solution", "/.", 
    RowBox[{"First", "[", "%", "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 FractionBox[
  SuperscriptBox["\[ExponentialE]", 
   FractionBox[
    RowBox[{"4", " ", "t", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "x"}], " ", "y"}], "+", 
       RowBox[{"t", " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["x", "2"], "+", 
          SuperscriptBox["y", "2"]}], ")"}]}]}], ")"}]}], 
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     RowBox[{"4", " ", 
      SuperscriptBox["t", "2"]}]}]]], 
  SqrtBox[
   RowBox[{"1", "-", 
    RowBox[{"4", " ", 
     SuperscriptBox["t", "2"]}]}]]]], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["A hypergeometric double sum", "Subsection"],

Cell["\<\
This sum can be found in \"Peter Paule: Parallel Algorithms in Computer \
Algebra - Zeilberger's Holonomic Systems Approach\".\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"k1", "+", "k2"}], ")"}]}], "*", 
       RowBox[{"Binomial", "[", 
        RowBox[{"n1", ",", "k1"}], "]"}], 
       RowBox[{"Binomial", "[", 
        RowBox[{"n2", ",", "k2"}], "]"}], 
       RowBox[{"Binomial", "[", 
        RowBox[{
         RowBox[{"k1", "+", "k2"}], ",", "k1"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"k1", ",", "0", ",", "n1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k2", ",", "0", ",", "n2"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{"KroneckerDelta", "[", 
     RowBox[{"n1", ",", "n2"}], "]"}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"k1", "=", "0"}], "n1"], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"k2", "=", "0"}], "n2"], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"k1", "+", "k2"}]], " ", 
       TemplateBox[{"n1","k1"},
        "Binomial"], " ", 
       TemplateBox[{"n2","k2"},
        "Binomial"], " ", 
       TemplateBox[{RowBox[{"k1", "+", "k2"}],"k1"},
        "Binomial"]}]}]}], "\[LongEqual]", 
    TemplateBox[{RowBox[{"n1", ",", "n2"}]},
     "KroneckerDeltaSeq"]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", 
   RowBox[{"n1_", ",", "n2_", ",", "k1_", ",", "k2_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"-", "1"}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"k1", "+", "k2"}], ")"}]}], 
   RowBox[{"Binomial", "[", 
    RowBox[{"n1", ",", "k1"}], "]"}], 
   RowBox[{"Binomial", "[", 
    RowBox[{"n2", ",", "k2"}], "]"}], 
   RowBox[{"Binomial", "[", 
    RowBox[{
     RowBox[{"k1", "+", "k2"}], ",", "k1"}], "]"}]}]}]], "Input"],

Cell["\<\
Such examples are a little bit problematic to do automatically with Chyzak's \
algorithm; since all computations are done in a rational Ore algebra, some \
polynomial factor that matters may be cancelled. We get a result that is true \
\"nearly everywhere\".\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"F", "[", 
      RowBox[{"n1", ",", "n2", ",", "k1", ",", "k2"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"k1", ",", "0", ",", "n1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k2", ",", "0", ",", "n2"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "n1", "]"}], ",", 
     RowBox[{"S", "[", "n2", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "1", "}"}]], "Output"]
}, Open  ]],

Cell["The bad factor can be seen when looking at the certificate:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CreativeTelescoping", "[", 
  RowBox[{
   RowBox[{"First", "[", 
    RowBox[{"CreativeTelescoping", "[", 
     RowBox[{
      RowBox[{"F", "[", 
       RowBox[{"n1", ",", "n2", ",", "k1", ",", "k2"}], "]"}], ",", 
      RowBox[{
       RowBox[{"S", "[", "k1", "]"}], "-", "1"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "k2", "]"}], ",", 
        RowBox[{"S", "[", "n1", "]"}], ",", 
        RowBox[{"S", "[", "n2", "]"}]}], "}"}]}], "]"}], "]"}], ",", 
   RowBox[{
    RowBox[{"S", "[", "k2", "]"}], "-", "1"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "n1", "]"}], ",", 
     RowBox[{"S", "[", "n2", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", "1", "}"}], ",", 
   RowBox[{"{", 
    FractionBox[
     RowBox[{
      RowBox[{"-", "k2"}], "+", "n1"}], 
     RowBox[{"n1", "-", "n2"}]], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Alternatively, we can employ other algorithms that are more robust against \
such misbehaviour. First, Zeilberger's slow algorithm:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"F", "[", 
     RowBox[{"n1", ",", "n2", ",", "k1", ",", "k2"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "n1", "]"}], ",", 
      RowBox[{"S", "[", "n2", "]"}], ",", 
      RowBox[{"S", "[", "k1", "]"}], ",", 
      RowBox[{"S", "[", "k2", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "k2"}], "+", 
      SuperscriptBox["k2", "2"]}], ")", 
     SubscriptBox["S", "k2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "k2"}], "-", 
      RowBox[{"k1", " ", "k2"}], "-", 
      SuperscriptBox["k2", "2"], "+", "n2", "+", 
      RowBox[{"k1", " ", "n2"}], "+", 
      RowBox[{"k2", " ", "n2"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "k1"}], "+", 
      SuperscriptBox["k1", "2"]}], ")", 
     SubscriptBox["S", "k1"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "k1"}], "-", 
      SuperscriptBox["k1", "2"], "-", 
      RowBox[{"k1", " ", "k2"}], "+", "n1", "+", 
      RowBox[{"k1", " ", "n1"}], "+", 
      RowBox[{"k2", " ", "n1"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "k2", "+", "n2"}], ")", 
     SubscriptBox["S", "n2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "n2"}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "k1", "+", "n1"}], ")", 
     SubscriptBox["S", "n1"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "n1"}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gb", "=", 
  RowBox[{"OreGroebnerBasis", "[", 
   RowBox[{"ann", ",", 
    RowBox[{"OreAlgebra", "[", 
     RowBox[{"k1", ",", "k2", ",", 
      RowBox[{"S", "[", "k1", "]"}], ",", 
      RowBox[{"S", "[", "k2", "]"}], ",", 
      RowBox[{"S", "[", "n1", "]"}], ",", 
      RowBox[{"S", "[", "n2", "]"}]}], "]"}], ",", 
    RowBox[{"MonomialOrder", "\[Rule]", 
     RowBox[{"EliminationOrder", "[", "2", "]"}]}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "-", "n2"}], ")", 
     SubscriptBox["S", "k2"], 
     SubscriptBox["S", "n1"], 
     SubsuperscriptBox["S", "n2", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"3", "+", 
      RowBox[{"2", " ", "n2"}]}], ")", 

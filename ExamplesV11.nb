Cell["\<\
We get a third-order differential equation for the inhomogeneous part. \
Annihilator in this case uses the closure property \"plus\", but we can do \
better by observing that this expression can be written as an operator \
application (recall the derivative of the arctangent function!):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ApplyOreOperator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"-", "2"}], "p", "*", 
     RowBox[{"Der", "[", "p", "]"}]}], "-", "1"}], ",", 
   RowBox[{"ArcTan", "[", "p", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{"2", " ", "p"}], 
    RowBox[{"1", "+", 
     SuperscriptBox["p", "2"]}]]}], "-", 
  RowBox[{"ArcTan", "[", "p", "]"}]}]], "Output"]
}, Open  ]],

Cell["\<\
Now we get a second-order differential equation (and finally the same \
4th-order DE as we obtained for the right-hand side)!\
\>", "Text"],


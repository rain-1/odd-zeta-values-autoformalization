Cell[CellGroupData[{

Cell["Boros/Moll's evaluation of the quartic", "Subsubsection"],

Cell["\<\
We reproduce the steps written in the book for finding the evaluation of the \
integral.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"dlm", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"2", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "2"}], "m"}], ")"}]}], "*", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"2", "^", "k"}], "*", 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"2", "m"}], "-", 
           RowBox[{"2", "k"}]}], ",", 
          RowBox[{"m", "-", "k"}]}], "]"}], "*", 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"m", "+", "k"}], ",", "m"}], "]"}], "*", 
        RowBox[{"Binomial", "[", 
         RowBox[{"k", ",", "l"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "l", ",", "m"}], "}"}]}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"S", "[", "l", "]"}], ",", 
      RowBox[{"S", "[", "m", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "l"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["l", "2"]}]}], ")", 
     SubscriptBox["S", "l"]}], "+", 
    RowBox[{"(", 
     RowBox[{"2", "-", 
      RowBox[{"2", " ", "l"}], "+", 
      RowBox[{"4", " ", "m"}], "-", 
      RowBox[{"2", " ", "l", " ", "m"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["m", "2"]}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", "l", "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["l", "2"]}], "-", 
      RowBox[{"7", " ", "m"}], "-", 
      RowBox[{"2", " ", "l", " ", "m"}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["m", "2"]}]}], ")"}]}], ",", 
   SubscriptBox["D", "a"], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "16"}], "+", 
      RowBox[{"8", " ", "l"}], "-", 
      RowBox[{"32", " ", "m"}], "+", 
      RowBox[{"12", " ", "l", " ", "m"}], "-", 
      RowBox[{"20", " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{"4", " ", "l", " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["m", "3"]}]}], ")", 
     SubsuperscriptBox["S", "m", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"38", "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["l", "2"]}], "+", 
      RowBox[{"86", " ", "m"}], "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["l", "2"], " ", "m"}], "+", 
      RowBox[{"64", " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{"16", " ", 
       SuperscriptBox["m", "3"]}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "15"}], "-", 
      RowBox[{"15", " ", "l"}], "-", 
      RowBox[{"47", " ", "m"}], "-", 
      RowBox[{"32", " ", "l", " ", "m"}], "-", 
      RowBox[{"48", " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"16", " ", "l", " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"16", " ", 
       SuperscriptBox["m", "3"]}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann1", "=", 
  RowBox[{"DFiniteTimes", "[", 
   RowBox[{
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{"a", "^", "l"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Der", "[", "a", "]"}], ",", 
        RowBox[{"S", "[", "l", "]"}], ",", 
        RowBox[{"S", "[", "m", "]"}]}], "}"}]}], "]"}], ",", "dlm"}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "l"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["l", "2"]}]}], ")", 
     SubscriptBox["S", "l"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "a"}], "-", 
      RowBox[{"2", " ", "a", " ", "l"}], "+", 
      RowBox[{"4", " ", "a", " ", "m"}], "-", 
      RowBox[{"2", " ", "a", " ", "l", " ", "m"}], "+", 
      RowBox[{"2", " ", "a", " ", 
       SuperscriptBox["m", "2"]}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "3"}], " ", "a"}], "-", 
      RowBox[{"a", " ", "l"}], "+", 
      RowBox[{"2", " ", "a", " ", 
       SuperscriptBox["l", "2"]}], "-", 
      RowBox[{"7", " ", "a", " ", "m"}], "-", 
      RowBox[{"2", " ", "a", " ", "l", " ", "m"}], "-", 
      RowBox[{"4", " ", "a", " ", 
       SuperscriptBox["m", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"a", 
     SubscriptBox["D", "a"]}], "-", "l"}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "16"}], "+", 
      RowBox[{"8", " ", "l"}], "-", 
      RowBox[{"32", " ", "m"}], "+", 
      RowBox[{"12", " ", "l", " ", "m"}], "-", 
      RowBox[{"20", " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{"4", " ", "l", " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["m", "3"]}]}], ")", 
     SubsuperscriptBox["S", "m", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"38", "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["l", "2"]}], "+", 
      RowBox[{"86", " ", "m"}], "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["l", "2"], " ", "m"}], "+", 
      RowBox[{"64", " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{"16", " ", 
       SuperscriptBox["m", "3"]}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "15"}], "-", 
      RowBox[{"15", " ", "l"}], "-", 
      RowBox[{"47", " ", "m"}], "-", 
      RowBox[{"32", " ", "l", " ", "m"}], "-", 
      RowBox[{"48", " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"16", " ", "l", " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"16", " ", 
       SuperscriptBox["m", "3"]}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pma", "=", 
  RowBox[{"First", "[", 
   RowBox[{"CreativeTelescoping", "[", 
    RowBox[{"ann1", ",", 
     RowBox[{
      RowBox[{"S", "[", "l", "]"}], "-", "1"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"S", "[", "m", "]"}], ",", 
       RowBox[{"Der", "[", "a", "]"}]}], "}"}]}], "]"}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "a"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"]}]}], ")", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"2", " ", "a"}], "-", 
      RowBox[{"4", " ", "m"}], "-", 
      RowBox[{"2", " ", "a", " ", "m"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SuperscriptBox["a", "2"]}], ")", 
     SubsuperscriptBox["D", "a", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", 
      RowBox[{"2", " ", "a"}], "-", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{"m", "+", 
      SuperscriptBox["m", "2"]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"eval", "=", 
  RowBox[{"DFiniteTimes", "[", 
   RowBox[{
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Pi", "/", "2"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "*", 
          RowBox[{"(", 
           RowBox[{"a", "+", "1"}], ")"}]}], ")"}], "^", 
        RowBox[{"(", 

          RowBox[{"x", "^", "2"}], "+", 
          RowBox[{"a", "^", "2"}]}], "]"}]}]}]}], "]"}], "/.", 
    RowBox[{"a", "\[Rule]", "1"}]}], "/.", 
   RowBox[{"b", "\[Rule]", "1"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{"BesselJ", "[", 
      RowBox[{"0", ",", "x"}], "]"}], " ", 

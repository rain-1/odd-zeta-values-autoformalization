Cell[CellGroupData[{

Cell["Theorem 2", "Subsubsection"],

Cell["\<\
For real x and t such that Abs[x]<1 and Abs[t]<1, and integer n>=3:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"k", "+", "n"}], ")"}], "/", "2"}], "]"}], "*", 
       RowBox[{
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"k", "+", "1"}], ")"}], "/", "2"}], "]"}], "/", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"n", "/", "2"}], "+", "k", "-", "1"}], "]"}]}], "*", " ", 
       RowBox[{"t", "^", "k"}], " ", "*", 
       RowBox[{"Hypergeometric2F1", "[", 
        RowBox[{"k", ",", 
         RowBox[{"k", "+", "n", "-", "1"}], ",", 
         RowBox[{"k", "+", 
          RowBox[{"n", "/", "2"}]}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", 
              RowBox[{"t", "^", "2"}]}], "]"}]}], ")"}], "/", "2"}]}], "]"}], 
       "*", 
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"k", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"n", "-", "2"}], ")"}], "/", "2"}], ",", "x"}], "]"}]}], 
      ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"n", "-", "2"}], ")"}], "*", 
     RowBox[{
      RowBox[{
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", "+", "1"}], ")"}], "/", "2"}], "]"}], "/", "2"}], "/", 
      
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"n", "/", "2"}], "+", "1"}], "]"}]}], "*", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       RowBox[{"t", "^", "2"}]}], "]"}], " ", "*", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{"n", ",", "1", ",", 
       RowBox[{
        RowBox[{"n", "/", "2"}], "+", "1"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "*", "t"}], "+", "1"}], ")"}], "/", "2"}]}], "]"}]}]}],
    "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], "\[Infinity]"], 
     FractionBox[
      RowBox[{
       TemplateBox[{FractionBox[
          RowBox[{"k", "+", "n"}], "2"]},
        "Gamma"], " ", 
       TemplateBox[{FractionBox[
          RowBox[{"k", "+", "1"}], "2"]},
        "Gamma"], " ", 
       SuperscriptBox["t", "k"], " ", 
       TemplateBox[{"k",RowBox[{"k", "+", "n", "-", "1"}],RowBox[{"k", "+", 
           FractionBox["n", "2"]}],RowBox[{
           FractionBox["1", "2"], " ", 
           RowBox[{"(", 
             RowBox[{"1", "-", 
               SqrtBox[
                RowBox[{"1", "-", 
                  SuperscriptBox["t", "2"]}]]}], ")"}]}]},
        "Hypergeometric2F1"], " ", 
       RowBox[{
        SubsuperscriptBox["C", "k", 
         RowBox[{"(", 
          FractionBox[
           RowBox[{"n", "-", "2"}], "2"], ")"}]], "(", "x", ")"}]}], 
      TemplateBox[{RowBox[{
          FractionBox["n", "2"], "+", "k", "-", "1"}]},
       "Gamma"]]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{"n", "-", "2"}], ")"}], " ", 
      TemplateBox[{FractionBox[
         RowBox[{"n", "+", "1"}], "2"]},
       "Gamma"], " ", 
      SqrtBox[
       RowBox[{"1", "-", 
        SuperscriptBox["t", "2"]}]], " ", 
      TemplateBox[{"n","1",RowBox[{
          FractionBox["n", "2"], "+", "1"}],RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
            RowBox[{
              RowBox[{"x", " ", "t"}], "+", "1"}], ")"}]}]},
       "Hypergeometric2F1"]}], 
     RowBox[{"2", " ", 
      TemplateBox[{RowBox[{
          FractionBox["n", "2"], "+", "1"}]},
       "Gamma"]}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


Cell[CellGroupData[{

Cell["Formula (4.8)", "Subsubsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "n"}], "+", "a", "+", "b"}], ")"}], " ", 
     RowBox[{"JacobiP", "[", 
      RowBox[{"n", ",", "a", ",", 
       RowBox[{"b", "-", "1"}], ",", "x"}], "]"}]}], "==", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"n", "+", "a", "+", "b"}], ")"}], " ", 
      RowBox[{"JacobiP", "[", 
       RowBox[{"n", ",", "a", ",", "b", ",", "x"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"n", "+", "a"}], ")"}], " ", 
      RowBox[{"JacobiP", "[", 
       RowBox[{
        RowBox[{"n", "-", "1"}], ",", "a", ",", "b", ",", "x"}], "]"}]}]}]}], 
   "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "n"}], "+", "a", "+", "b"}], ")"}], " ", 
     RowBox[{
      SubsuperscriptBox["P", "n", 
       RowBox[{"(", 
        RowBox[{"a", ",", 
         RowBox[{"b", "-", "1"}]}], ")"}]], "(", "x", ")"}]}], "\[LongEqual]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"n", "+", "a", "+", "b"}], ")"}], " ", 
      RowBox[{
       SubsuperscriptBox["P", "n", 
        RowBox[{"(", 
         RowBox[{"a", ",", "b"}], ")"}]], "(", "x", ")"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"n", "+", "a"}], ")"}], " ", 
      RowBox[{
       SubsuperscriptBox["P", 
        RowBox[{"n", "-", "1"}], 
        RowBox[{"(", 
         RowBox[{"a", ",", "b"}], ")"}]], "(", "x", ")"}]}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"First", "[", 
  RowBox[{"OreGroebnerBasis", "[", 

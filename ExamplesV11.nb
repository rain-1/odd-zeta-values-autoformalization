      RowBox[{"4", " ", 
       SuperscriptBox["y", "3"]}], "-", 
      SuperscriptBox["y", "4"]}], ")", 
     SubsuperscriptBox["D", "y", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "4"}], " ", "n"}], "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["n", "2"]}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["n", "3"]}], "+", 
      RowBox[{"4", " ", "n", " ", "y"}], "+", 
      RowBox[{"8", " ", 
       SuperscriptBox["n", "2"], " ", "y"}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["n", "3"], " ", "y"}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "4"}], " ", "y"}], "-", 
      RowBox[{"4", " ", "n", " ", "y"}], "+", 

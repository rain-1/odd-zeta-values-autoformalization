Cell[CellGroupData[{

Cell["\<\
5.5.3  Hypergeometric2F1^2 and Hypergeometric3F2
(takes quite long)\
\>", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{"a", ",", "b", ",", 
       RowBox[{"a", "+", "b", "+", 
        RowBox[{"1", "/", "2"}]}], ",", "z"}], "]"}], "^", "2"}], "\[Equal]", 
    
    RowBox[{"HypergeometricPFQ", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"2", "a"}], ",", 
        RowBox[{"2", "b"}], ",", 
        RowBox[{"a", "+", "b"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", "+", "b", "+", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{
         RowBox[{"2", "a"}], "+", 
         RowBox[{"2", "b"}]}]}], "}"}], ",", "z"}], "]"}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    SuperscriptBox[
     TemplateBox[{"a","b",RowBox[{"a", "+", "b", "+", 
         FractionBox["1", "2"]}],"z"},
      "Hypergeometric2F1"], "2"], "\[LongEqual]", 
    TagBox[
     TagBox[
      RowBox[{
       RowBox[{
        SubscriptBox["\[InvisiblePrefixScriptBase]", "3"], 
        SubscriptBox["F", "2"]}], "\[InvisibleApplication]", 
       RowBox[{"(", 
        RowBox[{
         TagBox[
          TagBox[
           RowBox[{
            TagBox[
             RowBox[{"2", " ", "a"}],
             HypergeometricPFQ,
             Editable->True,
             Selectable->True], ",", 
            TagBox[
             RowBox[{"2", " ", "b"}],
             HypergeometricPFQ,
             Editable->True,
             Selectable->True], ",", 
            TagBox[
             RowBox[{"a", "+", "b"}],
             HypergeometricPFQ,
             Editable->True,
             Selectable->True]}],
           InterpretTemplate[{
             SlotSequence[1]}& ]],
          HypergeometricPFQ,
          Editable->False,
          Selectable->False], ";", 
         TagBox[
          TagBox[
           RowBox[{
            TagBox[
             RowBox[{"a", "+", "b", "+", 
              FractionBox["1", "2"]}],
             HypergeometricPFQ,
             Editable->True,
             Selectable->True], ",", 
            TagBox[
             RowBox[{
              RowBox[{"2", " ", "a"}], "+", 
              RowBox[{"2", " ", "b"}]}],
             HypergeometricPFQ,
             Editable->True,
             Selectable->True]}],
           InterpretTemplate[{
             SlotSequence[1]}& ]],
          HypergeometricPFQ,
          Editable->False,
          Selectable->False], ";", 
         TagBox["z",
          HypergeometricPFQ,
          Editable->True,
          Selectable->True]}], ")"}]}],
      InterpretTemplate[HypergeometricPFQ[#, #2, #3]& ],
      Editable->False,
      Selectable->False],
     HypergeometricPFQ]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"6", " ", "a", " ", "n", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"3", " ", 
       SuperscriptBox["a", "2"], " ", "n", " ", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"5", " ", 
       SuperscriptBox["x", "4"]}], "+", 
      RowBox[{"5", " ", "a", " ", 
       SuperscriptBox["x", "4"]}], "-", 
      RowBox[{"3", " ", 
       SuperscriptBox["x", "6"]}], "-", 
      RowBox[{"3", " ", "n", " ", 
       SuperscriptBox["x", "6"]}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"6", " ", "n", " ", 
       SuperscriptBox["x", "3"]}], "-", 
      RowBox[{"6", " ", "a", " ", "n", " ", 

               RowBox[{"p", "^", "2"}], "*", "x"}]}], ")"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"p", ",", "i"}], "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "3"}], "}"}]}], "]"}], "/.", 
       RowBox[{"p", "\[Rule]", "0"}]}], "]"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}]}]], "Input"],


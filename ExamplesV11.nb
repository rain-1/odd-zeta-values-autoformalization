Cell["\<\
Since the identity does not hold for n=0, we compare the initial values n=1 \
and n=2.\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"mySum", "[", 
   RowBox[{"expr_", ",", 
    RowBox[{"{", 

        RowBox[{"S", "[", "l", "]"}], ",", 
        RowBox[{"S", "[", "m", "]"}], ",", 
        RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}], "]"}], "]"}], 
  "]"}]], "Input"],


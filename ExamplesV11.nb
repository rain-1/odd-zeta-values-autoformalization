       RowBox[{"(", 
        RowBox[{"l", "+", "m", "+", "n", "+", 
         RowBox[{"4", " ", "\[Lambda]"}]}], ")"}]}]}]}], "}"}]}], 
  "}"}]], "Output"]
}, Open  ]],

Cell["\<\
We see that in the leading coefficients many singularities may be hidden. To \
find them, the command AnnihilatorSingularities can be used.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sing", "=", 
  RowBox[{"AnnihilatorSingularities", "[", 
   RowBox[{"rhs", ",", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"\[Lambda]", ">", 
       RowBox[{"1", "/", "2"}]}], "&&", 
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"l", "+", "m", "+", "n"}], ")"}], "/", "2"}], ",", 
        "Integers"}], "]"}], "&&", 
      RowBox[{
       RowBox[{"l", "+", "m"}], "\[GreaterEqual]", "n"}], "&&", 
      RowBox[{
       RowBox[{"l", "+", "n"}], "\[GreaterEqual]", "m"}], "&&", 
      RowBox[{
       RowBox[{"m", "+", "n"}], "\[GreaterEqual]", "l"}]}]}]}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"l", "\[Rule]", "0"}], ",", 
       RowBox[{"n", "\[Rule]", "m"}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"\[Lambda]", ">", 
       FractionBox["1", "2"]}], "&&", 
      RowBox[{"m", "\[GreaterEqual]", "0"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", "\[Rule]", "0"}], ",", 
       RowBox[{"n", "\[Rule]", "l"}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"\[Lambda]", ">", 
       FractionBox["1", "2"]}], "&&", 
      RowBox[{"l", "\[GreaterEqual]", "0"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"l", "\[Rule]", "0"}], ",", 
       RowBox[{"m", "\[Rule]", "0"}], ",", 
       RowBox[{"n", "\[Rule]", "0"}]}], "}"}], ",", 
     RowBox[{"\[Lambda]", ">", 
      FractionBox["1", "2"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"l", "\[Rule]", "0"}], ",", 
       RowBox[{"m", "\[Rule]", "1"}], ",", 
       RowBox[{"n", "\[Rule]", "1"}]}], "}"}], ",", 
     RowBox[{"\[Lambda]", ">", 
      FractionBox["1", "2"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"l", "\[Rule]", "1"}], ",", 
       RowBox[{"m", "\[Rule]", "0"}], ",", 
       RowBox[{"n", "\[Rule]", "1"}]}], "}"}], ",", 
     RowBox[{"\[Lambda]", ">", 
      FractionBox["1", "2"]}]}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
For the 3 single singular points, the identity is readily verified:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{"integrand", "/.", 
          RowBox[{"First", "[", "#", "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
         RowBox[{"Assumptions", "\[Rule]", 
          RowBox[{"Last", "[", "#", "]"}]}]}], "]"}], "\[Equal]", "expr"}], "/.", 
      RowBox[{"First", "[", "#", "]"}]}], ",", 
     RowBox[{"Last", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
  RowBox[{"Drop", "[", 
   RowBox[{"sing", ",", "2"}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "True", ",", "True"}], "}"}]], "Output"]
}, Open  ]],

Cell[TextData[{
 "The first two entries of sing describe lines of points where none of the \
recurrences can be applied. They cannot be checked by ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ", so we recursively apply HolonomicFunctions. Both conditions lead to the \
same integrand:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"integrand", "/.", 
  RowBox[{"(", 
   RowBox[{"First", "/@", 
    RowBox[{"Take", "[", 
     RowBox[{"sing", ",", "2"}], "]"}]}], ")"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "-", 
       SuperscriptBox["x", "2"]}], ")"}], 
     RowBox[{
      RowBox[{"-", 
       FractionBox["1", "2"]}], "+", "\[Lambda]"}]], " ", 
    SuperscriptBox[
     RowBox[{"GegenbauerC", "[", 
      RowBox[{"m", ",", "\[Lambda]", ",", "x"}], "]"}], "2"]}], ",", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "-", 
       SuperscriptBox["x", "2"]}], ")"}], 
     RowBox[{
      RowBox[{"-", 
       FractionBox["1", "2"]}], "+", "\[Lambda]"}]], " ", 
    SuperscriptBox[
     RowBox[{"GegenbauerC", "[", 
      RowBox[{"l", ",", "\[Lambda]", ",", "x"}], "]"}], "2"]}]}], 
  "}"}]], "Output"]
}, Open  ]],

Cell["\<\
For both sides, we get in this special instance the same recurrence, which \
this time does not have any singularities.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"m", ",", "\[Lambda]", ",", "x"}], "]"}], "^", "2"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"x", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"\[Lambda]", "-", 
         RowBox[{"1", "/", "2"}]}], ")"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
   RowBox[{"S", "[", "m", "]"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"\[Lambda]", ">", 
     RowBox[{"1", "/", "2"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "-", 
     RowBox[{"2", " ", "m"}], "-", 
     SuperscriptBox["m", "2"], "-", "\[Lambda]", "-", 
     RowBox[{"m", " ", "\[Lambda]"}]}], ")", 
    SubscriptBox["S", "m"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["m", "2"], "+", 
     RowBox[{"3", " ", "m", " ", "\[Lambda]"}], "+", 
     RowBox[{"2", " ", 
      SuperscriptBox["\[Lambda]", "2"]}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],


     RowBox[{"EliminationOrder", "[", "1", "]"}]}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubsuperscriptBox["S", "m", "2"], 
     SubscriptBox["S", "n"]}], "-", 
    RowBox[{
     SubscriptBox["S", "m"], 
     SubsuperscriptBox["S", "n", "2"]}], "-", 
    SubscriptBox["S", "m"], "+", 
    SubscriptBox["S", "n"]}], ",", 
   RowBox[{
    RowBox[{"-", "2", 
     RowBox[{"Cos", "[", "x", "]"}], 
     SubscriptBox["S", "n"]}], "+", 
    SubsuperscriptBox["S", "n", "2"], "+", "1"}], ",", 
   RowBox[{
    RowBox[{"-", "2", 
     RowBox[{"Cos", "[", "x", "]"}], 
     SubscriptBox["S", "m"]}], "+", 
    SubsuperscriptBox["S", "m", "2"], "+", "1"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
The first operator is free of x and Der[x], hence it trivially annihilates \
the whole integral. But we can do better by including this operator to the \
annihilating ideal from above and perform Chyzak's algorithm.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{
    RowBox[{"First", "[", "gb", "]"}], ",", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"m", "*", "x"}], "]"}], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"n", "*", "x"}], "]"}]}]}], "]"}], "//", 
  "FullSimplify"}]], "Input"],

Cell[BoxData["0"], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"OreGroebnerBasis", "[", 
   RowBox[{
    RowBox[{"Append", "[", 
     RowBox[{"ann", ",", 
      RowBox[{"First", "[", "gb", "]"}]}], "]"}], ",", 
    RowBox[{"OreAlgebra", "[", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}]}], "]"}], ",", 
    RowBox[{"MonomialOrder", "\[Rule]", "DegreeLexicographic"}]}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubsuperscriptBox["S", "m", "2"], 
     SubscriptBox["S", "n"]}], "-", 
    RowBox[{
     SubscriptBox["S", "m"], 
     SubsuperscriptBox["S", "n", "2"]}], "-", 
    SubscriptBox["S", "m"], "+", 
    SubscriptBox["S", "n"]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"m", "+", 
      RowBox[{"m", " ", "n"}]}], ")", 
     SubsuperscriptBox["D", "x", "2"], 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "n"}], "-", 
      RowBox[{"m", " ", "n"}]}], ")", 
     SubsuperscriptBox["D", "x", "2"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"m", "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["m", "2"]}], "+", 
      SuperscriptBox["m", "3"], "-", 
      RowBox[{"m", " ", "n"}], "+", 
      RowBox[{
       SuperscriptBox["m", "3"], " ", "n"}], "-", 
      RowBox[{"m", " ", 
       SuperscriptBox["n", "2"]}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["m", "2"], " ", 
       SuperscriptBox["n", "2"]}], "+", 
      RowBox[{"m", " ", 
       SuperscriptBox["n", "3"]}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "n"}], "+", 
      RowBox[{"m", " ", "n"}], "+", 
      RowBox[{
       SuperscriptBox["m", "2"], " ", "n"}], "-", 
      RowBox[{
       SuperscriptBox["m", "3"], " ", "n"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["m", "2"], " ", 
       SuperscriptBox["n", "2"]}], "-", 
      SuperscriptBox["n", "3"], "-", 
      RowBox[{"m", " ", 
       SuperscriptBox["n", "3"]}]}], ")", 
     SubscriptBox["S", "n"]}]}], ",", 
   RowBox[{
    SubsuperscriptBox["D", "x", "4"], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubsuperscriptBox["D", "x", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["m", "4"], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["m", "2"], " ", 
       SuperscriptBox["n", "2"]}], "+", 
      SuperscriptBox["n", "4"]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", "n"}], ")", 
     SubsuperscriptBox["D", "x", "2"], 
     SubsuperscriptBox["S", "n", "3"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", "n"}], ")", 
     SubsuperscriptBox["D", "x", "2"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"12", " ", "m"}], "+", 
      RowBox[{"16", " ", "m", " ", "n"}], "+", 
      RowBox[{"4", " ", "m", " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubscriptBox["S", "m"], 
     SubsuperscriptBox["S", "n", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"9", "-", 
      RowBox[{"6", " ", "m"}], "+", 
      SuperscriptBox["m", "2"], "+", 
      RowBox[{"15", " ", "n"}], "-", 
      RowBox[{"8", " ", "m", " ", "n"}], "+", 
      RowBox[{
       SuperscriptBox["m", "2"], " ", "n"}], "+", 
      RowBox[{"7", " ", 
       SuperscriptBox["n", "2"]}], "-", 
      RowBox[{"2", " ", "m", " ", 
       SuperscriptBox["n", "2"]}], "+", 
      SuperscriptBox["n", "3"]}], ")", 
     SubsuperscriptBox["S", "n", "3"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"6", " ", "m"}], "-", 
      RowBox[{"3", " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"7", " ", "n"}], "-", 
      RowBox[{"8", " ", "m", " ", "n"}], "-", 
      RowBox[{
       SuperscriptBox["m", "2"], " ", "n"}], "-", 
      RowBox[{"5", " ", 
       SuperscriptBox["n", "2"]}], "-", 
      RowBox[{"2", " ", "m", " ", 
       SuperscriptBox["n", "2"]}], "-", 
      SuperscriptBox["n", "3"]}], ")", 
     SubscriptBox["S", "n"]}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ct", "=", 
  RowBox[{"CreativeTelescoping", "[", 
   RowBox[{"ann", ",", 
    RowBox[{"Der", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"m", "+", 
       RowBox[{"2", " ", 
        SuperscriptBox["m", "2"]}], "+", 
       SuperscriptBox["m", "3"], "-", 
       RowBox[{"m", " ", "n"}], "+", 
       RowBox[{
        SuperscriptBox["m", "3"], " ", "n"}], "-", 
       RowBox[{"m", " ", 
        SuperscriptBox["n", "2"]}], "-", 
       RowBox[{"2", " ", 
        SuperscriptBox["m", "2"], " ", 
        SuperscriptBox["n", "2"]}], "+", 
       RowBox[{"m", " ", 
        SuperscriptBox["n", "3"]}]}], ")", 
      SubscriptBox["S", "m"]}], "+", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "n"}], "+", 
       RowBox[{"m", " ", "n"}], "+", 
       RowBox[{
        SuperscriptBox["m", "2"], " ", "n"}], "-", 
       RowBox[{
        SuperscriptBox["m", "3"], " ", "n"}], "-", 
       RowBox[{"2", " ", 
        SuperscriptBox["n", "2"]}], "+", 
       RowBox[{"2", " ", 
        SuperscriptBox["m", "2"], " ", 
        SuperscriptBox["n", "2"]}], "-", 
       SuperscriptBox["n", "3"], "-", 
       RowBox[{"m", " ", 
        SuperscriptBox["n", "3"]}]}], ")", 
      SubscriptBox["S", "n"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"m", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", "n"}], ")"}]}], 
      SubscriptBox["D", "x"], 
      SubscriptBox["S", "m"]}], "+", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "n"}], "-", 
       RowBox[{"m", " ", "n"}]}], ")", 
      SubscriptBox["D", "x"], 
      SubscriptBox["S", "n"]}]}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["Check the delta part (it vanishes):", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"delta", "=", 
     RowBox[{"ApplyOreOperator", "[", 
      RowBox[{
       RowBox[{"ct", "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", "1"}], "]"}], "]"}], ",", 
       RowBox[{
        RowBox[{"Sin", "[", 
         RowBox[{"m", "*", "x"}], "]"}], "*", 
        RowBox[{"Sin", "[", 
         RowBox[{"n", "*", "x"}], "]"}]}]}], "]"}]}], "}"}], ",", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"delta", "/.", 
        RowBox[{"x", "\[Rule]", 
         RowBox[{"2", " ", "Pi"}]}]}], ")"}], "-", 
      RowBox[{"(", 
       RowBox[{"delta", "/.", 
        RowBox[{"x", "\[Rule]", "0"}]}], ")"}]}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"m", ",", "n"}], "}"}], ",", "Integers"}], "]"}]}]}], 
    "]"}]}], "]"}]], "Input"],

Cell[BoxData["0"], "Output"]
}, Open  ]],

Cell["\<\
Hence the first part of ct is an annihilating operator for the integral. In \
recurrence notation it looks as follows.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{
    RowBox[{"ct", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
    RowBox[{"f", "[", 
     RowBox[{"m", ",", "n"}], "]"}]}], "]"}], "/.", 
  RowBox[{"m", "\[Rule]", 
   RowBox[{"m", "-", "1"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "n"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "m"}], ")"}], " ", "n"}], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "m"}], ")"}], "2"], " ", "n"}], "-", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "m"}], ")"}], "3"], " ", "n"}], "-", 
     RowBox[{"2", " ", 
      SuperscriptBox["n", "2"]}], "+", 
     RowBox[{"2", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "m"}], ")"}], "2"], " ", 
      SuperscriptBox["n", "2"]}], "-", 
     SuperscriptBox["n", "3"], "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "m"}], ")"}], " ", 
      SuperscriptBox["n", "3"]}]}], ")"}], " ", 
   RowBox[{"f", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "+", "m"}], ",", 
     RowBox[{"1", "+", "n"}]}], "]"}]}], "+", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     RowBox[{"2", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "m"}], ")"}], "2"]}], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "m"}], ")"}], "3"], "+", "m", "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "m"}], ")"}], " ", "n"}], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "m"}], ")"}], "3"], " ", "n"}], "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "m"}], ")"}], " ", 
      SuperscriptBox["n", "2"]}], "-", 
     RowBox[{"2", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "m"}], ")"}], "2"], " ", 
      SuperscriptBox["n", "2"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "m"}], ")"}], " ", 
      SuperscriptBox["n", "3"]}]}], ")"}], " ", 
   RowBox[{"f", "[", 
    RowBox[{"m", ",", "n"}], "]"}]}]}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"m", ",", "n"}], "]"}], "==", 
  RowBox[{"Factor", "[", 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"m", ",", "n"}], "]"}], "/.", 
    RowBox[{"First", "[", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"%", "\[Equal]", "0"}], ",", 
       RowBox[{"f", "[", 
        RowBox[{"m", ",", "n"}], "]"}]}], "]"}], "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"m", ",", "n"}], "]"}], "\[Equal]", 
  FractionBox[
   RowBox[{"m", " ", "n", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"2", "-", "m", "+", "n"}], ")"}], "2"], " ", 
    RowBox[{"f", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "+", "m"}], ",", 
      RowBox[{"1", "+", "n"}]}], "]"}]}], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "m"}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", "n"}], ")"}], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "m"}], "+", "n"}], ")"}], "2"]}]]}]], "Output"]
}, Open  ]],

Cell["We investigate the leading coefficient:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Factor", "[", 
  RowBox[{
   RowBox[{"LeadingCoefficient", "[", 
    RowBox[{"ct", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}], "/.", 
   RowBox[{"m", "\[Rule]", 
    RowBox[{"m", "-", "1"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "1"}], "+", "m"}], ")"}], " ", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"m", "-", "n"}], ")"}], "2"], " ", 
  RowBox[{"(", 
   RowBox[{"1", "+", "n"}], ")"}]}]], "Output"]
}, Open  ]],

Cell["\<\
Since the leading monomial of the recurrence is S[m], we have to give initial \
values for m=1 and arbitrary n. The leading coefficient contains (m-1) as a \
factor, which is an additional reason to include initial values for m=1. \
\>", "Text"],

Cell["Similarly for the diagonal m=n:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"n", " ", "x"}], "]"}], "^", "2"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", 
       RowBox[{"2", "Pi"}]}], "}"}]}], "]"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"Element", "[", 
     RowBox[{"n", ",", "Integers"}], "]"}]}]}], "]"}]], "Input"],

Cell[BoxData["\[Pi]"], "Output"]
}, Open  ]],

Cell["\<\
And for m=1, n>1 the integral is 0 (symmetries around x=Pi/2 and x=3Pi/2).\
\>", "Text"],

Cell["\<\
The initial conditions match with the expression on the right hand side, and \
also the recurrence is fine:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{
    RowBox[{"ct", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
    RowBox[{"KroneckerDelta", "[", 
     RowBox[{"m", ",", "n"}], "]"}]}], "]"}], "//", "FullSimplify"}]], "Input"],

Cell[BoxData["0"], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Identity involving binomial sums", "Subsection"],

Cell["\<\
It was Gabor Hedeg\[UDoubleDot]s who asked for a proof of the following \
formula.\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"binom0", "[", 
   RowBox[{"n_Integer", ",", "k_Integer"}], "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"n", "\[GreaterEqual]", "k"}], ",", 
    RowBox[{"Binomial", "[", 
     RowBox[{"n", ",", "k"}], "]"}], ",", "0"}], "]"}]}]], "Input"],

Cell["Define", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"h", "[", 
     RowBox[{"n", ",", "m", ",", "t"}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"binom0", "[", 
      RowBox[{
       RowBox[{"n", "+", "1", "+", "t"}], ",", 
       RowBox[{"n", "+", "1"}]}], "]"}], "+", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "j"}], "*", 
        RowBox[{"binom0", "[", 
         RowBox[{"n", ",", "j"}], "]"}], "*", 
        RowBox[{"binom0", "[", 
         RowBox[{
          RowBox[{"n", "+", "t", "-", 
           RowBox[{"2", "j"}], "+", "1"}], ",", 
          RowBox[{"n", "+", "1"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}], "+", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"j", "+", "1"}], ")"}]}], "*", 
        RowBox[{"binom0", "[", 
         RowBox[{"n", ",", "j"}], "]"}], "*", 
        RowBox[{"binom0", "[", 
         RowBox[{
          RowBox[{"n", "+", "1", "+", "t", "-", "m", "-", 
           RowBox[{"2", "j"}]}], ",", 
          RowBox[{"n", "+", "1"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "0", ",", "n"}], "}"}]}], "]"}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{"h", "(", 
     RowBox[{"n", ",", "m", ",", "t"}], ")"}], "\[LongEqual]", 
    RowBox[{
     RowBox[{"binom0", "(", 
      RowBox[{
       RowBox[{"n", "+", "1", "+", "t"}], ",", 
       RowBox[{"n", "+", "1"}]}], ")"}], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "1"}], "n"], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "j"], " ", 
       RowBox[{"binom0", "(", 
        RowBox[{"n", ",", "j"}], ")"}], " ", 
       RowBox[{"binom0", "(", 
        RowBox[{
         RowBox[{"n", "+", "t", "-", 
          RowBox[{"2", " ", "j"}], "+", "1"}], ",", 
         RowBox[{"n", "+", "1"}]}], ")"}]}]}], "+", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "0"}], "n"], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"j", "+", "1"}]], " ", 
       RowBox[{"binom0", "(", 
        RowBox[{"n", ",", "j"}], ")"}], " ", 
       RowBox[{"binom0", "(", 
        RowBox[{
         RowBox[{"n", "+", "1", "+", "t", "-", "m", "-", 
          RowBox[{"2", " ", "j"}]}], ",", 
         RowBox[{"n", "+", "1"}]}], ")"}]}]}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["and prove that", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"h", "[", 
      RowBox[{"n", ",", "m", ",", "t"}], "]"}], "-", 
     RowBox[{"h", "[", 
      RowBox[{"n", ",", "m", ",", 
       RowBox[{"t", "-", "1"}]}], "]"}]}], "\[Equal]", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"Binomial", "[", 
       RowBox[{"n", ",", 
        RowBox[{"t", "-", "i"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "0", ",", 
        RowBox[{"m", "-", "1"}]}], "}"}]}], "]"}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     RowBox[{"h", "(", 
      RowBox[{"n", ",", "m", ",", "t"}], ")"}], "-", 
     RowBox[{"h", "(", 
      RowBox[{"n", ",", "m", ",", 
       RowBox[{"t", "-", "1"}]}], ")"}]}], "\[LongEqual]", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "0"}], 
      RowBox[{"m", "-", "1"}]], 
     TemplateBox[{"n",RowBox[{"t", "-", "i"}]},
      "Binomial"]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
First we convince ourselves that the function binom0[n,k] satisfies the same \
recurrences as Binomial[n,k] (this can be seen by looking at the leading \
coefficients of the recurrences):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Binomial", "[", 
    RowBox[{"n", ",", "k"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "k", "]"}], ",", 
     RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "k", "+", "n"}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "n"}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", "k"}], ")", 
     SubscriptBox["S", "k"]}], "+", 
    RowBox[{"(", 
     RowBox[{"k", "-", "n"}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Union", "[", 
  RowBox[{"Flatten", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"ApplyOreOperator", "[", 
       RowBox[{"%", ",", 
        RowBox[{"binom0", "[", 
         RowBox[{"n", ",", "k"}], "]"}]}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", 
       RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", 
       RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "0", "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Now we compute an annihilating ideal for the expression h[n,m,t]:\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"annh", "=", 
   RowBox[{"Annihilator", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Binomial", "[", 
       RowBox[{
        RowBox[{"n", "+", "1", "+", "t"}], ",", 
        RowBox[{"n", "+", "1"}]}], "]"}], "+", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], "^", "j"}], "*", 
         RowBox[{"Binomial", "[", 
          RowBox[{"n", ",", "j"}], "]"}], "*", 
         RowBox[{"Binomial", "[", 
          RowBox[{
           RowBox[{"n", "+", "t", "-", 
            RowBox[{"2", "j"}], "+", "1"}], ",", 
           RowBox[{"n", "+", "1"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}], "+", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"j", "+", "1"}], ")"}]}], "*", 
         RowBox[{"Binomial", "[", 
          RowBox[{"n", ",", "j"}], "]"}], "*", 
         RowBox[{"Binomial", "[", 
          RowBox[{
           RowBox[{"n", "+", "1", "+", "t", "-", "m", "-", 
            RowBox[{"2", "j"}]}], ",", 
           RowBox[{"n", "+", "1"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "0", ",", "n"}], "}"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"S", "[", "m", "]"}], ",", 
       RowBox[{"S", "[", "n", "]"}], ",", 
       RowBox[{"S", "[", "t", "]"}]}], "}"}]}], "]"}]}], ";"}]], "Input"],

Cell["It's quite big, that's why we do not display it here.", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ByteCount", "[", "annh", "]"}]], "Input"],

Cell[BoxData["180744"], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Support", "[", "annh", "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["S", "n"], 
      SubscriptBox["S", "t"]}], ",", 
     SubsuperscriptBox["S", "t", "2"], ",", 
     SubscriptBox["S", "m"], ",", 
     SubscriptBox["S", "n"], ",", 
     SubscriptBox["S", "t"], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubsuperscriptBox["S", "n", "2"], ",", 
     SubsuperscriptBox["S", "t", "2"], ",", 
     SubscriptBox["S", "m"], ",", 
     SubscriptBox["S", "n"], ",", 
     SubscriptBox["S", "t"], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["S", "m"], 
      SubscriptBox["S", "t"]}], ",", 
     SubsuperscriptBox["S", "t", "2"], ",", 
     SubscriptBox["S", "m"], ",", 
     SubscriptBox["S", "n"], ",", 
     SubscriptBox["S", "t"], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SubscriptBox["S", "m"], 
      SubscriptBox["S", "n"]}], ",", 
     SubsuperscriptBox["S", "t", "2"], ",", 
     SubscriptBox["S", "m"], ",", 
     SubscriptBox["S", "n"], ",", 
     SubscriptBox["S", "t"], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubsuperscriptBox["S", "m", "2"], ",", 
     SubsuperscriptBox["S", "t", "2"], ",", 
     SubscriptBox["S", "m"], ",", 
     SubscriptBox["S", "n"], ",", 
     SubscriptBox["S", "t"], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubsuperscriptBox["S", "t", "3"], ",", 
     SubsuperscriptBox["S", "t", "2"], ",", 
     SubscriptBox["S", "m"], ",", 
     SubscriptBox["S", "n"], ",", 
     SubscriptBox["S", "t"], ",", "1"}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Next we use closure properties to compute an annihilating ideal for the \
left-hand side:\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"annlhs", "=", 
   RowBox[{"DFiniteOreAction", "[", 
    RowBox[{
     RowBox[{"DFiniteSubstitute", "[", 
      RowBox[{"annh", ",", 
       RowBox[{"{", 
        RowBox[{"t", "\[Rule]", 
         RowBox[{"t", "-", "1"}]}], "}"}]}], "]"}], ",", 
     RowBox[{
      RowBox[{"S", "[", "t", "]"}], "-", "1"}]}], "]"}]}], ";"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ByteCount", "[", "annlhs", "]"}]], "Input"],

Cell[BoxData["62552"], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"uts", "=", 
  RowBox[{"UnderTheStaircase", "[", "annlhs", "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", 
   SubscriptBox["S", "t"], ",", 
   SubscriptBox["S", "n"], ",", 
   SubscriptBox["S", "m"]}], "}"}]], "Output"]
}, Open  ]],

Cell["Now the right-hand side. This is easier:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"annrhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"Binomial", "[", 
       RowBox[{"n", ",", 
        RowBox[{"t", "-", "i"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "0", ",", 
        RowBox[{"m", "-", "1"}]}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}], ",", 
      RowBox[{"S", "[", "t", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"m", "+", 
      RowBox[{"m", " ", "n"}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{"n", "-", 
      RowBox[{"m", " ", "n"}], "-", "t", "+", 
      RowBox[{"m", " ", "t"}], "+", 
      RowBox[{"n", " ", "t"}], "-", 
      SuperscriptBox["t", "2"]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "-", "m", "+", 
      RowBox[{"2", " ", "t"}], "-", 
      RowBox[{"m", " ", "t"}], "+", 
      SuperscriptBox["t", "2"]}], ")", 
     SubscriptBox["S", "t"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", 
      RowBox[{"2", " ", "n"}], "+", 
      RowBox[{"m", " ", "n"}], "-", 
      RowBox[{"m", " ", "t"}], "-", 
      RowBox[{"2", " ", "n", " ", "t"}], "+", 
      SuperscriptBox["t", "2"]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "4"}], "+", 
      RowBox[{"2", " ", "m"}], "-", 
      RowBox[{"4", " ", "t"}], "+", 
      RowBox[{"m", " ", "t"}], "-", 
      SuperscriptBox["t", "2"]}], ")", 
     SubsuperscriptBox["S", "t", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"m", " ", "n"}], "+", 
      SuperscriptBox["n", "2"], "-", 
      RowBox[{"m", " ", "t"}], "-", 
      RowBox[{"2", " ", "n", " ", "t"}], "+", 
      SuperscriptBox["t", "2"]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"3", " ", "n"}], "-", 
      RowBox[{"m", " ", "n"}], "+", 
      RowBox[{"m", " ", "t"}], "+", 
      RowBox[{"2", " ", "n", " ", "t"}], "-", 
      SuperscriptBox["t", "2"]}], ")", 
     SubscriptBox["S", "t"]}], "+", 
    RowBox[{"(", 
     RowBox[{"2", "-", 
      RowBox[{"2", " ", "m"}], "-", 
      RowBox[{"3", " ", "n"}], "-", 
      RowBox[{"m", " ", "n"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}], "+", 
      RowBox[{"4", " ", "t"}], "+", 
      RowBox[{"2", " ", "n", " ", "t"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{
     SubscriptBox["S", "n"], 
     SubscriptBox["S", "t"]}], "-", 
    SubscriptBox["S", "t"], "-", "1"}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", "m", "+", 
      RowBox[{"2", " ", "n"}], "+", 
      RowBox[{"m", " ", "n"}], "+", 
      SuperscriptBox["n", "2"], "-", 
      RowBox[{"2", " ", "t"}], "-", 
      RowBox[{"m", " ", "t"}], "-", 
      RowBox[{"2", " ", "n", " ", "t"}], "+", 
      SuperscriptBox["t", "2"]}], ")", 
     SubsuperscriptBox["S", "n", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"3", " ", "m"}], "-", 
      RowBox[{"7", " ", "n"}], "-", 
      RowBox[{"2", " ", "m", " ", "n"}], "-", 
      RowBox[{"3", " ", 
       SuperscriptBox["n", "2"]}], "+", 
      RowBox[{"6", " ", "t"}], "+", 
      RowBox[{"m", " ", "t"}], "+", 
      RowBox[{"4", " ", "n", " ", "t"}], "-", 
      SuperscriptBox["t", "2"]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "m", "-", 
      RowBox[{"2", " ", "t"}], "+", 
      RowBox[{"m", " ", "t"}], "-", 
      SuperscriptBox["t", "2"]}], ")", 
     SubscriptBox["S", "t"]}], "+", 
    RowBox[{"(", 
     RowBox[{"3", "+", "m", "+", 
      RowBox[{"6", " ", "n"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}], "-", 
      RowBox[{"2", " ", "t"}], "+", 
      RowBox[{"m", " ", "t"}], "-", 
      SuperscriptBox["t", "2"]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"UnderTheStaircase", "[", "annrhs", "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", 
   SubscriptBox["S", "t"], ",", 
   SubscriptBox["S", "n"]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
The two annihilating ideals for left- and right-hand side are not identical, \
but one is contained in the other:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OreReduce", "[", 
  RowBox[{"annlhs", ",", "annrhs"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0"}], 
  "}"}]], "Output"]
}, Open  ]],

Cell["\<\
This means that we have to compare 4 initial values, according to the \
elements under the staircase of the smaller ideal (that one for the left-hand \
side):\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"h", "[", 
   RowBox[{"n_Integer", ",", "m_Integer", ",", "t_Integer"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"binom0", "[", 
    RowBox[{
     RowBox[{"n", "+", "1", "+", "t"}], ",", 
     RowBox[{"n", "+", "1"}]}], "]"}], "+", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "^", "j"}], "*", 
      RowBox[{"binom0", "[", 
       RowBox[{"n", ",", "j"}], "]"}], "*", 
      RowBox[{"binom0", "[", 
       RowBox[{
        RowBox[{"n", "+", "t", "-", 
         RowBox[{"2", "j"}], "+", "1"}], ",", 
        RowBox[{"n", "+", "1"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}], "+", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"j", "+", "1"}], ")"}]}], "*", 
      RowBox[{"binom0", "[", 
       RowBox[{"n", ",", "j"}], "]"}], "*", 
      RowBox[{"binom0", "[", 
       RowBox[{
        RowBox[{"n", "+", "1", "+", "t", "-", "m", "-", 
         RowBox[{"2", "j"}]}], ",", 
        RowBox[{"n", "+", "1"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "0", ",", "n"}], "}"}]}], "]"}]}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{"uts", ",", 
    RowBox[{
     RowBox[{"h", "[", 
      RowBox[{"n", ",", "m", ",", "t"}], "]"}], "-", 
     RowBox[{"h", "[", 
      RowBox[{"n", ",", "m", ",", 
       RowBox[{"t", "-", "1"}]}], "]"}]}]}], "]"}], "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"m", "\[Rule]", "1"}], ",", 
    RowBox[{"n", "\[Rule]", "1"}], ",", 
    RowBox[{"t", "\[Rule]", "0"}]}], "}"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "1", ",", "1", ",", "1"}], "}"}]], "Output"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"Clear", "[", "rhs", "]"}], ";", 
  RowBox[{
   RowBox[{"rhs", "[", 
    RowBox[{"n_Integer", ",", "m_Integer", ",", "t_Integer"}], "]"}], ":=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"Binomial", "[", 
      RowBox[{"n", ",", 
       RowBox[{"t", "-", "i"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "0", ",", 
       RowBox[{"m", "-", "1"}]}], "}"}]}], "]"}]}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{"uts", ",", 
    RowBox[{"rhs", "[", 
     RowBox[{"n", ",", "m", ",", "t"}], "]"}]}], "]"}], "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"m", "\[Rule]", "1"}], ",", 
    RowBox[{"n", "\[Rule]", "1"}], ",", 
    RowBox[{"t", "\[Rule]", "0"}]}], "}"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "1", ",", "1", ",", "1"}], "}"}]], "Output"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"Clear", "[", "rhs", "]"}], ";"}]], "Input"],

Cell["\<\
Since the initial values match, the identity is proven for all integers m>0, \
n>0, and t>=0.\
\>", "Text"],

Cell["\<\
To be completely rigorous, we should have a look at the leading coefficients \
of the generators of annlhs and annrhs (appropriately shifted). If they have \
common zeros in the area of N^3 (where we claim the identity to hold), then \
we would have a problem.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GroebnerBasis", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"LeadingCoefficient", "[", "#", "]"}], "/.", 
       RowBox[{"Thread", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"m", ",", "n", ",", "t"}], "}"}], "\[Rule]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"m", ",", "n", ",", "t"}], "}"}], "-", 
           RowBox[{"LeadingExponent", "[", "#", "]"}]}], ")"}]}], "]"}]}], 
      ")"}], "&"}], "/@", "annlhs"}], ",", 
   RowBox[{"MonomialOrder", "\[Rule]", "Lexicographic"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"n", ",", 
   RowBox[{
    RowBox[{"-", "1"}], "+", "m"}], ",", "t"}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
The only common zero is (m=1,n=0,t=0) for which we do not claim the identity \
to hold.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GroebnerBasis", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"LeadingCoefficient", "[", "#", "]"}], "/.", 
       RowBox[{"Thread", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"m", ",", "n", ",", "t"}], "}"}], "\[Rule]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"m", ",", "n", ",", "t"}], "}"}], "-", 
           RowBox[{"LeadingExponent", "[", "#", "]"}]}], ")"}]}], "]"}]}], 
      ")"}], "&"}], "/@", "annrhs"}], ",", 
   RowBox[{"MonomialOrder", "\[Rule]", "Lexicographic"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "1", "}"}]], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Stirling sum from Gabor Heged\[UDoubleDot]s", "Subsection"],

Cell["Find an evaluation of the expression", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"d", "-", "i"}], ")"}]}], "*", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "j"}], "*", 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"i", "+", "1"}], ",", "j"}], "]"}], "*", 
        RowBox[{"Product", "[", 
         RowBox[{
          RowBox[{"n", "-", "l"}], ",", 
          RowBox[{"{", 
           RowBox[{"l", ",", "0", ",", 
            RowBox[{"j", "-", "1"}]}], "}"}]}], "]"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"n", "-", "j", "+", "m"}], ")"}]}], "*", 
          RowBox[{"StirlingS1", "[", 
           RowBox[{
            RowBox[{"n", "-", "j"}], ",", "m"}], "]"}]}], ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "0", ",", 
         RowBox[{"n", "-", "m"}]}], "}"}]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"n", "-", "i", "-", "1"}], ")"}]}], "*", 
     RowBox[{"Product", "[", 
      RowBox[{
       RowBox[{"n", "-", "j"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "0", ",", "i"}], "}"}]}], "]"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "i", "-", "1", "+", "m"}], ")"}]}], "*", 
       RowBox[{"StirlingS1", "[", 
        RowBox[{
         RowBox[{"n", "-", "i", "-", "1"}], ",", "m"}], "]"}]}], ")"}]}]}], 
   "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"d", "-", "i"}]], " ", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "0"}], 
       RowBox[{"n", "-", "m"}]], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "j"], " ", 
       TemplateBox[{RowBox[{"i", "+", "1"}],"j"},
        "Binomial"], " ", 
       RowBox[{"(", 
        RowBox[{
         UnderoverscriptBox["\[Product]", 
          RowBox[{"l", "=", "0"}], 
          RowBox[{"j", "-", "1"}]], 
         RowBox[{"(", 
          RowBox[{"n", "-", "l"}], ")"}]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], 
          RowBox[{"n", "-", "j", "+", "m"}]], " ", 
         TemplateBox[{RowBox[{"n", "-", "j"}],"m"},
          "StirlingS1"]}], ")"}]}]}]}], "+", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 

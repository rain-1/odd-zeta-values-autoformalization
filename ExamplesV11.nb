            RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"m", "+", "1"}], ")"}]}]}], ",", "a"}], "]"}], "/.", 
     RowBox[{"a", "\[Rule]", "0"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"Re", "[", "m", "]"}], "\[GreaterEqual]", "0"}]}]}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"2", " ", 
    RowBox[{"Gamma", "[", 
     FractionBox["7", "4"], "]"}], " ", 

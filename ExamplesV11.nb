}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Victor Moll: A Master Formula", "Subsection"],

Cell["\<\
This is called a \"Master Formula\" in Chapter 13 of \"Victor Moll: \
Irresistible Integrals\".\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "4"}], "+", 
            RowBox[{"2", "a", " ", 
             RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}]}], ")"}], "^", 
        "r"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "^", "2"}], "+", "1"}], ")"}], "/", 
         RowBox[{"x", "^", "2"}]}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "s"}], "+", "1"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{"Beta", "[", 
       RowBox[{
        RowBox[{"r", "-", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{"1", "/", "2"}]}], "]"}], "/", 
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{"r", "+", 
         RowBox[{"1", "/", "2"}]}], ")"}]}]}], "/", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"r", "-", 
        RowBox[{"1", "/", "2"}]}], ")"}]}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           SuperscriptBox["x", "2"], 
           RowBox[{
            SuperscriptBox["x", "4"], "+", 
            RowBox[{"2", " ", "a", " ", 
             SuperscriptBox["x", "2"]}], "+", "1"}]], ")"}], "r"], " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["x", "2"], "+", "1"}], ")"}]}], 
       RowBox[{
        SuperscriptBox["x", "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["x", "s"], "+", "1"}], ")"}]}]], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    FractionBox[
     TemplateBox[{RowBox[{"r", "-", 
         FractionBox["1", "2"]}],FractionBox["1", "2"]},
      "Beta"], 
     RowBox[{
      SuperscriptBox["2", 
       RowBox[{"r", "+", 
        FractionBox["1", "2"]}]], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"a", "+", "1"}], ")"}], 
       RowBox[{"r", "-", 
        FractionBox["1", "2"]}]]}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
We can try to solve it right away, but the factor (x^s+1) in the denominator \
causes the integrand to be non-holonomic. The right-hand side, however, is \
holonomic.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "4"}], "+", 
            RowBox[{"2", "a", " ", 
             RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}]}], ")"}], "^", 
        "r"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "^", "2"}], "+", "1"}], ")"}], "/", 
         RowBox[{"x", "^", "2"}]}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "s"}], "+", "1"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"S", "[", "r", "]"}], ",", 
      RowBox[{"S", "[", "s", "]"}], ",", 
      RowBox[{"Der", "[", "s", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","nondf",
   "\"The expression \\!\\(\\*RowBox[{\\\"\\\\\\\"(1 + \
x^s)^(-1)\\\\\\\"\\\"}]\\) is not recognized to be \[PartialD]-finite. The \
result might not generate a zero-dimensional ideal.\"",2,332,9,
   31736665789155565964,"Local"},
  "MessageTemplate"]], "Message", "MSG"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SubscriptBox["D", "a"], "+", 
   RowBox[{
    RowBox[{"2", " ", "r"}], 
    SubscriptBox["S", "r"]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Beta", "[", 
       RowBox[{
        RowBox[{"r", "-", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{"1", "/", "2"}]}], "]"}], "/", 
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{"r", "+", 
         RowBox[{"1", "/", "2"}]}], ")"}]}]}], "/", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"r", "-", 
        RowBox[{"1", "/", "2"}]}], ")"}]}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"S", "[", "r", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"4", " ", "r"}], "+", 
      RowBox[{"4", " ", "a", " ", "r"}]}], ")", 
     SubscriptBox["S", "r"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"2", " ", "r"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"2", " ", "a"}]}], ")", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"2", " ", "r"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
The relation that was found for the integral is contained in rhs. To conclude \
the proof, infinitely many initial values have to be compared (namely the \
cases a=0 and r>=1m as well as all higher derivatives with respect to a and \
r=1 (and of course, everything for symbolic s). This seems to be a cumbersome \
job, and we omit it.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OreReduce", "[", 
  RowBox[{"lhs", ",", "rhs"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "0", "}"}]], "Output"]
}, Open  ]],

Cell["\<\
For the special case s=0, we obtain the same annihilating ideal as for the \
right-hand side\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lhs1", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "4"}], "+", 
            RowBox[{"2", "a", " ", 
             RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}]}], ")"}], "^", 
        "r"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "^", "2"}], "+", "1"}], ")"}], "/", 
         RowBox[{"x", "^", "2"}]}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "0"}], "+", "1"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"S", "[", "r", "]"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"r", "\[GreaterEqual]", "1"}]}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"4", " ", "r"}], "+", 
      RowBox[{"4", " ", "a", " ", "r"}]}], ")", 
     SubscriptBox["S", "r"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"2", " ", "r"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "-", 
      RowBox[{"2", " ", "a"}]}], ")", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"2", " ", "r"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
So this case can be made rigorous by comparing one initial value, which can \
be done by Mathematica:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"x", "^", "4"}], "+", 
              RowBox[{"2", "a", " ", 
               RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}]}], ")"}], "^", 
          "r"}], "*", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"x", "^", "2"}], "+", "1"}], ")"}], "/", 
           RowBox[{"x", "^", "2"}]}], "/", "2"}]}], "/.", 
        RowBox[{"r", "\[Rule]", "1"}]}], "/.", 
       RowBox[{"a", "\[Rule]", "0"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "==", 
    RowBox[{
     RowBox[{
      RowBox[{"Beta", "[", 
       RowBox[{
        RowBox[{"r", "-", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{"1", "/", "2"}]}], "]"}], "/", 
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{"r", "+", 
         RowBox[{"1", "/", "2"}]}], ")"}]}]}], "/", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"r", "-", 
        RowBox[{"1", "/", "2"}]}], ")"}]}]}]}], "/.", 
   RowBox[{"r", "\[Rule]", "1"}]}], "/.", 
  RowBox[{"a", "\[Rule]", "0"}]}]], "Input"],

Cell[BoxData["True"], "Output"]
}, Open  ]],

Cell["\<\
For other specific values of s, we still get a zero-dimensional ideal, but \
for s>0 only a subideal of rhs. Interestingly, its vector space dimension \
seems to be Floor[s/4]+2 for even s>=2 and Floor[s/2]+3 for odd s.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Length", "[", 
    RowBox[{"UnderTheStaircase", "[", 
     RowBox[{"Annihilator", "[", 
      RowBox[{
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"x", "^", "2"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"x", "^", "4"}], "+", 
               RowBox[{"2", "a", " ", 
                RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}]}], ")"}], "^", 
           "r"}], "*", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"x", "^", "2"}], "+", "1"}], ")"}], "/", 
            RowBox[{"x", "^", "2"}]}], "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"x", "^", "s"}], "+", "1"}], ")"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Der", "[", "a", "]"}], ",", 
         RowBox[{"S", "[", "r", "]"}]}], "}"}], ",", 
       RowBox[{"Assumptions", "\[Rule]", 
        RowBox[{"r", "\[GreaterEqual]", "1"}]}]}], "]"}], "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"s", ",", "0", ",", "15"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "1", ",", "3", ",", "2", ",", "4", ",", "3", ",", "5", ",", "3", ",", "6", 
   ",", "4", ",", "7", ",", "4", ",", "8", ",", "5", ",", "9", ",", "5", ",", 
   "10"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Which", "[", 
    RowBox[{
     RowBox[{"s", "===", "0"}], ",", "1", ",", 
     RowBox[{"EvenQ", "[", "s", "]"}], ",", 
     RowBox[{
      RowBox[{"Floor", "[", 
       RowBox[{"s", "/", "4"}], "]"}], "+", "2"}], ",", 
     RowBox[{"OddQ", "[", "s", "]"}], ",", 
     RowBox[{
      RowBox[{"Floor", "[", 
       RowBox[{"s", "/", "2"}], "]"}], "+", "3"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"s", ",", "0", ",", "15"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "1", ",", "3", ",", "2", ",", "4", ",", "3", ",", "5", ",", "3", ",", "6", 
   ",", "4", ",", "7", ",", "4", ",", "8", ",", "5", ",", "9", ",", "5", ",", 

Cell["\<\
We can use Zeilberger's slow algorithm or Takayama (assuming natural \
boundaries)\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Timing", "[", 
  RowBox[{
   RowBox[{"gb", "=", 
    RowBox[{"OreGroebnerBasis", "[", 
     RowBox[{"ann", ",", 
      RowBox[{"OreAlgebra", "[", 
       RowBox[{"x", ",", 
        RowBox[{"Der", "[", "x", "]"}], ",", 
        RowBox[{"Der", "[", "a", "]"}], ",", 
        RowBox[{"Der", "[", "b", "]"}], ",", 
        RowBox[{"S", "[", "n", "]"}], ",", 
        RowBox[{"S", "[", "nu", "]"}]}], "]"}], ",", 
      RowBox[{"MonomialOrder", "\[Rule]", 

Cell[CellGroupData[{

Cell["substitution", "Subsubsection"],

Cell["Performing the substitution u=cos(x) we obtain", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", "x", "]"}], "^", 
       RowBox[{"(", 
        RowBox[{"2", "m"}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", 
        RowBox[{"Pi", "/", "2"}]}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"u", "^", 
        RowBox[{"(", 
         RowBox[{"2", "m"}], ")"}]}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", 
         RowBox[{"u", "^", "2"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"u", ",", "0", ",", "1"}], "}"}]}], "]"}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", 
      FractionBox["\[Pi]", "2"]], 
     RowBox[{
      RowBox[{
       SuperscriptBox["cos", 
        RowBox[{"2", " ", "m"}]], "(", "x", ")"}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "1"], 
     RowBox[{
      FractionBox[
       SuperscriptBox["u", 
        RowBox[{"2", " ", "m"}]], 
       SqrtBox[
        RowBox[{"1", "-", 
         SuperscriptBox["u", "2"]}]]], 
      RowBox[{"\[DifferentialD]", "u"}]}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "^", 
     RowBox[{"(", 
      RowBox[{"2", "m"}], ")"}]}], "/", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"1", "-", 
      RowBox[{"u", "^", "2"}]}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"u", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"Element", "[", 
      RowBox[{"m", ",", "Integers"}], "]"}], "&&", 
     RowBox[{"m", "\[GreaterEqual]", "0"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SqrtBox["\[Pi]"], " ", 
   RowBox[{"Gamma", "[", 
    RowBox[{
     FractionBox["1", "2"], "+", "m"}], "]"}]}], 
  RowBox[{"2", " ", 
   RowBox[{"Gamma", "[", 
    RowBox[{"1", "+", "m"}], "]"}]}]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"u", "^", 
       RowBox[{"(", 
        RowBox[{"2", "m"}], ")"}]}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "-", 
        RowBox[{"u", "^", "2"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"u", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
   RowBox[{"S", "[", "m", "]"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"m", "\[GreaterEqual]", "0"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "2"}], "-", 
     RowBox[{"2", " ", "m"}]}], ")", 
    SubscriptBox["S", "m"]}], "+", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"2", " ", "m"}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["The irresistible quartic integral", "Subsection"],

Cell["\<\
Evaluate the following integral (it can be found as formula (7.2.1) in the \
book \"Irresistible Integrals\" by Boros/Moll:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"1", "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "4"}], "+", 
         RowBox[{"2", " ", "a", " ", 
          RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"m", "+", "1"}], ")"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["x", "4"], "+", 
         RowBox[{"2", " ", "a", " ", 
          SuperscriptBox["x", "2"]}], "+", "1"}], ")"}], 
       RowBox[{"m", "+", "1"}]]], 
     RowBox[{"\[DifferentialD]", "x"}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " cannot evaluate this integral:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"1", "/", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "4"}], "+", 
       RowBox[{"2", " ", "a", " ", 
        RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"m", "+", "1"}], ")"}]}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"m", "\[GreaterEqual]", "0"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "a", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      SuperscriptBox["x", "4"]}], ")"}], 
    RowBox[{
     RowBox[{"-", "1"}], "-", "m"}]], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"m", "\[GreaterEqual]", "0"}]}]}], "]"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell["With Takayama's algorithm", "Subsubsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Takayama", "[", 
   RowBox[{
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "4"}], "+", 
          RowBox[{"2", " ", "a", " ", 
           RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"m", "+", "1"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "m", "]"}], ",", 
        RowBox[{"Der", "[", "a", "]"}], ",", 
        RowBox[{"Der", "[", "x", "]"}]}], "}"}]}], "]"}], ",", 
    RowBox[{"{", "x", "}"}], ",", 
    RowBox[{"Saturate", "\[Rule]", "True"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "4"}], "-", 
      RowBox[{"4", " ", "m"}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{
     RowBox[{"2", " ", "a"}], 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{"3", "+", 
      RowBox[{"4", " ", "m"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"4", "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["a", "2"]}]}], ")", 
     SubsuperscriptBox["D", "a", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "12"}], " ", "a"}], "-", 
      RowBox[{"8", " ", "a", " ", "m"}]}], ")", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"4", " ", "m"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["Hence we get the following differential equation:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"de", "=", 
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{
    RowBox[{"ann", "[", 
     RowBox[{"[", "2", "]"}], "]"}], ",", 
    RowBox[{"Int", "[", "a", "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "3"}], "-", 
     RowBox[{"4", " ", "m"}]}], ")"}], " ", 
   RowBox[{"Int", "[", "a", "]"}]}], "+", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "12"}], " ", "a"}], "-", 
     RowBox[{"8", " ", "a", " ", "m"}]}], ")"}], " ", 
   RowBox[{
    SuperscriptBox["Int", "\[Prime]",
     MultilineFunction->None], "[", "a", "]"}]}], "+", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"4", "-", 
     RowBox[{"4", " ", 
      SuperscriptBox["a", "2"]}]}], ")"}], " ", 
   RowBox[{
    SuperscriptBox["Int", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "a", "]"}]}]}]], "Output"]
}, Open  ]],

Cell["\<\
However, the integral does not have natural boundaries, and therefore we \
should also care about the delta part:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"ann", ",", 
    RowBox[{"{", "delta", "}"}]}], "}"}], "=", 
  RowBox[{"Takayama", "[", 
   RowBox[{
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "4"}], "+", 
          RowBox[{"2", " ", "a", " ", 
           RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"m", "+", "1"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "m", "]"}], ",", 
        RowBox[{"Der", "[", "a", "]"}], ",", 
        RowBox[{"Der", "[", "x", "]"}]}], "}"}]}], "]"}], ",", 
    RowBox[{"{", "x", "}"}], ",", 
    RowBox[{"Saturate", "\[Rule]", "True"}], ",", 
    RowBox[{"Extended", "\[Rule]", "True"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "4"}], "-", 
        RowBox[{"4", " ", "m"}]}], ")", 
       SubscriptBox["S", "m"]}], "+", 
      RowBox[{
       RowBox[{"2", " ", "a"}], 
       SubscriptBox["D", "a"]}], "+", 
      RowBox[{"(", 
       RowBox[{"3", "+", 
        RowBox[{"4", " ", "m"}]}], ")"}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"4", "-", 
        RowBox[{"4", " ", 
         SuperscriptBox["a", "2"]}]}], ")", 
       SubsuperscriptBox["D", "a", "2"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "12"}], " ", "a"}], "-", 
        RowBox[{"8", " ", "a", " ", "m"}]}], ")", 
       SubscriptBox["D", "a"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "3"}], "-", 
        RowBox[{"4", " ", "m"}]}], ")"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         RowBox[{"4", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            SuperscriptBox["a", "2"], "-", "m", "+", 
            RowBox[{
             SuperscriptBox["a", "2"], " ", "m"}]}], ")"}], " ", "x"}], 
         RowBox[{"1", "+", 
          SuperscriptBox["a", "2"]}]], 
        SubscriptBox["S", "m"]}], "-", 
       RowBox[{
        FractionBox[
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "a"}], "+", 
            SuperscriptBox["a", "3"]}], ")"}], " ", "x"}], 
         RowBox[{"1", "+", 
          SuperscriptBox["a", "2"]}]], 
        SubscriptBox["D", "a"]}], "-", 
       RowBox[{
        FractionBox[
         RowBox[{"2", " ", "a"}], 
         RowBox[{"1", "+", 
          SuperscriptBox["a", "2"]}]], 
        SubscriptBox["D", "x"]}], "-", "x"}]}], "}"}], "}"}]}], 
  "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ApplyOreOperator", "[", 
  RowBox[{"delta", ",", 
   RowBox[{"1", "/", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "4"}], "+", 
       RowBox[{"2", " ", "a", " ", 
        RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"m", "+", "1"}], ")"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"x", " ", 

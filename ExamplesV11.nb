Cell["\<\
The second evaluation follows from rewriting the Bernoulli numbers in terms \
of Zeta values.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Which", "[", 
    RowBox[{
     RowBox[{"m", "\[Equal]", "n", "\[Equal]", "0"}], ",", "1", ",", 

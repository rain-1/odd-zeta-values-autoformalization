       SuperscriptBox["x", "3"]}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "n", " ", 
       SuperscriptBox["x", "3"]}], "+", 
      SuperscriptBox["x", "5"], "+", 
      RowBox[{"3", " ", "a", " ", 
       SuperscriptBox["x", "5"]}], "+", 

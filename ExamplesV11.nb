 RowBox[{
  SubsuperscriptBox["S", "n", "4"], "+", 
  RowBox[{"(", 
   RowBox[{"1", "+", "a", "-", 
    SuperscriptBox["x", "2"]}], ")", 
   SubsuperscriptBox["S", "n", "2"]}], "+", "a"}]], "Output"]
}, Open  ]],

Cell["Note that recEven and recOdd commute:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{

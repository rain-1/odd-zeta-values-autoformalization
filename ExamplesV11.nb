Cell["\<\
Mathematica takes quite long and gives a very complicated answer:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ArcTan", "[", 
     RowBox[{"p", "*", "x"}], "]"}], "/", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       RowBox[{"p", "^", "2"}], "*", "x"}]}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"ConditionalExpression", "[", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"24", " ", 
       SuperscriptBox["p", "2"]}]], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[ImaginaryI]", " ", 
        SuperscriptBox["\[Pi]", "2"]}], "-", 
       RowBox[{"12", " ", "\[ImaginaryI]", " ", "\[Pi]", " ", 
        RowBox[{"ArcTan", "[", "p", "]"}]}], "+", 
       RowBox[{"24", " ", "\[ImaginaryI]", " ", 
        RowBox[{"ArcCot", "[", "p", "]"}], " ", 
        RowBox[{"ArcTan", "[", "p", "]"}]}], "+", 
       RowBox[{"24", " ", "\[ImaginaryI]", " ", 
        SuperscriptBox[
         RowBox[{"ArcTan", "[", "p", "]"}], "2"]}], "+", 
       RowBox[{"3", " ", "\[Pi]", " ", 
        RowBox[{"Log", "[", "16", "]"}]}], "+", 
       RowBox[{"24", " ", 
        RowBox[{"ArcCot", "[", "p", "]"}], " ", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "\[ImaginaryI]", " ", 
            RowBox[{"ArcCot", "[", "p", "]"}]}]]}], "]"}]}], "-", 
       RowBox[{"24", " ", 
        RowBox[{"ArcCot", "[", "p", "]"}], " ", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "\[ImaginaryI]", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"ArcCot", "[", "p", "]"}], "+", 
              RowBox[{"ArcTan", "[", "p", "]"}]}], ")"}]}]]}], "]"}]}], "-", 
       RowBox[{"24", " ", 
        RowBox[{"ArcTan", "[", "p", "]"}], " ", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "\[ImaginaryI]", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"ArcCot", "[", "p", "]"}], "+", 
              RowBox[{"ArcTan", "[", "p", "]"}]}], ")"}]}]]}], "]"}]}], "-", 
       RowBox[{"12", " ", "\[Pi]", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"-", 
          FractionBox[
           RowBox[{"2", " ", "\[ImaginaryI]"}], 
           RowBox[{
            RowBox[{"-", "\[ImaginaryI]"}], "+", "p"}]]}], "]"}]}], "+", 
       RowBox[{"24", " ", 
        RowBox[{"ArcTan", "[", "p", "]"}], " ", 
        RowBox[{"Log", "[", 
         RowBox[{"-", 
          FractionBox[
           RowBox[{"2", " ", "\[ImaginaryI]"}], 
           RowBox[{
            RowBox[{"-", "\[ImaginaryI]"}], "+", "p"}]]}], "]"}]}], "-", 
       RowBox[{"24", " ", 
        RowBox[{"ArcCot", "[", "p", "]"}], " ", 
        RowBox[{"Log", "[", 
         FractionBox[
          RowBox[{
           SqrtBox[
            RowBox[{"1", "+", 
             FractionBox["1", 
              SuperscriptBox["p", "2"]]}]], " ", "p"}], 
          RowBox[{"1", "+", 
           SuperscriptBox["p", "2"]}]], "]"}]}], "-", 
       RowBox[{"6", " ", "\[Pi]", " ", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "+", 
          SuperscriptBox["p", "2"]}], "]"}]}], "+", 
       RowBox[{"24", " ", 
        RowBox[{"ArcCot", "[", "p", "]"}], " ", 
        RowBox[{"Log", "[", 
         RowBox[{"Sin", "[", 
          RowBox[{
           RowBox[{"ArcCot", "[", "p", "]"}], "+", 
           RowBox[{"ArcTan", "[", "p", "]"}]}], "]"}], "]"}]}], "-", 
       RowBox[{"12", " ", "\[ImaginaryI]", " ", 
        RowBox[{"PolyLog", "[", 
         RowBox[{"2", ",", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "\[ImaginaryI]", " ", 
            RowBox[{"ArcCot", "[", "p", "]"}]}]]}], "]"}]}], "+", 
       RowBox[{"12", " ", "\[ImaginaryI]", " ", 
        RowBox[{"PolyLog", "[", 
         RowBox[{"2", ",", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "\[ImaginaryI]", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"ArcCot", "[", "p", "]"}], "+", 
              RowBox[{"ArcTan", "[", "p", "]"}]}], ")"}]}]]}], "]"}]}], "+", 
       RowBox[{"12", " ", "\[ImaginaryI]", " ", 
        RowBox[{"PolyLog", "[", 
         RowBox[{"2", ",", 
          FractionBox[
           RowBox[{"\[ImaginaryI]", "+", "p"}], 
           RowBox[{
            RowBox[{"-", "\[ImaginaryI]"}], "+", "p"}]]}], "]"}]}]}], 
      ")"}]}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Re", "[", "p", "]"}], "\[NotEqual]", "0"}], "||", 
      RowBox[{
       RowBox[{"-", "1"}], "<", 
       RowBox[{"Im", "[", "p", "]"}], "<", "0"}], "||", 
      RowBox[{"0", "<", 
       RowBox[{"Im", "[", "p", "]"}], "<", "1"}]}], ")"}], "&&", 
    RowBox[{
     RowBox[{"Re", "[", 
      FractionBox["1", 
       RowBox[{
        SqrtBox[
         RowBox[{"1", "+", 
          FractionBox["1", 
           SuperscriptBox["p", "2"]]}]], " ", "p"}]], "]"}], 
     "\[GreaterEqual]", "0"}], "&&", 
    RowBox[{
     RowBox[{"Re", "[", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"ArcTan", "[", 
         FractionBox["1", "p"], "]"}], "+", 
        RowBox[{"ArcTan", "[", "p", "]"}]}], "]"}], "]"}], "\[GreaterEqual]", 
     "0"}], "&&", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Re", "[", 
        SuperscriptBox["p", "2"], "]"}], ">", 
       RowBox[{"-", "1"}]}], "||", 
      RowBox[{
       SuperscriptBox["p", "2"], "\[NotElement]", "Reals"}]}], ")"}]}]}], 
  "]"}]], "Output"]
}, Open  ]],


Cell[TextData[{
 "The task is now to compute its inverse, i.e., a \"step-down\" operator that \
maps ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "4"], "(", 
    RowBox[{"a", ",", "b", ",", "c", ",", "d", ",", "x", ",", "y"}], ")"}], 
   TraditionalForm]]],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "4"], "(", 
    RowBox[{
     RowBox[{"a", "-", "1"}], ",", "b", ",", "c", ",", "d", ",", "x", ",", 
     "y"}], ")"}], TraditionalForm]], "Output",
  CellChangeTimes->{3.464097829838367*^9, 3.464117264641625*^9}],
 ". This can be done by ansatz; the shape of the ansatz is determined by the \
monomials under the stairs of the Gr\[ODoubleDot]bner basis."
}], "Text"],


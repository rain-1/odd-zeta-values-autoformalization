       RowBox[{
        SubsuperscriptBox["C", "m", 
         RowBox[{"(", "nu", ")"}]], "(", "x", ")"}], " ", 
       RowBox[{
        SubsuperscriptBox["C", "n", 
         RowBox[{"(", "nu", ")"}]], "(", "x", ")"}]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}],
    HoldForm], TraditionalForm]], "Output",
  GeneratedCell->False,
  CellAutoOverwrite->False,
  CellChangeTimes->{3.464354727491778*^9}]
}], "Subsection"],

Cell["\<\
The following identity (p. 795) holds for m \[NotEqual] n and Re[nu]>-1/2.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"x", "^", "2"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"nu", "-", 
          RowBox[{"1", "/", "2"}]}], ")"}]}], "*", 
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"m", ",", "nu", ",", "x"}], "]"}], "*", 
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"n", ",", "nu", ",", "x"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "\[Equal]", "0"}], 
   "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"-", "1"}], "1"], 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["x", "2"]}], ")"}], 
        RowBox[{"nu", "-", 
         FractionBox["1", "2"]}]], " ", 
       RowBox[{
        SubsuperscriptBox["C", "m", 
         RowBox[{"(", "nu", ")"}]], "(", "x", ")"}], " ", 
       RowBox[{
        SubsuperscriptBox["C", "n", 
         RowBox[{"(", "nu", ")"}]], "(", "x", ")"}]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", "0"}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
The exception for m=n is not recognized automatically by our program, so we \
get 1 as an annihilator, whatever m and n are:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"x", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"nu", "-", 
         RowBox[{"1", "/", "2"}]}], ")"}]}], "*", 
      RowBox[{"GegenbauerC", "[", 
       RowBox[{"m", ",", "nu", ",", "x"}], "]"}], "*", 
      RowBox[{"GegenbauerC", "[", 
       RowBox[{"n", ",", "nu", ",", "x"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "nu", "]"}], ",", 
     RowBox[{"S", "[", "m", "]"}], ",", 
     RowBox[{"S", "[", "n", "]"}]}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"nu", ">", 
     RowBox[{"1", "/", "2"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "1", "}"}]], "Output"]
}, Open  ]],

Cell["\<\
To see that for m=n, something goes wrong, we have to look at the certificate \
of creative telescoping. Indeed, the factor (m-n) appears in the denominator:\
\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CreativeTelescoping", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"x", "^", "2"}]}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"nu", "-", 
       RowBox[{"1", "/", "2"}]}], ")"}]}], "*", 
    RowBox[{"GegenbauerC", "[", 
     RowBox[{"m", ",", "nu", ",", "x"}], "]"}], "*", 
    RowBox[{"GegenbauerC", "[", 
     RowBox[{"n", ",", "nu", ",", "x"}], "]"}]}], ",", 
   RowBox[{"Der", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "nu", "]"}], ",", 
     RowBox[{"S", "[", "m", "]"}], ",", 
     RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", "1", "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"-", "1"}], "-", "m"}], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"m", "-", "n"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"m", "+", "n", "+", 
          RowBox[{"2", " ", "nu"}]}], ")"}]}]], 
      SubscriptBox["S", "m"]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"-", "1"}], "-", "n"}], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "m"}], "+", "n"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"m", "+", "n", "+", 
          RowBox[{"2", " ", "nu"}]}], ")"}]}]], 
      SubscriptBox["S", "n"]}], "+", 
     FractionBox["x", 
      RowBox[{"m", "+", "n", "+", 
       RowBox[{"2", " ", "nu"}]}]]}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["In the case m=n we get (for Re[nu]>-1/2,  formula 7.313.2):", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"x", "^", "2"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"nu", "-", 
          RowBox[{"1", "/", "2"}]}], ")"}]}], "*", 
       RowBox[{
        RowBox[{"GegenbauerC", "[", 
         RowBox[{"n", ",", "nu", ",", "x"}], "]"}], "^", "2"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{"Pi", "*", 
     RowBox[{"2", "^", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"2", "nu"}]}], ")"}]}], "*", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"2", "nu"}], "+", "n"}], "]"}], "/", 
        RowBox[{"n", "!"}]}], "/", 
       RowBox[{"(", 
        RowBox[{"n", "+", "nu"}], ")"}]}], "/", 
      RowBox[{
       RowBox[{"Gamma", "[", "nu", "]"}], "^", "2"}]}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"-", "1"}], "1"], 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["x", "2"]}], ")"}], 
        RowBox[{"nu", "-", 
         FractionBox["1", "2"]}]], " ", 
       SuperscriptBox[
        RowBox[{
         SubsuperscriptBox["C", "n", 
          RowBox[{"(", "nu", ")"}]], "(", "x", ")"}], "2"]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{"\[Pi]", " ", 
      SuperscriptBox["2", 
       RowBox[{"1", "-", 
        RowBox[{"2", " ", "nu"}]}]], " ", 
      TemplateBox[{RowBox[{
          RowBox[{"2", " ", "nu"}], "+", "n"}]},
       "Gamma"]}], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"n", "!"}], " ", 
        RowBox[{"(", 
         RowBox[{"n", "+", "nu"}], ")"}]}], ")"}], " ", 
      SuperscriptBox[
       TemplateBox[{"nu"},
        "Gamma"], "2"]}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
This evaluation can be FOUND automatically! We compute a recurrence in n for \
the integral and one initial value for n=0 (for the automatic treatment, we \
have to sharpen the conditions on nu):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"x", "^", "2"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"nu", "-", 
          RowBox[{"1", "/", "2"}]}], ")"}]}], "*", 
       RowBox[{
        RowBox[{"GegenbauerC", "[", 
         RowBox[{"n", ",", "nu", ",", "x"}], "]"}], "^", "2"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
    RowBox[{"S", "[", "n", "]"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"Re", "[", "nu", "]"}], ">", 
      RowBox[{"1", "/", "2"}]}]}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "-", 
     RowBox[{"2", " ", "n"}], "-", 
     SuperscriptBox["n", "2"], "-", "nu", "-", 
     RowBox[{"n", " ", "nu"}]}], ")", 
    SubscriptBox["S", "n"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["n", "2"], "+", 
     RowBox[{"3", " ", "n", " ", "nu"}], "+", 
     RowBox[{"2", " ", 
      SuperscriptBox["nu", "2"]}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"x", "^", "2"}]}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"nu", "-", 
      RowBox[{"1", "/", "2"}]}], ")"}]}], "*", 
   RowBox[{"GegenbauerC", "[", 
    RowBox[{"n", ",", "nu", ",", "x"}], "]"}], "*", 
   RowBox[{"GegenbauerC", "[", 
    RowBox[{"n", ",", "nu", ",", "x"}], "]"}]}], "/.", 
  RowBox[{"n", "\[Rule]", "0"}]}]], "Input"],

Cell[BoxData[
 SuperscriptBox[
  RowBox[{"(", 
   RowBox[{"1", "-", 
    SuperscriptBox["x", "2"]}], ")"}], 
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", "2"]}], "+", "nu"}]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{"%", ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"Re", "[", "nu", "]"}], ">", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "2"}]}]}]}], "]"}], "/.", 
  RowBox[{
   RowBox[{"Sec", "[", 
    RowBox[{"nu", "*", "Pi"}], "]"}], "\[Rule]", 
   RowBox[{
    RowBox[{"Gamma", "[", 
     RowBox[{
      RowBox[{"1", "/", "2"}], "+", "nu"}], "]"}], "*", 
    RowBox[{
     RowBox[{"Gamma", "[", 
      RowBox[{
       RowBox[{"1", "/", "2"}], "-", "nu"}], "]"}], "/", 
     "Pi"}]}]}]}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SqrtBox["\[Pi]"], " ", 
   RowBox[{"Gamma", "[", 
    RowBox[{
     FractionBox["1", "2"], "+", "nu"}], "]"}]}], 
  RowBox[{"Gamma", "[", 
   RowBox[{"1", "+", "nu"}], "]"}]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"RSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"ApplyOreOperator", "[", 
        RowBox[{
         RowBox[{"First", "[", "ann", "]"}], ",", 

Cell[TextData[{
 "Since we started by reducing the relation stepDown*stepUp=1, we got the \
\"step-down\" operator that maps ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "4"], "(", 
    RowBox[{
     RowBox[{"a", "+", "1"}], ",", "b", ",", "c", ",", "d", ",", "x", ",", 
     "y"}], ")"}], TraditionalForm]]],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "4"], "(", 
    RowBox[{"a", ",", "b", ",", "c", ",", "d", ",", "x", ",", "y"}], ")"}], 
   TraditionalForm]], "Output",
  CellChangeTimes->{3.464097829838367*^9, 3.464117264641625*^9}],
 ". Therefore we replace a by a-1."
}], "Text"],


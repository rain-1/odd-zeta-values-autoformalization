        RowBox[{"m", ",", 
         RowBox[{
          FractionBox["1", "2"], "+", "m"}], ",", "a"}], "]"}]}]}], ")"}]}], 
   ")"}], "/", 
  RowBox[{"(", 
   RowBox[{"3", " ", 
    RowBox[{"Gamma", "[", 
     RowBox[{"1", "+", "m"}], "]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"3", "+", 
         RowBox[{"4", " ", "m"}]}], ")"}], " ", 
       RowBox[{"Hypergeometric2F1Regularized", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "-", "m"}], ",", 
         RowBox[{"2", "+", "m"}], ",", 
         RowBox[{
          FractionBox["3", "2"], "+", "m"}], ",", 
         FractionBox["1", "2"]}], "]"}], " ", 
       RowBox[{"Hypergeometric2F1Regularized", "[", 
        RowBox[{
         RowBox[{"-", "m"}], ",", 
         RowBox[{"1", "+", "m"}], ",", 
         RowBox[{
          FractionBox["1", "2"], "-", "m"}], ",", 
         FractionBox["1", "2"]}], "]"}]}], "-", 
      RowBox[{
       RowBox[{"Hypergeometric2F1Regularized", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "-", "m"}], ",", 
         RowBox[{"2", "+", "m"}], ",", 
         RowBox[{
          FractionBox["1", "2"], "-", "m"}], ",", 
         FractionBox["1", "2"]}], "]"}], " ", 
       RowBox[{"Hypergeometric2F1Regularized", "[", 
        RowBox[{
         RowBox[{"-", "m"}], ",", 
         RowBox[{"1", "+", "m"}], ",", 
         RowBox[{
          FractionBox["3", "2"], "+", "m"}], ",", 
         FractionBox["1", "2"]}], "]"}]}]}], ")"}]}], ")"}]}]], "Output"]
}, Open  ]],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " 7 returned the following formula as the output of the previous command:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"-", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", "I"}], ")"}], " ", 
      RowBox[{"I", "^", 
       RowBox[{"-", "m"}]}], " ", 
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "-", "m"}], ")"}]}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         RowBox[{"a", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"1", "/", "4"}], ")"}]}], "-", 
         RowBox[{"m", "/", "2"}]}], ")"}]}], " ", 
      RowBox[{"Sqrt", "[", "\[Pi]", "]"}], " ", 
      RowBox[{"LegendreQ", "[", 
       RowBox[{"m", ",", 
        RowBox[{
         RowBox[{"1", "/", "2"}], "+", "m"}], ",", "a"}], "]"}]}], ")"}], "/", 
    RowBox[{"Gamma", "[", 
     RowBox[{"1", "+", "m"}], "]"}]}], ")"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", "\[ImaginaryI]"}], ")"}], " ", 
    SuperscriptBox["\[ImaginaryI]", 
     RowBox[{"-", "m"}]], " ", 
    SuperscriptBox["2", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "m"}]], " ", 
    SuperscriptBox[
     RowBox[{"(", 

Cell[TextData[{
 "Unfortunately, ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " cannot do these integrals. So we content ourselves with a numerical \
check:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"%", "/.", 
  RowBox[{"Integrate", "\[Rule]", "NIntegrate"}]}]], "Input"],


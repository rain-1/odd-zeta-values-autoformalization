Cell["\<\
Theory does not guarantee that a relation for the integral exists, since both \
factors of the integrand have dimension 1. Looking at its annihilator, it is \
easily seen that it delivers a creative telescoping relation:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"BernoulliB", "[", 
     RowBox[{"n", ",", "x"}], "]"}], "*", 
    RowBox[{"BernoulliB", "[", 
     RowBox[{"m", ",", "x"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "m", "]"}], ",", 
     RowBox[{"S", "[", "n", "]"}], ",", 
     RowBox[{"Der", "[", "x", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","nondf",
   "\"The expression \\!\\(\\*RowBox[{\\\"\\\\\\\"BernoulliB[m, \
x]\\\\\\\"\\\"}]\\) is not recognized to be \[PartialD]-finite. The result \
might not generate a zero-dimensional ideal.\"",2,107,29,31736875148575551998,
   "Local"},
  "MessageTemplate"]], "Message", "MSG"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","nondf",
   "\"The expression \\!\\(\\*RowBox[{\\\"\\\\\\\"BernoulliB[n, \
x]\\\\\\\"\\\"}]\\) is not recognized to be \[PartialD]-finite. The result \
might not generate a zero-dimensional ideal.\"",2,107,30,31736875148575551998,
   "Local"},
  "MessageTemplate"]], "Message", "MSG"],


     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "3"]}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"], " ", "y"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "3"], " ", "y"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
This is a classical case where a little bit of human intervention is desired. \
When the closure property DFinitePlus is used, the annihilating ideal often \
overshoots, especially when the two functions to be combined are very \
\"similar\" (as it is the case here). We can get a better result by applying \
the closure property DFiniteOreAction. To this purpose, the sum of the two \
Legendre polynomials has to be reformulated as applying the operator S[n]+1 \
to the function LegendreP[n-1,1-y].\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"ApplyOreOperator", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"S", "[", "n", "]"}], "+", "1"}], ",", 
      RowBox[{"LegendreP", "[", 
       RowBox[{
        RowBox[{"n", "-", "1"}], ",", 
        RowBox[{"1", "-", "y"}]}], "]"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "n", "]"}], ",", 
      RowBox[{"Der", "[", "y", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "n"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "y"}], "-", 
      RowBox[{"4", " ", "n", " ", "y"}], "+", 
      SuperscriptBox["y", "2"], "+", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["y", "2"]}]}], ")", 
     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "n"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}], "+", 
      RowBox[{"n", " ", "y"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"], " ", "y"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "y"}], "-", 
      SuperscriptBox["y", "2"]}], ")", 
     SubsuperscriptBox["D", "y", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"2", "-", "y"}], ")", 
     SubscriptBox["D", "y"]}], "+", 
    SuperscriptBox["n", "2"]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Now we get the same annihilating ideal, and have to compare two initial \
values.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"uts", "=", 
  RowBox[{"UnderTheStaircase", "[", "rhs", "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", 
   SubscriptBox["D", "y"]}], "}"}]], "Output"]
}, Open  ]],

Cell["For n=1:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"ApplyOreOperator", "[", 
      RowBox[{"uts", ",", 
       RowBox[{
        RowBox[{"ChebyshevT", "[", 
         RowBox[{"n", ",", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"x", "^", "2"}], " ", "y"}]}]}], "]"}], "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", 
          RowBox[{"x", "^", "2"}]}], "]"}]}]}], "]"}], "/.", 
     RowBox[{"n", "\[Rule]", "1"}]}], "/.", 
    RowBox[{"y", "\[Rule]", "0"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[Pi]", ",", 
   RowBox[{"-", 
    FractionBox["\[Pi]", "2"]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Together", "[", 
   RowBox[{
    RowBox[{"ApplyOreOperator", "[", 
     RowBox[{"uts", ",", 
      RowBox[{
       RowBox[{"Pi", "/", "2"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"LegendreP", "[", 
          RowBox[{"n", ",", 
           RowBox[{"1", "-", "y"}]}], "]"}], "+", 
         RowBox[{"LegendreP", "[", 
          RowBox[{
           RowBox[{"n", "-", "1"}], ",", 
           RowBox[{"1", "-", "y"}]}], "]"}]}], ")"}]}]}], "]"}], "/.", 
    RowBox[{"n", "\[Rule]", "1"}]}], "]"}], "/.", 
  RowBox[{"y", "\[Rule]", "0"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[Pi]", ",", 
   RowBox[{"-", 
    FractionBox["\[Pi]", "2"]}]}], "}"}]], "Output"]
}, Open  ]]
}, Closed]],


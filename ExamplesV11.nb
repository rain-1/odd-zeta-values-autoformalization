      RowBox[{"(", 
       RowBox[{"n", "+", "nu"}], ")"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"1", "+", "n"}], "]"}], " ", 
      SuperscriptBox[
       RowBox[{"Gamma", "[", "nu", "]"}], "2"]}]]}], "}"}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
This evaluation agrees exactly with the formula given in Gradshteyn/Ryzhik.\
\>", "Text"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[{
 "7.322  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", 
      RowBox[{"2", " ", "a"}]], 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"x", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", " ", "a"}], "-", "x"}], ")"}]}], ")"}], 
        RowBox[{"nu", "-", 
         FractionBox["1", "2"]}]], " ", 
       RowBox[{
        SubsuperscriptBox["C", "n", 
         RowBox[{"(", "nu", ")"}]], "(", 
        RowBox[{
         FractionBox["x", "a"], "-", "1"}], ")"}], " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "b"}], " ", "x"}]]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "n"], " ", "\[Pi]", " ", 
      RowBox[{"\[CapitalGamma]", "(", 
       RowBox[{"n", "+", 
        RowBox[{"2", " ", "nu"}]}], ")"}], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["a", 
         RowBox[{"2", " ", "b"}]], ")"}], "nu"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "a"}], " ", "b"}]], " ", 
      RowBox[{
       SubscriptBox["I", 
        RowBox[{"n", "+", "nu"}]], "(", 
       RowBox[{"a", " ", "b"}], ")"}]}], 
     RowBox[{
      RowBox[{"n", "!"}], " ", 
      RowBox[{"\[CapitalGamma]", "(", "nu", ")"}]}]]}], TraditionalForm]], 
  "Output",
  CellChangeTimes->{3.417372226289274*^9}],
 "\n",
 "(misprint in the book!)"
}], "Subsection"],

Cell["\<\
The formula 7.322  (S. 797) is not correct as we will show in the following.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "a"}], "-", "x"}], ")"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"nu", "-", 
          RowBox[{"1", "/", "2"}]}], ")"}]}], "*", 
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"n", ",", "nu", ",", 
         RowBox[{
          RowBox[{"x", "/", "a"}], "-", "1"}]}], "]"}], "*", 
       RowBox[{"E", "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "b"}], "*", "x"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", 
        RowBox[{"2", "a"}]}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", "n"}], "*", "Pi", "*", 
     RowBox[{
      RowBox[{
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"2", "nu"}], "+", "n"}], "]"}], "/", 
       RowBox[{"n", "!"}]}], "/", 
      RowBox[{"Gamma", "[", "nu", "]"}]}], "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "/", 
        RowBox[{"(", 
         RowBox[{"2", "b"}], ")"}]}], ")"}], "^", "nu"}], "*", 
     RowBox[{"E", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "*", "b"}], ")"}]}], "*", 
     RowBox[{"BesselI", "[", 
      RowBox[{
       RowBox[{"nu", "+", "n"}], ",", 
       RowBox[{"a", "*", "b"}]}], "]"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", 
      RowBox[{"2", " ", "a"}]], 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"x", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", " ", "a"}], "-", "x"}], ")"}]}], ")"}], 
        RowBox[{"nu", "-", 
         FractionBox["1", "2"]}]], " ", 
       RowBox[{
        SubsuperscriptBox["C", "n", 
         RowBox[{"(", "nu", ")"}]], "(", 
        RowBox[{
         FractionBox["x", "a"], "-", "1"}], ")"}], " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "b"}], " ", "x"}]]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "n"], " ", "\[Pi]", " ", 
      TemplateBox[{RowBox[{
          RowBox[{"2", " ", "nu"}], "+", "n"}]},
       "Gamma"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["a", 
         RowBox[{"2", " ", "b"}]], ")"}], "nu"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "a"}], " ", "b"}]], " ", 
      TemplateBox[{RowBox[{"nu", "+", "n"}],RowBox[{"a", " ", "b"}]},
       "BesselI"]}], 
     RowBox[{
      RowBox[{"n", "!"}], " ", 
      TemplateBox[{"nu"},
       "Gamma"]}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["Annihilating \[PartialD]-finite ideal for the integrand", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "a"}], "-", "x"}], ")"}]}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"nu", "-", 
        RowBox[{"1", "/", "2"}]}], ")"}]}], "*", 
     RowBox[{"GegenbauerC", "[", 
      RowBox[{"n", ",", "nu", ",", 
       RowBox[{
        RowBox[{"x", "/", "a"}], "-", "1"}]}], "]"}], "*", 
     RowBox[{"E", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "b"}], "*", "x"}], ")"}]}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"Der", "[", "b", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}], ",", 
      RowBox[{"S", "[", "nu", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["a", "2"], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "n"}], "-", 
      RowBox[{"a", " ", "x"}], "-", 
      RowBox[{"a", " ", "n", " ", "x"}]}], ")", 
     SubscriptBox["S", "n"]}], "-", 
    RowBox[{
     RowBox[{"2", " ", "nu"}], 
     SubscriptBox["S", "nu"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["a", "2"], " ", "n"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "nu"}]}], ")"}]}], ",", 
   RowBox[{
    SubscriptBox["D", "b"], "+", "x"}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox["a", "3"]}], "-", 
      RowBox[{"3", " ", 
       SuperscriptBox["a", "2"], " ", "x"}], "+", 
      RowBox[{"a", " ", 
       SuperscriptBox["x", "2"]}]}], ")", 
     SubscriptBox["D", "a"]}], "-", 
    RowBox[{
     RowBox[{"2", " ", "nu"}], 
     SubscriptBox["S", "nu"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["a", "2"], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "nu"}], "-", 
      RowBox[{"a", " ", "x"}], "+", 
      RowBox[{"2", " ", "a", " ", "n", " ", "x"}], "+", 
      RowBox[{"6", " ", "a", " ", "nu", " ", "x"}], "-", 
      RowBox[{"n", " ", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"2", " ", "nu", " ", 
       SuperscriptBox["x", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "x"}], "-", 
      RowBox[{"3", " ", "a", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      SuperscriptBox["x", "3"]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{
     RowBox[{"2", " ", "nu"}], 
     SubscriptBox["S", "nu"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["a", "2"], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "nu"}], "-", 
      RowBox[{"2", " ", "a", " ", "x"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "b", " ", "x"}], "-", 
      RowBox[{"2", " ", "a", " ", "n", " ", "x"}], "+", 
      SuperscriptBox["x", "2"], "-", 
      RowBox[{"3", " ", "a", " ", "b", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"n", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"b", " ", 
       SuperscriptBox["x", "3"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"4", " ", "nu"}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["nu", "2"]}]}], ")", 
     SubsuperscriptBox["S", "nu", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", 
       SuperscriptBox["a", "2"], " ", "nu"}], "-", 

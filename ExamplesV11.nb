Cell["Transformation of 2F1 functions", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Hypergeometric2F1", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], "n"}], ",", 
      RowBox[{
       RowBox[{"2", "n"}], "+", 
       RowBox[{"2", "a"}], "+", "1"}], ",", 
      RowBox[{"a", "+", "1"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}], "/", "2"}]}], "]"}], "==", 
    RowBox[{"Hypergeometric2F1", "[", 
     RowBox[{
      RowBox[{"-", "n"}], ",", 
      RowBox[{"n", "+", "a", "+", 
       RowBox[{"1", "/", "2"}]}], ",", 
      RowBox[{"a", "+", "1"}], ",", 
      RowBox[{"1", "-", 
       RowBox[{"x", "^", "2"}]}]}], "]"}]}], "]"}], "//", 
  "TraditionalForm"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    TemplateBox[{RowBox[{
        RowBox[{"-", "2"}], " ", "n"}],RowBox[{
        RowBox[{"2", " ", "n"}], "+", 
        RowBox[{"2", " ", "a"}], "+", "1"}],RowBox[{"a", "+", "1"}],
      FractionBox[
       RowBox[{"1", "-", "x"}], "2"]},
     "Hypergeometric2F1"], "\[LongEqual]", 
    TemplateBox[{RowBox[{"-", "n"}],RowBox[{"n", "+", "a", "+", 
        FractionBox["1", "2"]}],RowBox[{"a", "+", "1"}],RowBox[{"1", "-", 
        SuperscriptBox["x", "2"]}]},
     "Hypergeometric2F1"]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


Cell["5.6.2  recurrence for GegenbauerC", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"n", "+", "2", "+", "m"}], ")"}], "*", 
     RowBox[{"GegenbauerC", "[", 
      RowBox[{
       RowBox[{"n", "+", "2"}], ",", "m", ",", "x"}], "]"}]}], "\[Equal]", 
    RowBox[{"m", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"GegenbauerC", "[", 
        RowBox[{
         RowBox[{"n", "+", "2"}], ",", 
         RowBox[{"m", "+", "1"}], ",", "x"}], "]"}], "-", 
       RowBox[{"GegenbauerC", "[", 
        RowBox[{"n", ",", 
         RowBox[{"m", "+", "1"}], ",", "x"}], "]"}]}], ")"}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"n", "+", "2", "+", "m"}], ")"}], " ", 
     RowBox[{
      SubsuperscriptBox["C", 
       RowBox[{"n", "+", "2"}], 
       RowBox[{"(", "m", ")"}]], "(", "x", ")"}]}], "\[LongEqual]", 
    RowBox[{"m", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SubsuperscriptBox["C", 
         RowBox[{"n", "+", "2"}], 
         RowBox[{"(", 
          RowBox[{"m", "+", "1"}], ")"}]], "(", "x", ")"}], "-", 
       RowBox[{
        SubsuperscriptBox["C", "n", 
         RowBox[{"(", 
          RowBox[{"m", "+", "1"}], ")"}]], "(", "x", ")"}]}], ")"}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"GegenbauerC", "[", 
     RowBox[{"n", ",", "m", ",", "x"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 

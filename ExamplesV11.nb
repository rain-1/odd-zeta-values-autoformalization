        RowBox[{"Binomial", "[", 
         RowBox[{"n", ",", "s"}], "]"}], 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"n", "+", "r"}], ",", "r"}], "]"}], 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"n", "+", "s"}], ",", "s"}], "]"}], 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"2", "n"}], "-", 
           RowBox[{"(", 
            RowBox[{"r", "+", "s"}], ")"}]}], ",", "n"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"S", "[", "r", "]"}], "-", "1"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"S", "[", "s", "]"}], ",", 

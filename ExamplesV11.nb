Cell["\<\
Aiming at a rigorous proof, Zeilberger's original (slow) algorithm seems to \
be the perfect tool for this specific problem. Recall that this algorithm \
first completely eliminates x, and then does the splitting into principal \
part and delta part. Hence no x occurs in the delta part and we can expect \
the corresponding limits to converge. Additionally we would like to have no \
derivatives w.r.t. a or b in the delta parts, since they cause the same \
problems. 
Operators with these properties can be found by means of our command \
FindRelation, where the first condition can be encoded by the
option Eliminate, and the second by the option Support: we give all monomials \
up to total degree 2, but omit Der[a]*Der[x] and Der[b]*Der[x].\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ops", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Der", "[", "x", "]"}], ",", 
     RowBox[{"Der", "[", "a", "]"}], ",", 
     RowBox[{"Der", "[", "b", "]"}], ",", 
     RowBox[{"S", "[", "m", "]"}], ",", 
     RowBox[{"S", "[", "n", "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"supp", "=", 
  RowBox[{"Complement", "[", 
   RowBox[{
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"{", "1", "}"}], ",", "ops", ",", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Outer", "[", 
        RowBox[{"Times", ",", "ops", ",", "ops"}], "]"}], "]"}]}], "]"}], ",", 
    RowBox[{
     RowBox[{"Der", "[", "x", "]"}], "*", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Der", "[", "a", "]"}], ",", 
       RowBox[{"Der", "[", "b", "]"}]}], "}"}]}]}], "]"}]}]}], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", 
   RowBox[{"Der", "[", "a", "]"}], ",", 
   SuperscriptBox[
    RowBox[{"Der", "[", "a", "]"}], "2"], ",", 
   RowBox[{"Der", "[", "b", "]"}], ",", 
   RowBox[{
    RowBox[{"Der", "[", "a", "]"}], " ", 
    RowBox[{"Der", "[", "b", "]"}]}], ",", 
   SuperscriptBox[
    RowBox[{"Der", "[", "b", "]"}], "2"], ",", 
   RowBox[{"Der", "[", "x", "]"}], ",", 
   SuperscriptBox[
    RowBox[{"Der", "[", "x", "]"}], "2"], ",", 
   RowBox[{"S", "[", "m", "]"}], ",", 
   RowBox[{
    RowBox[{"Der", "[", "a", "]"}], " ", 
    RowBox[{"S", "[", "m", "]"}]}], ",", 
   RowBox[{
    RowBox[{"Der", "[", "b", "]"}], " ", 
    RowBox[{"S", "[", "m", "]"}]}], ",", 
   RowBox[{
    RowBox[{"Der", "[", "x", "]"}], " ", 
    RowBox[{"S", "[", "m", "]"}]}], ",", 
   SuperscriptBox[
    RowBox[{"S", "[", "m", "]"}], "2"], ",", 
   RowBox[{"S", "[", "n", "]"}], ",", 
   RowBox[{
    RowBox[{"Der", "[", "a", "]"}], " ", 
    RowBox[{"S", "[", "n", "]"}]}], ",", 
   RowBox[{
    RowBox[{"Der", "[", "b", "]"}], " ", 
    RowBox[{"S", "[", "n", "]"}]}], ",", 
   RowBox[{
    RowBox[{"Der", "[", "x", "]"}], " ", 
    RowBox[{"S", "[", "n", "]"}]}], ",", 
   RowBox[{
    RowBox[{"S", "[", "m", "]"}], " ", 
    RowBox[{"S", "[", "n", "]"}]}], ",", 
   SuperscriptBox[
    RowBox[{"S", "[", "n", "]"}], "2"]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rels", "=", 
  RowBox[{"FindRelation", "[", 
   RowBox[{
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"BesselJ", "[", 
        RowBox[{"m", ",", 
         RowBox[{"a", "*", "x"}]}], "]"}], "*", 
       RowBox[{"BesselJ", "[", 
        RowBox[{"n", ",", 
         RowBox[{"b", "*", "x"}]}], "]"}]}], ",", "ops"}], "]"}], ",", 
    RowBox[{"Eliminate", "\[Rule]", "x"}], ",", 
    RowBox[{"Support", "\[Rule]", "supp"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"a", " ", 
      SuperscriptBox["b", "2"], " ", "m"}], 
     SubscriptBox["D", "a"], 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["a", "2"], " ", "b"}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "b", " ", "n"}]}], ")", 
     SubscriptBox["D", "a"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["a", "2"]}], " ", "b"}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "b", " ", "n"}]}], ")", 
     SubscriptBox["D", "b"], 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{
     RowBox[{"a", " ", 
      SuperscriptBox["b", "2"], " ", "m"}], 
     SubscriptBox["D", "b"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["b", "2"]}], " ", "m"}], "-", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "n"}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubscriptBox["S", "m"]}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SubscriptBox["D", "x"], 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{"a", "+", 
      RowBox[{"a", " ", "m"}], "-", 
      RowBox[{"a", " ", "n"}]}], ")", 
     SubsuperscriptBox["S", "m", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "b"}], "+", 
      RowBox[{"2", " ", "b", " ", "m"}]}], ")", 
     SubscriptBox["S", "m"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "a"}], "-", 
      RowBox[{"a", " ", "m"}], "-", 
      RowBox[{"a", " ", "n"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"2", " ", "n"}]}], ")", 
     SubscriptBox["D", "x"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "a"}], "+", 
      RowBox[{"2", " ", "a", " ", "n"}]}], ")", 
     SubscriptBox["S", "m"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"b", "-", 
      RowBox[{"b", " ", "m"}], "+", 
      RowBox[{"b", " ", "n"}]}], ")", 
     SubsuperscriptBox["S", "n", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "b"}], "-", 
      RowBox[{"b", " ", "m"}], "-", 
      RowBox[{"b", " ", "n"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"a", " ", "b"}], 
     SubscriptBox["D", "a"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{
     RowBox[{"a", " ", "b"}], 
     SubscriptBox["D", "b"], 
     SubscriptBox["S", "m"]}], "-", 
    RowBox[{
     RowBox[{"a", " ", "n"}], 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{
     RowBox[{"b", " ", "m"}], 
     SubscriptBox["S", "n"]}]}], ",", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["b", "2"]}], 
     SubsuperscriptBox["D", "a", "2"]}], "+", 
    RowBox[{
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["b", "2"]}], 
     SubsuperscriptBox["D", "b", "2"]}], "-", 
    RowBox[{
     RowBox[{"a", " ", 
      SuperscriptBox["b", "2"]}], 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{
     RowBox[{
      SuperscriptBox["a", "2"], " ", "b"}], 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["n", "2"]}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
We now have to separate principal parts and delta parts by hand:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pps", "=", 
  RowBox[{"OrePolynomialSubstitute", "[", 
   RowBox[{"rels", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], "\[Rule]", "0"}], "}"}]}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"a", " ", 
      SuperscriptBox["b", "2"], " ", "m"}], 
     SubscriptBox["D", "a"], 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["a", "2"], " ", "b"}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "b", " ", "n"}]}], ")", 
     SubscriptBox["D", "a"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["a", "2"]}], " ", "b"}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "b", " ", "n"}]}], ")", 
     SubscriptBox["D", "b"], 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{
     RowBox[{"a", " ", 
      SuperscriptBox["b", "2"], " ", "m"}], 
     SubscriptBox["D", "b"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["b", "2"]}], " ", "m"}], "-", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "n"}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubscriptBox["S", "m"]}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"a", "+", 
      RowBox[{"a", " ", "m"}], "-", 
      RowBox[{"a", " ", "n"}]}], ")", 
     SubsuperscriptBox["S", "m", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "b"}], "+", 
      RowBox[{"2", " ", "b", " ", "m"}]}], ")", 
     SubscriptBox["S", "m"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "a"}], "-", 
      RowBox[{"a", " ", "m"}], "-", 
      RowBox[{"a", " ", "n"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "a"}], "+", 
      RowBox[{"2", " ", "a", " ", "n"}]}], ")", 
     SubscriptBox["S", "m"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"b", "-", 
      RowBox[{"b", " ", "m"}], "+", 
      RowBox[{"b", " ", "n"}]}], ")", 
     SubsuperscriptBox["S", "n", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "b"}], "-", 
      RowBox[{"b", " ", "m"}], "-", 
      RowBox[{"b", " ", "n"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"a", " ", "b"}], 
     SubscriptBox["D", "a"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{
     RowBox[{"a", " ", "b"}], 
     SubscriptBox["D", "b"], 
     SubscriptBox["S", "m"]}], "-", 
    RowBox[{
     RowBox[{"a", " ", "n"}], 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{
     RowBox[{"b", " ", "m"}], 
     SubscriptBox["S", "n"]}]}], ",", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["b", "2"]}], 
     SubsuperscriptBox["D", "a", "2"]}], "+", 
    RowBox[{
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["b", "2"]}], 
     SubsuperscriptBox["D", "b", "2"]}], "-", 
    RowBox[{
     RowBox[{"a", " ", 
      SuperscriptBox["b", "2"]}], 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{
     RowBox[{
      SuperscriptBox["a", "2"], " ", "b"}], 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["n", "2"]}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"deltas", "=", 
  RowBox[{"Together", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"Normal", "/@", 
      RowBox[{"(", 
       RowBox[{"rels", "-", "pps"}], ")"}]}], ")"}], "/", 
    RowBox[{"Der", "[", "x", "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", 
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", "m"}], ")"}], " ", 
    RowBox[{"S", "[", "m", "]"}]}], ",", 
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", "n"}], ")"}], " ", 
    RowBox[{"S", "[", "n", "]"}]}], ",", "0", ",", "0"}], "}"}]], "Output"]
}, Open  ]],

Cell["It is now obvious that all limits will tend to zero.", "Text"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ass", "=", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"a", ">", "0"}], "&&", 
     RowBox[{"b", ">", "0"}], "&&", 
     RowBox[{"m", "\[GreaterEqual]", "0"}], "&&", 
     RowBox[{"n", "\[GreaterEqual]", "0"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"inhom", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Limit", "[", 
        RowBox[{"#", ",", 
         RowBox[{"x", "\[Rule]", "Infinity"}], ",", "ass"}], "]"}], "-", 
       RowBox[{"FullSimplify", "[", 
        RowBox[{
         RowBox[{"#", "/.", 
          RowBox[{"x", "\[Rule]", "0"}]}], ",", "ass"}], "]"}]}], ")"}], 
     ")"}], "&"}], "/@", 
   RowBox[{"ApplyOreOperator", "[", 
    RowBox[{"deltas", ",", 
     RowBox[{
      RowBox[{"BesselJ", "[", 
       RowBox[{"m", ",", 
        RowBox[{"a", "*", "x"}]}], "]"}], "*", 
      RowBox[{"BesselJ", "[", 
       RowBox[{"n", ",", 
        RowBox[{"b", "*", "x"}]}], "]"}]}]}], "]"}]}]}]}], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0", ",", "0", ",", "0"}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
A final Gr\[ODoubleDot]bner basis computation is needed to convert these into \
our original setting:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"OreGroebnerBasis", "[", 
   RowBox[{"pps", ",", 
    RowBox[{"OreAlgebra", "[", 
     RowBox[{
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"Der", "[", "b", "]"}], ",", 
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}]}], "]"}], ",", 
    RowBox[{"MonomialOrder", "\[Rule]", "DegreeLexicographic"}]}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", "a", 
     SubscriptBox["D", "a"]}], "-", 
    RowBox[{"b", 
     SubscriptBox["D", "b"]}], "-", "1"}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["b", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["b", "2"], " ", "n"}], "-", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubsuperscriptBox["S", "n", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "b"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["b", "3"]}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "b", " ", "n"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["b", "3"], " ", "n"}]}], ")", 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["b", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "n"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["n", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["n", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b"}], "+", 
      RowBox[{"a", " ", "b", " ", "m"}], "+", 
      RowBox[{"a", " ", "b", " ", "n"}]}], ")", 
     SubscriptBox["S", "m"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["a", "2"], " ", "b"}], "-", 
      SuperscriptBox["b", "3"]}], ")", 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["b", "2"]}], "-", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", "m"}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "n"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["a", "2"]}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "m"}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubsuperscriptBox["S", "m", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "b"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["b", "3"]}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "b", " ", "m"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["b", "3"], " ", "m"}]}], ")", 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["a", "2"], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["b", "2"]}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["a", "2"], " ", "m"}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["b", "2"], " ", "m"}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["m", "2"]}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["n", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["a", "2"]}], " ", "b"}], "+", 
      SuperscriptBox["b", "3"]}], ")", 
     SubscriptBox["D", "b"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b", " ", "m"}], "-", 
      RowBox[{"a", " ", "b", " ", "n"}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["a", "2"]}], "+", 
      SuperscriptBox["b", "2"], "+", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", "m"}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "n"}]}], ")", 
     SubscriptBox["S", "n"]}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["a", "2"], " ", "b"}], "-", 
      SuperscriptBox["b", "3"]}], ")", 
     SubscriptBox["D", "b"], 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["b", "2"], " ", "m"}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "n"}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b", " ", "m"}], "-", 
      RowBox[{"a", " ", "b", " ", "n"}]}], ")", 
     SubscriptBox["S", "n"]}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["a", "2"]}], " ", 
       SuperscriptBox["b", "2"]}], "+", 
      SuperscriptBox["b", "4"]}], ")", 
     SubsuperscriptBox["D", "b", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["a", "2"]}], " ", "b"}], "+", 
      RowBox[{"3", " ", 
       SuperscriptBox["b", "3"]}]}], ")", 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["b", "2"], "-", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["n", "2"]}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Again, we get the same annihilating ideal as for the right-hand side:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GBEqual", "[", 
  RowBox[{"rhs", ",", "ann"}], "]"}]], "Input"],

Cell[BoxData["True"], "Output"]
}, Open  ]],

Cell["Initial values:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"uts", "=", 
  RowBox[{"UnderTheStaircase", "[", "rhs", "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", 
   SubscriptBox["S", "n"], ",", 
   SubscriptBox["S", "m"], ",", 
   SubscriptBox["D", "b"]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"ApplyOreOperator", "[", 
      RowBox[{"uts", ",", 
       RowBox[{
        RowBox[{"BesselJ", "[", 
         RowBox[{"m", ",", 
          RowBox[{"a", "*", "x"}]}], "]"}], "*", 
        RowBox[{"BesselJ", "[", 
         RowBox[{"n", ",", 
          RowBox[{"b", "*", "x"}]}], "]"}]}]}], "]"}], "/.", 
     RowBox[{"m", "\[Rule]", "0"}]}], "/.", 
    RowBox[{"n", "\[Rule]", "0"}]}], "/.", 
   RowBox[{"a", "\[Rule]", "1"}]}], "/.", 
  RowBox[{"b", "\[Rule]", 
   RowBox[{"1", "/", "2"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", 
      FractionBox["x", "2"]}], "]"}], " ", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", "x"}], "]"}]}], ",", 
   RowBox[{
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", "x"}], "]"}], " ", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"1", ",", 
      FractionBox["x", "2"]}], "]"}]}], ",", 
   RowBox[{
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", 
      FractionBox["x", "2"]}], "]"}], " ", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"1", ",", "x"}], "]"}]}], ",", 
   RowBox[{
    RowBox[{"-", "x"}], " ", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"0", ",", "x"}], "]"}], " ", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"1", ",", 
      FractionBox["x", "2"]}], "]"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[TextData[{
 "In some ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " versions, the last of the following integrals is declared to diverge, but \
in other versions it works (and the correct value is given)."
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{"%", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Integrate","idiv",
   "\"Integral of \\!\\(\\*RowBox[{RowBox[{\\\"-\\\", \\\"x\\\"}], \\\" \\\", \
RowBox[{\\\"BesselJ\\\", \\\"[\\\", RowBox[{\\\"0\\\", \\\",\\\", \
\\\"x\\\"}], \\\"]\\\"}], \\\" \\\", RowBox[{\\\"BesselJ\\\", \\\"[\\\", \
RowBox[{\\\"1\\\", \\\",\\\", FractionBox[\\\"x\\\", \\\"2\\\"]}], \
\\\"]\\\"}]}]\\) does not converge on \\!\\(\\*RowBox[{\\\"{\\\", \
RowBox[{\\\"0\\\", \\\",\\\", \\\"\[Infinity]\\\"}], \\\"}\\\"}]\\).\"",2,6,1,
   31736862217881225387,"Local"},
  "MessageTemplate"]], "Message", "MSG"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox[
    RowBox[{"2", " ", 
     RowBox[{"EllipticK", "[", 
      FractionBox["1", "4"], "]"}]}], "\[Pi]"], ",", "0", ",", "1", ",", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
    RowBox[{
     RowBox[{
      RowBox[{"-", "x"}], " ", 
      RowBox[{"BesselJ", "[", 
       RowBox[{"0", ",", "x"}], "]"}], " ", 

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GBEqual", "[", 
  RowBox[{
   RowBox[{"Annihilator", "[", 
    RowBox[{"sol1", ",", 
     RowBox[{"S", "[", "n", "]"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"ann2", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData["True"], "Output"]
}, Open  ]],

Cell["\<\
Using the second equation, we compute the factors of the solution that depend \
on d but not on n:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DFiniteTimes", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ChangeOreAlgebra", "[", 
     RowBox[{
      RowBox[{"ann2", "[", 
       RowBox[{"[", "2", "]"}], "]"}], ",", 
      RowBox[{"OreAlgebra", "[", 
       RowBox[{"S", "[", "d", "]"}], "]"}]}], "]"}], "}"}], ",", 
   RowBox[{"Annihilator", "[", 
    RowBox[{
     RowBox[{"1", "/", "sol1"}], ",", 
     RowBox[{"S", "[", "d", "]"}]}], "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"d", 
    SubscriptBox["S", "d"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "2"}], "+", 
     RowBox[{"4", " ", "d"}], "-", 
     RowBox[{"4", " ", "k"}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"RSolve", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"ApplyOreOperator", "[", 
      RowBox[{
       RowBox[{"First", "[", "%", "]"}], ",", 
       RowBox[{"f", "[", "d", "]"}]}], "]"}], "\[Equal]", "0"}], ",", 
    RowBox[{"f", "[", "d", "]"}], ",", "d"}], "]"}], "[", 
  RowBox[{"[", 
   RowBox[{"1", ",", "1", ",", "2"}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"-", "4"}], ")"}], 
    RowBox[{
     RowBox[{"-", "1"}], "+", "d"}]], " ", 
   RowBox[{"C", "[", "1", "]"}], " ", 
   RowBox[{"Pochhammer", "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "-", "k"}], ",", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "d"}]}], "]"}]}], 
  RowBox[{"Pochhammer", "[", 
   RowBox[{"1", ",", 
    RowBox[{
     RowBox[{"-", "1"}], "+", "d"}]}], "]"}]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sol2", "=", 
  RowBox[{"sol1", "*", 
   RowBox[{"%", "/", 
    RowBox[{"C", "[", "1", "]"}]}]}]}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"-", "4"}], ")"}], 
    RowBox[{
     RowBox[{"-", "1"}], "+", "d"}]], " ", 
   RowBox[{"Pochhammer", "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "-", "k"}], ",", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "d"}]}], "]"}], " ", 
   RowBox[{"Pochhammer", "[", 
    RowBox[{
     RowBox[{"d", "-", 

Cell["\<\
We compute an inhomogeneous differential equation for this integral and \
compare it to the defining Bessel equation.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"x", "*", 
       RowBox[{
        RowBox[{"ArcSinh", "[", "x", "]"}], "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", "1"}], "]"}]}], "*", 

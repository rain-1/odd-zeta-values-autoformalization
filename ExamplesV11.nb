Cell[BoxData["True"], "Output"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Formula (19):", "Subsubsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "n"}], "*", 
       RowBox[{"BesselJ", "[", 
        RowBox[{"n", ",", "x"}], "]"}], "*", 
       RowBox[{
        RowBox[{"Subscript", "[", 
         RowBox[{"S", ",", "\"\<-1,0\>\""}], "]"}], "[", "x", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"2", "^", "n"}], "*", 
     RowBox[{
      RowBox[{"Gamma", "[", 
       RowBox[{"n", "+", 
        RowBox[{"1", "/", "2"}]}], "]"}], "/", 
      RowBox[{"Sqrt", "[", "Pi", "]"}]}], "*", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ArcSinh", "[", "x", "]"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"x", "^", "2"}]}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"n", "+", "1"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
     RowBox[{
      SuperscriptBox["x", "n"], " ", 
      TemplateBox[{"n","x"},
       "BesselJ"], " ", 
      RowBox[{
       SubscriptBox["S", "\<\"-1,0\"\>"], "(", "x", ")"}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{
      SuperscriptBox["2", "n"], " ", 
      TemplateBox[{RowBox[{"n", "+", 
          FractionBox["1", "2"]}]},
       "Gamma"], " ", 
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
       RowBox[{
        FractionBox[
         RowBox[{
          SuperscriptBox["sinh", 
           RowBox[{"-", "1"}]], "(", "x", ")"}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", "+", 
            SuperscriptBox["x", "2"]}], ")"}], 
          RowBox[{"n", "+", "1"}]]], 
        RowBox[{"\[DifferentialD]", "x"}]}]}]}], 
     SqrtBox["\[Pi]"]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["A recurrence for the right-hand side is readily derived:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"2", "^", "n"}], "*", 
    RowBox[{
     RowBox[{"Gamma", "[", 
      RowBox[{"n", "+", 
       RowBox[{"1", "/", "2"}]}], "]"}], "/", 
     RowBox[{"Sqrt", "[", "Pi", "]"}]}], "*", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ArcSinh", "[", "x", "]"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"x", "^", "2"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"n", "+", "1"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], ",", 
   RowBox[{"S", "[", "n", "]"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"n", "\[GreaterEqual]", "0"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"4", "+", 
     RowBox[{"2", " ", "n"}]}], ")", 
    SubsuperscriptBox["S", "n", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "11"}], "-", 
     RowBox[{"18", " ", "n"}], "-", 
     RowBox[{"8", " ", 
      SuperscriptBox["n", "2"]}]}], ")", 
    SubscriptBox["S", "n"]}], "+", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"6", " ", "n"}], "+", 
     RowBox[{"12", " ", 
      SuperscriptBox["n", "2"]}], "+", 
     RowBox[{"8", " ", 
      SuperscriptBox["n", "3"]}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],

Cell[TextData[{
 "For the left-hand side we have to do the calculation in several steps. \
First we write down an annihilating ideal for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "0"}]], "(", "x", ")"}], TraditionalForm]]],
 " by homogenizing the above Bessel equation. Then use closure properties to \
get an annihilating ideal for the whole integrand."
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"annLommel", "=", 
  RowBox[{"ToOrePolynomial", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"S", "[", "n", "]"}], "-", "1"}], ",", 
      RowBox[{
       RowBox[{"Der", "[", "x", "]"}], "**", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "^", "2"}], "*", 
          RowBox[{
           RowBox[{"Der", "[", "x", "]"}], "^", "2"}]}], "+", 
         RowBox[{"x", "*", 
          RowBox[{"Der", "[", "x", "]"}]}], "+", 
         RowBox[{"x", "^", "2"}]}], ")"}]}]}], "}"}], ",", 
    RowBox[{"OreAlgebra", "[", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}]}], "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SubscriptBox["S", "n"], "-", "1"}], ",", 
   RowBox[{
    RowBox[{
     SuperscriptBox["x", "2"], 
     SubsuperscriptBox["D", "x", "3"]}], "+", 
    RowBox[{
     RowBox[{"3", " ", "x"}], 
     SubsuperscriptBox["D", "x", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["x", "2"]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"2", " ", "x"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"integrand", "=", 
  RowBox[{"DFiniteTimes", "[", 
   RowBox[{
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "n"}], "*", 
       RowBox[{"BesselJ", "[", 
        RowBox[{"n", ",", "x"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Der", "[", "x", "]"}], ",", 
        RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}], ",", "annLommel"}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SubsuperscriptBox["S", "n", "2"], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "-", 
      RowBox[{"2", " ", "n"}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    SuperscriptBox["x", "2"]}], ",", 
   RowBox[{
    RowBox[{
     SuperscriptBox["x", "3"], 
     SubsuperscriptBox["D", "x", "3"]}], "+", 
    RowBox[{
     RowBox[{"3", " ", 
      SuperscriptBox["x", "2"]}], 
     SubsuperscriptBox["D", "x", "2"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"3", " ", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"6", " ", "n", " ", 
       SuperscriptBox["x", "2"]}]}], ")", 
     SubsuperscriptBox["D", "x", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"3", " ", "x"}], "-", 
      RowBox[{"6", " ", "n", " ", "x"}]}], ")", 
     SubscriptBox["D", "x"], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"x", "-", 
      RowBox[{"6", " ", "n", " ", "x"}], "+", 
      RowBox[{"12", " ", 
       SuperscriptBox["n", "2"], " ", "x"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["x", "3"]}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{
     RowBox[{"4", " ", 
      SuperscriptBox["n", "2"]}], 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "8"}], " ", 
       SuperscriptBox["n", "3"]}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["x", "2"]}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Finally, we peform creative telescoping. Since the Lommel function is not \
given explicitely here, we omit checking the delta part and concentrate only \
on the principal part. It agrees with the recurrence for the right-hand side \
(all this is a little bit sloppy; the \"proof\" works also only for integer \
values of n).\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"First", "[", 
  RowBox[{"CreativeTelescoping", "[", 
   RowBox[{"integrand", ",", 
    RowBox[{"Der", "[", "x", "]"}], ",", 
    RowBox[{"S", "[", "n", "]"}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"4", "+", 
     RowBox[{"2", " ", "n"}]}], ")", 
    SubsuperscriptBox["S", "n", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "11"}], "-", 
     RowBox[{"18", " ", "n"}], "-", 
     RowBox[{"8", " ", 
      SuperscriptBox["n", "2"]}]}], ")", 
    SubscriptBox["S", "n"]}], "+", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"6", " ", "n"}], "+", 
     RowBox[{"12", " ", 
      SuperscriptBox["n", "2"]}], "+", 
     RowBox[{"8", " ", 
      SuperscriptBox["n", "3"]}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Integrated Jacobi polynomials for tetrahedral p-FEM", "Subsection"],

Cell[TextData[{
 "In the paper by Beuchler/Pillwein: \"Sparse shape functions for tetrahedral \
p-FEM using integrated Jacobi polynomials\" (Computing 80(4), 2007), we find \
some formulas that can be found with HolonomicFunctions automatically. In the \
following, the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    InterpretationBox[
     SubsuperscriptBox["p", "n", "a"],
     Subsuperscript[$CellContext`p, $CellContext`n, $CellContext`a],
     Editable->False], "(", "x", ")"}], TraditionalForm]], "Output",
  CellChangeTimes->{{3.473716941076893*^9, 3.473716948931638*^9}}],
 " corresponds to the Jacobi polynomial with b=0, and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    InterpretationBox[
     SubsuperscriptBox[
      OverscriptBox["p", "\<\"\[Wedge]\"\>"], "n", "a"],
     Subsuperscript[
      Overscript[$CellContext`p, "\[Wedge]"], $CellContext`n, $CellContext`a],
     
     Editable->False], "(", "x", ")"}], TraditionalForm]], "Output",
  CellChangeTimes->{{3.473716941076893*^9, 3.473716948931638*^9}, 
    3.473717208569915*^9}],
 " denotes its integrated version. We compute an annihilating ideal for the \
latter function:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"phat", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", "x"}], ")"}], "/", "n"}], " ", 
     RowBox[{"JacobiP", "[", 
      RowBox[{
       RowBox[{"n", "-", "1"}], ",", 
       RowBox[{"a", "-", "1"}], ",", "1", ",", "x"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}], ",", 
      RowBox[{"S", "[", "a", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"2", " ", "n"}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"a", "+", 
      RowBox[{"2", " ", "n"}], "-", 
      RowBox[{"a", " ", "x"}], "-", 
      RowBox[{"2", " ", "n", " ", "x"}]}], ")", 
     SubscriptBox["S", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{"2", "-", 
      RowBox[{"2", " ", "a"}], "-", 
      RowBox[{"2", " ", "n"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", "x"}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "a"}], "-", "n"}], ")", 
     SubscriptBox["S", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "a", "+", "n"}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "a", "-", "n", "+", "x", "+", 
      RowBox[{"a", " ", "x"}], "+", 
      RowBox[{"n", " ", "x"}]}], ")", 
     SubsuperscriptBox["S", "a", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"3", " ", "a"}], "+", 
      RowBox[{"2", " ", "n"}], "-", 
      RowBox[{"a", " ", "x"}], "-", 
      RowBox[{"2", " ", "n", " ", "x"}]}], ")", 
     SubscriptBox["S", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{"2", "-", 
      RowBox[{"2", " ", "a"}], "-", 
      RowBox[{"2", " ", "n"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],


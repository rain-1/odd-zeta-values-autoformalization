Cell["\<\
4.3.2  integral representation of BesselY
(improper use of Takayama's algorithm)\
\>", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"BesselY", "[", 
     RowBox[{"n", ",", "z"}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", "2"}], "/", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"1", "/", "2"}], "-", "n"}], "]"}]}], "/", 
       RowBox[{"Gamma", "[", 
        RowBox[{"1", "/", "2"}], "]"}]}], "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"z", "/", "2"}], ")"}], "^", "n"}]}], "*", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"z", " ", "t"}], "]"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"t", "^", "2"}], "-", "1"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"n", "+", 
           RowBox[{"1", "/", "2"}]}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "1", ",", "Infinity"}], "}"}]}], "]"}]}]}], "]"}], 
  "]"}]], "Input"],


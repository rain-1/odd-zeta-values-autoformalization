Cell[BoxData[
 RowBox[{"CreativeTelescoping", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ChebyshevT", "[", 
     RowBox[{"n", ",", 
      RowBox[{"1", "-", 
       RowBox[{
        RowBox[{"x", "^", "2"}], " ", "y"}]}]}], "]"}], "/", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"1", "-", 
      RowBox[{"x", "^", "2"}]}], "]"}]}], ",", 
   RowBox[{"Der", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "n", "]"}], ",", 
     RowBox[{"Der", "[", "y", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", "n"}], "+", 
        RowBox[{"2", " ", 
         SuperscriptBox["n", "2"]}]}], ")", 
       SubscriptBox["S", "n"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], " ", "y"}], "-", 
        RowBox[{"4", " ", "n", " ", "y"}], "+", 
        SuperscriptBox["y", "2"], "+", 
        RowBox[{"2", " ", "n", " ", 
         SuperscriptBox["y", "2"]}]}], ")", 
       SubscriptBox["D", "y"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], " ", "n"}], "-", 
        RowBox[{"2", " ", 
         SuperscriptBox["n", "2"]}], "+", 
        RowBox[{"n", " ", "y"}], "+", 
        RowBox[{"2", " ", 
         SuperscriptBox["n", "2"], " ", "y"}]}], ")"}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], " ", "y"}], "+", 
        SuperscriptBox["y", "2"]}], ")", 
       SubsuperscriptBox["D", "y", "2"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "2"}], "+", "y"}], ")", 
       SubscriptBox["D", "y"]}], "-", 
      SuperscriptBox["n", "2"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"y", " ", 
         RowBox[{"(", 
          RowBox[{"2", "-", 
           RowBox[{"2", " ", 
            SuperscriptBox["x", "2"]}], "-", 
           RowBox[{
            SuperscriptBox["x", "2"], " ", "y"}], "+", 
           RowBox[{
            SuperscriptBox["x", "4"], " ", "y"}]}], ")"}]}], "x"], 
       SubscriptBox["D", "y"]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "n"}], " ", "x"}], "+", 
         RowBox[{"n", " ", 
          SuperscriptBox["x", "3"]}]}], ")"}], " ", "y"}]}], ",", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"-", "1"}], "+", 
        SuperscriptBox["x", "2"]}], "x"], 
      SubscriptBox["D", "y"]}]}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["We can check by hand that the delta parts vanish...", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Limit", "[", 
      RowBox[{"#", ",", 
       RowBox[{"x", "\[Rule]", "1"}]}], "]"}], "-", 
     RowBox[{"Limit", "[", 
      RowBox[{"#", ",", 
       RowBox[{"x", "\[Rule]", 
        RowBox[{"-", "1"}]}]}], "]"}]}], ")"}], "&"}], "[", 
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{
    RowBox[{"Last", "[", "%", "]"}], ",", 
    RowBox[{
     RowBox[{"ChebyshevT", "[", 
      RowBox[{"n", ",", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"x", "^", "2"}], " ", "y"}]}]}], "]"}], "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       RowBox[{"x", "^", "2"}]}], "]"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0"}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
... or we can just use the command Annihilator, that does all these steps \
automatically:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ChebyshevT", "[", 
       RowBox[{"n", ",", 
        RowBox[{"1", "-", 
         RowBox[{
          RowBox[{"x", "^", "2"}], " ", "y"}]}]}], "]"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "-", 
        RowBox[{"x", "^", "2"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "n", "]"}], ",", 
     RowBox[{"Der", "[", "y", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "n"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "y"}], "-", 
      RowBox[{"4", " ", "n", " ", "y"}], "+", 
      SuperscriptBox["y", "2"], "+", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["y", "2"]}]}], ")", 
     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "n"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}], "+", 
      RowBox[{"n", " ", "y"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"], " ", "y"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "y"}], "+", 
      SuperscriptBox["y", "2"]}], ")", 
     SubsuperscriptBox["D", "y", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "+", "y"}], ")", 
     SubscriptBox["D", "y"]}], "-", 
    SuperscriptBox["n", "2"]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["Now the right-hand side:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Pi", "/", "2"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"LegendreP", "[", 
       RowBox[{"n", ",", 
        RowBox[{"1", "-", "y"}]}], "]"}], "+", 
      RowBox[{"LegendreP", "[", 
       RowBox[{
        RowBox[{"n", "-", "1"}], ",", 
        RowBox[{"1", "-", "y"}]}], "]"}]}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "n", "]"}], ",", 

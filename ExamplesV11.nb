Cell[TextData[{
 "Performing the obvious substitution u=cos(x) helps. Further we replace \
cos(t)=c (in order to prevent ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to do any simplification), and obtain the identity"
}], "Text"],


  RowBox[{"Plus", "@@", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"expr", "/.", 
      RowBox[{"k", "\[Rule]", "kk"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"kk", ",", "a", ",", "b"}], "}"}]}], "]"}]}]}]], "Input"],


 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ApplyOreOperator", "[", 
     RowBox[{
      RowBox[{"UnderTheStaircase", "[", "ann", "]"}], ",", "mollsol"}], "]"}],

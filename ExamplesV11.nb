         RowBox[{"b", " ", "n", " ", "x"}]}], ")"}]}]}]}], "}"}]}], 
  "}"}]], "Output"]
}, Open  ]],

Cell["\<\
The problem that arises here is that BesselJ[n,x] is asymptotically \
equivalent with Sqrt[2/(\[Pi]x)] for x\[RightArrow]\[Infinity]  (see, e.g., \
9.2.1 in Abramowitz/Stegun). This means that already with the delta part of \
the first relation, -x, we get into troubles, because x*Bessel*Bessel does \
not tend to zero:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"x", "*", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"3", ",", "x"}], "]"}], "*", 
    RowBox[{"BesselJ", "[", 
     RowBox[{"4", ",", "x"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1000"}], "}"}]}], "]"}]], "Input"],


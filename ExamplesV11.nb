      RowBox[{
       RowBox[{"-", "2"}], " ", "m"}], "-", "n"}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", "n"}], ")", 
     SubsuperscriptBox["S", "n", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "x"}], "-", 
      RowBox[{"2", " ", "m", " ", "x"}], "-", 
      RowBox[{"2", " ", "n", " ", "x"}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "m"}], "+", "n"}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
First solution: We simply take the recurrence and verify that it lies in the \
left ideal ann:\
\>", "Text"],


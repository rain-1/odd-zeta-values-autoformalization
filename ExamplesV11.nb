         RowBox[{
          RowBox[{"-", "567"}], " ", "x"}], "-", 
         RowBox[{"1332", " ", "k", " ", "x"}], "-", 
         RowBox[{"1164", " ", 
          SuperscriptBox["k", "2"], " ", "x"}], "-", 
         RowBox[{"448", " ", 
          SuperscriptBox["k", "3"], " ", "x"}], "-", 
         RowBox[{"64", " ", 
          SuperscriptBox["k", "4"], " ", "x"}], "+", 
         RowBox[{"1512", " ", 
          SuperscriptBox["x", "3"]}], "+", 
         RowBox[{"3678", " ", "k", " ", 
          SuperscriptBox["x", "3"]}], "+", 
         RowBox[{"3316", " ", 
          SuperscriptBox["k", "2"], " ", 
          SuperscriptBox["x", "3"]}], "+", 
         RowBox[{"1312", " ", 
          SuperscriptBox["k", "3"], " ", 
          SuperscriptBox["x", "3"]}], "+", 
         RowBox[{"192", " ", 
          SuperscriptBox["k", "4"], " ", 
          SuperscriptBox["x", "3"]}], "-", 
         RowBox[{"945", " ", 
          SuperscriptBox["x", "5"]}], "-", 
         RowBox[{"2346", " ", "k", " ", 
          SuperscriptBox["x", "5"]}], "-", 
         RowBox[{"2152", " ", 
          SuperscriptBox["k", "2"], " ", 
          SuperscriptBox["x", "5"]}], "-", 
         RowBox[{"864", " ", 
          SuperscriptBox["k", "3"], " ", 
          SuperscriptBox["x", "5"]}], "-", 
         RowBox[{"128", " ", 
          SuperscriptBox["k", "4"], " ", 
          SuperscriptBox["x", "5"]}]}], ")"}]}]}], "}"}], "}"}]}], 
  "}"}]], "Output"]
}, Open  ]],

Cell["But again, no inhomogeneous part arises.", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{"deltas", ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"LegendreP", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"2", "k"}], "+", "1"}], ",", "x"}], "]"}], "/", "x"}], 
      ")"}], "^", "2"}]}], "]"}], "//", "Simplify"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"4", " ", "x"}]], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"63", "+", 
      RowBox[{"64", " ", "k"}], "+", 
      RowBox[{"16", " ", 
       SuperscriptBox["k", "2"]}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["x", "2"]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"8", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", "k"}], ")"}], "2"], " ", 
       SuperscriptBox[
        RowBox[{"LegendreP", "[", 
         RowBox[{
          RowBox[{"1", "+", 
           RowBox[{"2", " ", "k"}]}], ",", "x"}], "]"}], "2"]}], "-", 
      RowBox[{"4", " ", 
       RowBox[{"(", 
        RowBox[{"5", "+", 
         RowBox[{"9", " ", "k"}], "+", 
         RowBox[{"4", " ", 
          SuperscriptBox["k", "2"]}]}], ")"}], " ", "x", " ", 
       RowBox[{"LegendreP", "[", 
        RowBox[{
         RowBox[{"1", "+", 
          RowBox[{"2", " ", "k"}]}], ",", "x"}], "]"}], " ", 
       RowBox[{"LegendreP", "[", 
        RowBox[{
         RowBox[{"2", "+", 
          RowBox[{"2", " ", "k"}]}], ",", "x"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "23"}], "+", 
         RowBox[{"35", " ", 
          SuperscriptBox["x", "2"]}], "+", 
         RowBox[{"8", " ", 
          SuperscriptBox["k", "2"], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{"2", " ", 
             SuperscriptBox["x", "2"]}]}], ")"}]}], "+", 
         RowBox[{"4", " ", "k", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "7"}], "+", 
            RowBox[{"12", " ", 
             SuperscriptBox["x", "2"]}]}], ")"}]}]}], ")"}], " ", 
       SuperscriptBox[
        RowBox[{"LegendreP", "[", 
         RowBox[{
          RowBox[{"3", "+", 
           RowBox[{"2", " ", "k"}]}], ",", "x"}], "]"}], "2"]}]}], ")"}]}]}], 
  "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{"%", "/.", 
    RowBox[{"x", "\[Rule]", "1"}]}], ")"}], "-", 
  RowBox[{"(", 
   RowBox[{"%", "/.", 
    RowBox[{"x", "\[Rule]", 
     RowBox[{"-", "1"}]}]}], ")"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "0", "}"}]], "Output"]
}, Open  ]],

Cell["\<\
The recurrence obtained by Takayama is of order 2 and is a multiple of the \
one computed by Chyzak's algorithm.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OreReduce", "[", 
  RowBox[{"tak", ",", 
   RowBox[{"Annihilator", "[", 
    RowBox[{"1", ",", 
     RowBox[{"S", "[", "k", "]"}]}], "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "0", "}"}]], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["with Zeilberger's slow algorithm (elimination by ansatz)", \
"Subsubsection"],

Cell["\<\
The command FindRelation can be used to compute an operator in the left ideal \
ann that is free of x. The methods used in FindRelation are ansatz ans \
coefficient comparison. Since the resulting operator is of considerable size, \
the computation takes a while.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Timing", "[", 
  RowBox[{
   RowBox[{"rel", "=", 
    RowBox[{"First", "[", 
     RowBox[{"FindRelation", "[", 
      RowBox[{"ann", ",", 
       RowBox[{"Eliminate", "\[Rule]", "x"}]}], "]"}], "]"}]}], ";"}], 
  "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"53.536`", ",", "Null"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ByteCount", "[", "rel", "]"}]], "Input"],

Cell[BoxData["140848"], "Output"]
}, Open  ]],

Cell["\<\
By substituting Der[x] \[RightArrow] 0, we obtain the principal part. it is a \
recurrence of order 7, that again is a multiple of the minimal recurrence \
computed above:\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"pp", "=", 
   RowBox[{"OrePolynomialSubstitute", "[", 
    RowBox[{"rel", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Der", "[", "x", "]"}], "\[Rule]", "0"}], "}"}]}], "]"}]}], 
  ";"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Support", "[", "pp", "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SubsuperscriptBox["S", "k", "7"], ",", 
   SubsuperscriptBox["S", "k", "6"], ",", 
   SubsuperscriptBox["S", "k", "5"], ",", 
   SubsuperscriptBox["S", "k", "4"], ",", 
   SubsuperscriptBox["S", "k", "3"], ",", 
   SubsuperscriptBox["S", "k", "2"], ",", 
   SubscriptBox["S", "k"]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OreReduce", "[", 
  RowBox[{"pp", ",", 
   RowBox[{"Annihilator", "[", 
    RowBox[{"1", ",", 
     RowBox[{"S", "[", "k", "]"}]}], "]"}]}], "]"}]], "Input"],

Cell[BoxData["0"], "Output"]
}, Open  ]],

Cell[TextData[{
 "The delta part is obtained by subtracting the principal part from the \
original relation and divide it by Der[x]. This division cannot be done in an \
Ore algebra. That's why we switch to standard ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " polynomials for this step."
}], "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"delta", "=", 
   RowBox[{"Together", "[", 
    RowBox[{
     RowBox[{"1", "/", 
      RowBox[{"Der", "[", "x", "]"}]}], "*", 
     RowBox[{"Normal", "[", 
      RowBox[{"ChangeOreAlgebra", "[", 
       RowBox[{
        RowBox[{"rel", "-", "pp"}], ",", 
        RowBox[{"OreAlgebra", "[", 
         RowBox[{
          RowBox[{"Der", "[", "x", "]"}], ",", "x", ",", 
          RowBox[{"S", "[", "k", "]"}]}], "]"}]}], "]"}], "]"}]}], "]"}]}], 
  ";"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PolynomialQ", "[", 
  RowBox[{"delta", ",", 
   RowBox[{"Der", "[", "x", "]"}]}], "]"}]], "Input"],

Cell[BoxData["True"], "Output"]
}, Open  ]],

Cell["\<\
For the subsequent computations, it is of advantage to bring the delta part \
to normal form with respect to the annihilator ann. Then it is again seen \
that the delta part vanishes at the integration bounds (and hence the \
principal part computed above is a recurrence for the integral).\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"delta", "=", 
   RowBox[{"OreReduce", "[", 
    RowBox[{"delta", ",", 
     RowBox[{"Together", "[", "ann", "]"}]}], "]"}]}], ";"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Together", "[", 
   RowBox[{"ApplyOreOperator", "[", 
    RowBox[{"delta", ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"LegendreP", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"2", "k"}], "+", "1"}], ",", "x"}], "]"}], "/", "x"}], 
       ")"}], "^", "2"}]}], "]"}], "]"}], "/.", 
  RowBox[{"x", "\[Rule]", "1"}]}]], "Input"],

Cell[BoxData["0"], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Together", "[", 
     RowBox[{"ApplyOreOperator", "[", 
      RowBox[{"delta", ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"LegendreP", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", "k"}], "+", "1"}], ",", "x"}], "]"}], "/", "x"}], 
         ")"}], "^", "2"}]}], "]"}], "]"}], "/.", 
    RowBox[{"x", "\[Rule]", 
     RowBox[{"-", "1"}]}]}], ",", 
   RowBox[{"Element", "[", 
    RowBox[{"k", ",", "Integers"}], "]"}]}], "]"}]], "Input"],

Cell[BoxData["0"], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
with Zeilberger's slow algorithm (elimination by Gr\[ODoubleDot]bner bases)\
\>", "Subsubsection"],

Cell["\<\
The elimination of the indeterminate x with Gr\[ODoubleDot]bner bases does \
not work very well in this instance. The computation takes extremely long, \
and the recurrence that we obtain is of order 8 even.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TimeConstrained", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"gb", "=", 
     RowBox[{"OreGroebnerBasis", "[", 
      RowBox[{"ann", ",", 
       RowBox[{"OreAlgebra", "[", 
        RowBox[{"x", ",", 
         RowBox[{"Der", "[", "x", "]"}], ",", 
         RowBox[{"S", "[", "k", "]"}]}], "]"}], ",", 
       RowBox[{"MonomialOrder", "\[Rule]", 
        RowBox[{"EliminationOrder", "[", "1", "]"}]}]}], "]"}]}], ";"}], ",", 
   "60"}], "]"}]], "Input"],

Cell[BoxData["$Aborted"], "Output"]
}, Open  ]],

Cell["\<\
With different options we can get at least some result, but still need a \
considerable amount of time. The option Incomplete \[RightArrow] True has the \
effect that the Gr\[ODoubleDot]bner basis computation is interrupted as soon \
as an x-free element is found, and this element is returned. The method \
\"elimination\" is a greedy strategy towards an x-free operator, in the sense \
that always a pair is chosen whose S-polynomial has the least degree in x.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Timing", "[", 
  RowBox[{
   RowBox[{"xfree", "=", 
    RowBox[{"OreGroebnerBasis", "[", 
     RowBox[{"ann", ",", 
      RowBox[{"OreAlgebra", "[", 
       RowBox[{"x", ",", 
        RowBox[{"Der", "[", "x", "]"}], ",", 
        RowBox[{"S", "[", "k", "]"}]}], "]"}], ",", 
      RowBox[{"MonomialOrder", "\[Rule]", 
       RowBox[{"EliminationOrder", "[", "1", "]"}]}], ",", 
      RowBox[{"Method", "\[Rule]", "\"\<elimination\>\""}], ",", 
      RowBox[{"Incomplete", "\[Rule]", "True"}]}], "]"}]}], ";"}], 
  "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"2430.24`", ",", "Null"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ByteCount", "[", "xfree", "]"}]], "Input"],

Cell[BoxData["22832816"], "Output"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"pp", "=", 
   RowBox[{"OrePolynomialSubstitute", "[", 
    RowBox[{"xfree", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Der", "[", "x", "]"}], "\[Rule]", "0"}], "}"}]}], "]"}]}], 
  ";"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Support", "[", "pp", "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    SubsuperscriptBox["S", "k", "11"], ",", 
    SubsuperscriptBox["S", "k", "10"], ",", 
    SubsuperscriptBox["S", "k", "9"], ",", 
    SubsuperscriptBox["S", "k", "8"], ",", 
    SubsuperscriptBox["S", "k", "7"], ",", 
    SubsuperscriptBox["S", "k", "6"], ",", 
    SubsuperscriptBox["S", "k", "5"], ",", 
    SubsuperscriptBox["S", "k", "4"], ",", 
    SubsuperscriptBox["S", "k", "3"], ",", 
    SubsuperscriptBox["S", "k", "2"], ",", 
    SubscriptBox["S", "k"]}], "}"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OreReduce", "[", 
  RowBox[{"pp", ",", 
   RowBox[{"Annihilator", "[", 
    RowBox[{"1", ",", 
     RowBox[{"S", "[", "k", "]"}]}], "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "0", "}"}]], "Output"]
}, Open  ]]
}, Closed]]
}, Closed]],

Cell[CellGroupData[{

Cell["Contiguous Relations for 2F1", "Subsection"],

Cell["\<\
We want to find all contiguous relations for the hypergeometric 2F1 function. \
We consider all relation between the function itself and two of its immediate \
neighbours, i.e., where one of the parameters a,b,c is decreased or increased \
by one. The possible combinations are (where we eliminated negative shifts):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"supps", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"NormalizeVector", "[", 
     RowBox[{"Append", "[", 
      RowBox[{"#", ",", "1"}], "]"}], "]"}], "&"}], "/@", 
   RowBox[{"Subsets", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"S", "[", "a", "]"}], ",", 
       RowBox[{"1", "/", 
        RowBox[{"S", "[", "a", "]"}]}], ",", 
       RowBox[{"S", "[", "b", "]"}], ",", 
       RowBox[{"1", "/", 
        RowBox[{"S", "[", "b", "]"}]}], ",", 
       RowBox[{"S", "[", "c", "]"}], ",", 
       RowBox[{"1", "/", 
        RowBox[{"S", "[", "c", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", "2", "}"}]}], "]"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"S", "[", "a", "]"}], "2"], ",", "1", ",", 
     RowBox[{"S", "[", "a", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "a", "]"}], ",", 
     RowBox[{"S", "[", "b", "]"}], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], " ", 
      RowBox[{"S", "[", "b", "]"}]}], ",", "1", ",", 
     RowBox[{"S", "[", "b", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "a", "]"}], ",", 
     RowBox[{"S", "[", "c", "]"}], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], " ", 
      RowBox[{"S", "[", "c", "]"}]}], ",", "1", ",", 
     RowBox[{"S", "[", "c", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", 
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], " ", 
      RowBox[{"S", "[", "b", "]"}]}], ",", 
     RowBox[{"S", "[", "a", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "b", "]"}], ",", 
     RowBox[{"S", "[", "a", "]"}], ",", 
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], " ", 
      RowBox[{"S", "[", "b", "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", 
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], " ", 
      RowBox[{"S", "[", "c", "]"}]}], ",", 
     RowBox[{"S", "[", "a", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "c", "]"}], ",", 
     RowBox[{"S", "[", "a", "]"}], ",", 
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], " ", 
      RowBox[{"S", "[", "c", "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"S", "[", "b", "]"}], "2"], ",", "1", ",", 
     RowBox[{"S", "[", "b", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "b", "]"}], ",", 
     RowBox[{"S", "[", "c", "]"}], ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "[", "b", "]"}], " ", 
      RowBox[{"S", "[", "c", "]"}]}], ",", "1", ",", 
     RowBox[{"S", "[", "c", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", 
     RowBox[{
      RowBox[{"S", "[", "b", "]"}], " ", 
      RowBox[{"S", "[", "c", "]"}]}], ",", 
     RowBox[{"S", "[", "b", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "c", "]"}], ",", 
     RowBox[{"S", "[", "b", "]"}], ",", 
     RowBox[{
      RowBox[{"S", "[", "b", "]"}], " ", 
      RowBox[{"S", "[", "c", "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"S", "[", "c", "]"}], "2"], ",", "1", ",", 
     RowBox[{"S", "[", "c", "]"}]}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Next we compute an annihilating ideal of 2F1 with respect to the shifts \
operators in question.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Hypergeometric2F1", "[", 
     RowBox[{"a", ",", "b", ",", "c", ",", "x"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], ",", 
      RowBox[{"S", "[", "b", "]"}], ",", 
      RowBox[{"S", "[", "c", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "b"}], " ", "c"}], "+", 
      RowBox[{"b", " ", "c", " ", "x"}]}], ")", 
     SubscriptBox["S", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b", " ", "x"}], "-", 
      RowBox[{"a", " ", "c", " ", "x"}], "-", 
      RowBox[{"b", " ", "c", " ", "x"}], "+", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "x"}]}], ")", 
     SubscriptBox["S", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"b", " ", "c"}], "+", 
      RowBox[{"a", " ", "c", " ", "x"}], "-", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "x"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "a"}], " ", "c"}], "+", 
      RowBox[{"a", " ", "c", " ", "x"}]}], ")", 
     SubscriptBox["S", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b", " ", "x"}], "-", 
      RowBox[{"a", " ", "c", " ", "x"}], "-", 
      RowBox[{"b", " ", "c", " ", "x"}], "+", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "x"}]}], ")", 
     SubscriptBox["S", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "c"}], "+", 
      RowBox[{"b", " ", "c", " ", "x"}], "-", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "x"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "-", 
      RowBox[{"a", " ", "x"}], "-", 
      RowBox[{"b", " ", "x"}], "+", 
      RowBox[{"a", " ", "b", " ", "x"}], "+", 
      RowBox[{"2", " ", "c", " ", "x"}], "-", 
      RowBox[{"a", " ", "c", " ", "x"}], "-", 
      RowBox[{"b", " ", "c", " ", "x"}], "+", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "x"}]}], ")", 
     SubsuperscriptBox["S", "c", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"c", "+", 
      SuperscriptBox["c", "2"], "-", "x", "+", 
      RowBox[{"a", " ", "x"}], "+", 
      RowBox[{"b", " ", "x"}], "-", 
      RowBox[{"3", " ", "c", " ", "x"}], "+", 
      RowBox[{"a", " ", "c", " ", "x"}], "+", 
      RowBox[{"b", " ", "c", " ", "x"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["c", "2"], " ", "x"}]}], ")", 
     SubscriptBox["S", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "c"}], "-", 
      SuperscriptBox["c", "2"], "+", 
      RowBox[{"c", " ", "x"}], "+", 
      RowBox[{
       SuperscriptBox["c", "2"], " ", "x"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],


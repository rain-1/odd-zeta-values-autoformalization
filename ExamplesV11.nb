Cell["Gradshteyn / Ryzhik", "Section"],

Cell[CellGroupData[{

Cell[TextData[{
 "2.148   ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Integral]", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["x", "2"]}], ")"}], "n"]], 
     RowBox[{"\[DifferentialD]", "x"}]}]}], TraditionalForm]], "Output",
  CellChangeTimes->{3.464548047044811*^9}]
}], "Subsection"],

Cell["(p. 77) Formula 3 is stated as follows:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"x", "^", "2"}]}], ")"}], "^", "n"}]}], ",", "x"}], "]"}], 
    "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "n"}], "-", "2"}], ")"}]}], "*", 
      RowBox[{"x", "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"x", "^", "2"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}]}]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "n"}], "-", "3"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "n"}], "-", "2"}], ")"}]}], "*", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"x", "^", "2"}]}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"n", "-", "1"}], ")"}]}]}], ",", "x"}], "]"}]}]}]}], "]"}],
   "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{"\[Integral]", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["x", "2"]}], ")"}], "n"]], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     FractionBox["x", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", "n"}], "-", "2"}], ")"}], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["x", "2"]}], ")"}], 
        RowBox[{"n", "-", "1"}]]}]], "+", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", "n"}], "-", "3"}], ")"}], " ", 
       RowBox[{"\[Integral]", 
        RowBox[{
         FractionBox["1", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"1", "+", 
             SuperscriptBox["x", "2"]}], ")"}], 
           RowBox[{"n", "-", "1"}]]], 
         RowBox[{"\[DifferentialD]", "x"}]}]}]}], 
      RowBox[{
       RowBox[{"2", " ", "n"}], "-", "2"}]]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["A slight rewriting gives", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"2", "n", "*", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"x", "^", "2"}]}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"n", "+", "1"}], ")"}]}]}], ",", "x"}], "]"}]}], "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "n"}], "-", "1"}], ")"}], "*", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"x", "^", "2"}]}], ")"}], "^", "n"}]}], ",", "x"}], 
       "]"}]}]}], "\[Equal]", 
    RowBox[{"x", "/", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"x", "^", "2"}]}], ")"}], "^", "n"}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     RowBox[{"2", " ", "n", " ", 
      RowBox[{"\[Integral]", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", "+", 
            SuperscriptBox["x", "2"]}], ")"}], 
          RowBox[{"n", "+", "1"}]]], 
        RowBox[{"\[DifferentialD]", "x"}]}]}]}], "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", "n"}], "-", "1"}], ")"}], " ", 
      RowBox[{"\[Integral]", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", "+", 
            SuperscriptBox["x", "2"]}], ")"}], "n"]], 
        RowBox[{"\[DifferentialD]", "x"}]}]}]}]}], "\[LongEqual]", 
    FractionBox["x", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "+", 
        SuperscriptBox["x", "2"]}], ")"}], "n"]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
We homogenize this recurrence by multiplying an annihilating operator for the \
inhomogeneous part to the operator on the left-hand side.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"First", "[", 
   RowBox[{"Annihilator", "[", 
    RowBox[{
     RowBox[{"x", "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"x", "^", "2"}]}], ")"}], "^", "n"}]}], ",", 
     RowBox[{"S", "[", "n", "]"}]}], "]"}], "]"}], "**", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"2", "n"}], ")"}], "**", 
     RowBox[{"S", "[", "n", "]"}]}], "-", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", "n"}], "-", "1"}], ")"}]}], ")"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{"2", "+", 
    RowBox[{"2", " ", "n"}], "+", 
    RowBox[{"2", " ", 
     SuperscriptBox["x", "2"]}], "+", 
    RowBox[{"2", " ", "n", " ", 
     SuperscriptBox["x", "2"]}]}], ")", 
   SubsuperscriptBox["S", "n", "2"]}], "+", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "1"}], "-", 
    RowBox[{"4", " ", "n"}], "-", 
    SuperscriptBox["x", "2"], "-", 
    RowBox[{"2", " ", "n", " ", 
     SuperscriptBox["x", "2"]}]}], ")", 
   SubscriptBox["S", "n"]}], "+", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "1"}], "+", 
    RowBox[{"2", " ", "n"}]}], ")"}]}]], "Output"]
}, Open  ]],

Cell["\<\
The recurrence that we directly obtain for the indefinite integral matches \
exactly:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"1", "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"x", "^", "2"}]}], ")"}], "^", "n"}]}], ",", "x"}], "]"}], 
   ",", 
   RowBox[{"S", "[", "n", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "2"}], "-", 
     RowBox[{"2", " ", "n"}], "-", 
     RowBox[{"2", " ", 
      SuperscriptBox["x", "2"]}], "-", 
     RowBox[{"2", " ", "n", " ", 
      SuperscriptBox["x", "2"]}]}], ")", 
    SubsuperscriptBox["S", "n", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"4", " ", "n"}], "+", 
     SuperscriptBox["x", "2"], "+", 
     RowBox[{"2", " ", "n", " ", 
      SuperscriptBox["x", "2"]}]}], ")", 
    SubscriptBox["S", "n"]}], "+", 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     RowBox[{"2", " ", "n"}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Formula 4 just unwinds the above inhomogeneous recurrence. However, it can be \
proven separately, too.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"x", "^", "2"}]}], ")"}], "^", "n"}]}], ",", "x"}], "]"}], 
    "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "n"}], "-", "1"}], ")"}]}], "*", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Product", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"2", "n"}], "-", 
              RowBox[{"2", "i"}], "+", "1"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "k"}], "}"}]}], "]"}], "/", 
           RowBox[{"2", "^", "k"}]}], "/", 
          RowBox[{"Product", "[", 
           RowBox[{
            RowBox[{"n", "-", "i"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "k"}], "}"}]}], "]"}]}], "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"x", "^", "2"}]}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"n", "-", "k"}], ")"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Factorial2", "[", 
         RowBox[{
          RowBox[{"2", "n"}], "-", "3"}], "]"}], "/", 
        RowBox[{"2", "^", 
         RowBox[{"(", 
          RowBox[{"n", "-", "1"}], ")"}]}]}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "!"}]}], "*", 
      RowBox[{"ArcTan", "[", "x", "]"}]}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{"\[Integral]", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["x", "2"]}], ")"}], "n"]], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     FractionBox[
      RowBox[{"x", " ", 
       RowBox[{
        UnderoverscriptBox["\[Sum]", "k", 
         RowBox[{"n", "-", "1"}]], 
        FractionBox[
         RowBox[{
          UnderoverscriptBox["\[Product]", "i", "k"], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", " ", "n"}], "-", 
            RowBox[{"2", " ", "i"}], "+", "1"}], ")"}]}], 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["2", "k"], " ", 
            RowBox[{
             UnderoverscriptBox["\[Product]", "i", "k"], 
             RowBox[{"(", 
              RowBox[{"n", "-", "i"}], ")"}]}]}], ")"}], " ", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"1", "+", 
             SuperscriptBox["x", "2"]}], ")"}], 
           RowBox[{"n", "-", "k"}]]}]]}]}], 
      RowBox[{
       RowBox[{"2", " ", "n"}], "-", "1"}]], "+", 
     FractionBox[
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", "n"}], "-", "3"}], ")"}], "!!"}], " ", 
       RowBox[{
        SuperscriptBox["tan", 
         RowBox[{"-", "1"}]], "(", "x", ")"}]}], 
      RowBox[{
       SuperscriptBox["2", 
        RowBox[{"n", "-", "1"}]], " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "!"}]}]]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["We rewrite it into more convenient notation:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"x", "^", "2"}]}], ")"}], "^", "n"}]}], ",", "x"}], "]"}], 
    "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "n"}], "-", "1"}], ")"}]}], "*", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Pochhammer", "[", 
           RowBox[{
            RowBox[{"n", "-", "k", "+", 
             RowBox[{"1", "/", "2"}]}], ",", "k"}], "]"}], "/", 
          RowBox[{"Pochhammer", "[", 
           RowBox[{
            RowBox[{"n", "-", "k"}], ",", "k"}], "]"}]}], "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"x", "^", "2"}]}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"n", "-", "k"}], ")"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Factorial2", "[", 
         RowBox[{
          RowBox[{"2", "n"}], "-", "3"}], "]"}], "/", 
        RowBox[{"2", "^", 
         RowBox[{"(", 
          RowBox[{"n", "-", "1"}], ")"}]}]}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "!"}]}], "*", 
      RowBox[{"ArcTan", "[", "x", "]"}]}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{"\[Integral]", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["x", "2"]}], ")"}], "n"]], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     FractionBox[
      RowBox[{"x", " ", 
       RowBox[{
        UnderoverscriptBox["\[Sum]", 
         RowBox[{"k", "=", "1"}], 
         RowBox[{"n", "-", "1"}]], 
        FractionBox[
         TemplateBox[{RowBox[{"n", "-", "k", "+", 
             FractionBox["1", "2"]}],"k"},
          "Pochhammer"], 
         RowBox[{
          TemplateBox[{RowBox[{"n", "-", "k"}],"k"},
           "Pochhammer"], " ", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"1", "+", 
             SuperscriptBox["x", "2"]}], ")"}], 
           RowBox[{"n", "-", "k"}]]}]]}]}], 
      RowBox[{
       RowBox[{"2", " ", "n"}], "-", "1"}]], "+", 
     FractionBox[
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", "n"}], "-", "3"}], ")"}], "!!"}], " ", 
       RowBox[{
        SuperscriptBox["tan", 
         RowBox[{"-", "1"}]], "(", "x", ")"}]}], 
      RowBox[{
       SuperscriptBox["2", 
        RowBox[{"n", "-", "1"}]], " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "!"}]}]]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
Doing the same for the expression on the right-hand side delivers a \
recurrence of order 3 (which is not too bad; but we can do better).\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"x", "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "n"}], "-", "1"}], ")"}]}], "*", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Pochhammer", "[", 
          RowBox[{
           RowBox[{"n", "-", "k", "+", 
            RowBox[{"1", "/", "2"}]}], ",", "k"}], "]"}], "/", 
         RowBox[{"Pochhammer", "[", 
          RowBox[{
           RowBox[{"n", "-", "k"}], ",", "k"}], "]"}]}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"x", "^", "2"}]}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"n", "-", "k"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", 
         RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Factorial2", "[", 
        RowBox[{
         RowBox[{"2", "n"}], "-", "3"}], "]"}], "/", 
       RowBox[{"2", "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}]}], "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"n", "-", "1"}], ")"}], "!"}]}], "*", 
     RowBox[{"ArcTan", "[", "x", "]"}]}]}], ",", 
   RowBox[{"S", "[", "n", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"8", "+", 
     RowBox[{"12", " ", "n"}], "+", 
     RowBox[{"4", " ", 
      SuperscriptBox["n", "2"]}], "+", 
     RowBox[{"16", " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"40", " ", "n", " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"32", " ", 
      SuperscriptBox["n", "2"], " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"8", " ", 
      SuperscriptBox["n", "3"], " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"8", " ", 
      SuperscriptBox["x", "4"]}], "+", 
     RowBox[{"28", " ", "n", " ", 
      SuperscriptBox["x", "4"]}], "+", 
     RowBox[{"28", " ", 
      SuperscriptBox["n", "2"], " ", 
      SuperscriptBox["x", "4"]}], "+", 
     RowBox[{"8", " ", 
      SuperscriptBox["n", "3"], " ", 
      SuperscriptBox["x", "4"]}]}], ")", 
    SubsuperscriptBox["S", "n", "3"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "12"}], "-", 
     RowBox[{"24", " ", "n"}], "-", 
     RowBox[{"12", " ", 
      SuperscriptBox["n", "2"]}], "-", 
     RowBox[{"24", " ", 
      SuperscriptBox["x", "2"]}], "-", 
     RowBox[{"76", " ", "n", " ", 
      SuperscriptBox["x", "2"]}], "-", 
     RowBox[{"76", " ", 
      SuperscriptBox["n", "2"], " ", 
      SuperscriptBox["x", "2"]}], "-", 
     RowBox[{"24", " ", 
      SuperscriptBox["n", "3"], " ", 
      SuperscriptBox["x", "2"]}], "-", 
     RowBox[{"12", " ", 
      SuperscriptBox["x", "4"]}], "-", 
     RowBox[{"44", " ", "n", " ", 
      SuperscriptBox["x", "4"]}], "-", 
     RowBox[{"48", " ", 
      SuperscriptBox["n", "2"], " ", 
      SuperscriptBox["x", "4"]}], "-", 
     RowBox[{"16", " ", 
      SuperscriptBox["n", "3"], " ", 
      SuperscriptBox["x", "4"]}]}], ")", 
    SubsuperscriptBox["S", "n", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{"3", "+", 
     RowBox[{"12", " ", "n"}], "+", 
     RowBox[{"12", " ", 
      SuperscriptBox["n", "2"]}], "+", 
     RowBox[{"6", " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"34", " ", "n", " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"56", " ", 
      SuperscriptBox["n", "2"], " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"24", " ", 
      SuperscriptBox["n", "3"], " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"3", " ", 
      SuperscriptBox["x", "4"]}], "+", 
     RowBox[{"14", " ", "n", " ", 
      SuperscriptBox["x", "4"]}], "+", 
     RowBox[{"20", " ", 
      SuperscriptBox["n", "2"], " ", 
      SuperscriptBox["x", "4"]}], "+", 
     RowBox[{"8", " ", 
      SuperscriptBox["n", "3"], " ", 
      SuperscriptBox["x", "4"]}]}], ")", 
    SubscriptBox["S", "n"]}], "+", 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     RowBox[{"4", " ", 
      SuperscriptBox["n", "2"]}], "+", 
     RowBox[{"3", " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"2", " ", "n", " ", 
      SuperscriptBox["x", "2"]}], "-", 
     RowBox[{"12", " ", 
      SuperscriptBox["n", "2"], " ", 
      SuperscriptBox["x", "2"]}], "-", 
     RowBox[{"8", " ", 
      SuperscriptBox["n", "3"], " ", 
      SuperscriptBox["x", "2"]}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
By including the derivative w.r.t. x into the set of Ore operators, we find \
(besides mixed relations) a recurrence of order 2, that matches the one for \
the integral!\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"x", "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "n"}], "-", "1"}], ")"}]}], "*", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Pochhammer", "[", 
          RowBox[{
           RowBox[{"n", "-", "k", "+", 
            RowBox[{"1", "/", "2"}]}], ",", "k"}], "]"}], "/", 
         RowBox[{"Pochhammer", "[", 
          RowBox[{
           RowBox[{"n", "-", "k"}], ",", "k"}], "]"}]}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"x", "^", "2"}]}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"n", "-", "k"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", 
         RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Factorial2", "[", 
        RowBox[{
         RowBox[{"2", "n"}], "-", "3"}], "]"}], "/", 
       RowBox[{"2", "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}]}], "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"n", "-", "1"}], ")"}], "!"}]}], "*", 
     RowBox[{"ArcTan", "[", "x", "]"}]}]}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "n", "]"}], ",", 
     RowBox[{"Der", "[", "x", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["x", "2"]}], ")", 
     SubsuperscriptBox["D", "x", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "4"}], " ", "n"}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{
     RowBox[{"2", " ", "x"}], 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "+", 
      RowBox[{"6", " ", "n"}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["n", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "n", " ", "x"}], "+", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["x", "3"]}]}], ")", 
     SubscriptBox["S", "n"], 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "n"}], "-", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["n", "2"], " ", 
       SuperscriptBox["x", "2"]}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"x", "-", 
      RowBox[{"2", " ", "n", " ", "x"}], "+", 
      SuperscriptBox["x", "3"], "-", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["x", "3"]}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"2", " ", "n"}], "-", 
      SuperscriptBox["x", "2"], "+", 
      RowBox[{"4", " ", "n", " ", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["n", "2"], " ", 
       SuperscriptBox["x", "2"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"2", " ", "n"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["x", "2"]}]}], ")", 
     SubsuperscriptBox["S", "n", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", 
      RowBox[{"4", " ", "n"}], "-", 
      SuperscriptBox["x", "2"], "-", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["x", "2"]}]}], ")", 

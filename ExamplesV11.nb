Cell[CellGroupData[{

Cell["\<\
10.1.41 - 10.1.44  derivatives of SphericalBessel w.r.t. the first parameter\
\>", "Subsection"],

Cell["\<\
We use the following transformation rules (10.1.1, 9.1.64, 9.1.65)\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"transRules", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"SphericalBesselJ", "[", 
       RowBox[{"n_", ",", "z_"}], "]"}], "\[Rule]", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"Pi", "/", 
         RowBox[{"(", 
          RowBox[{"2", "z"}], ")"}]}], "]"}], "*", 
       RowBox[{"BesselJ", "[", 
        RowBox[{
         RowBox[{"n", "+", 
          RowBox[{"1", "/", "2"}]}], ",", "z"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"SphericalBesselY", "[", 
       RowBox[{"n_", ",", "z_"}], "]"}], "\[Rule]", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"Pi", "/", 
         RowBox[{"(", 
          RowBox[{"2", "z"}], ")"}]}], "]"}], "*", 
       RowBox[{"BesselY", "[", 
        RowBox[{
         RowBox[{"n", "+", 
          RowBox[{"1", "/", "2"}]}], ",", "z"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"1", ",", "0"}], "]"}], "[", "BesselJ", "]"}], "[", 
       RowBox[{"nu_", ",", "z_"}], "]"}], "\[Rule]", 
      RowBox[{
       RowBox[{
        RowBox[{"BesselJ", "[", 
         RowBox[{"nu", ",", "z"}], "]"}], "*", 
        RowBox[{"Log", "[", 
         RowBox[{"z", "/", "2"}], "]"}]}], "-", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"z", "/", "2"}], ")"}], "^", "nu"}], "*", 
        RowBox[{"Hold", "[", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "^", "k"}], "*", 
            RowBox[{"PolyGamma", "[", 
             RowBox[{"nu", "+", "k", "+", "1"}], "]"}], "*", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"z", "^", "2"}], "/", "4"}], ")"}], "^", "k"}], "/", 
              
              RowBox[{"Gamma", "[", 
               RowBox[{"nu", "+", "k", "+", "1"}], "]"}]}], "/", 
             RowBox[{"k", "!"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], 
         "]"}]}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"1", ",", "0"}], "]"}], "[", "BesselY", "]"}], "[", 
       RowBox[{"arg_", ",", "z_"}], "]"}], "\[RuleDelayed]", 
      RowBox[{
       RowBox[{
        RowBox[{"Cot", "[", 
         RowBox[{"arg", "*", "Pi"}], "]"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"BesselJ", "[", 
             RowBox[{"arg", ",", "z"}], "]"}], ",", "nu"}], "]"}], "-", 
          RowBox[{"Pi", "*", 
           RowBox[{"BesselY", "[", 
            RowBox[{"arg", ",", "z"}], "]"}]}]}], ")"}]}], "-", 
       RowBox[{
        RowBox[{"Csc", "[", 
         RowBox[{"arg", "*", "Pi"}], "]"}], "*", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"BesselJ", "[", 
           RowBox[{
            RowBox[{"-", "arg"}], ",", "z"}], "]"}], ",", "nu"}], "]"}]}], 
       "-", 
       RowBox[{"Pi", "*", 
        RowBox[{"BesselJ", "[", 
         RowBox[{"arg", ",", "z"}], "]"}]}]}]}]}], "}"}]}], ";"}]], "Input"],


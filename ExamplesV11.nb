Cell["\<\
This integral can be found in Abramowitz/Stegun 9.1.24, where also the \
conditions Re[n]<1/2 and z>0 are given (which have been copied incorrectly in \
the thesis).\
\>", "Text"],

Cell["\<\
The first condition implies that it does not make sense to consider the \
operator S[n].\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", "2"}], "/", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"1", "/", "2"}], "-", "n"}], "]"}]}], "/", 
       RowBox[{"Gamma", "[", 
        RowBox[{"1", "/", "2"}], "]"}]}], "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"z", "/", "2"}], ")"}], "^", "n"}]}], "*", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"z", " ", "t"}], "]"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"t", "^", "2"}], "-", "1"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"n", "+", 
           RowBox[{"1", "/", "2"}]}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "1", ",", "Infinity"}], "}"}]}], "]"}]}], ",", 
    RowBox[{"Der", "[", "z", "]"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"z", ">", "0"}], "&&", 
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"Re", "[", "n", "]"}], "]"}], "<", 
       RowBox[{"1", "/", "2"}]}]}]}]}], "]"}]}]], "Input"],


Cell["9.181  Hypergeometric functions of two variables", "Subsection"],

Cell["\<\
The definition is 9.180, the differential equation is 9.181 (both on p. \
1018). For \:ffff|x|<1 and \:ffff|y|<1 we define\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Subscript", "[", 
      RowBox[{"F", ",", "1"}], "]"}], "[", 
     RowBox[{"a", ",", "b", ",", "bp", ",", 
      RowBox[{"c", ";", "x"}], ",", "y"}], "]"}], "==", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Pochhammer", "[", 
        RowBox[{"a", ",", 
         RowBox[{"m", "+", "n"}]}], "]"}], "*", 
       RowBox[{"Pochhammer", "[", 
        RowBox[{"b", ",", "m"}], "]"}], "*", 
       RowBox[{
        RowBox[{"Pochhammer", "[", 
         RowBox[{"bp", ",", "n"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Pochhammer", "[", 
           RowBox[{"c", ",", 
            RowBox[{"m", "+", "n"}]}], "]"}], "*", 
          RowBox[{"m", "!"}], "*", 
          RowBox[{"n", "!"}]}], ")"}]}], "*", 
       RowBox[{"x", "^", "m"}], "*", 
       RowBox[{"y", "^", "n"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", "0", ",", "Infinity"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubscriptBox["F", "1"], "(", 
     RowBox[{"a", ",", "b", ",", "bp", ",", 
      RowBox[{"c", ";", "x"}], ",", "y"}], ")"}], "\[LongEqual]", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"m", "=", "0"}], "\[Infinity]"], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"n", "=", "0"}], "\[Infinity]"], 
      FractionBox[
       RowBox[{
        TemplateBox[{"a",RowBox[{"m", "+", "n"}]},
         "Pochhammer"], " ", 

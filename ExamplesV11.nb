       SuperscriptBox["x", "2"]}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{"x", "+", 
      RowBox[{"n", " ", "x"}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 

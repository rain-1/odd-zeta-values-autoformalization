Cell[CellGroupData[{

Cell["Triple sum from Bernd Sturmfels", "Subsection"],

Cell["\<\
In an e-mail dated from 2010-11-23, Bernd wrote:
\"I wonder whether you would be willing to do me a quick \"summation favor\" \
of the \"A=B\" kind.
It concerns the sum in Theorem 5.15. Can it be simplified to something nicer \
??\"\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"smnd", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "4"}], ")"}], "^", "j"}], "*", 
    RowBox[{"Binomial", "[", 
     RowBox[{
      RowBox[{"d", "-", "2", "-", "k"}], ",", "j"}], "]"}], "*", 
    RowBox[{"Multinomial", "[", 
     RowBox[{
      RowBox[{"2", "i"}], ",", 
      RowBox[{"k", "-", "i"}], ",", 
      RowBox[{"n", "-", "k", "-", "i"}]}], "]"}], "*", 
    RowBox[{"CatalanNumber", "[", 
     RowBox[{"i", "+", "d", "-", "2", "-", "k", "-", "j"}], "]"}]}]}], 
  ";"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{
   RowBox[{"HoldForm", "[", 
    RowBox[{"Sum", "[", 
     RowBox[{"s", ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", 
        RowBox[{"d", "-", "2"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "0", ",", "n"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "0", ",", 
        RowBox[{"d", "-", "2", "-", "k"}]}], "}"}]}], "]"}], "]"}], "/.", 
   RowBox[{"s", "\[Rule]", "smnd"}]}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"k", "=", "0"}], 
     RowBox[{"d", "-", "2"}]], 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "0"}], "n"], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"j", "=", "0"}], 
       RowBox[{"d", "-", "2", "-", "k"}]], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "4"}], ")"}], "j"], " ", 
       TemplateBox[{RowBox[{
           RowBox[{"-", "2"}], "+", "d", "-", "k"}],"j"},
        "Binomial"], " ", 
       TemplateBox[{RowBox[{
           RowBox[{"-", "2"}], "+", "d", "+", "i", "-", "j", "-", "k"}]},
        "CatalanNumber"], " ", 
       TagBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"2", " ", "i"}], "+", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "i"}], "+", "k"}], ")"}], "+", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "i"}], "-", "k", "+", "n"}], ")"}]}], ";", 
           RowBox[{"2", " ", "i"}]}], ",", 
          RowBox[{
           RowBox[{"-", "i"}], "+", "k"}], ",", 
          RowBox[{
           RowBox[{"-", "i"}], "-", "k", "+", "n"}]}], ")"}],
        Multinomial,
        Editable->False]}]}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
After a few tries, one finds that the inner double sum can be simplified to a \
hypergeometric term. But we were not able to get a closed form for the entire \
expression.\
\>", "Text"],

Cell["\<\
Here is the annihilating ideal for the inner double sum (natural boundaries):\
\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann2", "=", 
  RowBox[{"First", "[", 
   RowBox[{"CreativeTelescoping", "[", 
    RowBox[{
     RowBox[{"First", "[", 
      RowBox[{"CreativeTelescoping", "[", 
       RowBox[{"smnd", ",", 
        RowBox[{
         RowBox[{"S", "[", "j", "]"}], "-", "1"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"S", "[", "i", "]"}], ",", 
          RowBox[{"S", "[", "k", "]"}], ",", 
          RowBox[{"S", "[", "d", "]"}], ",", 
          RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}], "]"}], ",", 
     RowBox[{
      RowBox[{"S", "[", "i", "]"}], "-", "1"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"S", "[", "k", "]"}], ",", 
       RowBox[{"S", "[", "d", "]"}], ",", 
       RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "d"}], "+", 
      RowBox[{"2", " ", "k"}], "+", 
      RowBox[{"d", " ", "k"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["k", "2"]}], "-", "n", "-", 
      RowBox[{"d", " ", "n"}], "+", 
      RowBox[{"3", " ", "k", " ", "n"}], "-", 
      SuperscriptBox["n", "2"]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"d", "-", "k", "+", "n", "+", 
      RowBox[{"d", " ", "n"}], "-", 
      RowBox[{"k", " ", "n"}], "+", 
      SuperscriptBox["n", "2"]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["d", "2"], "-", 
      RowBox[{"2", " ", "d", " ", "k"}], "+", 
      RowBox[{"d", " ", "n"}]}], ")", 
     SubscriptBox["S", "d"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", "d"}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["d", "2"]}], "+", 
      RowBox[{"2", " ", "k"}], "-", 
      RowBox[{"8", " ", "d", " ", "k"}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["k", "2"]}], "-", 
      RowBox[{"2", " ", "n"}], "+", 
      RowBox[{"4", " ", "d", " ", "n"}], "-", 
      RowBox[{"4", " ", "k", " ", "n"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "6"}], "+", 
      RowBox[{"10", " ", "d"}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["d", "2"]}], "-", 
      RowBox[{"16", " ", "k"}], "+", 
      RowBox[{"18", " ", "d", " ", "k"}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["d", "2"], " ", "k"}], "-", 
      RowBox[{"14", " ", 
       SuperscriptBox["k", "2"]}], "+", 
      RowBox[{"8", " ", "d", " ", 
       SuperscriptBox["k", "2"]}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["k", "3"]}], "+", 
      RowBox[{"6", " ", "n"}], "-", 
      RowBox[{"4", " ", "d", " ", "n"}], "+", 
      RowBox[{"10", " ", "k", " ", "n"}], "-", 
      RowBox[{"4", " ", "d", " ", "k", " ", "n"}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["k", "2"], " ", "n"}]}], ")", 
     SubscriptBox["S", "k"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "k"}], "-", 
      RowBox[{"3", " ", "d", " ", "k"}], "+", 
      RowBox[{
       SuperscriptBox["d", "2"], " ", "k"}], "+", 
      RowBox[{"6", " ", 
       SuperscriptBox["k", "2"]}], "-", 
      RowBox[{"4", " ", "d", " ", 
       SuperscriptBox["k", "2"]}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["k", "3"]}], "-", 
      RowBox[{"2", " ", "n"}], "+", 
      RowBox[{"3", " ", "d", " ", "n"}], "-", 
      RowBox[{
       SuperscriptBox["d", "2"], " ", "n"}], "-", 
      RowBox[{"9", " ", "k", " ", "n"}], "+", 
      RowBox[{"6", " ", "d", " ", "k", " ", "n"}], "-", 
      RowBox[{"8", " ", 
       SuperscriptBox["k", "2"], " ", "n"}], "+", 
      RowBox[{"3", " ", 
       SuperscriptBox["n", "2"]}], "-", 
      RowBox[{"2", " ", "d", " ", 
       SuperscriptBox["n", "2"]}], "+", 
      RowBox[{"5", " ", "k", " ", 
       SuperscriptBox["n", "2"]}], "-", 
      SuperscriptBox["n", "3"]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],


Cell["\<\
Let\[CloseCurlyQuote]s see which restrictions we have to impose on the \
parameters in order to make evaluation of the inhomogeneous part possible:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Limit", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", "k"}], "*", 
    RowBox[{"Zeta", "[", 
     RowBox[{"n", ",", 
      RowBox[{"a", "+", 
       RowBox[{"b", "*", "x"}]}]}], "]"}]}], ",", 
   RowBox[{"x", "\[Rule]", "Infinity"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"a", ">", "0"}], "&&", 
     RowBox[{"b", ">", "0"}], "&&", 
     RowBox[{"k", ">", "0"}], "&&", 
     RowBox[{"n", ">", 
      RowBox[{"k", "+", "1"}]}], "&&", 
     RowBox[{"Element", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"k", ",", "n"}], "}"}], ",", "Integers"}], "]"}]}]}]}], 
  "]"}]], "Input"],


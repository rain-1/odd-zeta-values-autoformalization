    RowBox[{"LegendreQ", "[", 
     RowBox[{"m", ",", 
      RowBox[{
       FractionBox["1", "2"], "+", "m"}], ",", "a"}], "]"}]}], 
   RowBox[{"Gamma", "[", 
    RowBox[{"1", "+", "m"}], "]"}]]}]], "Output"]

    SubscriptBox["D", "x"], 
    SubscriptBox["S", "n"]}], "+", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", "n"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"1", "+", "a", "+", "n"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"a", "+", 
       RowBox[{"2", " ", "n"}]}], ")"}]}], 
    SubscriptBox["S", "n"], 
    SubscriptBox["S", "a"]}], "+", 
   RowBox[{
    RowBox[{"2", " ", "n", " ", 
     RowBox[{"(", 
      RowBox[{"a", "+", "n"}], ")"}]}], 
    SubscriptBox["D", "x"]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ApplyOreOperator", "[", 
    RowBox[{
     RowBox[{"First", "[", 

Cell[TextData[{
 "In the Saito-Sturmfels-Takayama book we find on page 39 the following \
annihilating operators for the Appell ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "4"], TraditionalForm]]],
 " function."
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ops2", "=", 
  RowBox[{"ChangeOreAlgebra", "[", 
   RowBox[{
    RowBox[{"ToOrePolynomial", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Der", "[", "x", "]"}], "**", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Euler", "[", "x", "]"}], "+", "c", "-", "1"}], ")"}]}], 
        "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Euler", "[", "x", "]"}], "+", 
           RowBox[{"Euler", "[", "y", "]"}], "+", "a"}], ")"}], "**", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Euler", "[", "x", "]"}], "+", 
           RowBox[{"Euler", "[", "y", "]"}], "+", "b"}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Der", "[", "y", "]"}], "**", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Euler", "[", "y", "]"}], "+", "d", "-", "1"}], ")"}]}], 
        "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Euler", "[", "x", "]"}], "+", 
           RowBox[{"Euler", "[", "y", "]"}], "+", "a"}], ")"}], "**", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Euler", "[", "x", "]"}], "+", 
           RowBox[{"Euler", "[", "y", "]"}], "+", "b"}], ")"}]}]}]}], "}"}], 
     "]"}], ",", 
    RowBox[{"OreAlgebra", "[", "ops", "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "-", 
      SuperscriptBox["x", "2"]}], ")", 
     SubsuperscriptBox["D", "x", "2"]}], "-", 
    RowBox[{
     RowBox[{"2", " ", "x", " ", "y"}], 
     SubscriptBox["D", "x"], 
     SubscriptBox["D", "y"]}], "-", 
    RowBox[{
     SuperscriptBox["y", "2"], 
     SubsuperscriptBox["D", "y", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "c", "-", "x", "-", 
      RowBox[{"a", " ", "x"}], "-", 
      RowBox[{"b", " ", "x"}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "y"}], "-", 
      RowBox[{"a", " ", "y"}], "-", 
      RowBox[{"b", " ", "y"}]}], ")", 
     SubscriptBox["D", "y"]}], "-", 
    RowBox[{"a", " ", "b"}]}], ",", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["x", "2"], 
     SubsuperscriptBox["D", "x", "2"]}], "-", 
    RowBox[{
     RowBox[{"2", " ", "x", " ", "y"}], 
     SubscriptBox["D", "x"], 
     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"(", 
     RowBox[{"y", "-", 
      SuperscriptBox["y", "2"]}], ")", 
     SubsuperscriptBox["D", "y", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "x"}], "-", 
      RowBox[{"a", " ", "x"}], "-", 
      RowBox[{"b", " ", "x"}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "d", "-", "y", "-", 
      RowBox[{"a", " ", "y"}], "-", 
      RowBox[{"b", " ", "y"}]}], ")", 
     SubscriptBox["D", "y"]}], "-", 
    RowBox[{"a", " ", "b"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
However, they do not agree with Chyzak's definition. We therefore use \
Takayama's algorithm in order to derive the relations ourselves (and find \
that Chyzak's results are correct).\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GBEqual", "[", 
  RowBox[{"gb", ",", 
   RowBox[{"OreGroebnerBasis", "[", 
    RowBox[{"ops2", ",", 
     RowBox[{"MonomialOrder", "\[Rule]", "DegreeLexicographic"}]}], "]"}]}], 
  "]"}]], "Input"],

Cell[BoxData["False"], "Output"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"tak", "=", 
   RowBox[{"Takayama", "[", 
    RowBox[{
     RowBox[{"Annihilator", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Pochhammer", "[", 
         RowBox[{"a", ",", 
          RowBox[{"m", "+", "n"}]}], "]"}], "*", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Pochhammer", "[", 
             RowBox[{"b", ",", 
              RowBox[{"m", "+", "n"}]}], "]"}], "/", 
            RowBox[{"m", "!"}]}], "/", 
           RowBox[{"n", "!"}]}], "/", 
          RowBox[{"Pochhammer", "[", 
           RowBox[{"c", ",", "m"}], "]"}]}], "/", 
         RowBox[{"Pochhammer", "[", 
          RowBox[{"d", ",", "n"}], "]"}]}], "*", 
        RowBox[{"x", "^", "m"}], "*", 
        RowBox[{"y", "^", "n"}]}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"S", "[", "m", "]"}], ",", 
         RowBox[{"S", "[", "n", "]"}], ",", 
         RowBox[{"Der", "[", "x", "]"}], ",", 
         RowBox[{"Der", "[", "y", "]"}]}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"m", ",", "n"}], "}"}]}], "]"}]}], ";"}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GBEqual", "[", 
  RowBox[{"gb", ",", "tak"}], "]"}]], "Input"],

Cell[BoxData["True"], "Output"]
}, Open  ]],

Cell[TextData[{
 "A \"step-up\" operator, i.e., an operator that maps ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "4"], "(", 
    RowBox[{"a", ",", "b", ",", "c", ",", "d", ",", "x", ",", "y"}], ")"}], 
   TraditionalForm]]],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "4"], "(", 
    RowBox[{
     RowBox[{"a", "+", "1"}], ",", "b", ",", "c", ",", "d", ",", "x", ",", 
     "y"}], ")"}], TraditionalForm]], "Output",
  CellChangeTimes->{3.464097829838367*^9, 3.464117264641625*^9}],
 ", using the Ore operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["D", "x"], TraditionalForm]]],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["D", "y"], TraditionalForm]]],
 " only, can be read off directly from the definition of the function:"
}], "Text"],


Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"First", "[", "%", "]"}], "\[Equal]", 
   RowBox[{"(", 
    RowBox[{"BesselEq", "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"w", "\[Rule]", "S"}], ",", 

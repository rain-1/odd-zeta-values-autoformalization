                 RowBox[{"1", "/", "2"}]}], ")"}]}]}], ",", 
             RowBox[{"{", 
              RowBox[{"x", ",", "d"}], "}"}]}], "]"}], "]"}]}], "/.", 
         RowBox[{"x", "\[Rule]", "xx"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}]}], 
    "]"}]}]}]], "Input"],


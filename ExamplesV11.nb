Cell["\<\
But in this example, it pays off to extend the module in which the Takayama \
elimination takes place. Using the option StartDegree we can enforce that \
elements are included up to degree 7 at least (it started with degree 6 \
before).\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Printlevel", "=", "0"}], ";", 
  RowBox[{"ann2", "=", 
   RowBox[{"Takayama", "[", 
    RowBox[{"ann", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "j"}], "}"}], ",", 
     RowBox[{"StartDegree", "\[Rule]", "7"}]}], "]"}]}]}]], "Input"],


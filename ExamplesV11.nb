}, Open  ]],

Cell["It turns out that this solution is also valid for k=d-2:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Union", "[", 
  RowBox[{"Flatten", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"sol3", "-", 
      RowBox[{"MySum2", "[", 
       RowBox[{"k", ",", "d", ",", "n"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"d", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "0", ",", 
       RowBox[{"d", "-", "2"}]}], "}"}]}], "]"}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "0", "}"}]], "Output"]
}, Open  ]],

Cell["Here is our result:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "^", "d"}], "*", 
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "d"}], "-", "3"}], ")"}]}], "*", 
      RowBox[{"Pochhammer", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "2"}], "-", "k"}], ",", 
        RowBox[{"d", "-", "1"}]}], "]"}], "*", 
      RowBox[{"Pochhammer", "[", 
       RowBox[{
        RowBox[{"d", "+", "n", "-", 
         RowBox[{"2", "k"}]}], ",", "k"}], "]"}], "*", 
      RowBox[{
       RowBox[{
        RowBox[{"Pochhammer", "[", 
         RowBox[{
          RowBox[{"n", "+", "1", "-", "k"}], ",", "k"}], "]"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"d", "-", "1"}], ")"}], "!"}]}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "k"}], ")"}], "!"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "0", ",", 
       RowBox[{"d", "-", "2"}]}], "}"}]}], "]"}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"k", "=", "0"}], 
     RowBox[{"d", "-", "2"}]], 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "d"], " ", 
      SuperscriptBox["2", 
       RowBox[{
        RowBox[{"2", " ", "d"}], "-", "3"}]], " ", 
      TemplateBox[{RowBox[{
          FractionBox["1", "2"], "-", "k"}],RowBox[{"d", "-", "1"}]},
       "Pochhammer"], " ", 
      TemplateBox[{RowBox[{"d", "+", "n", "-", 
          RowBox[{"2", " ", "k"}]}],"k"},
       "Pochhammer"], " ", 
      TemplateBox[{RowBox[{"n", "+", "1", "-", "k"}],"k"},
       "Pochhammer"]}], 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"d", "-", "1"}], ")"}], "!"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", " ", "k"}], ")"}], "!"}]}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["A final check indicates that it is indeed correct:", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MySol", "[", 
   RowBox[{"d_Integer", ",", "n_Integer"}], "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", "d"}], "*", 
     RowBox[{"2", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "d"}], "-", "3"}], ")"}]}], "*", 
     RowBox[{"Pochhammer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "2"}], "-", "k"}], ",", 
       RowBox[{"d", "-", "1"}]}], "]"}], "*", 
     RowBox[{"Pochhammer", "[", 
      RowBox[{
       RowBox[{"d", "+", "n", "-", 
        RowBox[{"2", "k"}]}], ",", "k"}], "]"}], "*", 
     RowBox[{
      RowBox[{
       RowBox[{"Pochhammer", "[", 
        RowBox[{
         RowBox[{"n", "+", "1", "-", "k"}], ",", "k"}], "]"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"d", "-", "1"}], ")"}], "!"}]}], "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "k"}], ")"}], "!"}]}]}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "0", ",", 
      RowBox[{"d", "-", "2"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"SetDelayed", "@@", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"Hold", "[", 
     RowBox[{
      RowBox[{"MySum", "[", 
       RowBox[{"d_Integer", ",", "n_Integer"}], "]"}], ",", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"Sum", "[", 
           RowBox[{"s", ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "0", ",", 
              RowBox[{"d", "-", "2", "-", "k"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", "n"}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", 
          RowBox[{"d", "-", "2"}]}], "}"}]}], "]"}]}], "]"}], "/.", 
    RowBox[{"s", "\[Rule]", "smnd"}]}], ")"}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Union", "[", 
  RowBox[{"Flatten", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"MySum", "[", 
       RowBox[{"d", ",", "n"}], "]"}], "-", 
      RowBox[{"MySol", "[", 
       RowBox[{"d", ",", "n"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"d", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "10"}], "}"}]}], "]"}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "0", "}"}]], "Output"]
}, Open  ]]
}, Closed]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples taken from Fr\[EAcute]d\[EAcute]ric Chzyak's work", "Section"],

Cell["\<\
The shortcuts refer to the following literature:
98: Chyzak's thesis: Fonctions holonomes en Calcul formel
98b: Gr\[ODoubleDot]bner Bases, Symbolic Summation and Symbolic Integration  \
(Proceedings of the Conference 33 Years of Gr\[ODoubleDot]bner Bases)
00: An extension of Zeilberger's fast algorithm to general holonomic \
functions  (Discrete Math)\
\>", "Text"],

Cell[CellGroupData[{

Cell["[98, p.140] or [98b, Section 3.2]: Indefinite Integral", "Subsection"],

Cell["\<\
We get a better result (annihilator of lower vector space dimension) by a \
simpler approach:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"x", " ", "t"}], "+", 
         RowBox[{"t", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"-", "2"}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "y", ",", "Infinity"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"Der", "[", "y", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"4", "-", 
      SuperscriptBox["x", "2"]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "-", 
      RowBox[{"x", " ", "y"}]}], ")", 
     SubscriptBox["D", "y"]}], "-", 
    RowBox[{"3", " ", "x"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"x", " ", "y"}], "+", 
      SuperscriptBox["y", "2"]}], ")", 
     SubsuperscriptBox["D", "y", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "x"}], "+", 
      RowBox[{"4", " ", "y"}]}], ")", 
     SubscriptBox["D", "y"]}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[TextData[{
 "We try ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " on that..."
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"x", " ", "t"}], "+", 
      RowBox[{"t", "^", "2"}]}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"-", "2"}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "y", ",", "Infinity"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "y", "\[Infinity]"], 
  RowBox[{
   FractionBox["1", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "+", 
       SuperscriptBox["t", "2"], "+", 
       RowBox[{"t", " ", "x"}]}], ")"}], "2"]], 
   RowBox[{"\[DifferentialD]", "t"}]}]}]], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["[98, p.184]: Integral with four Bessel functions", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"x", " ", 
       RowBox[{"BesselJ", "[", 
        RowBox[{"1", ",", 
         RowBox[{"a", " ", "x"}]}], "]"}], " ", 
       RowBox[{"BesselI", "[", 
        RowBox[{"1", ",", 
         RowBox[{"a", " ", "x"}]}], "]"}], " ", 
       RowBox[{"BesselY", "[", 
        RowBox[{"0", ",", "x"}], "]"}], " ", 
       RowBox[{"BesselK", "[", 
        RowBox[{"0", ",", "x"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Log", "[", 
       RowBox[{"1", "-", 
        RowBox[{"a", "^", "4"}]}], "]"}]}], "/", 
     RowBox[{"(", 
      RowBox[{"2", "Pi", " ", 
       RowBox[{"a", "^", "2"}]}], ")"}]}]}], "]"}], "//", 
  "TraditionalForm"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
     RowBox[{"x", " ", 
      TemplateBox[{"1",RowBox[{"a", " ", "x"}]},
       "BesselJ"], " ", 
      TemplateBox[{"1",RowBox[{"a", " ", "x"}]},
       "BesselI"], " ", 
      TemplateBox[{"0","x"},
       "BesselY"], " ", 
      TemplateBox[{"0","x"},
       "BesselK"], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"log", "(", 
       RowBox[{"1", "-", 
        SuperscriptBox["a", "4"]}], ")"}], 
      RowBox[{"2", " ", "\[Pi]", " ", 
       SuperscriptBox["a", "2"]}]]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
Takayama's algorithm works perfect on this example (if we believe that the \
integral has natural boundaries).\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"x", " ", 
     RowBox[{"BesselJ", "[", 
      RowBox[{"1", ",", 
       RowBox[{"a", " ", "x"}]}], "]"}], " ", 
     RowBox[{"BesselI", "[", 
      RowBox[{"1", ",", 
       RowBox[{"a", " ", "x"}]}], "]"}], " ", 
     RowBox[{"BesselY", "[", 
      RowBox[{"0", ",", "x"}], "]"}], " ", 
     RowBox[{"BesselK", "[", 
      RowBox[{"0", ",", "x"}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"Der", "[", "a", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["a", "3"], 
     SubsuperscriptBox["D", "a", "4"]}], "+", 
    RowBox[{
     RowBox[{"4", " ", 

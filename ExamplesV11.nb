Cell["\<\
The inhomogeneous part simplifies to zero, and hence everything is fine, \
i.e., ann indeed annihilates the integral.\
\>", "Text"],

Cell["Find a recurrence in m:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OreGroebnerBasis", "[", 
  RowBox[{"ann", ",", 
   RowBox[{"OreAlgebra", "[", 
    RowBox[{
     RowBox[{"Der", "[", "a", "]"}], ",", 
     RowBox[{"S", "[", "m", "]"}]}], "]"}], ",", 
   RowBox[{"MonomialOrder", "\[Rule]", 
    RowBox[{"EliminationOrder", "[", "1", "]"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "32"}], "+", 
      RowBox[{"32", " ", 
       SuperscriptBox["a", "2"]}], "-", 
      RowBox[{"48", " ", "m"}], "+", 
      RowBox[{"48", " ", 
       SuperscriptBox["a", "2"], " ", "m"}], "-", 
      RowBox[{"16", " ", 
       SuperscriptBox["m", "2"]}], "+", 
      RowBox[{"16", " ", 
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["m", "2"]}]}], ")", 
     SubsuperscriptBox["S", "m", "2"]}], "+", 
    RowBox[{"(", 

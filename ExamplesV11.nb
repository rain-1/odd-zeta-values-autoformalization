Cell[TextData[{
 "The limit of  GegenbauerC[k, (n - 2)/2, x] for k -> Infinity cannot be \
computed by ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ", that's why the above evaluation does not work. Assuming that the sum has \
a natural upper bound, we find some annihilating relations for the sum on the \
left-hand side."
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Timing", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"lhs", ",", "inhom"}], "}"}], "=", 
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Binomial", "[", 
           RowBox[{
            RowBox[{"k", "+", "n", "-", "2"}], ",", "k"}], "]"}], "/", 
          RowBox[{"Binomial", "[", 
           RowBox[{
            RowBox[{"k", "+", 
             RowBox[{"n", "/", "2"}], "-", "2"}], ",", "k"}], "]"}]}], "*", 
         RowBox[{"t", "^", "k"}], "*", 
         RowBox[{"Hypergeometric2F1", "[", 
          RowBox[{"k", ",", 
           RowBox[{"1", "-", 
            RowBox[{"n", "/", "2"}]}], ",", 
           RowBox[{"k", "+", 
            RowBox[{"n", "/", "2"}]}], ",", 
           RowBox[{"t", "^", "2"}]}], "]"}], "*", 
         RowBox[{"GegenbauerC", "[", 
          RowBox[{"k", ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"n", "-", "2"}], ")"}], "/", "2"}], ",", "x"}], "]"}]}], 
        ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "n", "]"}], ",", 
        RowBox[{"Der", "[", "x", "]"}], ",", 
        RowBox[{"Der", "[", "t", "]"}]}], "}"}], ",", 

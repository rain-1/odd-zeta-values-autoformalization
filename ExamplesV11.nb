       RowBox[{"Der", "[", "a", "]"}], ",", 
       RowBox[{"Der", "[", "b", "]"}], ",", 
       RowBox[{"S", "[", "m", "]"}], ",", 
       RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}], "]"}]}]], "Input"],


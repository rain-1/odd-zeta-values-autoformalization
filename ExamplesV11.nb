Cell["\<\
So, although the limit of the delta part does not converge, the principal \
part makes perfect sense:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"BesselK", "[", 
     RowBox[{"0", ",", 
      RowBox[{"a", "*", 
       RowBox[{"b", "/", "2"}]}]}], "]"}], "^", "2"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Der", "[", "a", "]"}], ",", 
     RowBox[{"Der", "[", "b", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"a", 
     SubscriptBox["D", "a"]}], "-", 
    RowBox[{"b", 
     SubscriptBox["D", "b"]}]}], ",", 
   RowBox[{
    RowBox[{
     SuperscriptBox["b", "2"], 
     SubsuperscriptBox["D", "b", "3"]}], "+", 
    RowBox[{
     RowBox[{"3", " ", "b"}], 
     SubsuperscriptBox["D", "b", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["b", "2"]}]}], ")", 
     SubscriptBox["D", "b"]}], "-", 
    RowBox[{
     SuperscriptBox["a", "2"], " ", "b"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GBEqual", "[", 
  RowBox[{"%", ",", "ann"}], "]"}]], "Input"],

Cell[BoxData["True"], "Output"]
}, Open  ]],

Cell["\<\
Fortunately, we can avoid this problem by reversing the order of the \
operators Der[a] and Der[b]. This will influence the creative telescoping \
relations in a way that the delta parts vanish:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Log", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "+", 
            RowBox[{"a", "^", "2"}]}], "]"}], "+", "x"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "+", 
            RowBox[{"a", "^", "2"}]}], "]"}], "-", "x"}], ")"}]}], "]"}], "*", 
      RowBox[{
       RowBox[{"BesselJ", "[", 
        RowBox[{"0", ",", 
         RowBox[{"b", "*", "x"}]}], "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"x", "^", "2"}], "+", 
         RowBox[{"a", "^", "2"}]}], "]"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Der", "[", "b", "]"}], ",", 
     RowBox[{"Der", "[", "a", "]"}]}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{
      RowBox[{"Re", "[", "a", "]"}], ">", "0"}], "&&", 
     RowBox[{"b", ">", "0"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"b", 
     SubscriptBox["D", "b"]}], "-", 
    RowBox[{"a", 
     SubscriptBox["D", "a"]}]}], ",", 
   RowBox[{
    RowBox[{
     SuperscriptBox["a", "2"], 
     SubsuperscriptBox["D", "a", "3"]}], "+", 
    RowBox[{
     RowBox[{"3", " ", "a"}], 
     SubsuperscriptBox["D", "a", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["b", "2"]}]}], ")", 
     SubscriptBox["D", "a"]}], "-", 
    RowBox[{"a", " ", 
     SuperscriptBox["b", "2"]}]}]}], "}"}]], "Output"]
}, Open  ]],


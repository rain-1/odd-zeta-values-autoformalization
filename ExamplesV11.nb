        RowBox[{
         RowBox[{"(", 
          RowBox[{"m", "+", "1"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"n", "-", "k"}], ")"}]}]}], "/.", 
       RowBox[{"n", "\[Rule]", 
        RowBox[{"n", "+", "1"}]}]}], "/.", 
      RowBox[{"k", "\[Rule]", 
       RowBox[{"n", "+", "1"}]}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}]}]], "Input"],


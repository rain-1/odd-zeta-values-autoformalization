     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"i", "=", "0"}], "j"], 
      RowBox[{
       TemplateBox[{"n","j"},
        "Binomial"], " ", 
       TemplateBox[{"j","i"},
        "Binomial"], " ", 
       SuperscriptBox["x", "i"], " ", 
       SuperscriptBox["y", 
        RowBox[{"j", "-", "i"}]], " ", 
       SuperscriptBox["z", 
        RowBox[{"n", "-", "j"}]]}]}]}], "\[LongEqual]", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"x", "+", "y", "+", "z"}], ")"}], "n"]}],
   HoldForm], TraditionalForm]], "Output"]

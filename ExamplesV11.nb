       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"n", "+", "r", "+", "s"}]], " ", 
       TemplateBox[{"n","r"},
        "Binomial"], " ", 
       TemplateBox[{"n","s"},
        "Binomial"], " ", 
       TemplateBox[{RowBox[{"n", "+", "r"}],"r"},
        "Binomial"], " ", 
       TemplateBox[{RowBox[{"n", "+", "s"}],"s"},
        "Binomial"], " ", 
       TemplateBox[{RowBox[{
           RowBox[{"2", " ", "n"}], "-", 
           RowBox[{"(", 
             RowBox[{"r", "+", "s"}], ")"}]}],"n"},
        "Binomial"]}]}]}], "\[LongEqual]", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], "\[Infinity]"], 
     SuperscriptBox[
      TemplateBox[{"n","k"},
       "Binomial"], "4"]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
First observe that the sums have finite support, so we can safely write:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 

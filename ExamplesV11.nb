Cell["\<\
Better is to slightly rewrite the expression in order to use the closure \
property \"application of Ore operator\". We now obtain the second order \
differential equation that is given in Prop. 2.2  (note that we have to \
include S[n], since it is used in ApplyOreOperator):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"annUeven", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Sqrt", "[", "a", "]"}], "^", 
      RowBox[{"(", 
       RowBox[{"n", "/", "2"}], ")"}]}], "*", 
     RowBox[{"ApplyOreOperator", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"S", "[", "n", "]"}], "^", "2"}], "+", 
        RowBox[{"Sqrt", "[", "a", "]"}]}], ",", 
       RowBox[{"ChebyshevU", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"n", "/", "2"}], "-", "1"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "-", "a", "-", "1"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", 
            RowBox[{"Sqrt", "[", "a", "]"}]}], ")"}]}]}], "]"}]}], "]"}]}], 
    ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "n", "]"}], ",", 
      RowBox[{"Der", "[", "x", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "x"}], "+", 
      RowBox[{"3", " ", "a", " ", "x"}], "-", 
      RowBox[{"3", " ", 
       SuperscriptBox["a", "2"], " ", "x"}], "+", 
      RowBox[{
       SuperscriptBox["a", "3"], " ", "x"}], "+", 
      SuperscriptBox["x", "3"], "+", 
      RowBox[{"2", " ", "a", " ", 
       SuperscriptBox["x", "3"]}], "-", 
      RowBox[{"3", " ", 
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["x", "3"]}], "-", 
      RowBox[{"n", " ", 
       SuperscriptBox["x", "3"]}], "+", 

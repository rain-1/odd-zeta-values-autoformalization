Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Simplify", "[", 
     RowBox[{"ReleaseHold", "[", 
      RowBox[{"inh", "/.", 
       RowBox[{"Limit", "\[Rule]", "myLimit"}]}], "]"}], "]"}], "/.", 
    RowBox[{"myLimit", "\[Rule]", "Limit"}]}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"nu", "\[GreaterEqual]", "1"}], "&&", 
     RowBox[{"Element", "[", 
      RowBox[{"n", ",", "Integers"}], "]"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]], "Output"]
}, Open  ]],


       SuperscriptBox["x", "5"]}], "+", 
      RowBox[{"3", " ", 
       SuperscriptBox["n", "2"], " ", 
       SuperscriptBox["x", "5"]}], "+", 
      RowBox[{
       SuperscriptBox["n", "3"], " ", 
       SuperscriptBox["x", "5"]}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "+", 

                RowBox[{"I", "*", "a"}]}], ")"}], "/", 
              RowBox[{"Sqrt", "[", 
               RowBox[{"2", "b"}], "]"}]}]}], "]"}]}]}], ")"}]}], ")"}]}]}], 
    "]"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"b", "\[Rule]", "\[Beta]"}], ",", 
     RowBox[{"c", "\[Rule]", "\[Gamma]"}], ",", 
     RowBox[{"m", "\[Rule]", "\[Mu]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
     RowBox[{
      RowBox[{
       SuperscriptBox["x", 
        RowBox[{"\[Mu]", "-", "1"}]], " ", 
       RowBox[{"exp", "(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "\[Gamma]"}], " ", "x"}], "-", 
         RowBox[{"\[Beta]", " ", 
          SuperscriptBox["x", "2"]}]}], ")"}], " ", 
       RowBox[{"sin", "(", 
        RowBox[{"a", " ", "x"}], ")"}]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"exp", "(", 
          FractionBox[
           RowBox[{
            SuperscriptBox["\[Gamma]", "2"], "-", 
            SuperscriptBox["a", "2"]}], 
           RowBox[{"8", " ", "\[Beta]"}]], ")"}], " ", 
         TemplateBox[{"\[Mu]"},
          "Gamma"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"exp", "(", 
             RowBox[{"-", 
              FractionBox[
               RowBox[{"\[ImaginaryI]", " ", "a", " ", "\[Gamma]"}], 
               RowBox[{"4", " ", "\[Beta]"}]]}], ")"}], " ", 
            TemplateBox[{RowBox[{"-", "\[Mu]"}],FractionBox[
               RowBox[{"\[Gamma]", "-", 
                 RowBox[{"\[ImaginaryI]", " ", "a"}]}], 
               SqrtBox[
                RowBox[{"2", " ", "\[Beta]"}]]]},
             "ParabolicCylinderD"]}], "-", 
           RowBox[{
            RowBox[{"exp", "(", 
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", "a", " ", "\[Gamma]"}], 
              RowBox[{"4", " ", "\[Beta]"}]], ")"}], " ", 
            TemplateBox[{RowBox[{"-", "\[Mu]"}],FractionBox[
               RowBox[{"\[Gamma]", "+", 
                 RowBox[{"\[ImaginaryI]", " ", "a"}]}], 
               SqrtBox[
                RowBox[{"2", " ", "\[Beta]"}]]]},
             "ParabolicCylinderD"]}]}], ")"}]}], ")"}]}], 
      RowBox[{"2", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"2", " ", "\[Beta]"}], ")"}], 
        RowBox[{"\[Mu]", "/", "2"}]]}]]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["For convenience, we replace the greek letters by roman ones.", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rexpr", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "I"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "b"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"m", "/", "2"}], ")"}]}]}], ")"}]}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"c", "^", "2"}], "-", 
        RowBox[{"a", "^", "2"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"8", "b"}], ")"}]}], "]"}], "*", 
    RowBox[{"Gamma", "[", "m", "]"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], "*", "a", "*", 
         RowBox[{"c", "/", 
          RowBox[{"(", 
           RowBox[{"4", "b"}], ")"}]}]}], "]"}], "*", 
       RowBox[{"ParabolicCylinderD", "[", 
        RowBox[{
         RowBox[{"-", "m"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c", "-", 
            RowBox[{"I", "*", "a"}]}], ")"}], "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"2", "b"}], "]"}]}]}], "]"}]}], "-", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", "*", "a", "*", 
         RowBox[{"c", "/", 
          RowBox[{"(", 
           RowBox[{"4", "b"}], ")"}]}]}], "]"}], "*", 
       RowBox[{"ParabolicCylinderD", "[", 
        RowBox[{
         RowBox[{"-", "m"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c", "+", 
            RowBox[{"I", "*", "a"}]}], ")"}], "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"2", "b"}], "]"}]}]}], "]"}]}]}], ")"}]}]}], 
  ";"}]], "Input"],

Cell["Mathematica can not do this integral:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", 
     RowBox[{"(", 
      RowBox[{"m", "-", "1"}], ")"}]}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "c"}], "*", "x"}], "-", 
      RowBox[{"b", "*", 
       RowBox[{"x", "^", "2"}]}]}], "]"}], "*", 
    RowBox[{"Sin", "[", 
     RowBox[{"a", "*", "x"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{
      RowBox[{"Re", "[", "m", "]"}], ">", 
      RowBox[{"-", "1"}]}], "&&", 
     RowBox[{
      RowBox[{"Re", "[", "b", "]"}], ">", "0"}], "&&", 
     RowBox[{"a", ">", "0"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "c"}], " ", "x"}], "-", 
      RowBox[{"b", " ", 
       SuperscriptBox["x", "2"]}]}]], " ", 
    SuperscriptBox["x", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "m"}]], " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"a", " ", "x"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{
      RowBox[{"Re", "[", "m", "]"}], ">", 
      RowBox[{"-", "1"}]}], "&&", 
     RowBox[{
      RowBox[{"Re", "[", "b", "]"}], ">", "0"}], "&&", 
     RowBox[{"a", ">", "0"}]}]}]}], "]"}]], "Output"]
}, Open  ]],

Cell["\<\
First observe that the identity holds for a=0 as well. We now compute \
annihilating ideal for both sides.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", 
        RowBox[{"(", 
         RowBox[{"m", "-", "1"}], ")"}]}], "*", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "c"}], "*", "x"}], "-", 
         RowBox[{"b", "*", 
          RowBox[{"x", "^", "2"}]}]}], "]"}], "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"a", "*", "x"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"Der", "[", "b", "]"}], ",", 
      RowBox[{"Der", "[", "c", "]"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{
       RowBox[{"Re", "[", "m", "]"}], ">", 
       RowBox[{"-", "1"}]}], "&&", 
      RowBox[{
       RowBox[{"Re", "[", "b", "]"}], ">", "0"}], "&&", 
      RowBox[{"a", "\[GreaterEqual]", "0"}]}]}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"a", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{
     RowBox[{"2", " ", "b"}], 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"c", 
     SubscriptBox["D", "c"]}], "+", "m"}], ",", 
   RowBox[{
    SubscriptBox["S", "m"], "+", 
    SubscriptBox["D", "c"]}], ",", 
   RowBox[{
    SubsuperscriptBox["D", "c", "2"], "+", 
    SubscriptBox["D", "b"]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"4", " ", 
      SuperscriptBox["b", "2"]}], 
     SubsuperscriptBox["D", "b", "2"]}], "+", 
    RowBox[{
     RowBox[{"4", " ", "b", " ", "c"}], 
     SubscriptBox["D", "b"], 
     SubscriptBox["D", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["a", "2"]}], "+", 
      RowBox[{"6", " ", "b"}], "-", 
      SuperscriptBox["c", "2"], "+", 
      RowBox[{"4", " ", "b", " ", "m"}]}], ")", 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "c"}], "+", 
      RowBox[{"2", " ", "c", " ", "m"}]}], ")", 
     SubscriptBox["D", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{"m", "+", 
      SuperscriptBox["m", "2"]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{"rexpr", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"Der", "[", "b", "]"}], ",", 
      RowBox[{"Der", "[", "c", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"a", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{
     RowBox[{"2", " ", "b"}], 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"c", 
     SubscriptBox["D", "c"]}], "+", "m"}], ",", 
   RowBox[{
    SubsuperscriptBox["D", "c", "2"], "+", 
    SubscriptBox["D", "b"]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"4", " ", 
      SuperscriptBox["b", "2"]}], 
     SubsuperscriptBox["D", "b", "2"]}], "+", 
    RowBox[{
     RowBox[{"4", " ", "b", " ", "c"}], 
     SubscriptBox["D", "b"], 
     SubscriptBox["D", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["a", "2"]}], "+", 
      RowBox[{"6", " ", "b"}], "-", 
      SuperscriptBox["c", "2"], "+", 
      RowBox[{"4", " ", "b", " ", "m"}]}], ")", 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "c"}], "+", 
      RowBox[{"2", " ", "c", " ", "m"}]}], ")", 
     SubscriptBox["D", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{"m", "+", 
      SuperscriptBox["m", "2"]}], ")"}]}], ",", 
   RowBox[{
    SubsuperscriptBox["S", "m", "2"], "+", 
    SubscriptBox["D", "b"]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GBEqual", "[", 
  RowBox[{"lhs", ",", "rhs"}], "]"}]], "Input"],

Cell[BoxData["False"], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Length", "[", 
    RowBox[{"UnderTheStaircase", "[", "#", "]"}], "]"}], "&"}], "/@", 
  RowBox[{"{", 
   RowBox[{"lhs", ",", "rhs"}], "}"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"4", ",", "8"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OreReduce", "[", 
  RowBox[{"rhs", ",", "lhs"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}]], "Output"]
}, Open  ]],

Cell[TextData[{
 "We don't get the same ideal, but at least, rhs is a subideal of lhs. Why do \
we get less relations for the right-hand side?\nThe reason is the ",
 Cell[BoxData[
  FormBox[
   SqrtBox["b"], TraditionalForm]], "Output",
  CellChangeTimes->{3.482761764279954*^9}],
 " that appears in the argument of the parabolic cylinder function. \
Annihilator computes operators with coefficients  that are polynomials in the \
variables which correspond to the Ore operators in the algebra. This can \
increase the order of the resulting operators:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"ParabolicCylinderD", "[", 
    RowBox[{
     RowBox[{"-", "m"}], ",", 
     RowBox[{"Sqrt", "[", "b", "]"}]}], "]"}], ",", 
   RowBox[{"S", "[", "m", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "-", "m"}], ")", 
    SubsuperscriptBox["S", "m", "2"]}], "-", 
   RowBox[{
    SqrtBox["b"], 
    SubscriptBox["S", "m"]}], "+", "1"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"ParabolicCylinderD", "[", 
    RowBox[{
     RowBox[{"-", "m"}], ",", 
     RowBox[{"Sqrt", "[", "b", "]"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Der", "[", "b", "]"}], ",", 
     RowBox[{"S", "[", "m", "]"}]}], "}"}], ",", 
   RowBox[{"MonomialOrder", "\[Rule]", "Lexicographic"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"6", "+", 
      RowBox[{"5", " ", "m"}], "+", 
      SuperscriptBox["m", "2"]}], ")", 
     SubsuperscriptBox["S", "m", "4"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", "b", "-", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SubsuperscriptBox["S", "m", "2"]}], "+", "1"}], ",", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"4", " ", "b"}], 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "m"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["m", "2"]}]}], ")", 
     SubsuperscriptBox["S", "m", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "b"}], "-", 
      RowBox[{"2", " ", "m"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[TextData[{
 "However, the structure of our identity in question is special in the sense, \
that if we computed with ",
 Cell[BoxData[
  FormBox[
   SqrtBox["b"], TraditionalForm]], "Output",
  CellChangeTimes->{3.482761764279954*^9}],
 " in the coefficients, then all occurences of it would disappear in the \
final result. This can be reproduced by the following trick: We introduce a \
new variable ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b1", "=", 
    SqrtBox["b"]}], TraditionalForm]], "Output",
  CellChangeTimes->{3.482761764279954*^9}],
 " in the original expression, and in the end perform the corresponding \
\[PartialD]-finite substitution (and obtain the same annihilating ideal as \
for the left side):"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rexpr1", "=", 
  RowBox[{
   RowBox[{"rexpr", "/.", 
    RowBox[{"b", "\[Rule]", 
     RowBox[{"b1", "^", "2"}]}]}], "/.", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"b1", "^", "2"}], ")"}], "^", "a1_"}], "\[Rule]", 
    RowBox[{"b1", "^", 
     RowBox[{"(", 
      RowBox[{"2", "a1"}], ")"}]}]}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "\[ImaginaryI]"}], " ", 
  SuperscriptBox["2", 
   RowBox[{
    RowBox[{"-", "1"}], "-", 
    FractionBox["m", "2"]}]], " ", 
  SuperscriptBox["b1", 
   RowBox[{"-", "m"}]], " ", 
  SuperscriptBox["\[ExponentialE]", 
   FractionBox[
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["a", "2"]}], "+", 
     SuperscriptBox["c", "2"]}], 
    RowBox[{"8", " ", 
     SuperscriptBox["b1", "2"]}]]], " ", 
  RowBox[{"Gamma", "[", "m", "]"}], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"\[ImaginaryI]", " ", "a", " ", "c"}], 
        RowBox[{"4", " ", 
         SuperscriptBox["b1", "2"]}]]}]], " ", 
     RowBox[{"ParabolicCylinderD", "[", 
      RowBox[{
       RowBox[{"-", "m"}], ",", 
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", "a"}], "+", "c"}], 
        RowBox[{
         SqrtBox["2"], " ", "b1"}]]}], "]"}]}], "-", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", "a", " ", "c"}], 
       RowBox[{"4", " ", 
        SuperscriptBox["b1", "2"]}]]], " ", 
     RowBox[{"ParabolicCylinderD", "[", 
      RowBox[{
       RowBox[{"-", "m"}], ",", 
       FractionBox[
        RowBox[{
         RowBox[{"\[ImaginaryI]", " ", "a"}], "+", "c"}], 
        RowBox[{
         SqrtBox["2"], " ", "b1"}]]}], "]"}]}]}], ")"}]}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rhs1", "=", 
  RowBox[{"DFiniteSubstitute", "[", 
   RowBox[{
    RowBox[{"Annihilator", "[", 
     RowBox[{"rexpr1", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "m", "]"}], ",", 
        RowBox[{"Der", "[", "a", "]"}], ",", 
        RowBox[{"Der", "[", "b1", "]"}], ",", 
        RowBox[{"Der", "[", "c", "]"}]}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"b1", "\[Rule]", 
      RowBox[{"Sqrt", "[", "b", "]"}]}], "}"}], ",", 
    RowBox[{"Algebra", "\[Rule]", 
     RowBox[{"OreAlgebra", "[", 
      RowBox[{
       RowBox[{"S", "[", "m", "]"}], ",", 
       RowBox[{"Der", "[", "a", "]"}], ",", 
       RowBox[{"Der", "[", "b", "]"}], ",", 
       RowBox[{"Der", "[", "c", "]"}]}], "]"}]}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"a", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{
     RowBox[{"2", " ", "b"}], 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"c", 
     SubscriptBox["D", "c"]}], "+", "m"}], ",", 
   RowBox[{
    SubscriptBox["S", "m"], "+", 
    SubscriptBox["D", "c"]}], ",", 
   RowBox[{
    SubsuperscriptBox["D", "c", "2"], "+", 
    SubscriptBox["D", "b"]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"4", " ", 
      SuperscriptBox["b", "2"]}], 
     SubsuperscriptBox["D", "b", "2"]}], "+", 
    RowBox[{
     RowBox[{"4", " ", "b", " ", "c"}], 
     SubscriptBox["D", "b"], 
     SubscriptBox["D", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["a", "2"]}], "+", 
      RowBox[{"6", " ", "b"}], "-", 
      SuperscriptBox["c", "2"], "+", 
      RowBox[{"4", " ", "b", " ", "m"}]}], ")", 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "c"}], "+", 
      RowBox[{"2", " ", "c", " ", "m"}]}], ")", 
     SubscriptBox["D", "c"]}], "+", 
    RowBox[{"(", 
     RowBox[{"m", "+", 
      SuperscriptBox["m", "2"]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GBEqual", "[", 
  RowBox[{"lhs", ",", "rhs1"}], "]"}]], "Input"],

Cell[BoxData["True"], "Output"]
}, Open  ]],

Cell["\<\
Alternatively, we can set Der[b] aside. In the following we will also not \
consider the shift in m, since this restricts us to the integers. And the \
initial values that we have to check are still simple enough with symbolic m \
and b.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", 
        RowBox[{"(", 
         RowBox[{"m", "-", "1"}], ")"}]}], "*", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "c"}], "*", "x"}], "-", 
         RowBox[{"b", "*", 
          RowBox[{"x", "^", "2"}]}]}], "]"}], "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"a", "*", "x"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"Der", "[", "c", "]"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{
       RowBox[{"Re", "[", "m", "]"}], ">", 
       RowBox[{"-", "1"}]}], "&&", 
      RowBox[{
       RowBox[{"Re", "[", "b", "]"}], ">", "0"}], "&&", 
      RowBox[{"a", "\[GreaterEqual]", "0"}]}]}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"2", " ", "b"}], 
     SubsuperscriptBox["D", "c", "2"]}], "-", 
    RowBox[{"a", 
     SubscriptBox["D", "a"]}], "-", 

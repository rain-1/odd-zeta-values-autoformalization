Cell["\<\
If we believe that the occurring limits evaluate to 0, or even stronger, if \
we assume natural boundaries, we can just ignore the delta part, resp. use \
Takayama's algorithm:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"lhs1", "=", 
  RowBox[{"First", "[", 
   RowBox[{"CreativeTelescoping", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"HermiteH", "[", 
       RowBox[{"n", ",", "x"}], "]"}], "*", 
      RowBox[{"HermiteH", "[", 
       RowBox[{"n", ",", "y"}], "]"}], "*", 
      RowBox[{
       RowBox[{"t", "^", "n"}], "/", 
       RowBox[{"n", "!"}]}]}], ",", 
     RowBox[{
      RowBox[{"S", "[", "n", "]"}], "-", "1"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Der", "[", "t", "]"}], ",", 
       RowBox[{"Der", "[", "x", "]"}], ",", 
       RowBox[{"Der", "[", "y", "]"}]}], "}"}]}], "]"}], "]"}]}]], "Input"],


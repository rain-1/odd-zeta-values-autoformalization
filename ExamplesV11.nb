       RowBox[{
        RowBox[{"SinIntegral", "[", 
         RowBox[{"2", "x"}], "]"}], "*", 
        RowBox[{"Cos", "[", "x", "]"}]}]}], ")"}]}]}], "]"}], "//", 
  "FunctionExpand"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", "0", "}"}]], "Output"]
}, Open  ]],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " cannot evaluate the derivatives of the integrand. We use the \
representation introduced in the previous section:\n                     ",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["SphericalBesselJ", 
       TagBox[
        RowBox[{"(", 
         RowBox[{"1", ",", "0"}], ")"}],
        Derivative],
       MultilineFunction->None], "(", 
      RowBox[{"n", ",", "x"}], ")"}], "\[LongEqual]", 
     RowBox[{
      SqrtBox[
       FractionBox["\[Pi]", 
        RowBox[{"2", " ", "x"}]]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         TemplateBox[{RowBox[{"n", "+", 
             FractionBox["1", "2"]}],"x"},
          "BesselJ"], " ", 
         RowBox[{"log", "(", 
          FractionBox["x", "2"], ")"}]}], "-", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox["x", "2"], ")"}], 
          RowBox[{"n", "+", 
           FractionBox["1", "2"]}]], " ", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"k", "=", "0"}], "\[Infinity]"], 
          FractionBox[
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "k"], " ", 
            TemplateBox[{RowBox[{"n", "+", "k", "+", 
                FractionBox["3", "2"]}]},
             "PolyGamma"], " ", 
            SuperscriptBox[
             RowBox[{"(", 
              FractionBox[
               SuperscriptBox["x", "2"], "4"], ")"}], "k"]}], 
           RowBox[{
            TemplateBox[{RowBox[{"n", "+", "k", "+", 
                FractionBox["3", "2"]}]},
             "Gamma"], " ", 
            RowBox[{"k", "!"}]}]]}]}]}], ")"}]}]}],
    HoldForm], TraditionalForm]], "Output",
  CellChangeTimes->{3.468164144360852*^9}],
 "\nand define a function that evaluates the x-derivatives of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["SphericalBesselJ", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"1", ",", "0"}], ")"}],
      Derivative],
     MultilineFunction->None], "(", 
    RowBox[{"n", ",", "x"}], ")"}], TraditionalForm]], "Output",
  CellChangeTimes->{3.468164144360852*^9}],
 " at certain values."
}], "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"gives", " ", "the", " ", "value", " ", "of", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Derivative", "[", 
       RowBox[{"1", ",", "d"}], "]"}], "[", "SphericalBesselJ", "]"}], "[", 
     RowBox[{"n", ",", "xx"}], "]"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"dxj", "[", 

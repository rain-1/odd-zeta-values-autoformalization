Cell[CellGroupData[{

Cell["Recurrence for an elliptic integral", "Subsection"],

Cell["\<\
This problem was posed by Stefan B\[ODoubleDot]ttner. Find a recurrence in j \
for the following integral\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "-", 
        RowBox[{"m", "*", 
         RowBox[{
          RowBox[{"Sin", "[", "x", "]"}], "^", "2"}]}]}], "]"}], "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "j"}], "-", "1"}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", 
       RowBox[{"Pi", "/", "2"}]}], "}"}]}], "]"}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", 
     FractionBox["\[Pi]", "2"]], 
    RowBox[{
     SuperscriptBox[
      SqrtBox[
       RowBox[{"1", "-", 
        RowBox[{"m", " ", 
         RowBox[{
          SuperscriptBox["sin", "2"], "(", "x", ")"}]}]}]], 
      RowBox[{
       RowBox[{"2", " ", "j"}], "-", "1"}]], 
     RowBox[{"\[DifferentialD]", "x"}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["The integrand is not holonomic:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Sqrt", "[", 
     RowBox[{"1", "-", 
      RowBox[{"m", "*", 
       RowBox[{
        RowBox[{"Sin", "[", "x", "]"}], "^", "2"}]}]}], "]"}], "^", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", "j"}], "-", "1"}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Der", "[", "x", "]"}], ",", 
     RowBox[{"S", "[", "j", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","nondf",
   "\"The expression \\!\\(\\*RowBox[{\\\"\\\\\\\"(1 - m*Sin[x]^2)^((-1 + \
2*j)/2)\\\\\\\"\\\"}]\\) is not recognized to be \[PartialD]-finite. The \
result might not generate a zero-dimensional ideal.\"",2,108,1,
   31736665789155565964,"Local"},
  "MessageTemplate"]], "Message", "MSG"],

Cell[BoxData[
 RowBox[{"{", "}"}]], "Output"]
}, Open  ]],

Cell["\<\
But after a simple substitution u=sin(x), the integral becomes holonomic:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", 
         RowBox[{"m", "*", 
          RowBox[{"u", "^", "2"}]}]}], "]"}], "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "j"}], "-", "1"}], ")"}]}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "-", 
        RowBox[{"u", "^", "2"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"u", ",", "0", ",", "1"}], "}"}]}], "]"}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "1"], 
    RowBox[{
     FractionBox[
      SuperscriptBox[
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"m", " ", 
          SuperscriptBox["u", "2"]}]}]], 
       RowBox[{
        RowBox[{"2", " ", "j"}], "-", "1"}]], 
      SqrtBox[
       RowBox[{"1", "-", 
        SuperscriptBox["u", "2"]}]]], 
     RowBox[{"\[DifferentialD]", "u"}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", 
         RowBox[{"m", "*", 
          RowBox[{"u", "^", "2"}]}]}], "]"}], "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "j"}], "-", "1"}], ")"}]}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "-", 
        RowBox[{"u", "^", "2"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"u", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
   RowBox[{"S", "[", "j", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "3"}], "-", 
     RowBox[{"2", " ", "j"}]}], ")", 
    SubsuperscriptBox["S", "j", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{"4", "+", 
     RowBox[{"4", " ", "j"}], "-", 
     RowBox[{"2", " ", "m"}], "-", 
     RowBox[{"2", " ", "j", " ", "m"}]}], ")", 
    SubscriptBox["S", "j"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "-", 
     RowBox[{"2", " ", "j"}], "+", "m", "+", 
     RowBox[{"2", " ", "j", " ", "m"}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["Hence the desired recurrence is:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{
    RowBox[{"Factor", "[", 
     RowBox[{"First", "[", "%", "]"}], "]"}], ",", 
    RowBox[{"Int", "[", "j", "]"}]}], "]"}], "\[Equal]", "0"}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "j"}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "m"}], ")"}], " ", 
    RowBox[{"Int", "[", "j", "]"}]}], "-", 
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", "j"}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "+", "m"}], ")"}], " ", 
    RowBox[{"Int", "[", 
     RowBox[{"1", "+", "j"}], "]"}]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"2", " ", "j"}]}], ")"}], " ", 
    RowBox[{"Int", "[", 
     RowBox[{"2", "+", "j"}], "]"}]}]}], "\[Equal]", "0"}]], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Monthly Problem 11457", "Subsection"],

Cell["\<\
This problem has been proposed by M.L. Glasser in October 2009.
For  real numbers  0 \[LessEqual] a \[LessEqual] b:  \
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"ArcCos", "[", 
       RowBox[{"x", "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"a", "+", "b"}], ")"}], "*", "x"}], "-", 
          RowBox[{"a", "*", "b"}]}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}], "\[Equal]", 
    "\"\<?\>\""}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "a", "b"], 
     RowBox[{
      RowBox[{
       SuperscriptBox["cos", 
        RowBox[{"-", "1"}]], "(", 
       FractionBox["x", 
        SqrtBox[
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"a", "+", "b"}], ")"}], " ", "x"}], "-", 
          RowBox[{"a", " ", "b"}]}]]], ")"}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", "\<\"?\"\>"}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
An annihilating ideal for the integral can be computed completely \
automatically:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"ArcCos", "[", 
       RowBox[{"x", "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"a", "+", "b"}], ")"}], "*", "x"}], "-", 
          RowBox[{"a", "*", "b"}]}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"Der", "[", "b", "]"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"a", "\[GreaterEqual]", "0"}], "&&", 
      RowBox[{"b", "\[GreaterEqual]", "a"}]}]}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["a", "2"]}], "+", 
      SuperscriptBox["b", "2"]}], ")", 
     SubscriptBox["D", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "3"}], " ", "a"}], "-", "b"}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["a", "2"], "-", 
      SuperscriptBox["b", "2"]}], ")", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "a"}], "-", 
      RowBox[{"3", " ", "b"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Fortunately, we get two first-order differential equations, which can easily \
be solved:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ApplyOreOperator", "[", 
     RowBox[{
      RowBox[{"First", "[", "ann", "]"}], ",", 
      RowBox[{"f", "[", "b", "]"}]}], "]"}], "\[Equal]", "0"}], ",", 
   RowBox[{"f", "[", "b", "]"}], ",", "b"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"f", "[", "b", "]"}], "\[Rule]", 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "b"}], ")"}], "2"], " ", 
      RowBox[{"C", "[", "1", "]"}]}], 
     RowBox[{"a", "+", "b"}]]}], "}"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"solution", "=", 
  RowBox[{
   RowBox[{"f", "[", "b", "]"}], "/.", 
   RowBox[{"First", "[", "%", "]"}]}]}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "a"}], "+", "b"}], ")"}], "2"], " ", 
   RowBox[{"C", "[", "1", "]"}]}], 
  RowBox[{"a", "+", "b"}]]], "Output"]
}, Open  ]],

Cell["\<\
The above expression contains all factors that depend on b. In principle, \
C[1] still depends on a. So we compute a system of differential equations for \
\"the original solution divided by this part of the solution\". This system \
then will give us the only missing non-constant factors that depend on a (we \
see that there are none, so we have already the full solution).\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DFiniteTimes", "[", 
  RowBox[{"ann", ",", 
   RowBox[{"Annihilator", "[", 
    RowBox[{
     RowBox[{"1", "/", "solution"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Der", "[", "a", "]"}], ",", 
       RowBox[{"Der", "[", "b", "]"}]}], "}"}]}], "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SubscriptBox["D", "b"], ",", 
   SubscriptBox["D", "a"]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
By plugging in a=0 and b=1, the constant C[1] can be determined:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"solution", "\[Equal]", 
       RowBox[{"int", "[", 
        RowBox[{
         RowBox[{"ArcCos", "[", 
          RowBox[{"x", "/", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"a", "+", "b"}], ")"}], "*", "x"}], "-", 
             RowBox[{"a", "*", "b"}]}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}]}], ")"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"a", "\[Rule]", "0"}], ",", 
       RowBox[{"b", "\[Rule]", "1"}]}], "}"}]}], "/.", 
    RowBox[{"int", "\[Rule]", "Integrate"}]}], ",", 
   RowBox[{"C", "[", "1", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"C", "[", "1", "]"}], "\[Rule]", 
    FractionBox["\[Pi]", "4"]}], "}"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"solution", "=", 
  RowBox[{"solution", "/.", 
   RowBox[{"First", "[", "%", "]"}]}]}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "a"}], "+", "b"}], ")"}], "2"], " ", "\[Pi]"}], 
  RowBox[{"4", " ", 
   RowBox[{"(", 
    RowBox[{"a", "+", "b"}], ")"}]}]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Alternative (recursive) approach", "Subsubsection"],

Cell["\<\
We first derive only the differential equation in a. To determine its initial \
condition (for a=0), we recursively solve a similar problem, this time by \
computing a differential equation in b.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"de1", "=", 
  RowBox[{"First", "[", 
   RowBox[{"Annihilator", "[", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"ArcCos", "[", 
        RowBox[{"x", "/", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"a", "+", "b"}], ")"}], "*", "x"}], "-", 
           RowBox[{"a", "*", "b"}]}], "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "a", ",", "b"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"Der", "[", "a", "]"}], "}"}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{
       RowBox[{"a", "\[GreaterEqual]", "0"}], "&&", 
       RowBox[{"b", "\[GreaterEqual]", "a"}]}]}]}], "]"}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox["a", "2"], "-", 
    SuperscriptBox["b", "2"]}], ")", 
   SubscriptBox["D", "a"]}], "+", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "a"}], "-", 
    RowBox[{"3", " ", "b"}]}], ")"}]}]], "Output"]
}, Open  ]],

Cell["Now recursively solve the simpler problem (for a=0):", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"de2", "=", 
  RowBox[{"First", "[", 
   RowBox[{"Annihilator", "[", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"ArcCos", "[", 
        RowBox[{"x", "/", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"b", "*", "x"}], "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "b"}], "}"}]}], "]"}], ",", 
     RowBox[{"Der", "[", "b", "]"}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{"b", "\[GreaterEqual]", "0"}]}]}], "]"}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"b", 
   SubscriptBox["D", "b"]}], "-", "1"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"init2", "=", 
  RowBox[{
   RowBox[{"f", "[", "1", "]"}], "==", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"ArcCos", "[", 
      RowBox[{"Sqrt", "[", "x", "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "1", "]"}], "\[Equal]", 
  FractionBox["\[Pi]", "4"]}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"ApplyOreOperator", "[", 
       RowBox[{"de2", ",", 
        RowBox[{"f", "[", "b", "]"}]}], "]"}], "\[Equal]", "0"}], ",", 
     "init2"}], "}"}], ",", 
   RowBox[{"f", "[", "b", "]"}], ",", "b"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"f", "[", "b", "]"}], "\[Rule]", 
    FractionBox[
     RowBox[{"b", " ", "\[Pi]"}], "4"]}], "}"}], "}"}]], "Output"]
}, Open  ]],

Cell["Now the first differential equation can be solved:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"ApplyOreOperator", "[", 
       RowBox[{"de1", ",", 
        RowBox[{"f", "[", "a", "]"}]}], "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{
      RowBox[{"f", "[", "0", "]"}], "\[Equal]", 
      RowBox[{"b", "*", 
       RowBox[{"Pi", "/", "4"}]}]}]}], "}"}], ",", 
   RowBox[{"f", "[", "a", "]"}], ",", "a"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"f", "[", "a", "]"}], "\[Rule]", 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"a", "-", "b"}], ")"}], "2"], " ", "\[Pi]"}], 
     RowBox[{"4", " ", 
      RowBox[{"(", 
       RowBox[{"a", "+", "b"}], ")"}]}]]}], "}"}], "}"}]], "Output"]
}, Open  ]]
}, Closed]]
}, Closed]]
}, Open  ]],

Cell[CellGroupData[{

Cell["More advanced examples", "Section"],

Cell[CellGroupData[{

Cell["Wallis's Integral", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", "x", "]"}], "^", 
       RowBox[{"(", 
        RowBox[{"2", "m"}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", 
        RowBox[{"Pi", "/", "2"}]}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"Pi", "/", 
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "m"}], "+", "1"}], ")"}]}]}], "*", 
     RowBox[{"Binomial", "[", 
      RowBox[{
       RowBox[{"2", "m"}], ",", "m"}], "]"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", 
      FractionBox["\[Pi]", "2"]], 
     RowBox[{
      RowBox[{
       SuperscriptBox["cos", 
        RowBox[{"2", " ", "m"}]], "(", "x", ")"}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{"\[Pi]", " ", 
      TemplateBox[{RowBox[{"2", " ", "m"}],"m"},
       "Binomial"]}], 
     SuperscriptBox["2", 
      RowBox[{
       RowBox[{"2", " ", "m"}], "+", "1"}]]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " knows about this integral:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Cos", "[", "x", "]"}], "^", 
    RowBox[{"(", 
     RowBox[{"2", "m"}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", 
     RowBox[{"Pi", "/", "2"}]}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"Element", "[", 
      RowBox[{"m", ",", "Integers"}], "]"}], "&&", 
     RowBox[{"m", "\[GreaterEqual]", "0"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SqrtBox["\[Pi]"], " ", 
   RowBox[{"Gamma", "[", 
    RowBox[{
     FractionBox["1", "2"], "+", "m"}], "]"}]}], 
  RowBox[{"2", " ", 
   RowBox[{"Gamma", "[", 
    RowBox[{"1", "+", "m"}], "]"}]}]]], "Output"]
}, Open  ]],

Cell["The integrand is not \[PartialD]-finite:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Cos", "[", "x", "]"}], "^", 
    RowBox[{"(", 
     RowBox[{"2", "m"}], ")"}]}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "m", "]"}], ",", 
     RowBox[{"Der", "[", "x", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","nondf",
   "\"The expression \
\\!\\(\\*RowBox[{\\\"\\\\\\\"Cos[x]^(2*m)\\\\\\\"\\\"}]\\) is not recognized \
to be \[PartialD]-finite. The result might not generate a zero-dimensional \
ideal.\"",2,126,2,31736665789155565964,"Local"},
  "MessageTemplate"]], "Message", "MSG"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    SubscriptBox["S", "m"], 
    SubsuperscriptBox["D", "x", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "4"}], "-", 
     RowBox[{"8", " ", "m"}], "-", 
     RowBox[{"4", " ", 
      SuperscriptBox["m", "2"]}]}], ")", 
    SubscriptBox["S", "m"]}], "+", 
   RowBox[{"(", 
    RowBox[{"2", "+", 
     RowBox[{"6", " ", "m"}], "+", 
     RowBox[{"4", " ", 
      SuperscriptBox["m", "2"]}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Cos", "[", "x", "]"}], "^", 
    RowBox[{"(", 
     RowBox[{"2", "m"}], ")"}]}], ",", 
   RowBox[{"S", "[", "m", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SubscriptBox["S", "m"], "-", 
   SuperscriptBox[
    RowBox[{"Cos", "[", "x", "]"}], "2"]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Cos", "[", "x", "]"}], "^", 
    RowBox[{"(", 
     RowBox[{"2", "m"}], ")"}]}], ",", 
   RowBox[{"Der", "[", "x", "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","nondf",
   "\"The expression \
\\!\\(\\*RowBox[{\\\"\\\\\\\"Cos[x]^(2*m)\\\\\\\"\\\"}]\\) is not recognized \
to be \[PartialD]-finite. The result might not generate a zero-dimensional \
ideal.\"",2,128,3,31736665789155565964,"Local"},
  "MessageTemplate"]], "Message", "MSG"],

Cell[BoxData[
 RowBox[{"{", "}"}]], "Output"]
}, Open  ]],

Cell["\<\
In this special example, creative telescoping works, although by theory this \
is not guaranteed. Therefore we have to use the option Support in order to \
force some action.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CreativeTelescoping", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Cos", "[", "x", "]"}], "^", 
    RowBox[{"(", 
     RowBox[{"2", "m"}], ")"}]}], ",", 
   RowBox[{"Der", "[", "x", "]"}], ",", 
   RowBox[{"S", "[", "m", "]"}], ",", 
   RowBox[{"Support", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{
       RowBox[{"S", "[", "m", "]"}], "^", "2"}], ",", 
      RowBox[{
       RowBox[{"S", "[", "m", "]"}], "^", "3"}]}], "}"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","nondf",
   "\"The expression \
\\!\\(\\*RowBox[{\\\"\\\\\\\"Cos[x]^(2*m)\\\\\\\"\\\"}]\\) is not recognized \
to be \[PartialD]-finite. The result might not generate a zero-dimensional \
ideal.\"",2,129,4,31736665789155565964,"Local"},
  "MessageTemplate"]], "Message", "MSG"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "2"}], "-", 
       RowBox[{"2", " ", "m"}]}], ")", 
      SubscriptBox["S", "m"]}], "+", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"2", " ", "m"}]}], ")"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"-", 
     FractionBox["1", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", "m"}], ")"}]}]], 
     SubscriptBox["D", "x"], 
     SubscriptBox["S", "m"]}], "}"}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Takayama-style solution (sin(x) and cos(x) in the coefficients)\
\>", "Subsubsection"],

Cell["\<\
We can easily read off two relations for the integrand (although it is not \
\[PartialD]-finite --- that's why we allow sin(x) and cos(x) to appear in the \
coefficients):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"ToOrePolynomial", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{
         RowBox[{"m", "+", "1"}], ",", "x"}], "]"}], "\[Equal]", 
       RowBox[{
        RowBox[{
         RowBox[{"Cos", "[", "x", "]"}], "^", "2"}], "*", 
        RowBox[{"f", "[", 
         RowBox[{"m", ",", "x"}], "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "x", "]"}], "*", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"f", "[", 
           RowBox[{"m", ",", "x"}], "]"}], ",", "x"}], "]"}]}], "\[Equal]", 
       RowBox[{
        RowBox[{"-", "2"}], "*", "m", "*", 
        RowBox[{"Sin", "[", "x", "]"}], "*", 
        RowBox[{"f", "[", 
         RowBox[{"m", ",", "x"}], "]"}]}]}]}], "}"}], ",", 
    RowBox[{"f", "[", 
     RowBox[{"m", ",", "x"}], "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SubscriptBox["S", "m"], "-", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "x", "]"}], "2"]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"Cos", "[", "x", "]"}], 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"2", " ", "m", " ", 
     RowBox[{"Sin", "[", "x", "]"}]}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ApplyOreOperator", "[", 
   RowBox[{"ann", ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Cos", "[", "x", "]"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"2", "m"}], ")"}]}]}], "]"}], "//", "Simplify"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "0"}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
For Takayama's algorithm we have to include certain multiples (by sin(x) and \
cos(x)) to the set of relations (we fill them up to degree 2 in sin(x) and \
cos(x):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Join", "[", 
   RowBox[{"ann", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", "x", "]"}], "**", 
       RowBox[{"ann", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ",", 
      RowBox[{
       RowBox[{"Cos", "[", "x", "]"}], "**", 
       RowBox[{"ann", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SubscriptBox["S", "m"], "-", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "x", "]"}], "2"]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"Cos", "[", "x", "]"}], 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"2", " ", "m", " ", 
     RowBox[{"Sin", "[", "x", "]"}]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Cos", "[", "x", "]"}], " ", 
      RowBox[{"Sin", "[", "x", "]"}]}], 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"2", " ", "m", " ", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "x", "]"}], "2"]}]}], ",", 
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"Cos", "[", "x", "]"}], "2"], 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"2", " ", "m", " ", 
     RowBox[{"Cos", "[", "x", "]"}], " ", 
     RowBox[{"Sin", "[", "x", "]"}]}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
In order to separate the delta part (that has the form Der[x]*(...)) we \
commute Der[x] to the left and set it to 0:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"ChangeOreAlgebra", "[", 
   RowBox[{"ann", ",", 
    RowBox[{"OreAlgebra", "[", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"Sin", "[", "x", "]"}], ",", 
      RowBox[{"Cos", "[", "x", "]"}], ",", 
      RowBox[{"S", "[", "m", "]"}]}], "]"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox[
      RowBox[{"Cos", "[", "x", "]"}], "2"]}], "+", 
    SubscriptBox["S", "m"]}], ",", 
   RowBox[{
    RowBox[{
     SubscriptBox["D", "x"], 
     RowBox[{"Cos", "[", "x", "]"}]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "m"}]}], ")", 
     RowBox[{"Sin", "[", "x", "]"}]}]}], ",", 
   RowBox[{
    RowBox[{
     SubscriptBox["D", "x"], 
     RowBox[{"Sin", "[", "x", "]"}], 
     RowBox[{"Cos", "[", "x", "]"}]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "x", "]"}], "2"]}], "-", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "x", "]"}], "2"]}], ",", 
   RowBox[{
    RowBox[{
     SubscriptBox["D", "x"], 
     SuperscriptBox[
      RowBox[{"Cos", "[", "x", "]"}], "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"2", " ", "m"}]}], ")", 
     RowBox[{"Sin", "[", "x", "]"}], 
     RowBox[{"Cos", "[", "x", "]"}]}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"OrePolynomialSubstitute", "[", 
   RowBox[{"ann", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], "\[Rule]", "0"}], "}"}]}], 
   "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox[
      RowBox[{"Cos", "[", "x", "]"}], "2"]}], "+", 
    SubscriptBox["S", "m"]}], ",", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"2", " ", "m"}]}], ")", 
    RowBox[{"Sin", "[", "x", "]"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "x", "]"}], "2"]}], "-", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "x", "]"}], "2"]}], ",", 
   RowBox[{"(", 
    RowBox[{"2", "+", 
     RowBox[{"2", " ", "m"}]}], ")", 
    RowBox[{"Sin", "[", "x", "]"}], 
    RowBox[{"Cos", "[", "x", "]"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[TextData[{
 "The above steps somehow let ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " forget about the relations between sine and cosine since they are now \
treated as independent elements of the algebra. Hence we shall not forget to \
include the Pythagorean identity:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"AppendTo", "[", 
  RowBox[{"ann", ",", 
   RowBox[{
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], "^", "2"}], "+", 
    RowBox[{
     RowBox[{"Cos", "[", "x", "]"}], "^", "2"}], "-", "1"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox[
      RowBox[{"Cos", "[", "x", "]"}], "2"]}], "+", 
    SubscriptBox["S", "m"]}], ",", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"2", " ", "m"}]}], ")", 
    RowBox[{"Sin", "[", "x", "]"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "x", "]"}], "2"]}], "-", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "x", "]"}], "2"]}], ",", 
   RowBox[{"(", 
    RowBox[{"2", "+", 
     RowBox[{"2", " ", "m"}]}], ")", 
    RowBox[{"Sin", "[", "x", "]"}], 
    RowBox[{"Cos", "[", "x", "]"}]}], ",", 
   RowBox[{
    RowBox[{"-", "1"}], "+", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "x", "]"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"Sin", "[", "x", "]"}], "2"]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Now it is a simple exercise to eliminate sin(x) and cos(x), but without \
multiplying by them:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ann", "[", 
   RowBox[{"[", "3", "]"}], "]"}], "-", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"2", "m"}], "+", "1"}], ")"}], "**", 
   RowBox[{"ann", "[", 
    RowBox[{"[", "5", "]"}], "]"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "2"}], "-", 
    RowBox[{"2", " ", "m"}]}], ")", 
   SuperscriptBox[
    RowBox[{"Cos", "[", "x", "]"}], "2"]}], "+", 
  RowBox[{"(", 
   RowBox[{"1", "+", 
    RowBox[{"2", " ", "m"}]}], ")"}]}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"%", "-", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"2", "m"}], "+", "2"}], ")"}], "**", 
   RowBox[{"ann", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "2"}], "-", 
    RowBox[{"2", " ", "m"}]}], ")", 
   SubscriptBox["S", "m"]}], "+", 
  RowBox[{"(", 
   RowBox[{"1", "+", 
    RowBox[{"2", " ", "m"}]}], ")"}]}]], "Output"]
}, Open  ]],

Cell["\<\
Alternatively, the elimination of course can be achieved by \
Gr\[ODoubleDot]bner bases:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"OreGroebnerBasis", "[", 
  RowBox[{"ann", ",", 
   RowBox[{"OreAlgebra", "[", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", 
     RowBox[{"Cos", "[", "x", "]"}], ",", 
     RowBox[{"S", "[", "m", "]"}]}], "]"}], ",", 
   RowBox[{"MonomialOrder", "\[Rule]", 
    RowBox[{"EliminationOrder", "[", "2", "]"}]}], ",", 
   RowBox[{"ModuleBasis", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2"}], "}"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SubscriptBox["S", "m"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", 
      RowBox[{"2", " ", "m"}]}], ")"}]}], ",", 
   RowBox[{"Sin", "[", "x", "]"}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "-", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SuperscriptBox[
      RowBox[{"Cos", "[", "x", "]"}], "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", " ", "m"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"Sin", "[", "x", "]"}], 
    RowBox[{"Cos", "[", "x", "]"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "-", 
      RowBox[{"2", " ", "m"}]}], ")", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "x", "]"}], "2"]}], "+", "1"}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
All the above steps are done when calling the command Takayama:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Takayama", "[", 
  RowBox[{
   RowBox[{"ToOrePolynomial", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{
         RowBox[{"Cos", "[", "x", "]"}], "^", "2"}]}], "+", 
       RowBox[{"S", "[", "m", "]"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Cos", "[", "x", "]"}], " ", 
        RowBox[{"Der", "[", "x", "]"}]}], "+", 
       RowBox[{"2", " ", "m", " ", 
        RowBox[{"Sin", "[", "x", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Sin", "[", "x", "]"}], "^", "2"}], "+", 
       RowBox[{
        RowBox[{"Cos", "[", "x", "]"}], "^", "2"}], "-", "1"}]}], "}"}], 
    "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", 
     RowBox[{"Cos", "[", "x", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"2", "+", 
     RowBox[{"2", " ", "m"}]}], ")", 
    SubscriptBox["S", "m"]}], "+", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "-", 
     RowBox[{"2", " ", "m"}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],


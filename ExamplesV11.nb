}, Closed]],

Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", "0"}], "\[Infinity]"], 
     FractionBox[
      RowBox[{
       RowBox[{
        SubscriptBox["H", "n"], "(", "x", ")"}], " ", 
       RowBox[{
        SubscriptBox["H", "n"], "(", "y", ")"}], " ", 
       SuperscriptBox["t", "n"]}], 
      RowBox[{"n", "!"}]]}], "\[LongEqual]", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"1", "-", 
        RowBox[{"4", " ", 
         SuperscriptBox["t", "2"]}]}]]], " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       SuperscriptBox["y", "2"], "-", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"y", "-", 
           RowBox[{"2", " ", "x", " ", "t"}]}], ")"}], "2"], 
        RowBox[{"1", "-", 
         RowBox[{"4", " ", 
          SuperscriptBox["t", "2"]}]}]]}]]}]}],
   HoldForm], TraditionalForm]], "Output",
 CellChangeTimes->{3.417926016307496*^9}]], "Subsection"],

Cell["This example is taken from A=B, p. 197.", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"HermiteH", "[", 
        RowBox[{"n", ",", "x"}], "]"}], "*", 
       RowBox[{"HermiteH", "[", 
        RowBox[{"n", ",", "y"}], "]"}], "*", 
       RowBox[{
        RowBox[{"t", "^", "n"}], "/", 
        RowBox[{"n", "!"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "==", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"4", 
         RowBox[{"t", "^", "2"}]}]}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "2"}], ")"}]}], "*", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"y", "^", "2"}], "-", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", "-", 
           RowBox[{"2", "*", "x", "*", "t"}]}], ")"}], "^", "2"}], "/", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"4", 
           RowBox[{"t", "^", "2"}]}]}], ")"}]}]}], "]"}]}]}], "]"}], "//", 
  "TraditionalForm"}]], "Input"],

Cell[BoxData[
 FormBox[

Cell[CellGroupData[{

Cell[TextData[{
 "[98b]: Contiguous relations for the Appell ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "4"], TraditionalForm]], "None"],
 " hypergeometric function"
}], "Subsection"],

Cell[TextData[{
 "We consider the Appell ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "4"], TraditionalForm]]],
 " function that is defined as"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Subscript", "[", 
      RowBox[{"F", ",", "4"}], "]"}], "[", 
     RowBox[{"a", ",", "b", ",", "c", ",", "d", ",", "x", ",", "y"}], "]"}], 
    "\[Equal]", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Pochhammer", "[", 
        RowBox[{"a", ",", 
         RowBox[{"m", "+", "n"}]}], "]"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Pochhammer", "[", 
            RowBox[{"b", ",", 
             RowBox[{"m", "+", "n"}]}], "]"}], "/", 
           RowBox[{"m", "!"}]}], "/", 
          RowBox[{"n", "!"}]}], "/", 
         RowBox[{"Pochhammer", "[", 
          RowBox[{"c", ",", "m"}], "]"}]}], "/", 
        RowBox[{"Pochhammer", "[", 
         RowBox[{"d", ",", "n"}], "]"}]}], "*", 
       RowBox[{"x", "^", "m"}], "*", 
       RowBox[{"y", "^", "n"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", "0", ",", "Infinity"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubscriptBox["F", "4"], "(", 
     RowBox[{"a", ",", "b", ",", "c", ",", "d", ",", "x", ",", "y"}], ")"}], 
    "\[LongEqual]", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"m", "=", "0"}], "\[Infinity]"], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"n", "=", "0"}], "\[Infinity]"], 
      FractionBox[
       RowBox[{
        TemplateBox[{"a",RowBox[{"m", "+", "n"}]},
         "Pochhammer"], " ", 
        TemplateBox[{"b",RowBox[{"m", "+", "n"}]},
         "Pochhammer"], " ", 
        SuperscriptBox["x", "m"], " ", 
        SuperscriptBox["y", "n"]}], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"m", "!"}], " ", 
            RowBox[{"n", "!"}]}], ")"}], " ", 
          TemplateBox[{"c","m"},
           "Pochhammer"]}], ")"}], " ", 
        TemplateBox[{"d","n"},
         "Pochhammer"]}]]}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[TextData[{
 "These annihilating operators for the Appell ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "4"], TraditionalForm]]],
 " function are given in Chyzak98b, formula (0.3):"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ops", "=", 
  RowBox[{"ToOrePolynomial", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "**", 
       RowBox[{"Der", "[", "x", "]"}], "**", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "**", 
          RowBox[{"Der", "[", "x", "]"}]}], "+", "c", "-", "1"}], ")"}]}], 
      "-", 
      RowBox[{"x", "**", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "**", 
          RowBox[{"Der", "[", "x", "]"}]}], "+", 
         RowBox[{"y", "**", 
          RowBox[{"Der", "[", "y", "]"}]}], "+", "a"}], ")"}], "**", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "**", 
          RowBox[{"Der", "[", "x", "]"}]}], "+", 
         RowBox[{"y", "**", 
          RowBox[{"Der", "[", "y", "]"}]}], "+", "b"}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{"y", "**", 
       RowBox[{"Der", "[", "y", "]"}], "**", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"y", "**", 
          RowBox[{"Der", "[", "y", "]"}]}], "+", "d", "-", "1"}], ")"}]}], 
      "-", 
      RowBox[{"y", "**", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "**", 
          RowBox[{"Der", "[", "x", "]"}]}], "+", 
         RowBox[{"y", "**", 
          RowBox[{"Der", "[", "y", "]"}]}], "+", "a"}], ")"}], "**", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "**", 
          RowBox[{"Der", "[", "x", "]"}]}], "+", 
         RowBox[{"y", "**", 
          RowBox[{"Der", "[", "y", "]"}]}], "+", "b"}], ")"}]}]}]}], "}"}], 
   "]"}]}]], "Input"],


Cell["\<\
The annihilating ideal for the right-hand side can be obtained immediately:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rhs", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"t", "^", "2"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"2", "*", "t", "*", "x"}], "+", 
         RowBox[{"t", "^", "2"}]}], ")"}]}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{"n", "-", "1"}], ")"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "n", "]"}], ",", 
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"Der", "[", "t", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["t", "4"], "+", 
      RowBox[{"2", " ", "t", " ", "x"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["t", "3"], " ", "x"}]}], ")", 
     SubscriptBox["D", "t"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"4", " ", "t"}], "-", 
      RowBox[{"4", " ", "n", " ", "t"}], "-", 
      RowBox[{"2", " ", "x"}], "+", 
      RowBox[{"2", " ", "n", " ", "x"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["t", "2"], " ", "x"}], "+", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["t", "2"], " ", "x"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["t", "2"], "-", 
      RowBox[{"2", " ", "t", " ", "x"}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "t"}], "-", 
      RowBox[{"2", " ", "n", " ", "t"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["t", "2"], "-", 
      RowBox[{"2", " ", "t", " ", "x"}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["t", "2"]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],


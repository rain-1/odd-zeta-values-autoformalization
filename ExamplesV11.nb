Cell[CellGroupData[{

Cell["Final solution of Boros and Moll", "Subsubsection"],

Cell["\<\
In the above mentioned book, the following evaluation of the integral is \
given.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"mollsol", "=", 
   RowBox[{"Pi", "*", 
    RowBox[{
     RowBox[{
      RowBox[{"JacobiP", "[", 
       RowBox[{"m", ",", 
        RowBox[{"m", "+", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{
         RowBox[{"-", "m"}], "-", 
         RowBox[{"1", "/", "2"}]}], ",", "a"}], "]"}], "/", 
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{"m", "+", 
         RowBox[{"3", "/", "2"}]}], ")"}]}]}], "/", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"m", "+", 
        RowBox[{"1", "/", "2"}]}], ")"}]}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[Pi]", " ", 
   SuperscriptBox["2", 
    RowBox[{
     RowBox[{"-", "m"}], "-", 
     FractionBox["3", "2"]}]], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"a", "+", "1"}], ")"}], 
    RowBox[{
     RowBox[{"-", "m"}], "-", 
     FractionBox["1", "2"]}]], " ", 
   RowBox[{
    SubsuperscriptBox["P", "m", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"m", "+", 
        FractionBox["1", "2"]}], ",", 
       RowBox[{
        RowBox[{"-", "m"}], "-", 
        FractionBox["1", "2"]}]}], ")"}]], "(", "a", ")"}]}], 
  TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
We can immediately prove that it is correct (and hence equivalent to the \
evaluation that we found)\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{"mollsol", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "m", "]"}], ",", 
     RowBox[{"Der", "[", "a", "]"}]}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"4", "+", 
      RowBox[{"4", " ", "m"}]}], ")", 
     SubscriptBox["S", "m"]}], "-", 
    RowBox[{
     RowBox[{"2", " ", "a"}], 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"4", " ", "m"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "4"}], "+", 
      RowBox[{"4", " ", 
       SuperscriptBox["a", "2"]}]}], ")", 
     SubsuperscriptBox["D", "a", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"12", " ", "a"}], "+", 
      RowBox[{"8", " ", "a", " ", "m"}]}], ")", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{"3", "+", 
      RowBox[{"4", " ", "m"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GBEqual", "[", 
  RowBox[{"%", ",", "ann"}], "]"}]], "Input"],

Cell[BoxData["True"], "Output"]

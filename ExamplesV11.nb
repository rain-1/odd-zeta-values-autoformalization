Cell[CellGroupData[{

Cell["Zeta and Beta", "Subsection"],

Cell["\<\
This example can be found in \"Espinosa/Moll:  On some definite integrals \
involving the Hurwitz zeta function. Part 1.\".
It also appeared in Bruno Salvy's FPSAC'09 talk.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", 
        RowBox[{"(", 
         RowBox[{"k", "-", "1"}], ")"}]}], " ", 
       RowBox[{"Zeta", "[", 
        RowBox[{"n", ",", 
         RowBox[{"a", "+", 
          RowBox[{"b", " ", "x"}]}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"b", "^", 
      RowBox[{"(", 
       RowBox[{"-", "k"}], ")"}]}], 
     RowBox[{"Beta", "[", 
      RowBox[{"k", ",", 
       RowBox[{"n", "-", "k"}]}], "]"}], " ", 
     RowBox[{"Zeta", "[", 
      RowBox[{
       RowBox[{"n", "-", "k"}], ",", "a"}], "]"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
     RowBox[{
      SuperscriptBox["x", 
       RowBox[{"k", "-", "1"}]], " ", 
      TemplateBox[{"n",RowBox[{"a", "+", 
          RowBox[{"b", " ", "x"}]}]},
       "Zeta2"], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     SuperscriptBox["b", 
      RowBox[{"-", "k"}]], " ", 
     TemplateBox[{"k",RowBox[{"n", "-", "k"}]},
      "Beta"], " ", 
     TemplateBox[{RowBox[{"n", "-", "k"}],"a"},
      "Zeta2"]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


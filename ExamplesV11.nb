 RowBox[{
  RowBox[{"stepDown", "=", 
   RowBox[{"OrePolynomialSubstitute", "[", 
    RowBox[{
     RowBox[{"Together", "[", 
      RowBox[{"stepDown", "/.", 
       RowBox[{"Thread", "[", 
        RowBox[{
         RowBox[{"Array", "[", 
          RowBox[{"c", ",", "4"}], "]"}], "\[Rule]", 
         RowBox[{"Most", "[", "solution", "]"}]}], "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"a", "\[Rule]", 
       RowBox[{"a", "-", "1"}]}], "}"}]}], "]"}]}], ";"}]], "Input"],

Cell["We want to have some empirical correctness of our result.", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"test", "=", 
   RowBox[{
    RowBox[{"ApplyOreOperator", "[", 
     RowBox[{"stepDown", ",", 
      RowBox[{
       RowBox[{"Pochhammer", "[", 
        RowBox[{"a", ",", 
         RowBox[{"m", "+", "n"}]}], "]"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Pochhammer", "[", 
            RowBox[{"b", ",", 
             RowBox[{"m", "+", "n"}]}], "]"}], "/", 
           RowBox[{"m", "!"}]}], "/", 
          RowBox[{"n", "!"}]}], "/", 
         RowBox[{"Pochhammer", "[", 
          RowBox[{"c", ",", "m"}], "]"}]}], "/", 
        RowBox[{"Pochhammer", "[", 
         RowBox[{"d", ",", "n"}], "]"}]}], "*", 
       RowBox[{"x", "^", "m"}], "*", 
       RowBox[{"y", "^", "n"}]}]}], "]"}], "-", 
    RowBox[{
     RowBox[{"Pochhammer", "[", 
      RowBox[{
       RowBox[{"a", "-", "1"}], ",", 
       RowBox[{"m", "+", "n"}]}], "]"}], "*", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Pochhammer", "[", 
          RowBox[{"b", ",", 
           RowBox[{"m", "+", "n"}]}], "]"}], "/", 
         RowBox[{"m", "!"}]}], "/", 
        RowBox[{"n", "!"}]}], "/", 
       RowBox[{"Pochhammer", "[", 
        RowBox[{"c", ",", "m"}], "]"}]}], "/", 
      RowBox[{"Pochhammer", "[", 
       RowBox[{"d", ",", "n"}], "]"}]}], "*", 
     RowBox[{"x", "^", "m"}], "*", 
     RowBox[{"y", "^", "n"}]}]}]}], ";"}]], "Input"],


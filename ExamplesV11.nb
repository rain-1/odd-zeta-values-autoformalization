     SubsuperscriptBox["D", "a", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"12", " ", "a"}], "+", 
      RowBox[{"8", " ", "a", " ", "m"}]}], ")", 
     SubscriptBox["D", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{"3", "+", 
      RowBox[{"4", " ", "m"}]}], ")"}]}]}], "}"}]], "Output"]

       RowBox[{"Binomial", "[", 
        RowBox[{"n", ",", "s"}], "]"}], 
       RowBox[{"Binomial", "[", 
        RowBox[{
         RowBox[{"n", "+", "r"}], ",", "r"}], "]"}], 
       RowBox[{"Binomial", "[", 
        RowBox[{
         RowBox[{"n", "+", "s"}], ",", "s"}], "]"}], 
       RowBox[{"Binomial", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"2", "n"}], "-", 
          RowBox[{"(", 
           RowBox[{"r", "+", "s"}], ")"}]}], ",", "n"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "0", ",", "n"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", "n"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Binomial", "[", 
        RowBox[{"n", ",", "k"}], "]"}], "^", "4"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"r", "=", "0"}], "n"], 

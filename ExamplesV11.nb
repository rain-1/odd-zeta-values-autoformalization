    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "-", 
      RowBox[{"2", " ", "n"}], "+", 
      RowBox[{"2", " ", "y"}], "+", 
      RowBox[{"2", " ", "n", " ", "y"}]}], ")", 
     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"(", 
     RowBox[{"n", "+", 
      SuperscriptBox["n", "2"]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"4", " ", "n"}], "+", 

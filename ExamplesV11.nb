Cell["\<\
4.7.1  product of BesselJ, trick to eliminate cos(theta) with ChebyshevT\
\>", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"BesselJ", "[", 
      RowBox[{"n", ",", "z"}], "]"}], "*", 
     RowBox[{"BesselJ", "[", 
      RowBox[{"m", ",", "z"}], "]"}]}], "\[Equal]", 
    RowBox[{
     RowBox[{"2", "/", "Pi"}], "*", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"BesselJ", "[", 
         RowBox[{
          RowBox[{"m", "+", "n"}], ",", 
          RowBox[{"2", "z", "*", 
           RowBox[{"Cos", "[", "theta", "]"}]}]}], "]"}], "*", 
        RowBox[{"Cos", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "n"}], ")"}], "*", "theta"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"theta", ",", "0", ",", 
         RowBox[{"Pi", "/", "2"}]}], "}"}]}], "]"}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"n","z"},
      "BesselJ"], " ", 
     TemplateBox[{"m","z"},
      "BesselJ"]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{"2", " ", 
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", 
        FractionBox["\[Pi]", "2"]], 
       RowBox[{
        RowBox[{
         TemplateBox[{RowBox[{"m", "+", "n"}],RowBox[{"2", " ", "z", " ", 
             RowBox[{"cos", "(", "theta", ")"}]}]},
          "BesselJ"], " ", 
         RowBox[{"cos", "(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"m", "-", "n"}], ")"}], " ", "theta"}], ")"}]}], 
        RowBox[{"\[DifferentialD]", "theta"}]}]}]}], "\[Pi]"]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
Trick: First substitute t=cos(theta), then rewrite cos((m-n) arccos(t)) to \
ChebyshevT[m-n,t]\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"BesselJ", "[", 
      RowBox[{"n", ",", "z"}], "]"}], "*", 
     RowBox[{"BesselJ", "[", 
      RowBox[{"m", ",", "z"}], "]"}]}], "\[Equal]", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "/", "Pi"}], ")"}], "*", 
       RowBox[{"BesselJ", "[", 
        RowBox[{
         RowBox[{"m", "+", "n"}], ",", 
         RowBox[{"2", "z", " ", "t"}]}], "]"}], "*", 
       RowBox[{
        RowBox[{"ChebyshevT", "[", 
         RowBox[{
          RowBox[{"m", "-", "n"}], ",", "t"}], "]"}], "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", 
          RowBox[{"t", "^", "2"}]}], "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "1"}], "}"}]}], "]"}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"n","z"},
      "BesselJ"], " ", 
     TemplateBox[{"m","z"},
      "BesselJ"]}], "\[LongEqual]", 
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "1"], 
     RowBox[{
      FractionBox[
       RowBox[{"2", " ", 
        TemplateBox[{
         RowBox[{"m", "+", "n"}],RowBox[{"2", " ", "z", " ", "t"}]},
         "BesselJ"], " ", 
        RowBox[{
         SubscriptBox["T", 
          RowBox[{"m", "-", "n"}]], "(", "t", ")"}]}], 
       RowBox[{"\[Pi]", " ", 
        SqrtBox[
         RowBox[{"1", "-", 
          SuperscriptBox["t", "2"]}]]}]], 
      RowBox[{"\[DifferentialD]", "t"}]}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


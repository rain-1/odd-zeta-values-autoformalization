Cell["\<\
For even n, there are two options. Using the expression as it is given \
(standard closure properties like Plus and Times will be applied), delivers a \
DE of order 3:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Sqrt", "[", "a", "]"}], "^", 
     RowBox[{"(", 
      RowBox[{"n", "/", "2"}], ")"}]}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"ChebyshevU", "[", 
       RowBox[{
        RowBox[{"n", "/", "2"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "^", "2"}], "-", "a", "-", "1"}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", 
           RowBox[{"Sqrt", "[", "a", "]"}]}], ")"}]}]}], "]"}], "+", 
      RowBox[{
       RowBox[{"Sqrt", "[", "a", "]"}], "*", 
       RowBox[{"ChebyshevU", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"n", "/", "2"}], "-", "1"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "2"}], "-", "a", "-", "1"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", 
            RowBox[{"Sqrt", "[", "a", "]"}]}], ")"}]}]}], "]"}]}]}], ")"}]}], 
   ",", 
   RowBox[{"Der", "[", "x", "]"}]}], "]"}]], "Input"],


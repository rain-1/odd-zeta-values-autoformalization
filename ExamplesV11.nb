    RowBox[{
     RowBox[{"-", "3"}], "+", 
     RowBox[{"2", " ", "d"}]}]], " ", 
   RowBox[{"Pochhammer", "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "-", "k"}], ",", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "d"}]}], "]"}], " ", 

     SubscriptBox["S", "n2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "3"}], "-", 
      RowBox[{"2", " ", "n1"}]}], ")", 
     SubscriptBox["S", "k1"], 
     SubscriptBox["S", "n1"], 
     SubscriptBox["S", "n2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "+", "n1"}], ")", 
     SubscriptBox["S", "k1"], 
     SubscriptBox["S", "n2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"3", "+", "n1", "+", "n2"}], ")", 
     SubscriptBox["S", "n1"], 
     SubscriptBox["S", "n2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "n2"}], ")", 
     SubscriptBox["S", "n1"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "n1"}], ")", 
     SubscriptBox["S", "n2"]}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "-", "n2"}], ")", 

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"HoldForm", "[", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "^", 
         RowBox[{"(", 
          RowBox[{"r", "-", "1"}], ")"}]}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "x"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"s", "-", "1"}], ")"}]}], 
        RowBox[{"Hypergeometric2F1", "[", 
         RowBox[{"a", ",", "b", ",", "c", ",", "x"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}], "\[Equal]", 
     RowBox[{
      RowBox[{"Gamma", "[", "r", "]"}], " ", 
      RowBox[{
       RowBox[{"Gamma", "[", "s", "]"}], "/", 
       RowBox[{"Gamma", "[", 
        RowBox[{"r", "+", "s"}], "]"}]}], " ", 
      RowBox[{"HypergeometricPFQ", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"a", ",", "b", ",", "r"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"c", ",", 
          RowBox[{"r", "+", "s"}]}], "}"}], ",", "1"}], "]"}]}]}], "]"}], "//",
    "TraditionalForm"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Re", "[", "r", "]"}], ">", "0"}], ",", " ", 
    RowBox[{
     RowBox[{"Re", "[", "s", "]"}], ">", "0"}], ",", " ", 
    RowBox[{
     RowBox[{"Re", "[", 
      RowBox[{"c", "+", "s", "-", "a", "-", "b"}], "]"}], ">", "0"}]}], " ", 
   "*)"}], "\[IndentingNewLine]"}]], "Input"],


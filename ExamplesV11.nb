Cell["\<\
Module backwards shifting (and some typos) this list corresponds exactly to \
the one given in Gau\[SZ]'s paper \"Disquisitiones generales circa series \
infinitam ...\", 1813.\
\>", "Text"]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
Recurrence obtained from creative telescoping can overshoot arbitrarily\
\>", "Subsection"],

Cell["\<\
The following sum is a classical example for the fact creative telescoping \
does not necessarily deliver the minimal recurrence for the sum/integral. By \
looping over the order of the principal part, it is guaranteed that the \
creative telescoping relation with the smallest principal part is found. \
However, it might well be, that the sum itself allows a shorter recurrence.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "^", "k"}], " ", "*", 
       RowBox[{"Binomial", "[", 
        RowBox[{"n", ",", "k"}], "]"}], "*", " ", 
       RowBox[{"Binomial", "[", 
        RowBox[{
         RowBox[{"d", "*", "k"}], ",", "n"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "n"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "d"}], ")"}], "^", "n"}]}], "]"}], "//", 
  "TraditionalForm"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], "n"], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "k"], " ", 
      TemplateBox[{"n","k"},
       "Binomial"], " ", 
      TemplateBox[{RowBox[{"d", " ", "k"}],"n"},
       "Binomial"]}]}], "\[LongEqual]", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"-", "d"}], ")"}], "n"]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
Obviously, for any integer d, this sum satisfies a first-order recurrence. \
But for d>1 creative telescoping will deliver a recurrence of order d-1, \
showing that we can overshoot arbitrarily much.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"LeadingPowerProduct", "[", 
    RowBox[{
     RowBox[{"CreativeTelescoping", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "k"}], " ", "*", 
        RowBox[{"Binomial", "[", 
         RowBox[{"n", ",", "k"}], "]"}], "*", " ", 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"d", "*", "k"}], ",", "n"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"S", "[", "k", "]"}], "-", "1"}], ",", 
       RowBox[{"S", "[", "n", "]"}]}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"d", ",", "2", ",", "10"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SubscriptBox["S", "n"], ",", 
   SubsuperscriptBox["S", "n", "2"], ",", 
   SubsuperscriptBox["S", "n", "3"], ",", 
   SubsuperscriptBox["S", "n", "4"], ",", 
   SubsuperscriptBox["S", "n", "5"], ",", 
   SubsuperscriptBox["S", "n", "6"], ",", 
   SubsuperscriptBox["S", "n", "7"], ",", 
   SubsuperscriptBox["S", "n", "8"], ",", 
   SubsuperscriptBox["S", "n", "9"]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Note: Also Zeilberger's slow or Takayama's algorithm do not improve this \
situation.\
\>", "Text"],

Cell["\<\
Second note: Also for integrals, similar things can happen, as the following \
example demonstrates:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"LeadingPowerProduct", "[", 
    RowBox[{"First", "[", 
     RowBox[{"Annihilator", "[", 
      RowBox[{
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"1", "/", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"x", "^", "2"}], "+", "1"}], ")"}], "^", 
            RowBox[{"(", 
             RowBox[{"n", "+", "1"}], ")"}]}]}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "d"}], "+", "1"}], ")"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
       RowBox[{"S", "[", "n", "]"}], ",", 
       RowBox[{"Assumptions", "\[Rule]", 
        RowBox[{"n", "\[GreaterEqual]", "0"}]}]}], "]"}], "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"d", ",", "0", ",", "10"}], "}"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   SubscriptBox["S", "n"], ",", 
   SubsuperscriptBox["S", "n", "3"], ",", 
   SubscriptBox["S", "n"], ",", 
   SubsuperscriptBox["S", "n", "5"], ",", 
   SubsuperscriptBox["S", "n", "3"], ",", 
   SubsuperscriptBox["S", "n", "7"], ",", 
   SubsuperscriptBox["S", "n", "3"], ",", 
   SubsuperscriptBox["S", "n", "9"], ",", 
   SubsuperscriptBox["S", "n", "5"], ",", 
   SubsuperscriptBox["S", "n", "11"], ",", 
   SubsuperscriptBox["S", "n", "5"]}], "}"}]], "Output"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Takayama runs for ever due to extension/contraction", "Subsection"],

Cell["\<\
We want to integrate a simple rational function with Takayama's algorithm.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann1", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"y", "^", "2"}]}], ")"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"Der", "[", "y", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["y", "2"]}], ")", 
     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"2", " ", "y"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["y", "2"]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"2", " ", "x"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Takayama's algorithm runs into an infinite loop (due to \
extension/contraction).\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TimeConstrained", "[", 
  RowBox[{
   RowBox[{"Takayama", "[", 
    RowBox[{"ann1", ",", 
     RowBox[{"{", "x", "}"}]}], "]"}], ",", "10"}], "]"}]], "Input"],

Cell[BoxData["$Aborted"], "Output"]
}, Open  ]],

Cell["\<\
Singular's output of the full annihilator of 1/(x^2+y^2) in the polynomial \
Weyl algebra (using the command annfs of the library dmod.lib):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann2", "=", 
  RowBox[{"ToOrePolynomial", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"y", "*", 
        RowBox[{"Der", "[", "x", "]"}]}], "-", 
       RowBox[{"x", "*", 
        RowBox[{"Der", "[", "y", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{"x", "*", 
        RowBox[{"Der", "[", "x", "]"}]}], "+", 
       RowBox[{"y", "*", 
        RowBox[{"Der", "[", "y", "]"}]}], "+", "2"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "^", "2"}], "*", 
        RowBox[{"Der", "[", "y", "]"}]}], "+", 
       RowBox[{
        RowBox[{"y", "^", "2"}], "*", 
        RowBox[{"Der", "[", "y", "]"}]}], "+", 
       RowBox[{"2", "*", "y"}]}]}], "}"}], ",", 
    RowBox[{"OreAlgebra", "[", 
     RowBox[{
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"Der", "[", "y", "]"}]}], "]"}]}], "]"}]}]], "Input"],


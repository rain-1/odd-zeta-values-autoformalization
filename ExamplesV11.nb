Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Collect", "[", 
     RowBox[{"#", ",", 
      RowBox[{"ph", "[", "_", "]"}], ",", "Factor"}], "]"}], "&"}], "/@", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"ApplyOreOperator", "[", 
          RowBox[{
           RowBox[{"First", "[", 
            RowBox[{"FindRelation", "[", 
             RowBox[{"phat", ",", 
              RowBox[{"Pattern", "\[Rule]", 
               RowBox[{"{", 
                RowBox[{"0", ",", "_", ",", "0"}], "}"}]}]}], "]"}], "]"}], 
           ",", 
           RowBox[{"ph", "[", "n", "]"}]}], "]"}], "/.", 
         RowBox[{"n", "\[Rule]", 
          RowBox[{"n", "-", "1"}]}]}], ")"}], "\[Equal]", "0"}], ",", 
      RowBox[{"ph", "[", 
       RowBox[{"n", "+", "1"}], "]"}]}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "/.", 
  RowBox[{"Rule", "\[Rule]", "Equal"}]}]], "Input"],


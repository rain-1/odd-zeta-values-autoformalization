Cell["\<\
Obviously, on the right hand side there is a factor 2 missing. Hence we found \
a misprint in the Gradshteyn/Ryzhik book.\
\>", "Text"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[{
 "7.349  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"-", "1"}], "1"], 
     RowBox[{
      FractionBox[
       RowBox[{
        SubscriptBox["T", "n"], "(", 
        RowBox[{"1", "-", 
         RowBox[{
          SuperscriptBox["x", "2"], " ", "y"}]}], ")"}], 
       SqrtBox[
        RowBox[{"1", "-", 
         SuperscriptBox["x", "2"]}]]], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{"\[Pi]", " ", 
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{"n",RowBox[{"1", "-", "y"}]},
         "LegendreP"], "+", 
        TemplateBox[{RowBox[{"n", "-", "1"}],RowBox[{"1", "-", "y"}]},
         "LegendreP"]}], ")"}]}], "2"]}], TraditionalForm]], "Output",
  CellChangeTimes->{3.466266848673853*^9}]
}], "Subsection"],

Cell["On page 801, we find:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ChebyshevT", "[", 
        RowBox[{"n", ",", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"x", "^", "2"}], " ", "y"}]}]}], "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", 
         RowBox[{"x", "^", "2"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"Pi", "/", "2"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"LegendreP", "[", 
        RowBox[{"n", ",", 
         RowBox[{"1", "-", "y"}]}], "]"}], "+", 
       RowBox[{"LegendreP", "[", 
        RowBox[{
         RowBox[{"n", "-", "1"}], ",", 
         RowBox[{"1", "-", "y"}]}], "]"}]}], ")"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"-", "1"}], "1"], 
     RowBox[{
      FractionBox[
       RowBox[{
        SubscriptBox["T", "n"], "(", 
        RowBox[{"1", "-", 
         RowBox[{
          SuperscriptBox["x", "2"], " ", "y"}]}], ")"}], 
       SqrtBox[
        RowBox[{"1", "-", 
         SuperscriptBox["x", "2"]}]]], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     FractionBox["1", "2"], " ", "\[Pi]", " ", 
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"n",RowBox[{"1", "-", "y"}]},
        "LegendreP"], "+", 
       TemplateBox[{RowBox[{"n", "-", "1"}],RowBox[{"1", "-", "y"}]},
        "LegendreP"]}], ")"}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
We get two creative telescoping  relations for the integrand.\
\>", "Text"],


Cell[CellGroupData[{

Cell["Some identities for Jacobi polynomials", "Subsection"],

Cell["\<\
In Veronika Pillwein's thesis \"Computer algebra tools for special functions \
in high order finite element methods\", we find the following identities for \
Jacobi polynomials. We start with computing (actually, looking up) an \
annihilating ideal for Jacobi polynomials.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{"JacobiP", "[", 
     RowBox[{"n", ",", "a", ",", "b", ",", "x"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "a", "]"}], ",", 
      RowBox[{"S", "[", "b", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}], ",", 
      RowBox[{"Der", "[", "x", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"2", " ", "a"}], "+", 
      RowBox[{"2", " ", "b"}], "+", 
      RowBox[{"4", " ", "n"}], "+", 
      RowBox[{"2", " ", "a", " ", "n"}], "+", 
      RowBox[{"2", " ", "b", " ", "n"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"]}]}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{"2", "+", "a", "+", "b", "+", 
      RowBox[{"2", " ", "n"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"a", " ", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"b", " ", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"2", " ", "n", " ", 
       SuperscriptBox["x", "2"]}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "a"}], "-", 
      SuperscriptBox["a", "2"], "+", "b", "+", 
      SuperscriptBox["b", "2"], "-", 
      RowBox[{"a", " ", "n"}], "+", 
      RowBox[{"b", " ", "n"}], "-", 
      RowBox[{"2", " ", "x"}], "-", 
      RowBox[{"3", " ", "a", " ", "x"}], "-", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "x"}], "-", 
      RowBox[{"3", " ", "b", " ", "x"}], "-", 
      RowBox[{"2", " ", "a", " ", "b", " ", "x"}], "-", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", "x"}], "-", 
      RowBox[{"4", " ", "n", " ", "x"}], "-", 
      RowBox[{"3", " ", "a", " ", "n", " ", "x"}], "-", 
      RowBox[{"3", " ", "b", " ", "n", " ", "x"}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["n", "2"], " ", "x"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", "a", "+", "b", "+", "n"}], ")", 
     SubscriptBox["S", "b"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "-", "x"}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "a", "-", "b", "-", "n"}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", "a", "+", "b", "+", "n"}], ")", 
     SubscriptBox["S", "a"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "x"}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "-", "a", "-", "b", "-", "n"}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["x", "2"]}], ")", 
     SubsuperscriptBox["D", "x", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"a", "-", "b", "+", 
      RowBox[{"2", " ", "x"}], "+", 
      RowBox[{"a", " ", "x"}], "+", 
      RowBox[{"b", " ", "x"}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "n"}], "-", 
      RowBox[{"a", " ", "n"}], "-", 
      RowBox[{"b", " ", "n"}], "-", 
      SuperscriptBox["n", "2"]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
For some identities, we give several ways how to obtain them.\
\>", "Text"],

Cell[CellGroupData[{

Cell["Formula (4.5)", "Subsubsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"JacobiP", "[", 
       RowBox[{"n", ",", "a", ",", "b", ",", "x"}], "]"}], ",", "x"}], "]"}], 
    "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"n", "+", "a", "+", "b", "+", "1"}], ")"}], "/", "2"}], "*", 
     RowBox[{"JacobiP", "[", 
      RowBox[{
       RowBox[{"n", "-", "1"}], ",", 
       RowBox[{"a", "+", "1"}], ",", 
       RowBox[{"b", "+", "1"}], ",", "x"}], "]"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[PartialD]", 
      RowBox[{
       SubsuperscriptBox["P", "n", 
        RowBox[{"(", 
         RowBox[{"a", ",", "b"}], ")"}]], "(", "x", ")"}]}], 
     RowBox[{"\[PartialD]", "x"}],
     MultilineFunction->None], "\[LongEqual]", 
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"(", 
      RowBox[{"n", "+", "a", "+", "b", "+", "1"}], ")"}], " ", 
     RowBox[{
      SubsuperscriptBox["P", 
       RowBox[{"n", "-", "1"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"a", "+", "1"}], ",", 
         RowBox[{"b", "+", "1"}]}], ")"}]], "(", "x", ")"}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindRelation", "[", 
  RowBox[{"ann", ",", 
   RowBox[{"Support", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Der", "[", "x", "]"}], "*", 
       RowBox[{"S", "[", "n", "]"}]}], ",", 
      RowBox[{
       RowBox[{"S", "[", "a", "]"}], "*", 
       RowBox[{"S", "[", "b", "]"}]}]}], "}"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "2"}], "-", "a", "-", "b", "-", "n"}], ")", 
    SubscriptBox["S", "a"], 
    SubscriptBox["S", "b"]}], "+", 
   RowBox[{"2", 
    SubscriptBox["S", "n"], 
    SubscriptBox["D", "x"]}]}], "}"}]], "Output"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Formula (4.6)", "Subsubsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "x"}], ")"}], "*", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"JacobiP", "[", 
        RowBox[{"a", ",", "b", ",", "n", ",", "x"}], "]"}], ",", "x"}], 
      "]"}]}], "\[Equal]", 
    RowBox[{
     RowBox[{"a", "*", 
      RowBox[{"JacobiP", "[", 
       RowBox[{"n", ",", "a", ",", "b", ",", "x"}], "]"}]}], "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"n", "+", "a"}], ")"}], "*", 
      RowBox[{"JacobiP", "[", 
       RowBox[{"n", ",", 
        RowBox[{"a", "-", "1"}], ",", 
        RowBox[{"b", "+", "1"}], ",", "x"}], "]"}]}]}]}], "]"}], 
  "]"}]], "Input"],


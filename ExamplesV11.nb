Cell[CellGroupData[{

Cell["Krawtchouk and Meixner polynomials", "Subsection"],

Cell[TextData[{
 "We find that all three definitions given on ",
 StyleBox["MathWorld",
  FontSlant->"Italic"],
 " are equivalent:"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Superscript", "[", 
      RowBox[{
       RowBox[{"Subscript", "[", 
        RowBox[{"k", ",", "n"}], "]"}], ",", "\"\<(p)\>\""}], "]"}], "[", 
     RowBox[{"x", ",", "nn"}], "]"}], "\[Equal]", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "v"}], ")"}]}], "*", 
       RowBox[{"Binomial", "[", 
        RowBox[{
         RowBox[{"nn", "-", "x"}], ",", 
         RowBox[{"n", "-", "v"}]}], "]"}], "*", 
       RowBox[{"Binomial", "[", 
        RowBox[{"x", ",", "v"}], "]"}], "*", 
       RowBox[{"p", "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "v"}], ")"}]}], "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "p"}], ")"}], "^", "v"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"v", ",", "0", ",", "n"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", "n"}], "*", 
     RowBox[{"Binomial", "[", 
      RowBox[{"nn", ",", "n"}], "]"}], "*", 
     RowBox[{"p", "^", "n"}], "*", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{
       RowBox[{"-", "n"}], ",", 
       RowBox[{"-", "x"}], ",", 
       RowBox[{"-", "nn"}], ",", 
       RowBox[{"1", "/", "p"}]}], "]"}]}], "\[Equal]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", "n"}], "*", 
     RowBox[{
      RowBox[{"p", "^", "n"}], "/", 
      RowBox[{"n", "!"}]}], "*", 
     RowBox[{
      RowBox[{"Gamma", "[", 
       RowBox[{"nn", "-", "x", "+", "1"}], "]"}], "/", 
      RowBox[{"Gamma", "[", 
       RowBox[{"nn", "-", "x", "-", "n", "+", "1"}], "]"}]}], "*", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{
       RowBox[{"-", "n"}], ",", 
       RowBox[{"-", "x"}], ",", 
       RowBox[{"nn", "-", "x", "-", "n", "+", "1"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"p", "-", "1"}], ")"}], "/", "p"}]}], "]"}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     TemplateBox[{SubscriptBox["k", "n"],"\"(p)\""},
      "Superscript"], "\[InvisibleApplication]", 
     RowBox[{"(", 
      RowBox[{"x", ",", "nn"}], ")"}]}], "\[LongEqual]", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"v", "=", "0"}], "n"], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"n", "-", "v"}]], " ", 
      TemplateBox[{RowBox[{"nn", "-", "x"}],RowBox[{"n", "-", "v"}]},
       "Binomial"], " ", 
      TemplateBox[{"x","v"},
       "Binomial"], " ", 
      SuperscriptBox["p", 
       RowBox[{"n", "-", "v"}]], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", "p"}], ")"}], "v"]}]}], "\[LongEqual]", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "n"], " ", 
     TemplateBox[{"nn","n"},
      "Binomial"], " ", 
     SuperscriptBox["p", "n"], " ", 
     TemplateBox[{
      RowBox[{"-", "n"}],RowBox[{"-", "x"}],RowBox[{"-", "nn"}],FractionBox[
       "1", "p"]},
      "Hypergeometric2F1"]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "n"], " ", 
      SuperscriptBox["p", "n"], " ", 
      TemplateBox[{RowBox[{"nn", "-", "x", "+", "1"}]},
       "Gamma"], " ", 
      TemplateBox[{
       RowBox[{"-", "n"}],RowBox[{"-", "x"}],
        RowBox[{"nn", "-", "x", "-", "n", "+", "1"}],FractionBox[
         RowBox[{"p", "-", "1"}], "p"]},
       "Hypergeometric2F1"]}], 
     RowBox[{
      RowBox[{"n", "!"}], " ", 
      TemplateBox[{RowBox[{"nn", "-", "x", "-", "n", "+", "1"}]},
       "Gamma"]}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


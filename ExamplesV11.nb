      RowBox[{"a", " ", "bp", " ", "x"}], "-", 
      RowBox[{"a", " ", "bp", " ", "y"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", "-", "y"}], ")", 
     SubscriptBox["D", "x"], 
     SubscriptBox["D", "y"]}], "-", 
    RowBox[{"bp", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"b", 
     SubscriptBox["D", "y"]}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["x", "2"]}], "+", 
      SuperscriptBox["x", "3"], "+", 
      RowBox[{"x", " ", "y"}], "-", 
      RowBox[{
       SuperscriptBox["x", "2"], " ", "y"}]}], ")", 
     SubsuperscriptBox["D", "x", "2"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "c"}], " ", "x"}], "+", 
      SuperscriptBox["x", "2"], "+", 
      RowBox[{"a", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"b", " ", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"bp", " ", "y"}], "+", 
      RowBox[{"c", " ", "y"}], "-", 
      RowBox[{"x", " ", "y"}], "-", 
      RowBox[{"a", " ", "x", " ", "y"}], "-", 
      RowBox[{"b", " ", "x", " ", "y"}], "+", 
      RowBox[{"bp", " ", "x", " ", "y"}]}], ")", 
     SubscriptBox["D", "x"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"b", " ", "y"}], "-", 
      RowBox[{"b", " ", 
       SuperscriptBox["y", "2"]}]}], ")", 
     SubscriptBox["D", "y"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", "b", " ", "x"}], "-", 
      RowBox[{"a", " ", "b", " ", "y"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
When searching for a partial differential equation that does not contain bp \
or b, respectively, we obtain exactly the two PDEs given as 9.181.1:\
\>", "Text"],


Cell["\<\
The following is an example where removing contents does not work well with \
FactorTermsList (the computation took around 4 hours). That's why we switch \
to \"gcd\".\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Timing", "[", 
  RowBox[{
   RowBox[{"nm", "=", "$NormalizeMethod"}], ";", 
   RowBox[{"$NormalizeMethod", "=", "\"\<gcd\>\""}], ";", 
   RowBox[{"rhs", "=", 
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{"HypergeometricPFQ", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"2", "a"}], ",", 
          RowBox[{"2", "b"}], ",", 
          RowBox[{"a", "+", "b"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"a", "+", "b", "+", 
           RowBox[{"1", "/", "2"}]}], ",", 
          RowBox[{
           RowBox[{"2", "a"}], "+", 
           RowBox[{"2", "b"}]}]}], "}"}], ",", "z"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "a", "]"}], ",", 
        RowBox[{"S", "[", "b", "]"}], ",", 
        RowBox[{"Der", "[", "z", "]"}]}], "}"}]}], "]"}]}], ";", 
   RowBox[{"$NormalizeMethod", "=", "nm"}], ";"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"4.82`", ",", "Null"}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Still, it takes quite long. The annihilator of the 3F2 can also be computed \
with Takayama's algorithm using the definition of the HypergeometricPFQ \
function:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Timing", "[", 
  RowBox[{
   RowBox[{"tak", "=", 
    RowBox[{"Takayama", "[", 
     RowBox[{
      RowBox[{"Annihilator", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Pochhammer", "[", 
          RowBox[{
           RowBox[{"2", "a"}], ",", "k"}], "]"}], "*", 
         RowBox[{"Pochhammer", "[", 
          RowBox[{
           RowBox[{"2", "b"}], ",", "k"}], "]"}], "*", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Pochhammer", "[", 
             RowBox[{
              RowBox[{"a", "+", "b"}], ",", "k"}], "]"}], "/", 
            RowBox[{"Pochhammer", "[", 
             RowBox[{
              RowBox[{"a", "+", "b", "+", 
               RowBox[{"1", "/", "2"}]}], ",", "k"}], "]"}]}], "/", 
           RowBox[{"Pochhammer", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"2", "a"}], "+", 
              RowBox[{"2", "b"}]}], ",", "k"}], "]"}]}], "/", 
          RowBox[{"k", "!"}]}], "*", 
         RowBox[{"z", "^", "k"}]}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"S", "[", "k", "]"}], ",", 
          RowBox[{"S", "[", "a", "]"}], ",", 
          RowBox[{"S", "[", "b", "]"}], ",", 
          RowBox[{"Der", "[", "z", "]"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", "k", "}"}]}], "]"}]}], ";"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"27.56`", ",", "Null"}], "}"}]], "Output"]
}, Open  ]],


Cell[CellGroupData[{

Cell[TextData[{
 "4.539  ",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
      RowBox[{
       RowBox[{
        SuperscriptBox["x", 
         RowBox[{"s", "-", "1"}]], " ", 
        RowBox[{
         SuperscriptBox["tan", 
          RowBox[{"-", "1"}]], "(", 
         RowBox[{"a", " ", 
          RowBox[{"exp", "(", 
           RowBox[{"-", "x"}], ")"}]}], ")"}]}], 
       RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
     RowBox[{
      SuperscriptBox["2", 
       RowBox[{
        RowBox[{"-", "s"}], "-", "1"}]], " ", 
      TemplateBox[{"s"},
       "Gamma"], " ", "a", " ", 
      TemplateBox[{RowBox[{"-", 
          SuperscriptBox["a", "2"]}],RowBox[{"s", "+", "1"}],FractionBox[
        "1", "2"]},
       "LerchPhi"]}]}],
    HoldForm], TraditionalForm]], "Output",
  CellChangeTimes->{3.464369744388862*^9}]
}], "Subsection"],

Cell["4.539 (p. 604) states:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", 
        RowBox[{"(", 
         RowBox[{"s", "-", "1"}], ")"}]}], "*", 
       RowBox[{"ArcTan", "[", 
        RowBox[{"a", "*", 
         RowBox[{"Exp", "[", 
          RowBox[{"-", "x"}], "]"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"2", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "s"}], "-", "1"}], ")"}]}], "*", 
     RowBox[{"Gamma", "[", "s", "]"}], "*", "a", "*", 
     RowBox[{"LerchPhi", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"a", "^", "2"}]}], ",", 
       RowBox[{"s", "+", "1"}], ",", 
       RowBox[{"1", "/", "2"}]}], "]"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
     RowBox[{
      RowBox[{
       SuperscriptBox["x", 
        RowBox[{"s", "-", "1"}]], " ", 
       RowBox[{
        SuperscriptBox["tan", 
         RowBox[{"-", "1"}]], "(", 
        RowBox[{"a", " ", 
         RowBox[{"exp", "(", 
          RowBox[{"-", "x"}], ")"}]}], ")"}]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     SuperscriptBox["2", 
      RowBox[{
       RowBox[{"-", "s"}], "-", "1"}]], " ", 
     TemplateBox[{"s"},
      "Gamma"], " ", "a", " ", 
     TemplateBox[{RowBox[{"-", 
         SuperscriptBox["a", "2"]}],RowBox[{"s", "+", "1"}],FractionBox[
       "1", "2"]},
      "LerchPhi"]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
We perform the obvious substitution in order to bring the integrand to a form \
that is closer to holonomic.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", 
          RowBox[{"Log", "[", "t", "]"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"s", "-", "1"}], ")"}]}], "/", "t"}], "*", 
      RowBox[{"ArcTan", "[", 
       RowBox[{"a", "*", "t"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1"}], "}"}]}], "]"}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "1"], 
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", 
          RowBox[{"log", "(", "t", ")"}]}], ")"}], 
        RowBox[{"s", "-", "1"}]], " ", 
       RowBox[{
        SuperscriptBox["tan", 
         RowBox[{"-", "1"}]], "(", 
        RowBox[{"a", " ", "t"}], ")"}]}], "t"], 
     RowBox[{"\[DifferentialD]", "t"}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
A relation that holds for both left-hand and right-hand side, is computed \
automatically:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", 
          RowBox[{"Log", "[", "t", "]"}]}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{"s", "-", "1"}], ")"}]}], "/", "t"}], "*", 
      RowBox[{"ArcTan", "[", 
       RowBox[{"a", "*", "t"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Der", "[", "a", "]"}], ",", 
     RowBox[{"S", "[", "s", "]"}]}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"s", ">", "0"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","nondf",
   "\"The expression \\!\\(\\*RowBox[{\\\"\\\\\\\"(-Log[t])^(-1 + \
s)\\\\\\\"\\\"}]\\) is not recognized to be \[PartialD]-finite. The result \
might not generate a zero-dimensional ideal.\"",2,511,19,31736665789155565964,
   "Local"},
  "MessageTemplate"]], "Message", "MSG"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"a", 
    SubscriptBox["D", "a"], 
    SubscriptBox["S", "s"]}], "-", "s"}], "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Annihilator", "[", 
  RowBox[{
   RowBox[{"2", "^", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "s"}], "-", "1"}], ")"}]}], "*", 
   RowBox[{"Gamma", "[", "s", "]"}], "*", "a", "*", 
   RowBox[{"LerchPhi", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"a", "^", "2"}]}], ",", 
     RowBox[{"s", "+", "1"}], ",", 
     RowBox[{"1", "/", "2"}]}], "]"}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"a", 
    SubscriptBox["D", "a"], 
    SubscriptBox["S", "s"]}], "-", "s"}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
The leading monomial  Der[a]*S[s]  suggests that we have to compare initial \
values for 
1)  a=0 and arbitrary integer s>0,
2)  s=1 and arbitrary n-th derivative with respect to a, evaluated at some \
point.\
\>", "Text"],

Cell["\<\
For a=0, the integrand becomes 0, as well as the right-hand side.\
\>", "Text"],

Cell["For s=1 we get:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ArcTan", "[", 
     RowBox[{"a", "*", "t"}], "]"}], "/", "t"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"Element", "[", 
     RowBox[{"a", ",", "Reals"}], "]"}]}]}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"PolyLog", "[", 
     RowBox[{"2", ",", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", 
       RowBox[{"Abs", "[", "a", "]"}]}]}], "]"}], "-", 
    RowBox[{"PolyLog", "[", 
     RowBox[{"2", ",", 
      RowBox[{"\[ImaginaryI]", " ", 
       RowBox[{"Abs", "[", "a", "]"}]}]}], "]"}]}], ")"}], " ", 
  RowBox[{"Sign", "[", "a", "]"}]}]], "Output"]
}, Open  ]],

Cell[TextData[{
 "If we rewrite a*LerchPhi[-a^2, 2, 1/2]/4 = a/4*Sum[(-a^2)^k / (k+1/2)^2, \
{k,0,Infinity}] (i.e., the right-hand side for s=1) in hypergeometric PFQ \
notation, it is easily seen, that it matches the above expression (even for \
symbolic a). \n(",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " versions earlier than 7 and version 11 give a different output, using \
PolyLog)."
}], "Text"],

Cell["\<\
Now we compare the first a-derivative of both sides for s=1 (this is not \
necessarily required):\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ArcTan", "[", 
       RowBox[{"a", "*", "t"}], "]"}], "/", "t"}], ",", "a"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"Element", "[", 
      RowBox[{"a", ",", "Reals"}], "]"}], "&&", 
     RowBox[{"a", "\[NotEqual]", "0"}]}]}]}], "]"}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{"ArcTan", "[", "a", "]"}], "a"]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Together", "[", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"2", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "s"}], "-", "1"}], ")"}]}], "*", 
      RowBox[{"Gamma", "[", "s", "]"}], "*", "a", "*", 
      RowBox[{"LerchPhi", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"a", "^", "2"}]}], ",", 
        RowBox[{"s", "+", "1"}], ",", 
        RowBox[{"1", "/", "2"}]}], "]"}]}], ",", "a"}], "]"}], "/.", 
   RowBox[{"s", "\[Rule]", "1"}]}], "]"}]], "Input"],

Cell[BoxData[
 FractionBox[
  RowBox[{"ArcTan", "[", "a", "]"}], "a"]], "Output"]
}, Open  ]],

Cell["\<\
We get the same result for symbolic a. Hence all higher derivatives with \
respect to a, evaluated at 0, will also agree.\
\>", "Text"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[{
 "6.512.1  ",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
      RowBox[{
       TemplateBox[{"m",RowBox[{"a", " ", "x"}]},
        "BesselJ"], " ", 
       TemplateBox[{"n",RowBox[{"b", " ", "x"}]},
        "BesselJ"], 
       RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
     FractionBox[
      RowBox[{
       SuperscriptBox["b", "n"], " ", 
       SuperscriptBox["a", 
        RowBox[{
         RowBox[{"-", "n"}], "-", "1"}]], " ", 
       TemplateBox[{RowBox[{
           FractionBox["1", "2"], " ", 
           RowBox[{"(", 
             RowBox[{"m", "+", "n", "+", "1"}], ")"}]}]},
        "Gamma"], " ", 
       TemplateBox[{RowBox[{
           FractionBox["1", "2"], " ", 
           RowBox[{"(", 
             RowBox[{"m", "+", "n", "+", "1"}], ")"}]}],RowBox[{
           FractionBox["1", "2"], " ", 
           RowBox[{"(", 
             RowBox[{"n", "-", "m", "+", "1"}], ")"}]}],
         RowBox[{"n", "+", "1"}],FractionBox[
          SuperscriptBox["b", "2"], 
          SuperscriptBox["a", "2"]]},
        "Hypergeometric2F1"]}], 
      RowBox[{
       TemplateBox[{RowBox[{"n", "+", "1"}]},
        "Gamma"], " ", 
       TemplateBox[{RowBox[{
           FractionBox["1", "2"], " ", 
           RowBox[{"(", 
             RowBox[{"m", "-", "n", "+", "1"}], ")"}]}]},
        "Gamma"]}]]}],
    HoldForm], TraditionalForm]], "Output",
  CellChangeTimes->{3.466179219693782*^9}],
 "\nwith Zeilberger's slow algorithm. CT does not work here."
}], "Subsection"],

Cell["6.512.1  on page 660. For a>0, b>0, Re(m+n)>-1, b<a:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"BesselJ", "[", 
        RowBox[{"m", ",", 
         RowBox[{"a", "*", "x"}]}], "]"}], "*", 
       RowBox[{"BesselJ", "[", 
        RowBox[{"n", ",", 
         RowBox[{"b", "*", "x"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"b", "^", "n"}], "*", 
     RowBox[{"a", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "n"}], "-", "1"}], ")"}]}], "*", 
     RowBox[{
      RowBox[{
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"m", "+", "n", "+", "1"}], ")"}], "/", "2"}], "]"}], "/", 
       RowBox[{"Gamma", "[", 
        RowBox[{"n", "+", "1"}], "]"}]}], "/", 
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"m", "-", "n", "+", "1"}], ")"}], "/", "2"}], "]"}]}], "*", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"m", "+", "n", "+", "1"}], ")"}], "/", "2"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "m", "+", "1"}], ")"}], "/", "2"}], ",", 
       RowBox[{"n", "+", "1"}], ",", 
       RowBox[{
        RowBox[{"b", "^", "2"}], "/", 
        RowBox[{"a", "^", "2"}]}]}], "]"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
     RowBox[{
      TemplateBox[{"m",RowBox[{"a", " ", "x"}]},
       "BesselJ"], " ", 
      TemplateBox[{"n",RowBox[{"b", " ", "x"}]},
       "BesselJ"], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    FractionBox[
     RowBox[{
      SuperscriptBox["b", "n"], " ", 
      SuperscriptBox["a", 
       RowBox[{
        RowBox[{"-", "n"}], "-", "1"}]], " ", 
      TemplateBox[{RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
            RowBox[{"m", "+", "n", "+", "1"}], ")"}]}]},
       "Gamma"], " ", 
      TemplateBox[{RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
            RowBox[{"m", "+", "n", "+", "1"}], ")"}]}],RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
            RowBox[{"n", "-", "m", "+", "1"}], ")"}]}],
        RowBox[{"n", "+", "1"}],FractionBox[
         SuperscriptBox["b", "2"], 
         SuperscriptBox["a", "2"]]},
       "Hypergeometric2F1"]}], 
     RowBox[{
      TemplateBox[{RowBox[{"n", "+", "1"}]},
       "Gamma"], " ", 
      TemplateBox[{RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
            RowBox[{"m", "-", "n", "+", "1"}], ")"}]}]},
       "Gamma"]}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[TextData[{
 "When we try this identity directly, we don't get a result, even when \
including all kinds of assumptions (depending on which ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " version is used, the limit computation may consume a lot of memory):"
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MemoryConstrained", "[", 
  RowBox[{
   RowBox[{"Annihilator", "[", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"BesselJ", "[", 
         RowBox[{"m", ",", 
          RowBox[{"a", "*", "x"}]}], "]"}], "*", 
        RowBox[{"BesselJ", "[", 
         RowBox[{"n", ",", 
          RowBox[{"b", "*", "x"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Der", "[", "a", "]"}], ",", 
       RowBox[{"Der", "[", "b", "]"}], ",", 
       RowBox[{"S", "[", "m", "]"}], ",", 
       RowBox[{"S", "[", "n", "]"}]}], "}"}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{
       RowBox[{"a", ">", "0"}], "&&", 
       RowBox[{"b", ">", "0"}], "&&", 
       RowBox[{"b", "<", "a"}], "&&", 
       RowBox[{"m", ">", "0"}], "&&", 
       RowBox[{"n", ">", "0"}], "&&", 
       RowBox[{"Element", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"m", ",", "n"}], "}"}], ",", "Integers"}], "]"}]}]}]}], 
    "]"}], ",", 
   RowBox[{"10", "^", "8"}]}], "]"}]], "Input"],

Cell[BoxData[
 TemplateBox[{
  "Annihilator","fail",
   "\"\\!\\(\\*RowBox[{\\\"\\\\\\\"Cannot evaluate the delta part of an \
integral (problem with upper bound).\\\\\\\"\\\"}]\\)\"",2,517,20,
   31736665789155565964,"Local"},
  "MessageTemplate"]], "Message", "MSG"],

Cell[BoxData["$Failed"], "Output"]
}, Open  ]],

Cell["\<\
Therefore, we have a closer look at what happens after creative telescoping:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"ann", ",", "delta"}], "}"}], "=", 
  RowBox[{"CreativeTelescoping", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"BesselJ", "[", 
      RowBox[{"m", ",", 
       RowBox[{"a", "*", "x"}]}], "]"}], "*", 
     RowBox[{"BesselJ", "[", 
      RowBox[{"n", ",", 
       RowBox[{"b", "*", "x"}]}], "]"}]}], ",", 
    RowBox[{"Der", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"Der", "[", "b", "]"}], ",", 
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"a", 
       SubscriptBox["D", "a"]}], "+", 
      RowBox[{"b", 
       SubscriptBox["D", "b"]}], "+", "1"}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["b", "2"]}], "+", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", 
         SuperscriptBox["m", "2"]}], "-", 
        RowBox[{"2", " ", 
         SuperscriptBox["b", "2"], " ", "n"}], "-", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", 
         SuperscriptBox["n", "2"]}]}], ")", 
       SubsuperscriptBox["S", "n", "2"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", 
         SuperscriptBox["a", "2"], " ", "b"}], "-", 
        RowBox[{"2", " ", 
         SuperscriptBox["b", "3"]}], "+", 
        RowBox[{"2", " ", 
         SuperscriptBox["a", "2"], " ", "b", " ", "n"}], "-", 
        RowBox[{"2", " ", 
         SuperscriptBox["b", "3"], " ", "n"}]}], ")", 
       SubscriptBox["D", "b"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["b", "2"]}], "+", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", 
         SuperscriptBox["m", "2"]}], "-", 
        RowBox[{"2", " ", 
         SuperscriptBox["a", "2"], " ", "n"}], "-", 
        RowBox[{"2", " ", 
         SuperscriptBox["a", "2"], " ", 
         SuperscriptBox["n", "2"]}], "+", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", 
         SuperscriptBox["n", "2"]}]}], ")"}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"a", " ", "b"}], "+", 
        RowBox[{"a", " ", "b", " ", "m"}], "+", 
        RowBox[{"a", " ", "b", " ", "n"}]}], ")", 
       SubscriptBox["S", "m"], 
       SubscriptBox["S", "n"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["a", "2"], " ", "b"}], "-", 
        SuperscriptBox["b", "3"]}], ")", 
       SubscriptBox["D", "b"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["b", "2"]}], "-", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", "m"}], "-", 
        RowBox[{
         SuperscriptBox["a", "2"], " ", "n"}]}], ")"}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["a", "2"], "+", 
        RowBox[{"2", " ", 
         SuperscriptBox["a", "2"], " ", "m"}], "+", 
        RowBox[{
         SuperscriptBox["a", "2"], " ", 
         SuperscriptBox["m", "2"]}], "-", 
        RowBox[{
         SuperscriptBox["a", "2"], " ", 
         SuperscriptBox["n", "2"]}]}], ")", 
       SubsuperscriptBox["S", "m", "2"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], " ", 
         SuperscriptBox["a", "2"], " ", "b"}], "+", 
        RowBox[{"2", " ", 
         SuperscriptBox["b", "3"]}], "-", 
        RowBox[{"2", " ", 
         SuperscriptBox["a", "2"], " ", "b", " ", "m"}], "+", 
        RowBox[{"2", " ", 
         SuperscriptBox["b", "3"], " ", "m"}]}], ")", 
       SubscriptBox["D", "b"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["a", "2"]}], "+", 
        RowBox[{"2", " ", 
         SuperscriptBox["b", "2"]}], "-", 
        RowBox[{"2", " ", 
         SuperscriptBox["a", "2"], " ", "m"}], "+", 
        RowBox[{"4", " ", 
         SuperscriptBox["b", "2"], " ", "m"}], "-", 
        RowBox[{
         SuperscriptBox["a", "2"], " ", 
         SuperscriptBox["m", "2"]}], "+", 
        RowBox[{"2", " ", 
         SuperscriptBox["b", "2"], " ", 
         SuperscriptBox["m", "2"]}], "-", 
        RowBox[{
         SuperscriptBox["a", "2"], " ", 
         SuperscriptBox["n", "2"]}]}], ")"}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["a", "2"]}], " ", "b"}], "+", 
        SuperscriptBox["b", "3"]}], ")", 
       SubscriptBox["D", "b"], 
       SubscriptBox["S", "n"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"a", " ", "b", " ", "m"}], "-", 
        RowBox[{"a", " ", "b", " ", "n"}]}], ")", 
       SubscriptBox["S", "m"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["a", "2"]}], "+", 
        SuperscriptBox["b", "2"], "+", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", "m"}], "-", 
        RowBox[{
         SuperscriptBox["a", "2"], " ", "n"}]}], ")", 
       SubscriptBox["S", "n"]}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["a", "2"], " ", "b"}], "-", 
        SuperscriptBox["b", "3"]}], ")", 
       SubscriptBox["D", "b"], 
       SubscriptBox["S", "m"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["b", "2"], " ", "m"}], "-", 
        RowBox[{
         SuperscriptBox["a", "2"], " ", "n"}]}], ")", 
       SubscriptBox["S", "m"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"a", " ", "b", " ", "m"}], "-", 
        RowBox[{"a", " ", "b", " ", "n"}]}], ")", 
       SubscriptBox["S", "n"]}]}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["a", "2"], " ", 
         SuperscriptBox["b", "2"]}], "-", 
        SuperscriptBox["b", "4"]}], ")", 
       SubsuperscriptBox["D", "b", "2"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["a", "2"], " ", "b"}], "-", 
        RowBox[{"3", " ", 
         SuperscriptBox["b", "3"]}]}], ")", 
       SubscriptBox["D", "b"]}], "+", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["b", "2"]}], "+", 
        RowBox[{
         SuperscriptBox["b", "2"], " ", 
         SuperscriptBox["m", "2"]}], "-", 
        RowBox[{
         SuperscriptBox["a", "2"], " ", 
         SuperscriptBox["n", "2"]}]}], ")"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "x"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"2", " ", "b", " ", 
        RowBox[{"(", 
         RowBox[{"a", "+", 
          RowBox[{"a", " ", "n"}]}], ")"}], " ", "x"}], 
       SubscriptBox["S", "m"], 
       SubscriptBox["S", "n"]}], "-", 
      RowBox[{
       RowBox[{"2", " ", "b", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", "n"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", "m", "+", "n"}], ")"}]}], 
       SubscriptBox["S", "n"]}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["b", "2"], " ", 
       RowBox[{"(", 
        RowBox[{"x", "+", 
         RowBox[{"n", " ", "x"}]}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"a", " ", "b", " ", "x"}], 
       SubscriptBox["S", "m"], 
       SubscriptBox["S", "n"]}], "+", 
      RowBox[{
       SuperscriptBox["b", "2"], " ", "x"}]}], ",", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"2", " ", "a", " ", 
        RowBox[{"(", 
         RowBox[{"b", "+", 
          RowBox[{"b", " ", "m"}]}], ")"}], " ", "x"}], 
       SubscriptBox["S", "m"], 
       SubscriptBox["S", "n"]}], "+", 
      RowBox[{
       RowBox[{"2", " ", "a", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", "m"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", "m", "+", "n"}], ")"}]}], 
       SubscriptBox["S", "m"]}], "-", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["b", "2"], " ", "x"}], "+", 
         RowBox[{
          SuperscriptBox["b", "2"], " ", "m", " ", "x"}]}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"a", " ", "b", " ", "x"}], 
       SubscriptBox["S", "m"]}], "-", 
      RowBox[{
       RowBox[{
        SuperscriptBox["b", "2"], " ", "x"}], 
       SubscriptBox["S", "n"]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["b", "2"], " ", "x"}], 
       SubscriptBox["S", "m"]}], "-", 
      RowBox[{
       RowBox[{"a", " ", "b", " ", "x"}], 
       SubscriptBox["S", "n"]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"a", " ", 
        SuperscriptBox["b", "2"], " ", 
        SuperscriptBox["x", "2"]}], 
       SubscriptBox["S", "m"]}], "-", 
      RowBox[{
       RowBox[{
        SuperscriptBox["b", "3"], " ", 
        SuperscriptBox["x", "2"]}], 
       SubscriptBox["S", "n"]}], "-", 
      RowBox[{"b", " ", 

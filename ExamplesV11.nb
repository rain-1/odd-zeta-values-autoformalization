Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "1"], 
     RowBox[{
      RowBox[{
       SuperscriptBox["x", "n"], " ", 
       RowBox[{
        SuperscriptBox["log", "k"], "(", "x", ")"}]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "k"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "+", "n"}], ")"}], 
      RowBox[{
       RowBox[{"-", "k"}], "-", "1"}]], " ", 
     TemplateBox[{RowBox[{"1", "+", "k"}]},
      "Gamma"]}]}],
   HoldForm], TraditionalForm]], "Output",
 CellChangeTimes->{3.464055499958117*^9}]], "Subsection"],

Cell["This example was communicated to us by Clemens Raab.", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "n"}], " ", 
       RowBox[{
        RowBox[{"Log", "[", "x", "]"}], "^", "k"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}], "==", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", "k"}], "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", "n"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "k"}], "-", "1"}], ")"}]}], "*", 
     RowBox[{"Gamma", "[", 
      RowBox[{"1", "+", "k"}], "]"}]}]}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "1"], 
     RowBox[{
      RowBox[{
       SuperscriptBox["x", "n"], " ", 
       RowBox[{
        SuperscriptBox["log", "k"], "(", "x", ")"}]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], "\[LongEqual]", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "k"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "+", "n"}], ")"}], 
      RowBox[{
       RowBox[{"-", "k"}], "-", "1"}]], " ", 
     TemplateBox[{RowBox[{"1", "+", "k"}]},
      "Gamma"]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", "n"}], " ", 
    RowBox[{
     RowBox[{"Log", "[", "x", "]"}], "^", "k"}]}], ",", 

Cell["\<\
5.6.3  Laguerre and BesselJ
(OreSys bug)\
\>", "Subsection"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"LaguerreL", "[", 
     RowBox[{"n", ",", "a", ",", "x"}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"Exp", "[", "x", "]"}], "*", 
     RowBox[{
      RowBox[{"x", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "/", "2"}], ")"}]}], "/", 
      RowBox[{"n", "!"}]}], "*", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{"-", "t"}], "]"}], "*", 
        RowBox[{"t", "^", 
         RowBox[{"(", 
          RowBox[{"n", "+", 
           RowBox[{"a", "/", "2"}]}], ")"}]}], "*", 
        RowBox[{"BesselJ", "[", 
         RowBox[{"a", ",", 
          RowBox[{"2", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"t", "*", "x"}], ")"}], "^", 
            RowBox[{"(", 
             RowBox[{"1", "/", "2"}], ")"}]}]}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["L", "n", "a"], "(", "x", ")"}], "\[LongEqual]", 
    FractionBox[
     RowBox[{
      RowBox[{"exp", "(", "x", ")"}], " ", 
      SuperscriptBox["x", 
       RowBox[{"-", 
        FractionBox["a", "2"]}]], " ", 
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
       RowBox[{
        RowBox[{"exp", "(", 
         RowBox[{"-", "t"}], ")"}], " ", 
        SuperscriptBox["t", 
         RowBox[{"n", "+", 
          FractionBox["a", "2"]}]], " ", 
        TemplateBox[{"a",RowBox[{"2", " ", 
            SqrtBox[
             RowBox[{"t", " ", "x"}]]}]},
         "BesselJ"], 
        RowBox[{"\[DifferentialD]", "t"}]}]}]}], 
     RowBox[{"n", "!"}]]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


Cell["\<\
But a simple substitution (u=cos(x)) brings the problem to a perfectly \
\[PartialD]-finite integrand:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TraditionalForm", "[", 
  RowBox[{"HoldForm", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"LegendreP", "[", 
       RowBox[{
        RowBox[{"2", "n"}], ",", 
        RowBox[{"Cos", "[", "t", "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "Pi"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"LegendreP", "[", 
        RowBox[{
         RowBox[{"2", "n"}], ",", "u"}], "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", 
         RowBox[{"u", "^", "2"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"u", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], "]"}], 
  "]"}]], "Input"],

Cell[BoxData[
 FormBox[
  TagBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Integral]", "0", "\[Pi]"], 
     RowBox[{
      TemplateBox[{RowBox[{"2", " ", "n"}],RowBox[{"cos", "(", "t", ")"}]},
       "LegendreP"], 
      RowBox[{"\[DifferentialD]", "t"}]}]}], "\[LongEqual]", 
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"-", "1"}], "1"], 
     RowBox[{
      FractionBox[
       TemplateBox[{RowBox[{"2", " ", "n"}],"u"},
        "LegendreP"], 
       SqrtBox[
        RowBox[{"1", "-", 
         SuperscriptBox["u", "2"]}]]], 
      RowBox[{"\[DifferentialD]", "u"}]}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],


   RowBox[{"Pochhammer", "[", 
    RowBox[{
     RowBox[{"1", "-", "k", "+", "n"}], ",", "k"}], "]"}]}], 
  RowBox[{"Pochhammer", "[", 
   RowBox[{"1", ",", 
    RowBox[{
     RowBox[{"-", "1"}], "+", "d"}]}], "]"}]]], "Output"]
}, Open  ]],

Cell["\<\
Using the third equation, we compute the remaining factors of the solution \
that depend on k only:\

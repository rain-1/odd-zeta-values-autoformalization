     SubscriptBox["S", "n2"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "+", "n2"}], ")", 
     SubscriptBox["S", "n1"]}], "+", 
    RowBox[{"(", 
     RowBox[{"1", "+", "n1"}], ")", 
     SubscriptBox["S", "n2"]}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", "+", "n1"}], ")", 

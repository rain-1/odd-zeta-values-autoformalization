      RowBox[{"S", "[", "i", "]"}], ",", 
      RowBox[{"S", "[", "j", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}]}], "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "j", "+", "n"}], ")", 
     SubscriptBox["S", "n"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "z"}], "-", 
      RowBox[{"n", " ", "z"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "z"}], "+", 
      RowBox[{"i", " ", "z"}], "-", 
      RowBox[{"j", " ", "z"}]}], ")", 
     SubscriptBox["S", "j"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "j"}], " ", "y"}], "+", 
      RowBox[{"n", " ", "y"}]}], ")"}]}], ",", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"y", "+", 
      RowBox[{"i", " ", "y"}]}], ")", 
     SubscriptBox["S", "i"]}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"i", " ", "x"}], "-", 
      RowBox[{"j", " ", "x"}]}], ")"}]}]}], "}"}]], "Output"]
}, Open  ]],

Cell["\<\
Below we list seven commands which all deliver the first-order recurrence \
that proves the trinomial identity.\
\>", "Text"],


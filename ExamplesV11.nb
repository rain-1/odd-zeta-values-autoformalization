      RowBox[{
       RowBox[{"Binomial", "[", 
        RowBox[{"n", ",", "j"}], "]"}], 
       RowBox[{"Binomial", "[", 
        RowBox[{"j", ",", "i"}], "]"}], 
       RowBox[{"x", "^", "i"}], " ", 
       RowBox[{"y", "^", 
        RowBox[{"(", 
         RowBox[{"j", "-", "i"}], ")"}]}], " ", 
       RowBox[{"z", "^", 
        RowBox[{"(", 
         RowBox[{"n", "-", "j"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "0", ",", "n"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "0", ",", "j"}], "}"}]}], "]"}], "\[Equal]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"x", "+", "y", "+", "z"}], ")"}], "^", "n"}]}], "]"}], "//", 
  "TraditionalForm"}]], "Input"],


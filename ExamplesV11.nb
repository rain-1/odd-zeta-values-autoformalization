Cell["Apagodu: Series evaluation...", "Subsection"],

Cell["\<\
Moa Apagodu: Series evaluation of a quartic integral and generalizations
The computations in this paper are easily reproduced with HolonomicFunctions.\
\
\>", "Text"],

Cell["Theorem 1:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"reca", "=", 
  RowBox[{"DFiniteDE2RE", "[", 
   RowBox[{
    RowBox[{"Annihilator", "[", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "^", "4"}], "+", 
            RowBox[{"2", "*", "a", "*", 
             RowBox[{"x", "^", "2"}]}], "+", "1"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"m", "+", "1"}], ")"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", "Infinity"}], "}"}]}], "]"}], ",", 
      RowBox[{"Der", "[", "a", "]"}], ",", 
      RowBox[{"Assumptions", "\[Rule]", 
       RowBox[{"m", "\[GreaterEqual]", "0"}]}]}], "]"}], ",", 
    RowBox[{"{", "a", "}"}], ",", 
    RowBox[{"{", "l", "}"}]}], "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "8"}], "-", 
     RowBox[{"12", " ", "l"}], "-", 
     RowBox[{"4", " ", 
      SuperscriptBox["l", "2"]}]}], ")", 
    SubsuperscriptBox["S", "l", "2"]}], "+", 
   RowBox[{"(", 
    RowBox[{"3", "+", 
     RowBox[{"8", " ", "l"}], "+", 
     RowBox[{"4", " ", 
      SuperscriptBox["l", "2"]}], "+", 
     RowBox[{"4", " ", "m"}], "+", 
     RowBox[{"8", " ", "l", " ", "m"}]}], ")"}]}], "}"}]], "Output"]
}, Open  ]],


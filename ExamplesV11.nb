      RowBox[{"n", "\[Equal]", "0"}]}], ",", "0", ",", "True", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "^", "m"}], "*", 
      RowBox[{"m", "!"}], "*", 
      RowBox[{
       RowBox[{"n", "!"}], "/", 
       RowBox[{"2", "^", 
        RowBox[{"(", 
         RowBox[{"m", "+", "n", "-", "1"}], ")"}]}]}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"Pi", "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"m", "+", "n"}], ")"}], "/", "2"}]}], "]"}], "*", 
      RowBox[{
       RowBox[{"Zeta", "[", 
        RowBox[{"m", "+", "n"}], "]"}], "/", 
       RowBox[{"Pi", "^", 
        RowBox[{"(", 
         RowBox[{"m", "+", "n"}], ")"}]}]}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"m", ",", "0", ",", "6"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"n", ",", "0", ",", "6"}], "}"}]}], "]"}]], "Input"],


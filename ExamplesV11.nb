         "Pochhammer"], " ", 
        TemplateBox[{"bp","n"},
         "Pochhammer"], " ", 
        SuperscriptBox["x", "m"], " ", 
        SuperscriptBox["y", "n"]}], 
       RowBox[{
        TemplateBox[{"c",RowBox[{"m", "+", "n"}]},
         "Pochhammer"], " ", 
        RowBox[{"m", "!"}], " ", 
        RowBox[{"n", "!"}]}]]}]}]}],
   HoldForm], TraditionalForm]], "Output"]
}, Open  ]],

Cell["\<\
Since this double sum has natural boundaries, we can apply Takayama's \
algorithm in order to compute a system of partial differential equations for \
it.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ann", "=", 
  RowBox[{"Annihilator", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Pochhammer", "[", 
      RowBox[{"a", ",", 
       RowBox[{"m", "+", "n"}]}], "]"}], "*", 
     RowBox[{"Pochhammer", "[", 
      RowBox[{"b", ",", "m"}], "]"}], "*", 
     RowBox[{
      RowBox[{"Pochhammer", "[", 
       RowBox[{"bp", ",", "n"}], "]"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Pochhammer", "[", 
         RowBox[{"c", ",", 
          RowBox[{"m", "+", "n"}]}], "]"}], "*", 
        RowBox[{"m", "!"}], "*", 
        RowBox[{"n", "!"}]}], ")"}]}], "*", 
     RowBox[{"x", "^", "m"}], "*", 
     RowBox[{"y", "^", "n"}]}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "m", "]"}], ",", 
      RowBox[{"S", "[", "n", "]"}], ",", 
      RowBox[{"Der", "[", "x", "]"}], ",", 
      RowBox[{"Der", "[", "y", "]"}]}], "}"}]}], "]"}]}]], "Input"],


Cell["\<\
Let's see why we get this error. We do the creative telescoping by hand.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ct", "=", 
  RowBox[{"CreativeTelescoping", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"z", " ", "t"}], "]"}], "/", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"t", "^", "2"}], "-", "1"}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"n", "+", 
        RowBox[{"1", "/", "2"}]}], ")"}]}]}], ",", 
    RowBox[{"Der", "[", "t", "]"}], ",", 
    RowBox[{"Der", "[", "z", "]"}]}], "]"}]}]], "Input"],

